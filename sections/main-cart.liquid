<script>
(function () {
  'use strict';

  /* ─── Currency helpers (subset — only what the shipping bar needs) ──────── */

  const COMMA_DECIMAL_CURRENCIES = new Set([
    'EUR','DKK','NOK','SEK','ISK','PLN','CZK','HUF','RON','BGN','HRK','RSD',
    'BAM','MKD','ALL','TRY','UAH','RUB','KZT','UZS','AZN','AMD','GEL','MDL',
    'BRL','ARS','CLP','COP','VEF','UYU','PYG','BOB','PEN','GTQ','HNL','NIO',
    'CRC','SVC','DOP','AWG','ANG','SRD','MZN','MNT','LAK','IDR','VND','CHF'
  ]);

  const CURRENCY_SYMBOL_MAP = {
    'AED':'د.إ','AFN':'؋','ALL':'Lek','AMD':'֏','ANG':'ƒ','AOA':'Kz','ARS':'$',
    'AUD':'$','AWG':'ƒ','AZN':'₼','BAM':'KM','BBD':'$','BDT':'৳','BGN':'лв',
    'BHD':'.د.ب','BMD':'$','BND':'$','BOB':'Bs.','BRL':'R$','BSD':'$','BWP':'P',
    'BYR':'p.','BZD':'BZ$','CAD':'$','CHF':'CHF','CLP':'$','CNY':'¥','COP':'$',
    'CRC':'₡','CUP':'₱','CZK':'Kč','DKK':'kr','DOP':'RD$','EGP':'£','EUR':'€',
    'FJD':'$','GBP':'£','GEL':'₾','GHS':'₵','GIP':'£','GTQ':'Q','GYD':'$',
    'HKD':'$','HNL':'L','HRK':'kn','HUF':'Ft','IDR':'Rp','ILS':'₪','INR':'₹',
    'IRR':'﷼','ISK':'kr','JMD':'J$','JPY':'¥','KES':'KSh','KGS':'лв','KHR':'៛',
    'KPW':'₩','KRW':'₩','KWD':'د.ك','KYD':'$','KZT':'лв','LAK':'₭','LBP':'£',
    'LKR':'₨','LRD':'$','MAD':'MAD','MDL':'L','MKD':'ден','MNT':'₮','MUR':'₨',
    'MVR':'Rf','MXN':'$','MYR':'RM','MZN':'MT','NAD':'$','NGN':'₦','NIO':'C$',
    'NOK':'kr','NPR':'₨','NZD':'$','OMR':'﷼','PAB':'B/.','PEN':'S/.','PHP':'₱',
    'PKR':'₨','PLN':'zł','PYG':'Gs','QAR':'﷼','RON':'lei','RSD':'Дин.','RUB':'₽',
    'SAR':'﷼','SCR':'₨','SEK':'kr','SGD':'$','SHP':'£','SOS':'S','SRD':'$',
    'SYP':'£','THB':'฿','TRY':'₺','TTD':'TT$','TWD':'NT$','UAH':'₴','USD':'$',
    'UYU':'$U','UZS':'лв','VEF':'Bs.F','VND':'₫','XCD':'$','YER':'﷼','ZAR':'R',
    'ZWD':'Z$'
  };

  const NO_DECIMAL_CURRENCIES = new Set([
    'JPY','KRW','VND','IDR','ISK','CLP','GNF','KMF','MGA','PYG','RWF','UGX',
    'XAF','XOF','XPF'
  ]);

  function getActiveCurrencyFormat(iso) {
    const symbol = CURRENCY_SYMBOL_MAP[iso] || iso;
    if (NO_DECIMAL_CURRENCIES.has(iso)) return symbol + '{{amount_no_decimals_with_comma_separator}}';
    if (COMMA_DECIMAL_CURRENCIES.has(iso))  return symbol + '{{amount_with_comma_separator}}';
    return symbol + '{{amount}}';
  }

  function formatMoney(cents, format) {
    if (typeof cents === 'string') cents = cents.replace('.', '');
    const placeholderRegex = /\{\{\s*(\w+)\s*\}\}/;
    const formatString     = format || (window.Shopify && window.Shopify.money_format) || '€{{amount_with_comma_separator}}';

    function formatWithDelimiters(number, precision, thousands, decimal) {
      precision = precision == null ? 2  : precision;
      thousands = thousands == null ? ',' : thousands;
      decimal   = decimal   == null ? '.' : decimal;
      if (isNaN(number) || number == null) return '0';
      number = (number / 100.0).toFixed(precision);
      const parts   = number.split('.');
      const dollars = parts[0].replace(/(\d)(?=(\d\d\d)+(?!\d))/g, '$1' + thousands);
      const centsStr = parts[1] ? (decimal + parts[1]) : '';
      return dollars + centsStr;
    }

    const match = formatString.match(placeholderRegex);
    if (!match) return '€' + formatWithDelimiters(cents, 2, '.', ',');

    let value = '';
    switch (match[1]) {
      case 'amount':                                  value = formatWithDelimiters(cents, 2);        break;
      case 'amount_no_decimals':                      value = formatWithDelimiters(cents, 0);        break;
      case 'amount_with_comma_separator':             value = formatWithDelimiters(cents, 2, '.', ','); break;
      case 'amount_no_decimals_with_comma_separator': value = formatWithDelimiters(cents, 0, '.', '');  break;
      case 'amount_with_apostrophe_separator':        value = formatWithDelimiters(cents, 2, "'", '.'); break;
      default: value = formatWithDelimiters(cents, 2); break;
    }
    return formatString.replace(placeholderRegex, value);
  }

  function fmtCurrency(cents, isoOverride) {
    const iso = isoOverride
      || (window.Shopify && window.Shopify.currency && window.Shopify.currency.active)
      || '{{ cart.currency.iso_code }}';
    return formatMoney(parseInt(cents), getActiveCurrencyFormat(iso));
  }

  /* ─── Core shipping-bar update function ────────────────────────────────── */

  function updateShippingBar(totalCents, isoOverride) {
    const bar = document.getElementById('cart-shipping-bar');
    if (!bar) return;

    // Read ISO from the Liquid-rendered data attribute (always correct for current market)
    const iso             = isoOverride || bar.dataset.currencyIso || undefined;
    const threshold       = parseInt(bar.dataset.threshold) || 10000;
    const remaining       = Math.max(0, threshold - totalCents);
    const progress        = Math.min(100, (totalCents * 100) / threshold);

    const remainingEl     = bar.querySelector('[data-shipping-remaining]');
    const progressEl      = bar.querySelector('[data-shipping-progress]');
    const textEl          = bar.querySelector('.cart-drawer-shipping__text');

    if (progressEl) progressEl.style.width = progress + '%';

    const formattedRemaining = fmtCurrency(remaining, iso);
    if (remainingEl) remainingEl.textContent = formattedRemaining;

    if (textEl) {
      if (remaining > 0) {
        textEl.innerHTML = `You're <span class="cart-drawer-shipping__amount" data-shipping-remaining>${formattedRemaining}</span> away from Free Standard Shipping`;
      } else {
        textEl.innerHTML = "🎉 You've unlocked Free Standard Shipping!";
      }
    }
  }

  /* ─── Live refresh via /cart.js (never stale) ───────────────────────────── */

  function refreshShippingBarFromCart() {
    fetch('/cart.js')
      .then(r => r.json())
      .then(cart => updateShippingBar(cart.items_subtotal_price))
      .catch(() => {});
  }

  /* ─── Expose globally so other scripts (cart drawer JS) can call it ─────── */
  window.CartShippingBar = {
    update: updateShippingBar,
    refresh: refreshShippingBarFromCart
  };

  /* ─── Initialise on DOMContentLoaded ───────────────────────────────────── */
  document.addEventListener('DOMContentLoaded', () => {
    // Small delay to let the cart drawer fully render
    setTimeout(refreshShippingBarFromCart, 900);
  });

  /* ─── Re-sync when cart drawer opens (MutationObserver on <dialog>) ─────── */
  const cartDialog = document.getElementById('CartDrawer');
  if (cartDialog) {
    new MutationObserver(() => {
      if (cartDialog.hasAttribute('open')) {
        refreshShippingBarFromCart();
      }
    }).observe(cartDialog, { attributes: true, attributeFilter: ['open'] });
  }

  /* ─── Listen for cart-update events fired by other scripts ─────────────── */
  const CART_EVENTS = [
    'cart:updated', 'cart:refresh', 'cart-drawer:refreshed',
    'theme:cart:updated', 'taxify:cart:updated'
  ];
  CART_EVENTS.forEach(name => {
    document.addEventListener(name, refreshShippingBarFromCart);
  });

})();
</script>

