{% comment %}
  Why Choose Us Section
  - Left: Video/Image with overlay text and play button (plays inline)
  - Right: 2x2 Features Grid with icons
  - Bottom: Trust badge/text
  - Mobile: Heading on top, image below, 2x2 grid features
{% endcomment %}

<style>
  #why-choose-us-{{ section.id }} {
    --section-bg-color: {{ section.settings.section_bg_color }};
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --section-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --section-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --video-heading-color: {{ section.settings.video_heading_color }};
    --video-heading-size: {{ section.settings.video_heading_font_size }}px;
    --video-heading-size-mobile: {{ section.settings.video_heading_font_size_mobile }}px;
    --main-title-color: {{ section.settings.main_title_color }};
    --main-title-size: {{ section.settings.main_title_font_size }}px;
    --main-title-size-mobile: {{ section.settings.main_title_font_size_mobile }}px;
    --main-desc-color: {{ section.settings.main_description_color }};
    --main-desc-size: {{ section.settings.main_description_font_size }}px;
    --main-desc-size-mobile: {{ section.settings.main_description_font_size_mobile }}px;
    --feature-title-color: {{ section.settings.feature_title_color }};
    --feature-title-size: {{ section.settings.feature_title_font_size }}px;
    --feature-title-size-mobile: {{ section.settings.feature_title_font_size_mobile }}px;
    --feature-desc-color: {{ section.settings.feature_description_color }};
    --feature-desc-size: {{ section.settings.feature_description_font_size }}px;
    --feature-desc-size-mobile: {{ section.settings.feature_description_font_size_mobile }}px;
    --icon-color: {{ section.settings.icon_color }};
    --icon-size: {{ section.settings.icon_size }}px;
    --icon-size-mobile: {{ section.settings.icon_size_mobile }}px;
    --badge-bg-color: {{ section.settings.badge_bg_color }};
    --badge-text-color: {{ section.settings.badge_text_color }};
    --badge-font-size: {{ section.settings.badge_font_size }}px;
    --badge-font-size-mobile: {{ section.settings.badge_font_size_mobile }}px;
    --play-btn-color: {{ section.settings.play_button_color }};
    --play-btn-bg: {{ section.settings.play_button_bg }};
  }

  #why-choose-us-{{ section.id }} .why-choose-wrapper {
    position: relative;
    padding-top: var(--section-padding-top);
    padding-bottom: var(--section-padding-bottom);
    background-color: var(--section-bg-color);
    {% if section.settings.section_bg_image != blank %}
    background-image: url('{{ section.settings.section_bg_image | image_url: width: 1920 }}');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    {% endif %}
  }

  #why-choose-us-{{ section.id }} .hdt-container {
    position: relative;
  }

  @media (max-width: 768px) {
    #why-choose-us-{{ section.id }} .why-choose-wrapper {
      padding-top: var(--section-padding-top-mobile);
      padding-bottom: var(--section-padding-bottom-mobile);
    }
  }

  #why-choose-us-{{ section.id }} .mobile-section-heading {
    display: none;
    font-size: var(--video-heading-size-mobile, 22px);
    font-weight: 700;
    color: #000000;
    margin: 0;
    line-height: 1.3;
    text-align: center;
  }

  @media (max-width: 767px) {
    #why-choose-us-{{ section.id }} .mobile-section-heading {
      display: block;
    }
  }

  #why-choose-us-{{ section.id }} .hdt-container::before,
  #why-choose-us-{{ section.id }} .hdt-container::after {
    content: '';
    position: absolute;
    left: 50px;
    right: 50px;
    height: 1px;
    background-color: #e0e0e0;
  }

  #why-choose-us-{{ section.id }} .hdt-container::before {
    top: -70px;
  }

  #why-choose-us-{{ section.id }} .hdt-container::after {
    bottom: -80px;
  }

  {% if section.settings.hide_borders %}
  #why-choose-us-{{ section.id }} .hdt-container::before,
  #why-choose-us-{{ section.id }} .hdt-container::after {
    display: none;
  }
  {% endif %}

  #why-choose-us-{{ section.id }} .border-star {
    position: absolute;
    left: 0;
    right: 0;
    {% comment %} background-color: var(--section-bg-color, #f8f8f8); {% endcomment %}
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
  }

  #why-choose-us-{{ section.id }} .border-star.bottom-star {
    bottom: -105px;
  }

  #why-choose-us-{{ section.id }} .media-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 20px;
    background: linear-gradient(to right, rgba(0,0,0,0.4) 0%, rgba(0,0,0,0.2) 50%, transparent 100%);
    padding: 30px;
    transition: opacity 0.3s ease, visibility 0.3s ease;
    z-index: 3;
    cursor: pointer;
  }

  #why-choose-us-{{ section.id }} .media-overlay.hidden {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  /* Darker overlay when showing over active video (paused state) */
  #why-choose-us-{{ section.id }} .media-overlay.video-paused {
    background: rgba(0,0,0,0.4);
  }

  #why-choose-us-{{ section.id }} .media-heading {
    font-size: var(--video-heading-size, 28px);
    font-weight: 700;
    color: var(--video-heading-color, #ffffff);
    margin: 0;
    line-height: 1.3;
    text-align: center;
    text-shadow: 0 2px 4px rgba(0,0,0,0.3);
  }

  @media (max-width: 767px) {
    #why-choose-us-{{ section.id }} .media-heading {
      display: none;
    }
    
    #why-choose-us-{{ section.id }} .media-overlay {
      background: rgba(0,0,0,0.2);
    }
  }

  #why-choose-us-{{ section.id }} .play-button {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background-color: var(--play-btn-bg, #ffffff);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
  }

  #why-choose-us-{{ section.id }} .play-button svg {
    color: var(--play-btn-color, #000000);
    margin-left: 3px;
    width: 40px;
    height: 40px;
  }

  #why-choose-us-{{ section.id }} .play-button:hover {
    transform: scale(1.1);
    box-shadow: 0 6px 30px rgba(0, 0, 0, 0.3);
  }

  @media (max-width: 768px) {
    #why-choose-us-{{ section.id }} .media-overlay {
      gap: 16px;
      padding: 20px;
    }

    #why-choose-us-{{ section.id }} .play-button {
      width: 50px;
      height: 50px;
    }

    #why-choose-us-{{ section.id }} .play-button svg {
      width: 20px;
      height: 20px;
    }
  }

  .why-choose-us-section *,
  .why-choose-us-section *::before,
  .why-choose-us-section *::after {
    box-sizing: border-box;
  }

  .why-choose-us-section .why-choose-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: stretch;
  }

  .why-choose-us-section .why-choose-media {
    position: relative;
    width: 100%;
  }

  .why-choose-us-section .media-wrapper {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    height: 100%;
    min-height: 400px;
  }

  .why-choose-us-section .media-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    position: absolute;
    top: 0;
    left: 0;
    transition: opacity 0.3s ease;
  }

  .why-choose-us-section .media-image.hidden {
    opacity: 0;
  }

  .why-choose-us-section .media-placeholder {
    width: 100%;
    height: 100%;
    background-color: #e0e0e0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.3s ease;
  }

  .why-choose-us-section .media-placeholder.hidden {
    opacity: 0;
  }

  .why-choose-us-section .media-placeholder svg {
    width: 100%;
    height: 100%;
    opacity: 0.5;
  }

  /* Inline Video Styles */
  #why-choose-us-{{ section.id }} .inline-video-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
    z-index: 1;
    background-color: #000;
  }

  #why-choose-us-{{ section.id }} .inline-video-container.active {
    opacity: 1;
    visibility: visible;
  }

  #why-choose-us-{{ section.id }} .inline-video-container video,
  #why-choose-us-{{ section.id }} .inline-video-container iframe {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .why-choose-us-section .why-choose-features {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .why-choose-us-section .features-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  .why-choose-us-section .feature-item {
    border-radius: 12px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .why-choose-us-section .feature-icon {
    width: var(--icon-size, 48px);
    height: var(--icon-size, 48px);
    flex-shrink: 0;
  }

  .why-choose-us-section .feature-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .why-choose-us-section .feature-icon .default-icon {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .why-choose-us-section .feature-icon .default-icon svg {
    width: 100%;
    height: 100%;
    color: var(--icon-color, #c9a227);
  }

  .why-choose-us-section .feature-icon .default-icon svg path {
    fill: var(--icon-color, #c9a227);
  }

  .why-choose-us-section .feature-content {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  @media(min-width:1000px) {
    {% if section.settings.main_title != blank %}
    #shopify-section-{{ section.id }} .why-choose-us-section .why-choose-features {
      justify-content: center;
    }
    {% endif %}

    {% if section.settings.video_right != blank %}
    #shopify-section-{{ section.id }} .why-choose-us-section .why-choose-container {
      display: flex !important;
      flex-direction: row-reverse;
    }
    .why-choose-us-section .why-choose-media {
      width: 55%;
    }
    .why-choose-us-section .why-choose-features {
      width: 40%;
    }
    {% endif %}
  }

  .why-choose-us-section .main-content-box {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
  }

  .why-choose-us-section .main-feature-title {
    font-size: var(--main-title-size, 18px);
    font-weight: 500;
    color: var(--main-title-color, #000000);
    margin: 0;
    line-height: 1.3;
  }

  .why-choose-us-section .main-feature-description {
    font-size: var(--main-desc-size, 14px);
    color: var(--main-desc-color, #666666);
    margin: 20px 0 0;
    line-height: 1.6;
    max-width: 86%;
  }

  .why-choose-us-section .feature-title {
    font-size: var(--feature-title-size, 18px);
    font-weight: 600;
    color: var(--feature-title-color, #000000);
    margin: 0;
    line-height: 1.3;
  }

  .why-choose-us-section .feature-description {
    font-size: var(--feature-desc-size, 14px);
    color: var(--feature-desc-color, #666666);
    margin: 0;
    line-height: 1.6;
  }

  .why-choose-us-section .hdt-btn.main-content-btn {
    background: {{ section.settings.btn_bgcolor }};
    color: {{ section.settings.btn_txtcolor }};
    width: max-content;
    margin-top: 20px;
    min-width: 290px;
    min-height: 50px;
    border-radius: 12px;
  }

  .why-choose-us-section .trust-badge {
    display: flex;
    align-items: center;
    gap: 12px;
    background-color: var(--badge-bg-color, #ffffff);
    padding: 10px 25px;
    border-radius: 30px;
    width: max-content;
    margin-left: 25px;
  }

  .why-choose-us-section .badge-icon,
  .why-choose-us-section .badge-icon-svg {
    width: 20px;
    height: 24px;
    flex-shrink: 0;
  }

  .why-choose-us-section .badge-text {
    font-size: var(--badge-font-size, 13px);
    color: var(--badge-text-color, #333333);
    line-height: 1.5;
    font-weight: 500;
  }

  @media (min-width: 1400px) {
    .why-choose-us-section .why-choose-container {
      gap: 60px;
    }
    .why-choose-us-section .features-grid {
      gap: 30px;
    }
    .why-choose-us-section .feature-item {
      padding: 28px;
    }
  }

  @media (max-width: 1399px) {
    .why-choose-us-section .why-choose-container {
      gap: 30px;
    }
    .why-choose-us-section .feature-item {
      padding: 20px;
    }
  }

  @media (max-width: 1023px) {
    .why-choose-us-section .why-choose-container {
      grid-template-columns: 1fr;
      gap: 30px;
    }
    .why-choose-us-section .media-wrapper {
      min-height: 350px;
      max-height: 400px;
    }
    .why-choose-us-section .features-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }
    .why-choose-us-section .feature-item {
      padding: 20px;
    }
  }

  @media (max-width: 899px) {
    .why-choose-us-section .media-wrapper {
      min-height: 300px;
      max-height: 350px;
    }
    .why-choose-us-section .features-grid {
      gap: 16px;
    }
    .why-choose-us-section .feature-item {
      padding: 18px;
      gap: 12px;
    }
    .why-choose-us-section .feature-icon {
      width: var(--icon-size-mobile, 40px);
      height: var(--icon-size-mobile, 40px);
    }
    .why-choose-us-section .main-feature-title {
      font-size: var(--main-title-size-mobile, 16px);
    }
    .why-choose-us-section .main-feature-description {
      font-size: var(--main-desc-size-mobile, 13px);
    }
    .why-choose-us-section .feature-title {
      font-size: var(--feature-title-size-mobile, 16px);
    }
    .why-choose-us-section .feature-description {
      font-size: var(--feature-desc-size-mobile, 13px);
    }
    .why-choose-us-section .trust-badge {
      padding: 14px 16px;
    }
    .why-choose-us-section .badge-text {
      font-size: var(--badge-font-size-mobile, 11px);
    }
  }

  @media (max-width: 767px) {
    #why-choose-us-{{ section.id }} .main-feature-title.mobile-title {
      display: block !important;
      text-align: center;
    }
    #why-choose-us-{{ section.id }} span.main-feature-description {
      margin: 0 !important;
      text-align: center;
    }
    .why-choose-us-section .main-content-box {
      align-items: center;
    }
    #why-choose-us-{{ section.id }} h3.main-feature-title {
      display: none;
    }
    #why-choose-us-{{ section.id }} .hdt-container::before,
    #why-choose-us-{{ section.id }} .hdt-container::after {
      left: 15px;
      right: 15px;
    }
    #why-choose-us-{{ section.id }} .hdt-container::before {
      top: -40px;
    }
    .why-choose-us-section .why-choose-container {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .why-choose-us-section .media-wrapper {
      min-height: 220px;
      max-height: 280px;
      border-radius: 12px;
    }
    .why-choose-us-section .features-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }
    .why-choose-us-section .feature-item {
      padding: 16px 12px;
      gap: 10px;
      border-radius: 10px;
      align-items: center;
      text-align: center;
    }
    .why-choose-us-section .feature-icon {
      width: 36px;
      height: 36px;
    }
    .why-choose-us-section .feature-content {
      align-items: center;
      gap: 6px;
    }
    .why-choose-us-section .feature-title {
      font-size: 14px;
      text-align: center;
    }
    .why-choose-us-section .feature-description {
      font-size: 12px;
      text-align: center;
      line-height: 1.4;
    }
    .why-choose-us-section .why-choose-features {
      gap: 16px;
    }
    .why-choose-us-section .trust-badge {
      padding: 14px 16px;
      gap: 15px;
      border-radius: 30px;
      justify-content: center;
      width: 90%;
      margin: 0 auto;
    }
    .why-choose-us-section .badge-text {
      text-align: left;
      line-height: normal;
    }
  }

  @media (max-width: 480px) {
    .why-choose-us-section .mobile-section-heading {
      font-size: 24px;
    }
    .why-choose-us-section .media-wrapper {
      min-height: 200px;
      max-height: 240px;
      border-radius: 10px;
    }
    .why-choose-us-section .features-grid {
      gap: 12px;
    }
    .why-choose-us-section .feature-item {
      padding: 14px 10px;
      gap: 8px;
    }
    .why-choose-us-section .feature-icon {
      width: 32px;
      height: 32px;
    }
    .why-choose-us-section .feature-description {
      font-size: 11px;
    }
    .why-choose-us-section .trust-badge {
      flex-direction: row;
      text-align: center;
      padding: 12px 20px;
    }
  }

  @media (max-width: 375px) {
    .why-choose-us-section .mobile-section-heading {
      font-size: 22px;
    }
    .why-choose-us-section .media-wrapper {
      min-height: 180px;
      max-height: 220px;
    }
    .why-choose-us-section .features-grid {
      gap: 10px;
    }
    .why-choose-us-section .feature-item {
      padding: 12px 8px;
    }
    .why-choose-us-section .feature-icon {
      width: 28px;
      height: 28px;
    }
    .why-choose-us-section .feature-title {
      font-size: 12px;
    }
    .why-choose-us-section .feature-description {
      font-size: 10px;
      line-height: 1.3;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .why-choose-us-section .feature-item,
    .why-choose-us-section .play-button {
      transition: none;
    }
    .why-choose-us-section .feature-item:hover,
    .why-choose-us-section .play-button:hover {
      transform: none;
    }
  }

  @media (prefers-contrast: high) {
    .why-choose-us-section .feature-item,
    .why-choose-us-section .trust-badge {
      border: 2px solid #000000;
    }
  }

  @media print {
    .why-choose-us-section .why-choose-container {
      display: block;
    }
    .why-choose-us-section .why-choose-media {
      display: none;
    }
    .why-choose-us-section .features-grid {
      display: grid !important;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }
    .why-choose-us-section .feature-item {
      box-shadow: none;
      border: 1px solid #cccccc;
      break-inside: avoid;
    }
  }
</style>

<section id="why-choose-us-{{ section.id }}" class="why-choose-us-section">
  <div class="why-choose-wrapper">
    <div class="hdt-container">
      {% if section.settings.show_topbar %}
      <div class="border-star top-star"></div>
      {% endif %}
      {% if section.settings.show_bottombar %}
      <div class="border-star bottom-star">
        <svg xmlns="http://www.w3.org/2000/svg" width="51" height="51" viewBox="0 0 51 51" fill="none">
          <path d="M25.48 7.57031C26.0717 7.57031 26.5558 8.04956 26.5961 8.63991C27.1711 17.0727 33.9197 23.8094 42.3575 24.3662C42.9489 24.4052 43.4297 24.8868 43.4297 25.4795C43.4297 26.0722 42.9489 26.5538 42.3575 26.5928C33.9073 27.1505 27.1514 33.9072 26.5938 42.3575C26.5547 42.9489 26.0727 43.4297 25.48 43.4297C24.8873 43.4297 24.4052 42.9489 24.3662 42.3575C23.8093 33.9197 17.0727 27.1711 8.63991 26.5961C8.04956 26.5558 7.57031 26.0712 7.57031 25.4795C7.57031 24.8878 8.04956 24.4032 8.63991 24.3629C17.0603 23.7888 23.7897 17.0602 24.3639 8.63991C24.4041 8.04956 24.8883 7.57031 25.48 7.57031Z" fill="#696969"/>
