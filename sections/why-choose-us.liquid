      {% endif %}

      <div class="why-choose-container">
        {% if section.settings.video_heading != blank %}
        <h2 class="mobile-section-heading">{{ section.settings.video_heading }}</h2>
        {% endif %}

        {% if section.settings.main_title != blank %}
        <h3 class="main-feature-title mobile-title" style="display:none">{{ section.settings.main_title }}</h3>
        {% endif %}

        <div class="why-choose-media">
          <div class="media-wrapper">
            {% if section.settings.video_thumbnail != blank %}
            <img 
              src="{{ section.settings.video_thumbnail | image_url: width: 800 }}" 
              alt="{{ section.settings.video_heading }}"
              class="media-image"
              id="thumbnail-{{ section.id }}"
              loading="lazy"
              width="800"
              height="500"
            >
            {% else %}
            <div class="media-placeholder" id="thumbnail-{{ section.id }}">
              {{ 'lifestyle-1' | placeholder_svg_tag }}
            </div>
            {% endif %}

            {% comment %} Inline Video Container {% endcomment %}
            <div class="inline-video-container" id="inline-video-{{ section.id }}">
              {% if section.settings.shopify_video != blank %}
              {{ section.settings.shopify_video | video_tag: autoplay: false, loop: false, muted: false, controls: true, class: 'inline-shopify-video' }}
              {% endif %}
              <iframe id="video-iframe-{{ section.id }}" src="" frameborder="0" allowfullscreen allow="autoplay; encrypted-media" style="display: none;"></iframe>
            </div>

            <div class="media-overlay" id="media-overlay-{{ section.id }}">
              {% if section.settings.video_heading != blank %}
              <h2 class="media-heading">{{ section.settings.video_heading }}</h2>
              {% endif %}

              {% assign has_video = false %}
              {% if section.settings.shopify_video != blank %}
              {% assign has_video = true %}
              {% elsif section.settings.video_url != blank %}
              {% assign has_video = true %}
              {% endif %}

              {% if has_video %}
              <button class="play-button" 
                {% if section.settings.shopify_video != blank %}
                data-video-type="shopify"
                {% else %}
                data-video-type="external"
                data-video-url="{{ section.settings.video_url }}"
                {% endif %}
                aria-label="Play video">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M8 5v14l11-7z"/>
                </svg>
              </button>
              {% endif %}
            </div>
          </div>
        </div>

