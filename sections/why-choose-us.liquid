<script>
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.getElementById('why-choose-us-{{ section.id }}');
    const playBtn = section.querySelector('.play-button');
    const inlineVideoContainer = document.getElementById('inline-video-{{ section.id }}');
    const mediaOverlay = document.getElementById('media-overlay-{{ section.id }}');
    const thumbnail = document.getElementById('thumbnail-{{ section.id }}');
    const iframe = document.getElementById('video-iframe-{{ section.id }}');
    const shopifyVideo = inlineVideoContainer ? inlineVideoContainer.querySelector('video') : null;
    const mediaHeading = mediaOverlay ? mediaOverlay.querySelector('.media-heading') : null;
    
    function getVideoEmbedUrl(url) {
      // YouTube
      let match = url.match(/(?:youtube\.com\/(?:[^\/]+\/.+\/|(?:v|e(?:mbed)?)\/|.*[?&]v=)|youtu\.be\/)([^"&?\/\s]{11})/);
      if (match) {
        return 'https://www.youtube.com/embed/' + match[1] + '?autoplay=1&rel=0';
      }
      // Vimeo
      match = url.match(/vimeo\.com\/(?:video\/)?(\d+)/);
      if (match) {
        return 'https://player.vimeo.com/video/' + match[1] + '?autoplay=1';
      }
      return url;
    }

    function showPlayButton(isPaused) {
      mediaOverlay.classList.remove('hidden');
      if (isPaused) {
        mediaOverlay.classList.add('video-paused');
        // Hide heading when showing paused overlay
        if (mediaHeading) mediaHeading.style.display = 'none';
      }
    }

    function hidePlayButton() {
      mediaOverlay.classList.add('hidden');
      mediaOverlay.classList.remove('video-paused');
    }

    function resetToThumbnail() {
      inlineVideoContainer.classList.remove('active');
      mediaOverlay.classList.remove('hidden');
      mediaOverlay.classList.remove('video-paused');
      // Show heading again
      if (mediaHeading) mediaHeading.style.display = '';
      if (thumbnail) {
        thumbnail.classList.remove('hidden');
      }
      if (shopifyVideo) {
        shopifyVideo.currentTime = 0;
      }
    }

    function playVideo() {
      const videoType = playBtn.getAttribute('data-video-type');
      
      // Hide overlay and thumbnail
      hidePlayButton();
      if (thumbnail) {
        thumbnail.classList.add('hidden');
      }
      
      // Show video container
      inlineVideoContainer.classList.add('active');
      
      if (videoType === 'shopify' && shopifyVideo) {
        // Show and play Shopify hosted video
        shopifyVideo.style.display = 'block';
        if (iframe) iframe.style.display = 'none';
        shopifyVideo.play();
      } else {
        // Show external video (YouTube/Vimeo)
        const videoUrl = playBtn.getAttribute('data-video-url');
        if (iframe) {
          iframe.src = getVideoEmbedUrl(videoUrl);
          iframe.style.display = 'block';
        }
        if (shopifyVideo) shopifyVideo.style.display = 'none';
      }
    }

    function resumeVideo() {
      if (shopifyVideo && shopifyVideo.paused) {
        shopifyVideo.play();
      }
    }

    function toggleVideoPlayPause() {
      if (shopifyVideo) {
        if (shopifyVideo.paused) {
          shopifyVideo.play();
        } else {
          shopifyVideo.pause();
        }
      }
    }
    
    if (playBtn && inlineVideoContainer) {
      // Play button click
      playBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        if (shopifyVideo && shopifyVideo.paused && inlineVideoContainer.classList.contains('active')) {
          // Video is paused, resume it
          resumeVideo();
        } else {
          playVideo();
        }
      });

      // Click on overlay (outside play button) to play/resume
      mediaOverlay.addEventListener('click', function(e) {
        if (e.target !== playBtn && !playBtn.contains(e.target)) {
          if (shopifyVideo && shopifyVideo.paused && inlineVideoContainer.classList.contains('active')) {
            // Video is paused, resume it
            resumeVideo();
          } else {
            playVideo();
          }
        }
      });

      if (shopifyVideo) {
        // Click/tap on video to toggle play/pause (works on mobile and desktop)
        shopifyVideo.addEventListener('click', function(e) {
          // Check if click is on the video controls area (bottom ~40px)
          const videoRect = shopifyVideo.getBoundingClientRect();
          const clickY = e.clientY - videoRect.top;
          const controlsHeight = 50; // Approximate height of video controls
          
          // If click is not in the controls area, toggle play/pause
          if (clickY < videoRect.height - controlsHeight) {
            e.preventDefault();
            toggleVideoPlayPause();
          }
        });

        // Also handle touch events for better mobile support
        shopifyVideo.addEventListener('touchend', function(e) {
          // Check if it's a tap (not a scroll or other gesture)
          if (e.changedTouches.length === 1) {
            const touch = e.changedTouches[0];
            const videoRect = shopifyVideo.getBoundingClientRect();
            const touchY = touch.clientY - videoRect.top;
            const controlsHeight = 50;
            
            // If touch is not in the controls area, toggle play/pause
            if (touchY < videoRect.height - controlsHeight) {
              // Small delay to differentiate from other gestures
              toggleVideoPlayPause();
            }
          }
        });

        // Show play button when video is paused
        shopifyVideo.addEventListener('pause', function() {
          // Only show if video hasn't ended (currentTime < duration)
          if (shopifyVideo.currentTime < shopifyVideo.duration) {
            showPlayButton(true); // true = video is paused
          }
        });

        // Hide play button when video starts playing
        shopifyVideo.addEventListener('play', function() {
          hidePlayButton();
        });

        // Handle video end - reset to thumbnail state
        shopifyVideo.addEventListener('ended', function() {
          resetToThumbnail();
        });
      }
    }
  });
</script>

