          <path d="M27.0046 47.7191V49.3856C27.0046 49.4674 26.9705 49.5454 26.9105 49.6009L25.5978 50.8149C25.4849 50.9193 25.3107 50.9188 25.1984 50.8139L23.8997 49.6008C23.8403 49.5453 23.8066 49.4677 23.8066 49.3865V47.7191C23.8066 47.5571 23.9379 47.4258 24.0999 47.4258H26.7113C26.8733 47.4258 27.0046 47.5571 27.0046 47.7191Z" fill="#696969"/>
