<script>
document.addEventListener('click', function(e) {
  const searchWrapper = document.querySelector('.hdt_predictive-search2');
  if (!searchWrapper) return;
  
  if (!searchWrapper.contains(e.target)) {
    searchWrapper.querySelectorAll('.hdt-cart-show-has-results').forEach(el => {
      el.classList.add('hdt-hidden');
    });
    searchWrapper.querySelectorAll('[data-results-search]').forEach(el => {
      el.innerHTML = '';
    });
    const input = searchWrapper.querySelector('[data-input-search]');
    if (input) {
      input.value = '';
      input.blur();
    }
  }
});
</script>
