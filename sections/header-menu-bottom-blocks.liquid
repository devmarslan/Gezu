/* Panel Menu Dialog Styles */
.hdt-dialog-drawer--panels {
  max-width: 320px !important;
  width: 85vw !important;
  padding: 0 !important;
}
.hdt-dialog-drawer--panels .hdt-dialog-drawer__inner {
  padding: 0 !important;
  height: 100%;
  display: flex;
  flex-direction: column;
}
.hdt-dialog-drawer--panels .hdt-dialog-btn__close {
  display: none !important;
}
/* Mobile Panel Menu Styles */
.mobile-panel-menu {
  position: relative;
  width: 100%;
  flex: 1;
  overflow: hidden;
}
.menu-panel {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: #fff;
  transform: translateX(100%);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  display: flex;
  flex-direction: column;
  z-index: 1;
  will-change: transform;
}
.menu-panel--main {
  transform: translateX(0);
  z-index: 2;
}
.menu-panel.is-active {
  transform: translateX(0);
  z-index: 10;
}
.menu-panel.is-hidden {
  transform: translateX(-30%);
  z-index: 1;
  pointer-events: none;
}
/* Panel Header - Blue Bar */
.menu-panel__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  background: #003da5;
  color: #fff;
  min-height: 52px;
  flex-shrink: 0;
}

.menu-panel__back {
  display: flex;
  align-items: center;
  gap: 6px;
  background: none;
  border: none;
  color: #fff;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  padding: 0;
  white-space: nowrap;
}
.menu-panel__back svg {
  flex-shrink: 0;
  width: 18px;
  height: 18px;
}
.menu-panel__close {
  background: none;
  border: none;
  color: #fff;
  cursor: pointer;
  padding: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: auto;
}
.menu-panel__close svg {
  width: 22px;
  height: 22px;
}
/* Panel Body */
.menu-panel__body {
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}
.menu-panel__section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px;
  border-bottom: 1px solid #e5e5e5;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 5;
}
.menu-panel__section-title {
  font-size: 14px;
  font-weight: 700;
  color: #1a1a1a;
}
.menu-panel__shop-all {
  font-size: 12px;
  font-weight: 600;
  color: #003da5;
  text-decoration: underline;
}
.menu-panel__shop-all:hover {
  text-decoration: underline;
}
/* Menu List Items */
.menu-panel__list {
  list-style: none;
  margin: 0;
  padding: 0;
}
.menu-panel__item {
  border-bottom: 1px solid #f0f0f0;
}
.menu-panel__item:last-child {
  border-bottom: none;
}
.menu-panel__link {
  display: flex;
  align-items: center;
  width: 100%;
  padding: 14px 16px;
  background: none;
  border: none;
  text-decoration: none;
  color: #1a1a1a;
  font-size: 15px;
  font-weight: 400;
  cursor: pointer;
  text-align: left;
  gap: 12px;
  transition: background 0.15s ease;
}
.menu-panel__link:hover,
.menu-panel__link:active {
  background: #f5f5f5;
}
.menu-panel__link--has-children {
  padding-right: 12px;
}

/* Panel Footer */
.menu-panel__footer {
  padding: 16px;
  border-top: 1px solid #e5e5e5;
  background: #f8f8f8;
  flex-shrink: 0;
}
.menu-panel__footer-item {
  margin-bottom: 14px;
}
.menu-panel__footer-item:last-of-type {
  margin-bottom: 0;
}
.menu-panel__footer-link {
  display: flex;
  align-items: center;
  gap: 10px;
  color: #1a1a1a;
  text-decoration: none;
  font-size: 14px;
  font-weight: 500;
}
.menu-panel__footer-link svg {
  color: #003da5;
}
.menu-panel__footer-link:hover {
  color: #003da5;
}
.menu-panel__footer-localization {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-top: 16px;
  padding-top: 16px;
  border-top: 1px solid #e0e0e0;
}
.only-mobile-icons .hdt-site-nav_icon.hdt-site-nav_user, .only-mobile-icons .hdt-site-nav_icon.hdt-site-nav_cart {
  display: none !important;
}
.only-mobile-icons {
  display: none;
}
/* Animation for smoother transitions */
@media (prefers-reduced-motion: no-preference) {
  .menu-panel {
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }
}
/* Ensure proper height on iOS */
@supports (-webkit-touch-callout: none) {
  .mobile-panel-menu {
    height: calc(100vh - 120px);
    height: calc(100dvh - 120px);
  }
}
@media (max-width:768px) {
  .only-mobile-icons {
    display: block !important;
  }
  .hdt-site-nav_icon.hdt-site-nav_search {
      display: none;
  }
  .only-mobile-icons .hdt-site-nav_icon.hdt-site-nav_search {
      display: block !important;
  }
  .hdt-main-header .hdt-custom-col-3.hdr-first-col {
      width: 15%;
  }
  .hdt-main-header .hdt-custom-col-6.aa {
    width: 60%;
  }
}
</style>

