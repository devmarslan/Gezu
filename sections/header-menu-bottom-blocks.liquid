                                {%- render 'pr_loop_item', section_id: section.id, product: product, sizes: "68px", widths: "68, 136, 150, 174, 240, 300" -%}
                              {%- endfor -%}
                            </div>
                          </div>
                        {%- endif -%}
                      </div>
                    </div>
                  </div>
                {%- endif -%}
              </div>
              </hdt-predictive-search>
            {%- else -%}
              </search-form>
            {%- endif -%}
