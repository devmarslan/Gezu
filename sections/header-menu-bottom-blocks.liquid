{%- style -%}html{--header-height:{{section.settings.header_height_mb}}px;--header-height2:{{section.settings.header_height_mb}}px;--header-bottom-height:0}@media(min-width:1150px){html{--header-height:{{section.settings.header_height | plus:section.settings.header_bottom_height}}px;--header-height2:{{section.settings.header_height}}px;--header-bottom-height:{{section.settings.header_bottom_height}}px}.hdt-navigation{--spacing-menu-item:calc({{ section.settings.spacing_nav}}px * .7)}}@media (min-width:1441px){.hdt-navigation{--spacing-menu-item:{{section.settings.spacing_nav}}px}}.hdt-menu-uppercase-true #hdt-nav-ul>li>a,.hdt-menu-uppercase-true #hdt-nav-ul>li>details>summary, .hdt-menu-uppercase-true #hdt-nav-ul>li> hdt-header-menu > details > summary{text-transform:uppercase;letter-spacing:.6px}.hdt-header-language_currencies{gap:28px}.hdt-header-language_currencies button[aria-expanded="true"]+.hdt-popover{z-index:9}{%- endstyle -%}
