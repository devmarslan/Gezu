<!-- Collections-list-simple.liquid -->
{%- style -%}.hdt-text-uppercase-true .hdt-collection-title{text-transform:uppercase;letter-spacing:.7px}.hdt-collections-list-simple .hdt-collection-item .hdt-collection-title{padding:0 var(--spacing-3);height:50px;line-height:48px;color:rgb(var(--color-button-text));background-color:rgb(var(--color-button));border:solid 1px rgb(var(--color-button-border));max-width:100%;border-radius:var(--radius-collection-card)}.hdt-collections-list-simple .hdt-collection-item{flex:0 0 auto}.hdt-collection-other_link{margin-top:30px}.hdt-collection-other_link a{color:rgb(var(--color-link));gap:8px}.hdt-collection-other_link a::after{width:100%;height:1px;background-color:rgb(var(--color-link));content:"";position:absolute;z-index:1;bottom:0;left:0;right:0}@media(min-width:1150px){.hdt-collection-other_link{margin-top:50px}} @media (-moz-touch-enabled:0),(hover:hover) and (min-width:1150px){.hdt-collections-list-simple .hdt-collection-item .hdt-collection-title:hover{background-color:rgb(var(--color-button-text));color:rgb(var(--color-button));border-color:rgb(var(--color-button-text))}.hdt-collection-other_link a:hover{color: rgb(var(--color-accent));}.hdt-collection-other_link a:hover::after{background-color:rgb(var(--color-accent))}}{%- endstyle -%}
<style>
  #shopify-section-{{ section.id }}.hdt-collections-list-simple .hdt-collection-item .hdt-collection-title{background-color:transparent !important; border-radius: 30px;}
  @media (max-width:768px){
    #shopify-section-{{ section.id }}.hdt-collections-list-simple .hdt-collection-item .hdt-collection-title{
      font-size: 12px;
      padding: 0 var(--spacing-2);
      height: 40px;
        --spacing-3: 1rem;
    }
  }
  
  /* Slider Arrow Styles - Desktop only */
  #shopify-section-{{ section.id }} .hdt-slider-arrows {
    display: none;
  }
  #shopify-section-{{ section.id }} .hdt-container {
    position: relative;
  }
  #shopify-section-{{ section.id }} .hdt-slider__viewport {
    padding-bottom: 2px;
}
  @media (min-width: 769px) {
    #shopify-section-{{ section.id }} .hdt-slider-arrows {
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: absolute;
      top: 70%;
      left: 4px;
      right: 4px;
      transform: translateY(-50%);
      pointer-events: none;
      z-index: 10;
      padding: 0 0px;
    }
  }
  
  #shopify-section-{{ section.id }} .hdt-slider-arrow {
    pointer-events: auto;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color:#e1e9f5;
    color: #000;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: opacity 0.3s ease, visibility 0.3s ease, transform 0.2s ease;
    opacity: 1;
    visibility: visible;
  }
  
  #shopify-section-{{ section.id }} .hdt-slider-arrow:hover {
    transform: scale(1.05);
  }
  
  #shopify-section-{{ section.id }} .hdt-slider-arrow:active {
    transform: scale(0.95);
  }
  
  #shopify-section-{{ section.id }} .hdt-slider-arrow.is-hidden {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }
  
  #shopify-section-{{ section.id }} .hdt-slider-arrow:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  
  #shopify-section-{{ section.id }} .hdt-slider-arrow svg {
    width: 16px;
    height: 16px;
  }
  
  #shopify-section-{{ section.id }} .hdt-section-spacing {
    position: relative;
  }
  
  /* Smooth slider container transition - Desktop only */
  @media (min-width: 769px) {
    #shopify-section-{{ section.id }}.arrows-enabled .hdt-slider__container {
      transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1) !important;
      will-change: transform;
      -webkit-backface-visibility: hidden;
      backface-visibility: hidden;
      -webkit-transform-style: preserve-3d;
      transform-style: preserve-3d;
    }
  }
  
  /* Ensure slides don't have conflicting transitions */
  #shopify-section-{{ section.id }} .hdt-slider__slide {
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
  }
</style>

{{ 'hdt-collections-list.css' | asset_url | stylesheet_tag }}
<div id="{{ section.id }}" class="hdt-section-spacing hdt-s-gradient" style="--section-pt: {{ section.settings.padding_top }}px; --section-pb: {{ section.settings.padding_bottom }}px; --section-prate:{{ section.settings.padding_rate }};" color-scheme="{{ section.settings.color_scheme }}">
  <div class="hdt-container{%- if section.settings.section_fullwidth -%}-full{% endif %}">
    {% content_for 'block', type: 'section-heading', id: 'collection-list-simple' %}
    {%- if section.settings.option_layout == 'carousel' -%}
      {%- assign show_arrows = section.settings.show_arrows -%}
      
      {%- if show_arrows -%}
        <div class="hdt-slider-arrows" id="SliderArrows-{{ section.id }}">
          <button type="button" class="hdt-slider-arrow hdt-slider-arrow--prev is-hidden" aria-label="Previous">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
          </button>
          <button type="button" class="hdt-slider-arrow hdt-slider-arrow--next" aria-label="Next">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </button>
        </div>
      {%- endif -%}
      
      <hdt-slider id="Slider-{{ section.id }}" class="hdt-flex md:hdt-justify-center hdt-oh hdt-slider hdt-slider-has-dots-dk hdt-dots-outline hdt-text-uppercase-{{ section.settings.text_transform }} hdt-slides-auto hdt-slide-spacing-10 only-desktop" config='{ "id": "Slider-{{ section.id }}", "navUI": false, "dotUI": true }' hdt-reveal="slide-in" timeline>
        <div class="hdt-slider__viewport hdt-relative">
          <div class="hdt-slider__container">
            {%- if section.settings.collection_list != blank -%}
              {%- for collection in section.settings.collection_list -%}
                <div class="hdt-slider__slide hdt-collection-item hdt-text-center">
                  <a class="hdt-collection-title hdt-flex hdt-align-center hdt-radius-xs hdt-text-md hdt-font-normal" href="{{ collection.url }}"><span class="hdt-collection-title-text hdt-truncate">{{ collection.title }}</span></a>
                </div>
              {%- endfor -%}
            {%- else -%}
              {%- for i in (1..6) -%}
                <div class="hdt-slider__slide hdt-collection-item hdt-text-center">
                  <a class="hdt-collection-title hdt-flex hdt-align-center hdt-radius-xs hdt-text-md hdt-font-normal" href="#"><span class="hdt-collection-title-text hdt-truncate">{{ 'onboarding.collection_title' | t }}</span></a>
                </div>
              {%- endfor -%}
            {%- endif -%}
          </div>
          
          {% if section.settings.show_dots %}
          <div hdt-slider-dots class="hdt-slider__dots hdt-flex hdt-align-center hdt-justify-center" aria-controls="Slider-{{ section.id }}"></div>
          {% endif %}
        </div>
      </hdt-slider>
      
      {%- if show_arrows -%}
      <script>
        (function() {
          var sectionId = '{{ section.id }}';
          var section = document.querySelector('#shopify-section-' + sectionId);
          var slider = document.querySelector('#Slider-' + sectionId);
          var arrowsContainer = document.querySelector('#SliderArrows-' + sectionId);
          
          if (!slider || !arrowsContainer || !section) return;
          
          var container = slider.querySelector('.hdt-slider__container');
          var slides = slider.querySelectorAll('.hdt-slider__slide');
          var viewport = slider.querySelector('.hdt-slider__viewport');
          var prevBtn = arrowsContainer.querySelector('.hdt-slider-arrow--prev');
          var nextBtn = arrowsContainer.querySelector('.hdt-slider-arrow--next');
          
          if (!container || !slides.length || !prevBtn || !nextBtn || !viewport) return;
          
          var currentPosition = 0;
          var isAnimating = false;
          var gap = 10;
          var isDesktop = window.innerWidth >= 769;
          
          function getSlideWidth() {
            return slides[0].offsetWidth;
          }
          
          function getViewportWidth() {
            return viewport.offsetWidth;
          }
          
          function getTotalWidth() {
            return (slides.length * (getSlideWidth() + gap)) - gap;
          }
          
          function getMaxScroll() {
            return Math.max(0, getTotalWidth() - getViewportWidth());
          }
          
          function updateButtons() {
            var maxScroll = getMaxScroll();
            
            if (currentPosition <= 0) {
              prevBtn.classList.add('is-hidden');
            } else {
              prevBtn.classList.remove('is-hidden');
            }
            
            if (currentPosition >= maxScroll - 1) {
              nextBtn.classList.add('is-hidden');
            } else {
              nextBtn.classList.remove('is-hidden');
            }
          }
          
          function scrollTo(position) {
            if (isAnimating || !isDesktop) return;
            
            var maxScroll = getMaxScroll();
            currentPosition = Math.max(0, Math.min(position, maxScroll));
            
            isAnimating = true;
            
            requestAnimationFrame(function() {
              container.style.transform = 'translate3d(-' + currentPosition + 'px, 0, 0)';
              updateButtons();
              
              setTimeout(function() {
                isAnimating = false;
              }, 500);
            });
          }
          
          function scrollPrev() {
            if (isAnimating || !isDesktop) return;
            var slideWidth = getSlideWidth() + gap;
            scrollTo(currentPosition - slideWidth);
          }
          
          function scrollNext() {
            if (isAnimating || !isDesktop) return;
            var slideWidth = getSlideWidth() + gap;
            scrollTo(currentPosition + slideWidth);
          }
          
          function enableDesktopMode() {
            isDesktop = true;
            section.classList.add('arrows-enabled');
            container.style.pointerEvents = 'none';
            for (var i = 0; i < slides.length; i++) {
              slides[i].style.pointerEvents = 'auto';
            }
            updateButtons();
          }
          
          function enableMobileMode() {
            isDesktop = false;
            section.classList.remove('arrows-enabled');
            // Reset transform and enable drag
            container.style.transform = '';
            container.style.pointerEvents = '';
            for (var i = 0; i < slides.length; i++) {
              slides[i].style.pointerEvents = '';
            }
            currentPosition = 0;
          }
          
          function handleResize() {
            var wasDesktop = isDesktop;
            isDesktop = window.innerWidth >= 769;
            
            if (isDesktop && !wasDesktop) {
              enableDesktopMode();
            } else if (!isDesktop && wasDesktop) {
              enableMobileMode();
            } else if (isDesktop) {
              // Just recalculate on desktop
              var maxScroll = getMaxScroll();
              if (currentPosition > maxScroll) {
                currentPosition = maxScroll;
                container.style.transform = 'translate3d(-' + currentPosition + 'px, 0, 0)';
              }
              updateButtons();
            }
          }
          
          prevBtn.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            scrollPrev();
          });
          
          nextBtn.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            scrollNext();
          });
          
          // Initial setup based on screen size
          if (isDesktop) {
            enableDesktopMode();
          }
          
          // Handle resize with debounce
          var resizeTimeout;
          window.addEventListener('resize', function() {
            clearTimeout(resizeTimeout);
            resizeTimeout = setTimeout(handleResize, 150);
          });
        })();
      </script>
      {%- endif -%}
     
    {%- else -%}
      <div class="hdt-collections-list-simple-grid hdt-row-grid hdt-text-uppercase-{{ section.settings.text_transform }} hdt-grid-cols-{{ section.settings.mobile_grid_columns }} md:hdt-grid-cols-{{ section.settings.grid_columns }}">
        {%- if section.settings.collection_list != blank -%}
          {%- for collection in section.settings.collection_list -%}
            <div class="hdt-collection-item hdt-text-center">
              <a class="hdt-collection-title hdt-flex hdt-align-center hdt-radius-xs hdt-text-lg hdt-font-normal" href="{{ collection.url }}"><span class="hdt-collection-title-text hdt-truncate">{{ collection.title }}</span></a>
            </div>
          {%- endfor -%}
        {%- else -%}
          {%- for i in (1..6) -%}
            <div class="hdt-collection-item hdt-text-center">
              <a class="hdt-collection-title hdt-flex hdt-align-center hdt-radius-xs hdt-text-lg hdt-font-normal" href="#"><span class="hdt-collection-title-text hdt-truncate">{{ 'onboarding.collection_title' | t }}</span></a>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    {%- endif -%}
    {%- if section.settings.other_link_label != blank and section.settings.other_link != blank -%}
      <div class="hdt-flex hdt-justify-center hdt-align-center hdt-collection-other_link">
        <a class="hdt-text-base hdt-font-semibold hdt-inline-flex hdt-justify-center hdt-align-center hdt-relative" href="{{ section.settings.other_link }}">
          {{ section.settings.other_link_label }}
          <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 8 8" fill="none">
            <path d="M0.861539 8L0 7.13846L5.90769 1.23077H0.615385V0H8V7.38462H6.76923V2.09231L0.861539 8Z" fill="currentColor"/>
          </svg>
        </a>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.collection_list.name_simple",
  "tag": "section",
  "class": "hdt-section hdt-collections-list hdt-collections-list-simple",
  "disabled_on": {
    "groups": [
      "*"
    ]
  },
  "settings": [
    {
      "type": "select",
      "id": "option_layout",
      "label": "Layout (Desktop)",
      "options": [
        {
          "value": "grid",
          "label": "Grid"
        },
        {
          "value": "carousel",
          "label": "Carousel"
        }
      ],
      "default": "grid"
    },
    {
      "type": "select",
      "id": "number_of_items",
      "label": "Number of items",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2", 
          "label": "2"
        },
        {
          "value": "3",
          "label": "3"
        },
        {
          "value": "4",
          "label": "4"
        },
        {
          "value": "5",
          "label": "5"
        },
        {
          "value": "6",
          "label": "6"
        }
      ],
      "default": "6"
    },
    {
      "type": "select",
      "id": "grid_columns",
      "label": "Item per row on desktop",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" },
        { "value": "6", "label": "6" }
      ],
      "default": "4",
      "visible_if": "{{ section.settings.option_layout == 'grid' or section.settings.option_layout == 'grid2' }}"
    },
    {
      "type": "select",
      "id": "mobile_grid_columns",
      "label": "Item per row on mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" }
      ],
      "default": "2",
      "visible_if": "{{ section.settings.option_layout == 'grid' or section.settings.option_layout == 'grid2' }}"
    },
    {
      "type": "header",
      "content": "t:sections.collection_list.options_collection"
    },
    {
      "id": "collection_list",
      "type": "collection_list",
      "label": "t:sections.collection_list.settings.collection_list"
    },
    {
      "type": "checkbox",
      "id": "text_transform",
      "label": "t:sections.collection_list.settings.text_transform",
      "default": false,
      "visible_if": "{{ section.settings.collection_list != blank }}"
    },
    {
      "type": "text",
      "id": "other_link_label",
      "label": "t:sections.all.button.settings.text.label",
      "default": "View all categories",
      "visible_if": "{{ section.settings.collection_list != blank }}"
    },
    {
      "type": "url",
      "id": "other_link",
      "label": "t:sections.all.button.settings.url.label",
      "visible_if": "{{ section.settings.collection_list != blank }}"
    },
    {
      "type": "header",
      "content": "t:sections.all.section_layout",
      "visible_if": "{{ section.settings.collection_list != blank }}"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show slider arrows",
      "info": "Arrows on desktop, drag on mobile",
      "default": false,
      "visible_if": "{{ section.settings.option_layout == 'carousel' }}"
    },
    {
