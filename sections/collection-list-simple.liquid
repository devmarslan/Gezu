      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "t:sections.all.padding.padding_rate",
      "default": 75,
      "visible_if": "{{ section.settings.collection_list != blank }}"
    }
  ],
  "blocks": [
    {
      "type": "section-heading"
    }
  ],
  "presets": [
    {
      "name": "t:sections.collection_list.name_simple",
      "category": "t:sections_categories.03_collections.name",
      "blocks": [
        {
          "type": "section-heading",
          "static": true,
          "id": "collection-list-simple",
          "blocks": [
            {
              "type": "heading",
              "settings": {
                "heading": "<h4>Sustainable Style</h4>",
                "heading_size": "h4"
              }
            }
          ]
        }
      ]
    }
  ]
}
{% endschema %}