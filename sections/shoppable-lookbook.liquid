{% comment %}
  Shoppable Lookbook / Product Hotspots Section with Tabs
  - Tab navigation to switch between different lookbook images
  - Full-width background image per tab (desktop + mobile)
  - Clickable hotspot markers positioned on products
  - Product popup on click with image, title, price, quick view
  - Fully responsive with mobile-specific images and hotspot positions
{% endcomment %}

{{ 'section-shoppable-lookbook.css' | asset_url | stylesheet_tag }}

<style>
  #shoppable-lookbook-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --section-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --section-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --hotspot-color: {{ section.settings.hotspot_color }};
    --hotspot-bg: {{ section.settings.hotspot_bg }};
    --hotspot-size: {{ section.settings.hotspot_size }}px;
    --hotspot-size-mobile: {{ section.settings.hotspot_size_mobile }}px;
    --popup-bg: {{ section.settings.popup_bg }};
    --popup-title-color: {{ section.settings.popup_title_color }};
    --popup-title-size: {{ section.settings.popup_title_font_size }}px;
    --popup-price-color: {{ section.settings.popup_price_color }};
    --popup-price-size: {{ section.settings.popup_price_font_size }}px;
    --popup-compare-color: {{ section.settings.popup_compare_price_color }};
    --popup-discount-color: {{ section.settings.popup_discount_color }};
    --popup-btn-bg: {{ section.settings.popup_btn_bg }};
    --popup-btn-color: {{ section.settings.popup_btn_color }};
    --image-height: {{ section.settings.image_height }}px;
    --image-height-mobile: {{ section.settings.image_height_mobile }}px;
    --tab-bg: {{ section.settings.tab_bg }};
    --tab-color: {{ section.settings.tab_color }};
    --tab-active-bg: {{ section.settings.tab_active_bg }};
    --tab-active-color: {{ section.settings.tab_active_color }};
    --tab-border-color: {{ section.settings.tab_border_color }};
  }

  #shoppable-lookbook-{{ section.id }} .lookbook-wrapper {
    padding-top: var(--section-padding-top);
    padding-bottom: var(--section-padding-bottom);
    {% if section.settings.section_bg_color != blank %}
    background-color: {{ section.settings.section_bg_color }};
    {% endif %}
  }

  @media (max-width: 768px) {
    #shoppable-lookbook-{{ section.id }} .lookbook-wrapper {
      padding-top: var(--section-padding-top-mobile);
      padding-bottom: var(--section-padding-bottom-mobile);
    }
  }

  /* Header + Tabs Row */
  #shoppable-lookbook-{{ section.id }} .lookbook-header-tabs-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 30px;
    margin-bottom: 30px;
    padding: 0 20px;
    flex-wrap: wrap;
  }

  #shoppable-lookbook-{{ section.id }} .lookbook-header {
    flex: 0 1 auto;
    max-width: 400px;
  }

  #shoppable-lookbook-{{ section.id }} .lookbook-heading {
    margin: 0 0 8px 0;
  }

  #shoppable-lookbook-{{ section.id }} .lookbook-subheading {
    margin: 0;
    line-height: 1.5;
  }

  /* Tab Styles */
  #shoppable-lookbook-{{ section.id }} .lookbook-tabs {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    flex: 1 1 auto;
  }

  #shoppable-lookbook-{{ section.id }} .lookbook-tab-btn {
    padding: 12px 28px;
    border: 2px solid var(--tab-border-color, #0066cc);
    background-color: var(--tab-bg, #ffffff);
    color: var(--tab-color, #0066cc);
    font-size: {{ section.settings.tab_font_size }}px;
    font-weight: 600;
    border-radius: 50px;
    cursor: pointer;
    transition: all 0.3s ease;
    white-space: nowrap;
  }

  #shoppable-lookbook-{{ section.id }} .lookbook-tab-btn:hover {
    background-color: var(--tab-active-bg, #0066cc);
    color: var(--tab-active-color, #ffffff);
  }

  #shoppable-lookbook-{{ section.id }} .lookbook-tab-btn.active {
    background-color: var(--tab-active-bg, #0066cc);
    color: var(--tab-active-color, #ffffff);
  }

  #shoppable-lookbook-{{ section.id }} .lookbook-tab-content {
    display: none;
  }

  #shoppable-lookbook-{{ section.id }} .lookbook-tab-content.active {
    display: block;
  }

  /* Tab Content Background Images */
  {% for block in section.blocks %}
    {% if block.type == 'tab' %}
      {% if block.settings.tab_bg_image != blank %}
        #shoppable-lookbook-{{ section.id }} .lookbook-tab-content[data-tab-content="tab-{{ block.id }}"] {
          background-image: url('{{ block.settings.tab_bg_image | image_url: width: 1920 }}');
          background-size: cover;
          background-position: center;
          background-repeat: no-repeat;
        }
      {% endif %}
      
      {% if block.settings.tab_bg_image_mobile != blank %}
        @media (max-width: 768px) {
          #shoppable-lookbook-{{ section.id }} .lookbook-tab-content[data-tab-content="tab-{{ block.id }}"] {
            background-image: url('{{ block.settings.tab_bg_image_mobile | image_url: width: 800 }}');
          }
        }
      {% endif %}
    {% endif %}
  {% endfor %}

  /* Quick View Button in Popup - Override theme styles */
  #shoppable-lookbook-{{ section.id }} .popup-qv-wrapper {
    width: 100%;
  }

  #shoppable-lookbook-{{ section.id }} .popup-qv-wrapper wrapp-hdt-open-modal-btn {
    width: 100%;
    max-width: 100%;
    display: block;
  }

  #shoppable-lookbook-{{ section.id }} .popup-qv-wrapper .hdt-card-product__btn-quick-view {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100% !important;
    max-width: 100% !important;
    background: #0047AB !important;
    color: #fff !important;
    border: none;
    border-radius: 10px !important;
    height: 45px;
    font-weight: 500 !important;
    font-size: 14px !important;
    text-transform: capitalize;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    gap: 8px;
    aspect-ratio: unset;
    box-shadow: none !important;
  }

  #shoppable-lookbook-{{ section.id }} .popup-qv-wrapper .hdt-card-product__btn-quick-view:hover {
    background: #003d91 !important;
  }

  #shoppable-lookbook-{{ section.id }} .popup-qv-wrapper .hdt-card-product__btn-quick-view svg {
    display: none;
  }

  #shoppable-lookbook-{{ section.id }} .popup-qv-wrapper .hdt-card-product__btn-quick-view span {
    display: block !important;
  }

  /* Custom Quick View Link Button */
  #shoppable-lookbook-{{ section.id }} .popup-quick-view-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    background: #0047AB !important;
    color: #fff !important;
    border: none;
    border-radius: 10px;
    height: 45px;
    font-weight: 500;
    font-size: 14px;
    text-transform: capitalize;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    gap: 8px;
  }

  #shoppable-lookbook-{{ section.id }} .popup-quick-view-link:hover {
    background: #003d91 !important;
    color: #fff !important;
  }

  /* Updated Popup Styles */
  #shoppable-lookbook-{{ section.id }} .popup-inner {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  #shoppable-lookbook-{{ section.id }} .popup-image {
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    background: #f8f8f8;
    border-radius: 8px;
    padding: 10px;
  }

  #shoppable-lookbook-{{ section.id }} .popup-image img {
    max-width: 100%;
    height: auto;
    max-height: 150px;
    object-fit: contain;
  }

  #shoppable-lookbook-{{ section.id }} .popup-content {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  #shoppable-lookbook-{{ section.id }} .popup-title {
    font-size: var(--popup-title-size, 14px);
    font-weight: 600;
    color: var(--popup-title-color, #000);
    margin: 0;
    line-height: 1.3;
  }

  #shoppable-lookbook-{{ section.id }} .popup-price {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  #shoppable-lookbook-{{ section.id }} .popup-price .current-price {
    font-size: var(--popup-price-size, 18px);
    font-weight: 700;
    color: #0047AB;
  }

  #shoppable-lookbook-{{ section.id }} .popup-price .compare-price {
    font-size: 14px;
    color: rgba(0, 0, 0, 0.32);
    text-decoration: line-through;
    font-weight: 400;
  }

  #shoppable-lookbook-{{ section.id }} .popup-price .discount-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    color: #CB2424;
    font-size: 12px;
    font-weight: 700;
    padding: 0;
    line-height: 1;
    white-space: nowrap;
  }
   @media (min-width: 992px) {
   #shoppable-lookbook-{{ section.id }} .popup-image {
     height: 100%;
  }
}
  @media (max-width: 991px) {
    #shoppable-lookbook-{{ section.id }} .lookbook-header-tabs-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
    }

    #shoppable-lookbook-{{ section.id }} .lookbook-header {
      max-width: 100%;
      text-align: center;
    }

    #shoppable-lookbook-{{ section.id }} .lookbook-tabs {
      justify-content: center;
      width: 100%;
    }
  }

  @media (max-width: 768px) {
    #shoppable-lookbook-{{ section.id }} .lookbook-header-tabs-row {
      margin-bottom: 20px;
    }
    #shoppable-lookbook-{{ section.id }} h2.lookbook-heading {
      font-size: 18px !important;
      font-weight: 500;
    }
    #shoppable-lookbook-{{ section.id }} .lookbook-tabs {
      gap: 20px;
    }

    #shoppable-lookbook-{{ section.id }} .lookbook-tab-btn {
      padding: 15px 20px;
      font-size: {{ section.settings.tab_font_size }}px;
      line-height: 1;
    }

    #shoppable-lookbook-{{ section.id }} .popup-qv-wrapper .hdt-card-product__btn-quick-view {
      height: 40px;
      font-size: 12px !important;
    }

    #shoppable-lookbook-{{ section.id }} .popup-quick-view-link {
      height: 40px;
      font-size: 12px;
    }
  }

</style>

<section id="shoppable-lookbook-{{ section.id }}" class="shoppable-lookbook-section">
  <div class="lookbook-wrapper">
    {% if section.settings.full_width %}
      <div class="lookbook-container full-width">
    {% else %}
      <div class="page-width">
        <div class="lookbook-container">
    {% endif %}

    {% comment %} Check if we have tabs {% endcomment %}
    {% assign has_tabs = false %}
    {% assign tab_count = 0 %}
    {% for block in section.blocks %}
      {% if block.type == 'tab' %}
        {% assign has_tabs = true %}
        {% assign tab_count = tab_count | plus: 1 %}
      {% endif %}
    {% endfor %}

    {% if has_tabs %}
      {% comment %} Header + Tabs Row {% endcomment %}
      <div class="lookbook-header-tabs-row hdt-container">
        {% comment %} Section Header {% endcomment %}
        {% if section.settings.heading != blank or section.settings.subheading != blank %}
          <div class="lookbook-header">
            {% if section.settings.heading != blank %}
              <h2 class="lookbook-heading" style="font-size: {{ section.settings.heading_font_size }}px; color: {{ section.settings.heading_color }};">
                {{ section.settings.heading }}
              </h2>
            {% endif %}
            {% if section.settings.subheading != blank %}
              <p class="lookbook-subheading" style="font-size: {{ section.settings.subheading_font_size }}px; color: {{ section.settings.subheading_color }};">
                {{ section.settings.subheading }}
              </p>
            {% endif %}
          </div>
        {% endif %}

        {% comment %} Tab Navigation {% endcomment %}
        <div class="lookbook-tabs" role="tablist">
          {% assign tab_index = 0 %}
          {% for block in section.blocks %}
            {% if block.type == 'tab' %}
              <button 
                class="lookbook-tab-btn{% if tab_index == 0 %} active{% endif %}"
                data-tab-id="tab-{{ block.id }}"
                data-tab-index="{{ tab_index }}"
                role="tab"
                aria-selected="{% if tab_index == 0 %}true{% else %}false{% endif %}"
                aria-controls="tab-panel-{{ block.id }}"
                {{ block.shopify_attributes }}
              >
                {{ block.settings.tab_title | default: 'Tab' }}
              </button>
              {% assign tab_index = tab_index | plus: 1 %}
            {% endif %}
          {% endfor %}
        </div>
      </div>

      {% comment %} Tab Content Panels {% endcomment %}
      {% assign tab_index = 0 %}
      {% for block in section.blocks %}
        {% if block.type == 'tab' %}
          <div 
            class="lookbook-tab-content{% if tab_index == 0 %} active{% endif %}"
            id="tab-panel-{{ block.id }}"
            role="tabpanel"
            data-tab-content="tab-{{ block.id }}"
            data-tab-index="{{ tab_index }}"
          >
            <div class="lookbook-image-container" {% if block.settings.tab_image_mobile != blank %}data-has-mobile-image="true"{% endif %}>
              {% if block.settings.tab_image != blank %}
                <img 
                  src="{{ block.settings.tab_image | image_url: width: 1920 }}" 
                  alt="{{ block.settings.tab_title | default: 'Lookbook image' }}"
                  class="lookbook-image lookbook-image-desktop"
                  loading="{% if tab_index == 0 %}eager{% else %}lazy{% endif %}"
                  width="1920"
                  height="{{ section.settings.image_height }}"
                >
              {% endif %}

              {% comment %} Mobile Image {% endcomment %}
              {% if block.settings.tab_image_mobile != blank %}
                <img 
                  src="{{ block.settings.tab_image_mobile | image_url: width: 800 }}" 
                  alt="{{ block.settings.tab_title | default: 'Lookbook image' }}"
                  class="lookbook-image lookbook-image-mobile"
                  loading="{% if tab_index == 0 %}eager{% else %}lazy{% endif %}"
                  width="800"
                  height="{{ section.settings.image_height_mobile }}"
                >
              {% endif %}

              {% comment %} Hotspots for this tab {% endcomment %}
              {% assign current_tab_index = tab_index | append: '' %}
              {% for hotspot_block in section.blocks %}
                {% if hotspot_block.type == 'hotspot' %}
                  {% assign hotspot_tab = hotspot_block.settings.tab_index | append: '' %}
                  {% if hotspot_tab == current_tab_index %}
                    {% assign product = hotspot_block.settings.product %}
                    {% assign mobile_x = hotspot_block.settings.position_x_mobile | default: hotspot_block.settings.position_x %}
                    {% assign mobile_y = hotspot_block.settings.position_y_mobile | default: hotspot_block.settings.position_y %}
                    <div 
                      class="hotspot" 
                      style="--desktop-x: {{ hotspot_block.settings.position_x }}%; --desktop-y: {{ hotspot_block.settings.position_y }}%; --mobile-x: {{ mobile_x }}%; --mobile-y: {{ mobile_y }}%;"
                      data-hotspot-id="{{ hotspot_block.id }}"
                      data-desktop-x="{{ hotspot_block.settings.position_x }}"
                      data-desktop-y="{{ hotspot_block.settings.position_y }}"
                      data-mobile-x="{{ mobile_x }}"
                      data-mobile-y="{{ mobile_y }}"
                      {{ hotspot_block.shopify_attributes }}
                    >
                      <button class="hotspot-button" aria-label="View product details">
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                          <path class="icon-horizontal" d="M0 7h14" stroke="currentColor" stroke-width="2"/>
                          <path class="icon-vertical" d="M7 0v14" stroke="currentColor" stroke-width="2"/>
                        </svg>
                      </button>

                      {% comment %} Product Popup {% endcomment %}
                      <div class="hotspot-popup popup-{{ hotspot_block.settings.popup_position }}" data-mobile-position="{{ hotspot_block.settings.popup_position_mobile | default: 'center' }}">
                        <div class="popup-inner">
                          {% if product != blank %}
                            <div class="popup-image">
                              {% if product.featured_image %}
                                <img src="{{ product.featured_image | image_url: width: 300 }}" alt="{{ product.title }}" loading="lazy">
                              {% endif %}
                            </div>
                            <div class="popup-content">
                              {% comment %} Quick View Button - Using Theme's Snippet {% endcomment %}
                              <div class="popup-qv-wrapper">
                                {% render 'btn-quick-view', class: 'hdt-pr_btn', product: product, section_id: section.id, disable_sr_only: true %}
                              </div>

                              <h4 class="popup-title">{{ product.title }}</h4>
                              <div class="popup-price">
                                <span class="current-price">{{ product.price | money }}</span>
                                {% if product.compare_at_price > product.price %}
                                  <span class="compare-price">{{ product.compare_at_price | money }}</span>
                                  {% assign discount = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round %}
                                  <span class="discount-badge">{{ discount }}% OFF</span>
                                {% endif %}
                              </div>
                            </div>
                          {% else %}
                            <div class="popup-image">
                              {% if hotspot_block.settings.custom_image != blank %}
                                <img src="{{ hotspot_block.settings.custom_image | image_url: width: 300 }}" alt="{{ hotspot_block.settings.custom_title }}" loading="lazy">
                              {% endif %}
                            </div>
                            <div class="popup-content">
                              {% comment %} Quick View Button for custom content - links to custom URL {% endcomment %}
                              <a href="{{ hotspot_block.settings.custom_link }}" class="popup-quick-view-link">
                                <span>Quick View</span>
                              </a>

                              <h4 class="popup-title">{{ hotspot_block.settings.custom_title | default: 'Product Title' }}</h4>
                              <div class="popup-price">
                                <span class="current-price">{{ hotspot_block.settings.custom_price | default: '£50.47' }}</span>
                                {% if hotspot_block.settings.custom_compare_price != blank %}
                                  <span class="compare-price">{{ hotspot_block.settings.custom_compare_price }}</span>
                                  <span class="discount-badge">{{ hotspot_block.settings.custom_discount | default: '20% OFF' }}</span>
                                {% endif %}
                              </div>
                            </div>
                          {% endif %}
                        </div>
                        <div class="popup-arrow"></div>
                      </div>
                    </div>
                  {% endif %}
                {% endif %}
              {% endfor %}
            </div>
          </div>
          {% assign tab_index = tab_index | plus: 1 %}
        {% endif %}
      {% endfor %}

    {% else %}
      {% comment %} Fallback if no tabs - show header and single image with hotspots {% endcomment %}
      {% if section.settings.heading != blank or section.settings.subheading != blank %}
        <div class="lookbook-header hdt-container" style="padding: 0 20px; margin-bottom: 30px;">
          {% if section.settings.heading != blank %}
            <h2 class="lookbook-heading" style="font-size: {{ section.settings.heading_font_size }}px; color: {{ section.settings.heading_color }};">
              {{ section.settings.heading }}
            </h2>
          {% endif %}
          {% if section.settings.subheading != blank %}
            <p class="lookbook-subheading" style="font-size: {{ section.settings.subheading_font_size }}px; color: {{ section.settings.subheading_color }};">
              {{ section.settings.subheading }}
            </p>
          {% endif %}
        </div>
      {% endif %}

      <div class="lookbook-image-container" {% if section.settings.lookbook_image_mobile != blank %}data-has-mobile-image="true"{% endif %}>
        {% if section.settings.lookbook_image != blank %}
          <img 
            src="{{ section.settings.lookbook_image | image_url: width: 1920 }}" 
            alt="{{ section.settings.heading | default: 'Shoppable lookbook' }}"
            class="lookbook-image lookbook-image-desktop"
            loading="lazy"
            width="1920"
            height="{{ section.settings.image_height }}"
          >
        {% endif %}

        {% comment %} Mobile Fallback Image {% endcomment %}
        {% if section.settings.lookbook_image_mobile != blank %}
          <img 
            src="{{ section.settings.lookbook_image_mobile | image_url: width: 800 }}" 
            alt="{{ section.settings.heading | default: 'Shoppable lookbook' }}"
            class="lookbook-image lookbook-image-mobile"
            loading="lazy"
            width="800"
            height="{{ section.settings.image_height_mobile }}"
          >
        {% endif %}

        {% for block in section.blocks %}
          {% if block.type == 'hotspot' %}
            {% assign product = block.settings.product %}
            {% assign mobile_x = block.settings.position_x_mobile | default: block.settings.position_x %}
            {% assign mobile_y = block.settings.position_y_mobile | default: block.settings.position_y %}
            <div 
              class="hotspot" 
              style="--desktop-x: {{ block.settings.position_x }}%; --desktop-y: {{ block.settings.position_y }}%; --mobile-x: {{ mobile_x }}%; --mobile-y: {{ mobile_y }}%;"
              data-hotspot-id="{{ block.id }}"
              data-desktop-x="{{ block.settings.position_x }}"
              data-desktop-y="{{ block.settings.position_y }}"
              data-mobile-x="{{ mobile_x }}"
              data-mobile-y="{{ mobile_y }}"
              {{ block.shopify_attributes }}
            >
              <button class="hotspot-button" aria-label="View product details">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <path class="icon-horizontal" d="M0 7h14" stroke="currentColor" stroke-width="2"/>
                  <path class="icon-vertical" d="M7 0v14" stroke="currentColor" stroke-width="2"/>
                </svg>
              </button>

              <div class="hotspot-popup popup-{{ block.settings.popup_position }}" data-mobile-position="{{ block.settings.popup_position_mobile | default: 'center' }}">
                <div class="popup-inner">
                  {% if product != blank %}
                    <div class="popup-image">
                      {% if product.featured_image %}
                        <img src="{{ product.featured_image | image_url: width: 300 }}" alt="{{ product.title }}" loading="lazy">
                      {% endif %}
                    </div>
                    <div class="popup-content">
                      {% comment %} Quick View Button - Using Theme's Snippet {% endcomment %}
                      <div class="popup-qv-wrapper">
                        {% render 'btn-quick-view', class: 'hdt-pr_btn', product: product, section_id: section.id, disable_sr_only: true %}
                      </div>

                      <h4 class="popup-title">{{ product.title }}</h4>
                      <div class="popup-price">
                        <span class="current-price">{{ product.price | money }}</span>
                        {% if product.compare_at_price > product.price %}
                          <span class="compare-price">{{ product.compare_at_price | money }}</span>
                          {% assign discount = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round %}
                          <span class="discount-badge">{{ discount }}% OFF</span>
                        {% endif %}
                      </div>
                    </div>
                  {% else %}
                    <div class="popup-image">
                      {% if block.settings.custom_image != blank %}
                        <img src="{{ block.settings.custom_image | image_url: width: 300 }}" alt="{{ block.settings.custom_title }}" loading="lazy">
                      {% endif %}
                    </div>
                    <div class="popup-content">
                      {% comment %} Quick View Button for custom content {% endcomment %}
                      <a href="{{ block.settings.custom_link }}" class="popup-quick-view-link">
                        <span>Quick View</span>
                      </a>

                      <h4 class="popup-title">{{ block.settings.custom_title | default: 'Product Title' }}</h4>
                      <div class="popup-price">
                        <span class="current-price">{{ block.settings.custom_price | default: '£50.47' }}</span>
                        {% if block.settings.custom_compare_price != blank %}
                          <span class="compare-price">{{ block.settings.custom_compare_price }}</span>
                          <span class="discount-badge">{{ block.settings.custom_discount | default: '20% OFF' }}</span>
                        {% endif %}
                      </div>
                    </div>
                  {% endif %}
                </div>
                <div class="popup-arrow"></div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}

    {% if section.settings.full_width %}
      </div>
    {% else %}
        </div>
      </div>
    {% endif %}
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.getElementById('shoppable-lookbook-{{ section.id }}');
    if (!section) return;

    // Tab functionality
    const tabBtns = section.querySelectorAll('.lookbook-tab-btn');
    const tabContents = section.querySelectorAll('.lookbook-tab-content');

    tabBtns.forEach(btn => {
      btn.addEventListener('click', function() {
        const tabId = this.getAttribute('data-tab-id');

        // Update button states
        tabBtns.forEach(b => {
          b.classList.remove('active');
          b.setAttribute('aria-selected', 'false');
        });
        this.classList.add('active');
        this.setAttribute('aria-selected', 'true');

        // Update content panels
        tabContents.forEach(content => {
          content.classList.remove('active');
        });
        const targetContent = section.querySelector(`[data-tab-content="${tabId}"]`);
        if (targetContent) {
          targetContent.classList.add('active');
        }

        // Close any open hotspot popups
        section.querySelectorAll('.hotspot.active').forEach(h => h.classList.remove('active'));
      });
    });

    // Hotspot functionality
    const hotspots = section.querySelectorAll('.hotspot');
    
    hotspots.forEach(hotspot => {
      const button = hotspot.querySelector('.hotspot-button');
      
      // Toggle popup on hotspot button click only
      button.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        
        // Close all other popups
        hotspots.forEach(h => {
          if (h !== hotspot) {
            h.classList.remove('active');
          }
        });
        
        // Toggle current popup
        hotspot.classList.toggle('active');
      });
    });
    
    // Close popup when clicking outside (but not on quick view elements)
    document.addEventListener('click', function(e) {
      // Don't close if clicking on quick view button or wrapper
      if (e.target.closest('.popup-qv-wrapper') || 
          e.target.closest('.hdt-card-product__btn-quick-view') ||
          e.target.closest('wrapp-hdt-open-modal-btn')) {
        return;
      }
      
      if (!e.target.closest('.hotspot')) {
        section.querySelectorAll('.hotspot.active').forEach(h => h.classList.remove('active'));
      }
    });
    
    // Close popup on escape key
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        section.querySelectorAll('.hotspot.active').forEach(h => h.classList.remove('active'));
      }
    });

    // Prevent popup content clicks from closing (except quick view which should work)
    section.querySelectorAll('.hotspot-popup').forEach(popup => {
      popup.addEventListener('click', function(e) {
        // Allow quick view button clicks to propagate normally
        if (e.target.closest('.popup-qv-wrapper') || 
            e.target.closest('.hdt-card-product__btn-quick-view') ||
            e.target.closest('wrapp-hdt-open-modal-btn')) {
          return;
        }
        e.stopPropagation();
      });
    });

    // Keyboard navigation for tabs
    tabBtns.forEach((btn, index) => {
      btn.addEventListener('keydown', function(e) {
        let targetIndex;
        if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
          e.preventDefault();
          targetIndex = (index + 1) % tabBtns.length;
        } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
          e.preventDefault();
          targetIndex = (index - 1 + tabBtns.length) % tabBtns.length;
        } else if (e.key === 'Home') {
          e.preventDefault();
          targetIndex = 0;
        } else if (e.key === 'End') {
          e.preventDefault();
          targetIndex = tabBtns.length - 1;
        }

        if (targetIndex !== undefined) {
          tabBtns[targetIndex].focus();
          tabBtns[targetIndex].click();
        }
      });
    });
  });
</script>

