<script>
(function(){
  'use strict';
  // ── RELATED PRODUCTS (Shopify Recommendations API) ───────────────────────
async function fetchRelatedProducts() {
  try {
    const cartRes = await fetch('/cart.js');
    const cart    = await cartRes.json();
    if (cart.currency) _activeCurrencyISO = cart.currency;
    if (!cart.items || cart.items.length === 0) return [];
    const cartProductIds = [...new Set(cart.items.map(item => item.product_id))];
    const sourceId = cartProductIds[0];
    const res  = await fetch(`/recommendations/products.json?product_id=${sourceId}&limit=8&intent=related`);
    const data = await res.json();
    const filtered = data.products.filter(p => !cartProductIds.includes(p.id)).slice(0, 5);

    const enriched = await Promise.all(filtered.map(async (product) => {
      try {
        const pRes  = await fetch(`/products/${product.handle}`);
        const pText = await pRes.text();
        const pDoc  = new DOMParser().parseFromString(pText, 'text/html');
        const priceEl   = pDoc.querySelector('.hdt-price__sale hdt-price .hdt-money, hdt-price .hdt-money');
        const compareEl = pDoc.querySelector('.hdt-compare-at-price .hdt-money, hdt-compare-at-price .hdt-money');
        const priceText   = priceEl   ? priceEl.textContent.replace(/inc\s*vat/gi,'').trim() : null;
        const compareText = compareEl ? compareEl.textContent.trim() : null;
        const hasComp     = !!(compareText && compareText.trim().length > 0);
        return Object.assign({}, product, {
          _priceText:   priceText,
          _compareText: hasComp ? compareText : null,
          _hasCompare:  hasComp,
        });
      } catch(e) {
        return product;
      }
    }));

    return enriched;
  } catch(e) {
    console.error('Related products fetch error:', e);
    return [];
  }
}

