{%- if request.page_type != 'cart' -%}
{{ 'hdt-cart-drawer.css' | asset_url | stylesheet_tag }}

<hdt-cart-drawer detect-adm-se-evt section-id="{{ section.id }}" ref="hdt-cart" data-count="{{ cart.item_count }}" nested color-scheme="{{ section.settings.color_scheme }}" class="hdt-contents" data-currency-iso="{{ cart.currency.iso_code }}">
  <dialog id="CartDrawer" ref="dialog" class="hdt-dialog hdt-dialog-drawer hdt-dialog-drawer--cart hdt-mini-cart" scroll-lock pos="right">
    <div class="cart-drawer-wrapper">
      {% comment %} {%- if section.settings.collection != blank -%}
        <div class="cart-drawer-left-panel">
        <div class="cart-drawer-left-panel-full">
          <h4 class="cart-drawer-left-panel__title">often bought together</h4>
          <div class="cart-drawer-left-panel__scroll">
            <div class="cart-drawer-left-panel__products">
              {%- for product in collections[section.settings.collection].products limit: 5 -%}
                <div class="cart-drawer-left-product">
                  <div class="cart-drawer-left-product__image">
                    <a href="{{ product.url }}">{%- if product.featured_image -%}<img src="{{ product.featured_image | image_url: width: 200 }}" alt="{{ product.featured_image.alt | escape }}" width="100" height="100" loading="lazy">{%- else -%}{{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}{%- endif -%}</a>
                    <button type="button" class="cart-drawer-left-product__quickview" data-quick-view data-product-handle="{{ product.handle }}">
                      <svg width="17" height="11" viewBox="0 0 17 11" fill="none" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M8.5 0C10.3723 0 12.1095 0.821176 13.5136 1.82296C15.5567 3.28163 16.8833 5.10681 16.8833 5.10681C17.0389 5.32008 17.0389 5.60846 16.8833 5.82173C16.8833 5.82173 15.5567 7.64696 13.5136 9.10558C12.1096 10.1074 10.3723 10.9285 8.5 10.9285C6.62765 10.9285 4.89053 10.1074 3.48641 9.10558C1.44328 7.6469 0.116686 5.82173 0.116686 5.82173C-0.0388954 5.60846 -0.0388954 5.32008 0.116686 5.10681C0.116686 5.10681 1.4433 3.28157 3.48641 1.82296C4.89045 0.821176 6.62765 0 8.5 0ZM8.5 1.2143C6.88726 1.2143 5.40208 1.94742 4.19226 2.81111C2.84893 3.7704 1.84177 4.90048 1.37956 5.4643C1.84175 6.02818 2.84885 7.15825 4.19226 8.11749C5.40201 8.98116 6.88722 9.7143 8.5 9.7143C10.1128 9.7143 11.5979 8.98117 12.8077 8.11749C14.1511 7.15819 15.1582 6.02812 15.6204 5.4643C15.1583 4.90042 14.1511 3.77034 12.8077 2.81111C11.598 1.94744 10.1128 1.2143 8.5 1.2143ZM8.5 2.42859C10.1757 2.42859 11.5357 3.78861 11.5357 5.46434C11.5357 7.14007 10.1757 8.50008 8.5 8.50008C6.82427 8.50008 5.46426 7.14007 5.46426 5.46434C5.46426 3.78861 6.82427 2.42859 8.5 2.42859ZM8.5 3.64289C7.49441 3.64289 6.67855 4.45874 6.67855 5.46434C6.67855 6.46993 7.49441 7.28578 8.5 7.28578C9.50559 7.28578 10.3214 6.46993 10.3214 5.46434C10.3214 4.45874 9.50559 3.64289 8.5 3.64289Z" fill="white"></path></svg> QUICK VIEW
                    </button>
                  </div>
                  <div class="cart-drawer-left-product__info">
                    <a href="{{ product.url }}" class="cart-drawer-left-product__name">{{ product.title }}</a>
                    <div class="cart-drawer-left-product__prices">{%- if product.compare_at_price > product.price -%}<s class="cart-drawer-left-product__compare">{{ product.compare_at_price | money }}</s><span class="cart-drawer-left-product__price cart-drawer-left-product__price--sale">{{ product.price | money }} <span class="tax-text" style="color:#000;font-size: 12px; font-weight: 400;">Inc VAT</span></span>{%- else -%}<span class="cart-drawer-left-product__price">{{ product.price | money }} <span class="tax-text"style="color:#000;font-size: 12px; font-weight: 400;">Inc VAT</span></span>{%- endif -%}</div>
                  </div>
                </div>
              {%- endfor -%}
            </div>
          </div>
        </div>
        </div>
      {%- endif -%} {% endcomment %}
<div class="cart-drawer-left-panel" id="cart-related-panel" {% if cart == empty %}style="display:none"{% endif %}>
  <div class="cart-drawer-left-panel-full" id="cart-drawer-related-full">
    <h4 class="cart-drawer-left-panel__title">Often Bought Together</h4>
    <div class="cart-drawer-left-panel__scroll">
      <div class="cart-drawer-left-panel__products" id="cart-drawer-related-products">
        <div class="cart-related-loading">
          <span class="loading-spinner" style="width:20px;height:20px;border-width:3px;margin:30px auto;display:block;"></span>
        </div>
      </div>
    </div>
  </div>
</div>
      <div class="cart-drawer-main-panel" id="cart-panel">
        <div class="cart-drawer-header">
          <h3 class="cart-drawer-header__title">Your Cart</h3>
          <div class="cart-drawer-header__actions">
            <button type="button" class="cart-drawer-toggle__btn cart-drawer-toggle__btn--cart is-active" data-drawer-toggle="cart"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg><span class="cart-drawer-toggle__count" data-cart-count>{{ cart.item_count }}</span></button>
            <button type="button" class="cart-drawer-toggle__btn cart-drawer-toggle__btn--wishlist" data-drawer-toggle="wishlist"><svg width="13" height="16" viewBox="0 0 13 16" fill="none"><path d="M12.5 0H0.5C0.367 0 0.24 0.056 0.146 0.156C0.053 0.255 0 0.39 0 0.531V15.399C0 15.5 0.027 15.599 0.078 15.684C0.129 15.769 0.202 15.837 0.288 15.88C0.374 15.922 0.47 15.938 0.564 15.925C0.658 15.913 0.747 15.871 0.82 15.807L6.5 10.78L12.18 15.807C12.27 15.886 12.383 15.93 12.5 15.93C12.573 15.93 12.646 15.913 12.712 15.88C12.798 15.837 12.871 15.769 12.922 15.684C12.973 15.599 13 15.5 13 15.399V0.531C13 0.39 12.947 0.255 12.854 0.156C12.76 0.056 12.633 0 12.5 0ZM12 14.266L6.82 9.681C6.73 9.602 6.617 9.558 6.5 9.558C6.383 9.558 6.27 9.602 6.18 9.681L1 14.266V1.062H12V14.266Z" fill="currentColor"/></svg><span class="cart-drawer-toggle__count" id="toggle-wishlist-count">0</span></button>
            <button class="cart-drawer-header__close" aria-controls="CartDrawer"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
          </div>
        </div>

        {%- if section.settings.show_free_shipping_bar -%}
          {%- assign cart_total = cart.total_price -%}
          {%- assign shipping_threshold = localization.market.metafields.custom.free_shipping_threshold | default: 10000 -%}
          {%- assign remaining = shipping_threshold | minus: cart_total -%}
          {%- if remaining < 0 -%}{%- assign remaining = 0 -%}{%- endif -%}
          {%- assign progress = cart_total | times: 100 | divided_by: shipping_threshold -%}
          {%- if progress > 100 -%}{%- assign progress = 100 -%}{%- endif -%}
          {%- assign threshold_money = shipping_threshold | money_without_trailing_zeros -%}
          <div class="cart-drawer-shipping" id="cart-shipping-bar" data-threshold="{{ shipping_threshold }}" data-currency-iso="{{ cart.currency.iso_code }}">
            <p class="cart-drawer-shipping__text">
              {%- if remaining > 0 -%}
                You're <span class="cart-drawer-shipping__amount" data-shipping-remaining>{{ cart.currency.symbol }}{{ remaining | money_without_currency }}</span> away from Free Standard Shipping
              {%- else -%}
                🎉 You've unlocked Free Standard Shipping!
              {%- endif -%}
            </p>
            <div class="cart-drawer-shipping__bar"><div class="cart-drawer-shipping__progress" style="width: {{ progress }}%;" data-shipping-progress></div></div>
            <div class="cart-drawer-shipping__labels"><span>{{ cart.currency.symbol }}0</span><span>{{ threshold_money }}</span></div>
          </div>
        {%- endif -%}

        <div class="cart-drawer-warning" id="cart-warning" {% if cart == empty %}style="display:none"{% endif %}>
          <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 17 17" fill="none"><path d="M8.5 0C3.81282 0 0 3.8131 0 8.5C0 13.1869 3.81282 17 8.5 17C13.1872 17 17 13.1869 17 8.5C17 3.8131 13.1872 0 8.5 0ZM8.5 15.8667C4.43813 15.8667 1.13333 12.5622 1.13333 8.5C1.13333 4.43785 4.43813 1.13333 8.5 1.13333C12.5619 1.13333 15.8667 4.43785 15.8667 8.5C15.8667 12.5622 12.5619 15.8667 8.5 15.8667Z" fill="black"/><path d="M8.69037 13.0486C8.6358 13.0486 8.58463 13.0178 8.53686 12.9562C8.48909 12.8946 8.46517 12.8184 8.46517 12.7277C8.46517 12.2543 8.82563 10.8668 9.54705 8.56521C9.98934 7.15829 10.2105 6.36076 10.2105 6.17274C10.2105 6.01714 10.152 5.89394 10.0365 5.80316C9.9206 5.71238 9.75405 5.66699 9.53572 5.66699C9.14058 5.66699 8.66192 5.81773 8.09967 6.11919C7.53743 6.42066 6.91545 6.92805 6.23438 7.64126L6.68465 7.97191C7.28497 7.41431 7.67218 7.08366 7.84615 6.97996C8.02011 6.8762 8.17532 6.82435 8.31178 6.82435C8.43457 6.82435 8.496 6.88918 8.496 7.01883C8.496 7.13557 8.47214 7.26851 8.42437 7.4176C7.40109 10.5687 6.88939 12.5494 6.88939 13.3598C6.88939 13.6127 6.95931 13.8104 7.09917 13.9531C7.23896 14.0956 7.42829 14.167 7.66702 14.167C7.93993 14.167 8.29126 14.0503 8.72102 13.8168C9.15084 13.5834 9.83305 13.0486 10.7677 12.2122L10.3686 11.8426C9.46806 12.6466 8.9087 13.0486 8.69037 13.0486Z" fill="black"/><path d="M8.50052 5.10016C9.12644 5.10016 9.63385 4.59275 9.63385 3.96683C9.63385 3.34091 9.12644 2.8335 8.50052 2.8335C7.8746 2.8335 7.36719 3.34091 7.36719 3.96683C7.36719 4.59275 7.8746 5.10016 8.50052 5.10016Z" fill="black"/></svg>
          <p>Your items aren't reserved, <strong>checkout quickly to make sure you don't miss out.</strong></p>
        </div>

        <div class="cart-drawer-content">
          <div class="cart-drawer-scroll" id="cart-drawer-scroll">
            <div class="cart-drawer-empty" id="cart-empty-state" {% if cart != empty %}style="display:none"{% endif %}>
              <div class="cart-drawer-empty__icon"><svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg></div>
              <h3 class="cart-drawer-empty__title">Your cart is empty</h3>
              <p class="cart-drawer-empty__text">Looks like you have not added anything yet</p>
              <a href="/collections/all" class="cart-drawer-empty__btn">Continue Shopping</a>
            </div>

            <div class="cart-drawer-items" id="cart-drawer-items" {% if cart == empty %}style="display:none"{% endif %}>
              {%- for item in cart.items -%}
                <div class="cart-drawer-item" data-line-item data-line="{{ forloop.index }}" data-key="{{ item.key }}">
                  <div class="cart-drawer-item__main-content">
                    <div class="cart-drawer-item__image"><a href="{{ item.url }}">{%- if item.image -%}<img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.image.alt | escape }}" width="80" height="80" loading="lazy">{%- else -%}{{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}{%- endif -%}</a></div>
                    <div class="cart-drawer-item__content">
                      <div class="cart-drawer-item__top">
                        <div class="cart-drawer-item__info">
                          <a href="{{ item.url }}" class="cart-drawer-item__title">{{ item.product.title }}</a>
                          {%- if item.sku != blank -%}<p class="cart-drawer-item__sku">SKU: {{ item.sku }}</p>{%- endif -%}
                          {%- unless item.product.has_only_default_variant -%}<p class="cart-drawer-item__variant">{{ item.variant.title }}</p>{%- endunless -%}
                        </div>
                        <button type="button" class="cart-drawer-item__wishlist" data-wishlist-btn data-product-id="{{ item.product.id }}" data-product-handle="{{ item.product.handle }}"><svg width="13" height="16" viewBox="0 0 13 16" fill="none"><path d="M12.5 0H0.5C0.367 0 0.24 0.056 0.146 0.156C0.053 0.255 0 0.39 0 0.531V15.399C0 15.5 0.027 15.599 0.078 15.684C0.129 15.769 0.202 15.837 0.288 15.88C0.374 15.922 0.47 15.938 0.564 15.925C0.658 15.913 0.747 15.871 0.82 15.807L6.5 10.78L12.18 15.807C12.27 15.886 12.383 15.93 12.5 15.93C12.573 15.93 12.646 15.913 12.712 15.88C12.798 15.837 12.871 15.769 12.922 15.684C12.973 15.599 13 15.5 13 15.399V0.531C13 0.39 12.947 0.255 12.854 0.156C12.76 0.056 12.633 0 12.5 0ZM12 14.266L6.82 9.681C6.73 9.602 6.617 9.558 6.5 9.558C6.383 9.558 6.27 9.602 6.18 9.681L1 14.266V1.062H12V14.266Z" fill="currentColor"/></svg></button>
                      </div>
                      <div class="cart-drawer-item__price-row">
                        <span class="cart-drawer-item__price aa" data-item-price>{{ item.final_line_price | money }} <span class="tax-text" style="color:#000;font-size: 12px; font-weight: 400;">Inc VAT</span></span>
                        {%- if item.original_line_price > item.final_line_price -%}
                          <s class="cart-drawer-item__compare">{{ item.original_line_price | money }}</s>
                        {%- else -%}
                          <s class="cart-drawer-item__compare" style="display:none"></s>
                        {%- endif -%}
                      </div>
                    </div>
                  </div>
                  <div class="cart-drawer-item__actions">
                    <div class="cart-drawer-qty"><button type="button" class="cart-drawer-qty__btn" data-qty-minus data-line="{{ forloop.index }}">−</button><input type="number" class="cart-drawer-qty__input" value="{{ item.quantity }}" min="1" data-qty-input data-line="{{ forloop.index }}" data-unit-price="{{ item.final_price }}"><button type="button" class="cart-drawer-qty__btn" data-qty-plus data-line="{{ forloop.index }}">+</button></div>
                    <button type="button" class="cart-drawer-item__remove" data-remove-item data-line="{{ forloop.index }}">Remove</button>
                  </div>
                </div>
              {%- endfor -%}
            </div>

            {% comment %} {%- if section.settings.collection != blank -%}
              <div class="cart-drawer-recommendations" id="cart-recommendations" {% if cart == empty %}style="display:none"{% endif %}>
                <h4 class="cart-drawer-recommendations__title">often bought together</h4>
                <div class="cart-drawer-recommendations__scroll">
                  {%- for product in collections[section.settings.collection].products limit: 5 -%}
                    <div class="cart-drawer-rec-card">
                      <div class="cart-drawer-rec-card__image">
                        <a href="{{ product.url }}">{%- if product.featured_image -%}<img src="{{ product.featured_image | image_url: width: 200 }}" alt="{{ product.featured_image.alt | escape }}" loading="lazy">{%- endif -%}</a>
                        <button type="button" class="cart-drawer-rec-card__quickview-hover" data-quick-view data-product-handle="{{ product.handle }}"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>Quick View</button>
                      </div>
                      <div class="cart-drawer-rec-card__info">
                        <a href="{{ product.url }}" class="cart-drawer-rec-card__title">{{ product.title }}</a>
                        <div class="cart-drawer-rec-card__prices"><span class="cart-drawer-rec-card__price">{{ product.price | money }}</span>{%- if product.compare_at_price > product.price -%}<s class="cart-drawer-rec-card__compare">{{ product.compare_at_price | money }}</s>{%- endif -%}</div>
                        <button type="button" class="cart-drawer-rec-card__quickview-text" data-quick-view data-product-handle="{{ product.handle }}"><u>Quick View</u></button>
                      </div>
                    </div>
                  {%- endfor -%}
                </div>
              </div>
            {%- endif -%} {% endcomment %}
            <div class="cart-drawer-recommendations" id="cart-recommendations" {% if cart == empty %}style="display:none"{% endif %}>
              <h4 class="cart-drawer-recommendations__title">often bought together</h4>
              <div class="cart-drawer-recommendations__scroll" id="cart-recommendations-scroll">
                <div class="cart-related-loading">
                  <span class="loading-spinner" style="width:20px;height:20px;border-width:3px;margin:30px auto;display:block;"></span>
                </div>
              </div>
            </div>
          </div>

          <div class="cart-drawer-bottom" id="cart-drawer-bottom" {% if cart == empty %}style="display:none"{% endif %}>
            {%- if section.settings.show_trust_badges -%}
