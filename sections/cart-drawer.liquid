  function ajaxRemoveFromWishlist(productId,element){
    const item=element.closest('[data-wishlist-item]')||element.closest('.hdt-card-product')||element.closest('.hdt-card')||element.closest('[data-product-id]')||element.closest('.wishlist-product-item')||element.closest('.wishlist-card')||element.closest('.wishlist__item')||element.closest('[data-wishlist-product]');
    if(element.tagName==='BUTTON'){element.disabled=true;element.innerHTML='<span class="loading-spinner"></span>';}
    const isWishlistPage=window.location.href.includes('wishlist')||window.location.search.includes('view=wishlist');
    if(item&&isWishlistPage){item.style.transition='all 0.5s ease';item.classList.add('is-removing');}
    removeFromWishlist(productId);
    document.querySelectorAll(`hdt-wishlist[data-id="${productId}"]`).forEach(btn=>btn.setAttribute('action','add'));
    document.querySelectorAll(`[data-wishlist-btn][data-product-id="${productId}"]`).forEach(btn=>btn.classList.remove('is-added'));
    setTimeout(()=>{if(item&&isWishlistPage)item.remove();updateWishlistUI();checkWishlistPageEmpty();},550);
  }

  function checkWishlistPageEmpty(){
    const isWishlistPage=window.location.href.includes('wishlist')||window.location.search.includes('view=wishlist');
    if(isWishlistPage){
      const ids=getWishlistIds();
      if(ids.length===0){
        const productsGrid=document.querySelector('.hdt-products-grid,.hdt-grid,.wishlist-grid,[data-wishlist-grid]');
        const emptyState=document.querySelector('.wishlist-empty,.hdt-wishlist-empty,[data-wishlist-empty]');
        if(productsGrid)productsGrid.style.display='none';
        if(emptyState)emptyState.style.display='block';
      }
    }
  }

  function triggerTaxifyRefresh(){
    if(window.Taxify&&typeof window.Taxify.refresh==='function')window.Taxify.refresh();
    if(window.Taxify&&typeof window.Taxify.init==='function')window.Taxify.init();
    if(window.Exemptify&&typeof window.Exemptify.refresh==='function')window.Exemptify.refresh();
    const evts=['taxify:refresh','taxify:cart:updated','cart:refresh','cart:updated','cart-drawer:refreshed','theme:cart:updated','section:load'];
    evts.forEach(name=>document.dispatchEvent(new CustomEvent(name,{bubbles:true})));
  }

  async function refreshCart(){
    try{
      const [sectionRes,cartRes]=await Promise.all([fetch(sectionUrl()),fetch('/cart.js')]);
      const [html,cart]=await Promise.all([sectionRes.text(),cartRes.json()]);

      if (cart.currency) {
        _activeCurrencyISO = cart.currency;
        const hdtEl = document.querySelector('hdt-cart-drawer');
        if (hdtEl) hdtEl.dataset.currencyIso = cart.currency;
      }
      const doc=new DOMParser().parseFromString(html,'text/html');

      const newItems=doc.getElementById('cart-drawer-items');
      const currentItems=document.getElementById('cart-drawer-items');
      if(newItems&&currentItems)currentItems.innerHTML=newItems.innerHTML;

      // ── Sync discount applied badge in discount section ──────────────────
      const newDiscountSection=doc.querySelector('.hdt-cart-discount-section');
      const currentDiscountSection=document.querySelector('.hdt-cart-discount-section');
      if(newDiscountSection&&currentDiscountSection){
        currentDiscountSection.querySelectorAll('.hdt-cart-discount-applied').forEach(el=>el.remove());
        newDiscountSection.querySelectorAll('.hdt-cart-discount-applied').forEach(el=>currentDiscountSection.appendChild(el.cloneNode(true)));
      }

      // ── CHANGE 1: Sync discount rows in summary section ──────────────────
      document.querySelectorAll('.cart-drawer-summary__row--discount').forEach(el=>el.remove());
      const newDiscountRows=doc.querySelectorAll('.cart-drawer-summary__row--discount');
      const summaryEl=document.querySelector('.cart-drawer-summary');
      const totalRow=summaryEl?summaryEl.querySelector('.cart-drawer-summary__row--total'):null;
      if(summaryEl&&newDiscountRows.length){
        newDiscountRows.forEach(row=>{
          totalRow?summaryEl.insertBefore(row.cloneNode(true),totalRow):summaryEl.appendChild(row.cloneNode(true));
        });
      }
      // ─────────────────────────────────────────────────────────────────────

      const liquidSubtotal=doc.querySelector('[data-cart-subtotal]');
      const liquidSubtotalText=liquidSubtotal?liquidSubtotal.textContent.trim():null;

      const liquidTotalEl = doc.querySelector('[data-cart-total]');
      const liquidTotalHTML = liquidTotalEl ? liquidTotalEl.innerHTML : null;

      const liquidShippingBar = doc.getElementById('cart-shipping-bar');
      const currentShippingBar = document.getElementById('cart-shipping-bar');
      if (liquidShippingBar && currentShippingBar) {
        currentShippingBar.replaceWith(liquidShippingBar.cloneNode(true));
      }

      updateCartUI(cart,liquidSubtotalText,true, liquidTotalHTML);
      triggerTaxifyRefresh();
      updateRelatedPanel();
    }catch(e){console.error('Cart refresh error:',e);}
  }

  function updateShippingBar(totalCents, isoOverride){
    const shippingBar=document.getElementById('cart-shipping-bar'); if(!shippingBar)return;
    const iso = isoOverride || shippingBar.dataset.currencyIso || undefined;
    const shippingThreshold=parseInt(shippingBar.dataset.threshold)||10000;
    const remaining=Math.max(0,shippingThreshold-totalCents); const progress=Math.min(100,(totalCents*100)/shippingThreshold);
    const remainingEl=shippingBar.querySelector('[data-shipping-remaining]'); const progressEl=shippingBar.querySelector('[data-shipping-progress]'); const textEl=shippingBar.querySelector('.cart-drawer-shipping__text');
    if(progressEl)progressEl.style.width=progress+'%';
    const formattedRemaining=fmtCurrency(remaining,iso);
    if(remainingEl)remainingEl.textContent=formattedRemaining;
    if(textEl){
      if(remaining>0){textEl.innerHTML=`You're <span class="cart-drawer-shipping__amount" data-shipping-remaining>${formattedRemaining}</span> away from Free Standard Shipping`;}
      else{textEl.innerHTML='🎉 You\'ve unlocked Free Standard Shipping!';}
    }
  }

  function readDisplayedSubtotalCents(){
    const subtotalEl=document.querySelector('[data-cart-subtotal]');
    if(subtotalEl&&subtotalEl.textContent.trim()){
      const raw=subtotalEl.textContent.replace(/[^\d.,]/g,'').trim(); let normalised=raw;
      if(raw.indexOf(',')>-1&&raw.indexOf('.')>-1){if(raw.lastIndexOf('.')<raw.lastIndexOf(','))normalised=raw.replace(/\./g,'').replace(',','.');else normalised=raw.replace(/,/g,'');}
      else if(raw.indexOf(',')>-1){normalised=raw.replace(',','.');}
      const parsed=parseFloat(normalised); if(!isNaN(parsed)&&parsed>0)return Math.round(parsed*100);
    }
    return null;
  }

  function updateCartUI(cart, liquidSubtotalText, skipShippingBar, liquidTotalHTML){
    const isEmpty=cart.item_count===0;
    const emptyState=document.getElementById('cart-empty-state'); const itemsContainer=document.getElementById('cart-drawer-items');
    const bottomSection=document.getElementById('cart-drawer-bottom'); const warningSection=document.getElementById('cart-warning');
    const recsSection=document.getElementById('cart-recommendations'); const leftPanel=document.querySelector('.cart-drawer-left-panel');
    if(emptyState)emptyState.style.display=isEmpty?'block':'none';
    if(itemsContainer)itemsContainer.style.display=isEmpty?'none':'block';
    if(bottomSection)bottomSection.style.display=isEmpty?'none':'block';
    if(warningSection)warningSection.style.display=isEmpty?'none':'flex';
    if(recsSection){recsSection.style.display=isEmpty?'none':'block';if(!isEmpty)setTimeout(()=>recsSection.classList.add('is-visible'),400);else recsSection.classList.remove('is-visible');}
    if(leftPanel&&isEmpty)leftPanel.classList.remove('is-visible');
    const relatedPanelWrap = document.getElementById('cart-related-panel');
   if (relatedPanelWrap) relatedPanelWrap.style.display = isEmpty ? 'none' : '';
    document.querySelectorAll('[data-cart-count]').forEach(el=>el.textContent=cart.item_count);
    document.querySelectorAll('.hdt-count-box,hdt-cart-count').forEach(el=>el.textContent=cart.item_count);
    if(liquidSubtotalText){
      document.querySelectorAll('[data-cart-subtotal]').forEach(el=>el.textContent=liquidSubtotalText);
    } else {
      document.querySelectorAll('[data-cart-subtotal]').forEach(el=>el.textContent=fmtCurrency(cart.items_subtotal_price));
    }
    // ── CHANGE 2: Total with Inc VAT text preserved ───────────────────────
    //document.querySelectorAll('[data-cart-total]').forEach(el=>{
    //  el.innerHTML=fmtCurrency(cart.total_price)+' <span class="tax-text" style="color:#000;font-size:12px;font-weight:400;">Inc VAT</span>';
    //});
    document.querySelectorAll('[data-cart-total]').forEach(el=>{
      if(liquidTotalHTML){
        el.innerHTML = liquidTotalHTML;
      } else {
        el.innerHTML = fmtCurrency(cart.total_price) + ' <span class="tax-text" style="color:#000;font-size:12px;font-weight:400;">Inc VAT</span>';
      }
    });
    // ─────────────────────────────────────────────────────────────────────
    if(!skipShippingBar) updateShippingBar(cart.items_subtotal_price);
  }

  async function changeQuantity(line,quantity,element){
    if(!line)return; if(element)element.classList.add('is-updating');
    try{
      const response=await fetch('/cart/change.js',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({line:parseInt(line),quantity:parseInt(quantity)})});
      if(!response.ok)throw new Error('Failed');
      const cart=await response.json();

      if (cart.currency) {
        _activeCurrencyISO = cart.currency;
        const hdtEl = document.querySelector('hdt-cart-drawer');
        if (hdtEl) hdtEl.dataset.currencyIso = cart.currency;
      }
      
      if(quantity===0&&element){
        element.classList.add('is-removing');
        setTimeout(async()=>{element.remove();document.querySelectorAll('[data-line-item]').forEach((item,idx)=>{item.dataset.line=idx+1;item.querySelectorAll('[data-line]').forEach(el=>el.dataset.line=idx+1);}); updateCartUI(cart); await refreshCart();},450);
      }else{await refreshCart();if(element){const qtyInput=element.querySelector('[data-qty-input]');if(qtyInput)qtyInput.value=quantity;}}
    }catch(e){await refreshCart();}
    finally{if(element)element.classList.remove('is-updating');}
  }

  async function addToCart(variantId,quantity,button){
    if(button){button.disabled=true;button.dataset.originalText=button.textContent;button.innerHTML='<span class="loading-spinner"></span> Adding...';}
    try{
      const response=await fetch('/cart/add.js',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:parseInt(variantId),quantity:parseInt(quantity)||1})});
      if(!response.ok){const error=await response.json();throw new Error(error.description||'Failed to add');}
      await refreshCart(); if(button){button.innerHTML='✓ Added!';button.disabled=false;} return{success:true};
    }catch(e){console.error('Add to cart error:',e);if(button){button.innerHTML='Error - Try Again';button.disabled=false;}return{success:false,error:e.message};}
  }

  function openDrawer(){ const drawer=document.querySelector('hdt-cart-drawer'); if(drawer&&drawer.open)drawer.open(); else document.querySelector('[aria-controls="CartDrawer"]')?.click(); }
  function closeDrawer(){ const drawer=document.querySelector('hdt-cart-drawer'); if(drawer&&drawer.close)drawer.close(); }
  function isDrawerOpen(){ const dialog=document.getElementById('CartDrawer'); return dialog&&dialog.open; }

  function showPanel(panel){
