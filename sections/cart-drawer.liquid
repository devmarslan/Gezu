              <form action="{{ routes.cart_url }}" method="POST" id="CartDrawer-Form"><button type="submit" name="checkout" class="cart-drawer-checkout-btn">Proceed to Checkout</button></form>
              <div class="cart-drawer-cta-info"><a href="/cart" class="cart-drawer-checkout-btn-link">VIEW CART</a></div>
