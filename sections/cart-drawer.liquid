  function getWishlistIds(){ const s=localStorage.getItem(WL_KEY); return s?s.split(',').filter(id=>id&&id.trim()):[]; }
  function saveWishlistIds(ids){ const u=[...new Set(ids.filter(id=>id&&id.trim()))]; u.length>0?localStorage.setItem(WL_KEY,u.join(',')):localStorage.removeItem(WL_KEY); return u; }
  function isInWishlist(id){ return getWishlistIds().includes(id.toString()); }
  function addToWishlist(id){ const idStr=id.toString(); if(isInWishlist(idStr))return false; let ids=getWishlistIds(); ids.unshift(idStr); saveWishlistIds(ids); document.dispatchEvent(new CustomEvent('theme4:wishlist:update',{bubbles:true,detail:'cartDrawer'})); return true; }
  function removeFromWishlist(id){ const idStr=id.toString(); let ids=getWishlistIds().filter(i=>i!==idStr); saveWishlistIds(ids); document.dispatchEvent(new CustomEvent('theme4:wishlist:update',{bubbles:true,detail:'cartDrawer'})); return true; }

  function updateWishlistUI(){
