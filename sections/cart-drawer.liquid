      const doc  = new DOMParser().parseFromString(text, 'text/html');
      const priceEl = doc.querySelector('.hdt-price-wrapp');
      const html = priceEl ? priceEl.outerHTML : null;
      if (html) qvPriceCache[handle] = html;
      return html;
    } catch(e) {
      return null;
    }
  }

  async function fetchLiquidVariantPrices(handle) {
    const cacheKey = handle + ':variants';
    if (qvPriceCache[cacheKey]) return qvPriceCache[cacheKey];
    const root = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) || '/';
    const variantMap = {};
    try {
      const res  = await fetch(root.replace(/\/$/, '') + '/products/' + handle + '.js');
      const prod = await res.json();
      for (const v of prod.variants) {
        const vRes  = await fetch(root.replace(/\/$/, '') + '/products/' + handle + '?variant=' + v.id);
