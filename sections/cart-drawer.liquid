        const vDoc  = new DOMParser().parseFromString(vText, 'text/html');
        const vPriceEl = vDoc.querySelector('.hdt-price-wrapp');
        if (vPriceEl) variantMap[v.id] = vPriceEl.outerHTML;
      }
