                {%- endif -%}
                <div class="cart-drawer-summary__row"><span class="ct-btm-subtotal">Item Subtotal (<span data-cart-count>{{ cart.item_count }}</span>)</span><span class="ct-btm-subtota" data-cart-subtotal>{{ cart.items_subtotal_price | money }} <span class="tax-text" style="color:#000;font-size: 12px; font-weight: 400;">Inc VAT</span></span></div>
