    const symbol = CURRENCY_SYMBOL_MAP[iso] || iso;
    const noDecimalCurrencies = new Set(['JPY','KRW','VND','IDR','ISK','CLP','GNF','KMF','MGA','PYG','RWF','UGX','XAF','XOF','XPF']);
    if (noDecimalCurrencies.has(iso)) return symbol + '{{amount_no_decimals_with_comma_separator}}';
