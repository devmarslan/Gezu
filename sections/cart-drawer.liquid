  const qvModal=document.getElementById('cqv-modal');
  const qvOverlay=document.getElementById('cqv-overlay');
  const qvContent=document.getElementById('cqv-content');
  const qvClose=document.getElementById('cqv-close');

  async function openQuickView(handle){
    if(!qvModal||!handle)return;
    isQuickViewOpen=true;
    qvModal.classList.add('is-open');
    qvOverlay.classList.add('is-open');
    document.body.style.overflow='hidden';

    const preEl = document.querySelector(`.cqv-prerendered[data-cqv-handle="${handle}"]`);

    if(preEl){
      // ── Pre-rendered path (static collection products) ──────────────────
      qvContent.innerHTML = preEl.innerHTML;
      const jsonScript = qvContent.querySelector('.cqv-variants-json');
      let variantsData = [];
      if(jsonScript){
        try{ variantsData = JSON.parse(jsonScript.textContent.trim()); }catch(e){}
        jsonScript.remove();
      }
      const productId = preEl.dataset.productId || '';
      const wishlistBtn = qvContent.querySelector('[data-qv-wishlist]');
      if(wishlistBtn && productId){
        const inWl = isInWishlist(productId);
        if(inWl){ wishlistBtn.classList.add('is-active'); const t=wishlistBtn.querySelector('.cqv-wishlist__text'); if(t)t.textContent='In Wishlist'; }
      }
      initQuickViewEventsLiquid(handle, variantsData, productId);

    } else {
      // ── Dynamic fallback path (Recommendations API products) ────────────
      qvContent.innerHTML = '<div style="display:flex;align-items:center;justify-content:center;min-height:200px"><span class="loading-spinner" style="width:24px;height:24px;border-width:3px;"></span></div>';
      try {
        const res  = await fetch(`/products/${handle}.js`);
        const prod = await res.json();
        const productId = prod.id.toString();
        const firstVariant = prod.variants[0];

        const hasCompare = !!(prod.compare_at_price) && parseInt(prod.compare_at_price) > parseInt(prod.price);
        const discountPct = hasCompare ? Math.round((prod.compare_at_price - prod.price) * 100 / prod.compare_at_price) : 0;

        // HTML page se market-correct prices fetch karo
        let qvPriceStr = fmtCurrency(prod.price);
        let qvCompareStr = hasCompare ? fmtCurrency(prod.compare_at_price) : '';
        try {
          const hRes  = await fetch(`/products/${handle}`);
          const hText = await hRes.text();
          const hDoc  = new DOMParser().parseFromString(hText, 'text/html');
          const hPriceEl   = hDoc.querySelector('hdt-price .hdt-money, .hdt-price .hdt-money');
          const hCompareEl = hDoc.querySelector('hdt-compare-at-price .hdt-money, .hdt-compare-at-price .hdt-money');
          if (hPriceEl)   qvPriceStr   = hPriceEl.textContent.replace(/inc\s*vat/gi,'').trim();
          if (hCompareEl) qvCompareStr = hCompareEl.textContent.trim();
        } catch(e) {}

        // Sabhi variants ke market prices parallel pre-fetch karo
        const variantPriceCache = {};
        await Promise.all(prod.variants.map(async (v) => {
          try {
            const vr = await fetch(`/products/${handle}?variant=${v.id}`);
            const vt = await vr.text();
            const vd = new DOMParser().parseFromString(vt, 'text/html');
            const vp = vd.querySelector('hdt-price .hdt-money, .hdt-price .hdt-money');
            const vc = vd.querySelector('hdt-compare-at-price .hdt-money, .hdt-compare-at-price .hdt-money');
            if(vp) variantPriceCache[v.id] = {
              price:   vp.textContent.replace(/inc\s*vat/gi,'').trim(),
              compare: vc ? vc.textContent.trim() : ''
            };
          } catch(e) {}
        }));

        const variantsData = prod.variants.map(v => {
          const vHasCompare = !!(v.compare_at_price) && parseInt(v.compare_at_price) > parseInt(v.price);
          const vDiscount   = vHasCompare ? Math.round((v.compare_at_price - v.price) * 100 / v.compare_at_price) : 0;
          return {
            id:            v.id,
            price:         fmtCurrency(v.price),
            compare_price: vHasCompare ? fmtCurrency(v.compare_at_price) : '',
            has_compare:   vHasCompare,
            discount_pct:  vDiscount,
            available:     v.available,
            options:       v.options
          };
        });

        let optionsHtml = '';
        prod.options.forEach((opt, idx) => {
          const optName = typeof opt === 'string' ? opt : (opt.name || String(opt));
          if(prod.options.length === 1 && optName === 'Title') return;
          const seen = [];
          let btnsHtml = '';
          prod.variants.forEach(v => {
            const rawVal = v.options[idx];
            const val = typeof rawVal === 'string' ? rawVal : String(rawVal);
            if(seen.includes(val)) return;
            seen.push(val);
            const isFirst = seen.length === 1;
            btnsHtml += `<button type="button" class="cqv-option__btn ${isFirst?'is-active':''} ${!v.available?'is-soldout':''}" data-option-index="${idx}" data-option-value="${val}">${val}</button>`;
          });
          const firstVal = prod.variants[0].options[idx];
          const firstValStr = typeof firstVal === 'string' ? firstVal : String(firstVal);
          optionsHtml += `<div class="cqv-option" data-option-index="${idx}">
            <div class="cqv-option__label">${optName}: <strong data-option-selected="${idx}">${firstValStr}</strong></div>
            <div class="cqv-option__btns">${btnsHtml}</div>
          </div>`;
        });

        const images = prod.images || [];
        const imgsHtml = images.length
          ? images.map((img, i) => {
              const rawSrc = typeof img === 'string' ? img : (img.src || '');
              const cleanSrc = rawSrc.replace(/^\/\//, 'https://').replace(/(\?.*)?$/, '') + '?width=800';
              return `<div class="cqv-gallery__item"><img src="${cleanSrc}" alt="${prod.title.replace(/"/g,'&quot;')}" loading="${i===0?'eager':'lazy'}"></div>`;
            }).join('')
          : '<div class="cqv-gallery__placeholder">No image</div>';

        const inWl = isInWishlist(productId);

        qvContent.innerHTML = `
          <div class="cqv-product${images.length > 1 ? ' has-gallery' : ''}">
            <div class="cqv-product__images">
              <div class="cqv-gallery">${imgsHtml}</div>
            </div>
            <div class="cqv-product__info">
              <h2 class="cqv-product__title">${prod.title}</h2>
              <div class="cqv-product__pricing">
                ${buildThemePriceFromStrings(qvPriceStr, qvCompareStr, hasCompare, discountPct)}
              </div>
              ${optionsHtml}
              <div class="cqv-product__availability" data-qv-availability>${!firstVariant.available ? '<span class="cqv-soldout-text">Sold Out</span>' : ''}</div>
              <div class="cqv-product__actions">
                <div class="cqv-qty">
                  <button type="button" class="cqv-qty__btn" data-qv-minus>−</button>
                  <input type="text" class="cqv-qty__input" value="1" data-qv-qty readonly>
                  <button type="button" class="cqv-qty__btn" data-qv-plus>+</button>
                </div>
                <button type="button" class="cqv-add ${!firstVariant.available ? 'is-disabled' : ''}" data-qv-add data-variant-id="${firstVariant.id}" ${!firstVariant.available ? 'disabled' : ''}>
                  ${firstVariant.available ? 'ADD TO CART' : 'SOLD OUT'}
                </button>
              </div>
              <button type="button" class="cqv-wishlist ${inWl ? 'is-active' : ''}" data-qv-wishlist data-product-id="${productId}">
                <svg width="13" height="16" viewBox="0 0 13 16" fill="none"><path d="M12.5 0H0.5C0.367 0 0.24 0.056 0.146 0.156C0.053 0.255 0 0.39 0 0.531V15.399C0 15.5 0.027 15.599 0.078 15.684C0.129 15.769 0.202 15.837 0.288 15.88C0.374 15.922 0.47 15.938 0.564 15.925C0.658 15.913 0.747 15.871 0.82 15.807L6.5 10.78L12.18 15.807C12.27 15.886 12.383 15.93 12.5 15.93C12.573 15.93 12.646 15.913 12.712 15.88C12.798 15.837 12.871 15.769 12.922 15.684C12.973 15.599 13 15.5 13 15.399V0.531C13 0.39 12.947 0.255 12.854 0.156C12.76 0.056 12.633 0 12.5 0ZM12 14.266L6.82 9.681C6.73 9.602 6.617 9.558 6.5 9.558C6.383 9.558 6.27 9.602 6.18 9.681L1 14.266V1.062H12V14.266Z" fill="currentColor"></path></svg>
                <span class="cqv-wishlist__text">${inWl ? 'In Wishlist' : 'Add to Wishlist'}</span>
              </button>
            </div>
          </div>`;

        initQuickViewEventsLiquid(handle, variantsData, productId);

      } catch(err) {
        console.error('QV dynamic fetch error:', err);
        qvContent.innerHTML = '<div class="cqv-error"><p>Could not load product</p></div>';
      }
    }
  }

  function initQuickViewEventsLiquid(handle, variantsData, productId){
    const qtyInput      = qvContent.querySelector('[data-qv-qty]');
    const addBtn        = qvContent.querySelector('[data-qv-add]');
    const wishlistBtn   = qvContent.querySelector('[data-qv-wishlist]');
    const availabilityEl= qvContent.querySelector('[data-qv-availability]');
    if(!qtyInput||!addBtn)return;

    qvContent.querySelector('[data-qv-minus]').onclick = ()=>{ const q=parseInt(qtyInput.value)||1; if(q>1)qtyInput.value=q-1; };
    qvContent.querySelector('[data-qv-plus]').onclick  = ()=>{ qtyInput.value=(parseInt(qtyInput.value)||1)+1; };

    const optionBtnGroups = qvContent.querySelectorAll('.cqv-option');
    let selectedOptions = [];
    optionBtnGroups.forEach((group, idx)=>{
      const activeBtn = group.querySelector('.cqv-option__btn.is-active');
      selectedOptions[idx] = activeBtn ? activeBtn.dataset.optionValue.trim() : '';
    });

    // ── Exact variant match (trim for safety) ────────────────────────────
    function findVariant(opts){
      if(!variantsData||!variantsData.length) return null;
      return variantsData.find(v =>
        v.options && v.options.length === opts.length &&
        v.options.every((opt,i) => String(opt).trim() === String(opts[i]).trim())
      ) || null;
    }

    // ── Availability check: variantsData first, DOM fallback ─────────────
    function isAvailable(opts){
      const v = findVariant(opts);
      if(v !== null) return { available: v.available, variant: v };
      // DOM fallback: any active button is-soldout → sold out
      const active = [...qvContent.querySelectorAll('.cqv-option__btn.is-active')];
      const anySoldout = active.some(b => b.classList.contains('is-soldout'));
      return { available: !anySoldout, variant: null };
    }

    // ── Apply button state ────────────────────────────────────────────────
    // ── Apply button state ────────────────────────────────────────────────
    function applyState(opts, variantOverride){
      // ── DOM check PEHLE: koi bhi active button soldout hai? ───────────
      // Yeh sabse reliable source hai — Liquid ne render kiya hai
      const activeButtons = [...qvContent.querySelectorAll('.cqv-option__btn.is-active')];
      const domSaysUnavailable = activeButtons.some(b => b.classList.contains('is-soldout'));

      if(domSaysUnavailable){
        if(variantOverride && variantOverride.id) addBtn.dataset.variantId = variantOverride.id;
        addBtn.disabled = true;
        addBtn.classList.add('is-disabled');
        addBtn.textContent = 'SOLD OUT';
        if(availabilityEl) availabilityEl.innerHTML = '<span class="cqv-soldout-text">Sold Out</span>';
        return;
      }

      // ── DOM ne available bola — variantsData/override se confirm karo ─
      const { available, variant } = variantOverride !== undefined
        ? { available: variantOverride.available, variant: variantOverride }
        : isAvailable(opts);

      if(variant) addBtn.dataset.variantId = variant.id;

      if(available){
        addBtn.disabled        = false;
        addBtn.classList.remove('is-disabled');
        addBtn.textContent     = 'ADD TO CART';
        if(availabilityEl) availabilityEl.innerHTML = '';
      } else {
        addBtn.disabled        = true;
        addBtn.classList.add('is-disabled');
        addBtn.textContent     = 'SOLD OUT';
        if(availabilityEl) availabilityEl.innerHTML = '<span class="cqv-soldout-text">Sold Out</span>';
      }
    }

    // ── Set initial state on QV open ──────────────────────────────────────
    applyState(selectedOptions);

    // ── Option button clicks ──────────────────────────────────────────────
    qvContent.querySelectorAll('.cqv-option__btn').forEach(btn=>{
      btn.onclick = function(){
        const optIdx   = parseInt(this.dataset.optionIndex);
        const optValue = this.dataset.optionValue.trim();

        this.closest('.cqv-option').querySelectorAll('.cqv-option__btn').forEach(b=>b.classList.remove('is-active'));
        this.classList.add('is-active');
        const lbl = qvContent.querySelector('[data-option-selected="'+optIdx+'"]');
        if(lbl) lbl.textContent = optValue;
        selectedOptions[optIdx] = optValue;

        // Find exact variant, fallback auto-adjust
        let matchingVariant = findVariant(selectedOptions);
        if(!matchingVariant){
          matchingVariant = variantsData.find(v => v.options && String(v.options[optIdx]).trim() === optValue) || null;
          if(matchingVariant){
            matchingVariant.options.forEach((opt,i)=>{
              if(i===optIdx) return;
              const trimOpt = String(opt).trim();
              selectedOptions[i] = trimOpt;
              const grp = optionBtnGroups[i];
              if(grp){
                grp.querySelectorAll('.cqv-option__btn').forEach(b=>b.classList.toggle('is-active', b.dataset.optionValue.trim()===trimOpt));
                const l2 = qvContent.querySelector('[data-option-selected="'+i+'"]');
                if(l2) l2.textContent = trimOpt;
              }
            });
          }
        }

        // ── Update button IMMEDIATELY ─────────────────────────────────────
        applyState(selectedOptions, matchingVariant || undefined);

        // ── Update price async ────────────────────────────────────────────
        if(matchingVariant){
          const priceWrapper = qvContent.querySelector('.cqv-product__pricing');
          if(priceWrapper){
            priceWrapper.innerHTML = buildThemePriceFromStrings(
              matchingVariant.price, matchingVariant.compare_price,
              matchingVariant.has_compare, matchingVariant.discount_pct
            );
            fetch('/products/'+handle+'?variant='+matchingVariant.id)
              .then(r=>r.text())
              .then(html=>{
                const vDoc=new DOMParser().parseFromString(html,'text/html');
                const vP=vDoc.querySelector('hdt-price .hdt-money, .hdt-price .hdt-money');
                const vC=vDoc.querySelector('hdt-compare-at-price .hdt-money, .hdt-compare-at-price .hdt-money');
                if(vP){
                  priceWrapper.innerHTML = buildThemePriceFromStrings(
                    vP.textContent.replace(/inc\s*vat/gi,'').trim(),
                    vC?vC.textContent.trim():'',
                    matchingVariant.has_compare, matchingVariant.discount_pct
                  );
                }
                // Re-confirm state after price re-render
                applyState(selectedOptions, matchingVariant);
              }).catch(()=>{});
          }
        }
      };
    });

    addBtn.onclick = async function(){
      if(this.disabled)return;
      const variantId=this.dataset.variantId; const quantity=parseInt(qtyInput.value)||1;
      this.disabled=true; this.textContent='ADDING...';
      const result=await addToCart(variantId,quantity,null);
      if(result.success){this.textContent='ADDED!';setTimeout(()=>{closeQuickView();setTimeout(openDrawer,300);},500);}
      else{this.disabled=false;this.textContent='ADD TO CART';alert(result.error||'Could not add to cart');}
    };

    if(wishlistBtn){
      wishlistBtn.onclick=function(){
        const pid=productId||this.dataset.productId; const text=this.querySelector('.cqv-wishlist__text');
        if(isInWishlist(pid)){removeFromWishlist(pid);this.classList.remove('is-active');if(text)text.textContent='Add to Wishlist';}
        else{addToWishlist(pid);this.classList.add('is-active');if(text)text.textContent='In Wishlist';}
        updateWishlistUI();renderWishlist();
      };
    }
  }

  function buildThemePriceFromStrings(priceStr, compareStr, hasCompare, discountPct){
    return `<div class="hdt-price-wrapp cqv-hdt-price${hasCompare?' hdt-price--show-badge':''}">
      <div class="hdt-price__container">
        <div class="hdt-price__sale hdt-price__list">
          <hdt-price class="hdt-price" data-qv-price>
            <span class="hdt-money">${priceStr}</span>
          </hdt-price>
          <hdt-compare-at-price class="hdt-compare-at-price"${hasCompare?'':' hidden'}>
            <span class="hdt-money">${hasCompare?compareStr:''}</span>
          </hdt-compare-at-price>
        </div>
        ${hasCompare&&discountPct>0?`<span class="sale-badge">${discountPct}% OFF</span>`:''}
      </div>
      
    </div>`;
  }

  function closeQuickView(){
    if(!qvModal)return;
    isQuickViewOpen=false;
    qvModal.classList.remove('is-open');
    qvOverlay.classList.remove('is-open');
    document.body.style.overflow='';
    if(wasCartDrawerOpen){setTimeout(()=>{openDrawer();wasCartDrawerOpen=false;},300);}
  }

  if(qvClose)qvClose.addEventListener('click',closeQuickView);
  if(qvOverlay)qvOverlay.addEventListener('click',closeQuickView);
  document.addEventListener('keydown',e=>{if(e.key==='Escape'&&isQuickViewOpen)closeQuickView();});

  document.addEventListener('theme4:wishlist:update',(e)=>{
    if(e.detail!=='cartDrawer')setTimeout(()=>{updateWishlistUI();renderWishlist();},100);
  });

  const cartDialog=document.getElementById('CartDrawer');
  if(cartDialog){
    const observer=new MutationObserver((mutations)=>{
      mutations.forEach((mutation)=>{
        if(mutation.attributeName==='open'){
          const leftPanel=document.querySelector('.cart-drawer-left-panel-full');
          const recsSection=document.getElementById('cart-recommendations');
          if(cartDialog.hasAttribute('open')){
            if(leftPanel){leftPanel.classList.remove('is-visible');setTimeout(()=>leftPanel.classList.add('is-visible'),200);}
            updateRelatedPanel(); 
            if(recsSection&&recsSection.style.display!=='none'){recsSection.classList.remove('is-visible');setTimeout(()=>recsSection.classList.add('is-visible'),400);}
            fetch('/cart.js').then(r=>r.json()).then(cart=>{
              //updateShippingBar(cart.items_subtotal_price);
              refreshCart();
            }).catch(()=>{});
          }else{
            if(leftPanel)leftPanel.classList.remove('is-visible');
            if(recsSection)recsSection.classList.remove('is-visible');
          }
        }
      });
    });
    observer.observe(cartDialog,{attributes:true});
  }

  document.addEventListener('click',function(e){
    const hdtWishlist=e.target.closest('hdt-wishlist');
    if(!hdtWishlist)return;
    if(isProcessingWishlist){e.preventDefault();e.stopPropagation();e.stopImmediatePropagation();return false;}
    const productId=hdtWishlist.dataset.id; if(!productId)return;
    e.preventDefault();e.stopPropagation();e.stopImmediatePropagation();
    isProcessingWishlist=true;
    const currentlyInWishlist=isInWishlist(productId);
    const isWishlistPage=window.location.href.includes('wishlist')||window.location.search.includes('view=wishlist');
    if(currentlyInWishlist){
      if(isWishlistPage&&hdtWishlist.hasAttribute('remove-on-page')){ajaxRemoveFromWishlist(productId,hdtWishlist);}
      else{removeFromWishlist(productId);hdtWishlist.setAttribute('action','add');updateWishlistUI();renderWishlist();}
    }else{addToWishlist(productId);hdtWishlist.setAttribute('action','added');updateWishlistUI();renderWishlist();}
    setTimeout(()=>{isProcessingWishlist=false;},300);
    return false;
  },true);

  document.addEventListener('click',e=>{
    const toggleBtn=e.target.closest('[data-drawer-toggle]');
    if(toggleBtn){e.preventDefault();showPanel(toggleBtn.dataset.drawerToggle);return;}

    const wishlistBtn=e.target.closest('[data-wishlist-btn]');
    if(wishlistBtn){
      e.preventDefault();e.stopPropagation();
      const productId=wishlistBtn.dataset.productId; if(!productId)return;
      if(isInWishlist(productId)){removeFromWishlist(productId);wishlistBtn.classList.remove('is-added');document.querySelectorAll(`hdt-wishlist[data-id="${productId}"]`).forEach(btn=>btn.setAttribute('action','add'));}
      else{addToWishlist(productId);wishlistBtn.classList.add('is-added');document.querySelectorAll(`hdt-wishlist[data-id="${productId}"]`).forEach(btn=>btn.setAttribute('action','added'));}
      updateWishlistUI();renderWishlist();return;
    }

    const removeWishlistBtn=e.target.closest('[data-remove-wishlist]');
    if(removeWishlistBtn){e.preventDefault();e.stopPropagation();ajaxRemoveFromWishlist(removeWishlistBtn.dataset.removeWishlist,removeWishlistBtn);return;}

    const plusBtn=e.target.closest('[data-qty-plus]');
    if(plusBtn){
      e.preventDefault(); const item=plusBtn.closest('[data-line-item]'); if(!item)return;
      const input=item.querySelector('[data-qty-input]'); const newQty=(parseInt(input.value)||1)+1;
      input.value=newQty; changeQuantity(item.dataset.line,newQty,item);return;
    }

    const minusBtn=e.target.closest('[data-qty-minus]');
    if(minusBtn){
      e.preventDefault(); const item=minusBtn.closest('[data-line-item]'); if(!item)return;
      const input=item.querySelector('[data-qty-input]'); const currentQty=parseInt(input.value)||1;
      if(currentQty>1){input.value=currentQty-1;changeQuantity(item.dataset.line,currentQty-1,item);}return;
    }

    const removeBtn=e.target.closest('[data-remove-item]');
    if(removeBtn){e.preventDefault();const item=removeBtn.closest('[data-line-item]');if(!item)return;changeQuantity(item.dataset.line,0,item);return;}

    const quickViewBtn=e.target.closest('[data-quick-view]');
    if(quickViewBtn){
      e.preventDefault();e.stopPropagation();
      const handle=quickViewBtn.dataset.productHandle; if(!handle)return;
      wasCartDrawerOpen=isDrawerOpen();
      if(wasCartDrawerOpen)closeDrawer();
      setTimeout(()=>openQuickView(handle),wasCartDrawerOpen?300:0);return;
    }
  });

  document.addEventListener('submit',async e=>{
    const form=e.target;
    if(form.action&&form.action.includes('/cart/add')){
      e.preventDefault();e.stopPropagation();
      const variantInput=form.querySelector('[name="id"]'); const qtyInput=form.querySelector('[name="quantity"]'); const submitBtn=form.querySelector('[type="submit"][name="add"]');
      if(!variantInput)return;
      const result=await addToCart(variantInput.value,qtyInput?qtyInput.value:1,submitBtn);
      if(result.success){if(isQuickViewOpen)closeQuickView();setTimeout(openDrawer,300);if(submitBtn)setTimeout(()=>submitBtn.textContent='Add to cart',1500);}
    }
  },true);

  function syncWishlistPage(){
    const isWishlistPage=window.location.href.includes('wishlist')||window.location.search.includes('view=wishlist')||document.querySelector('[data-wishlist-page]')||document.querySelector('.wishlist-page')||document.querySelector('.template-wishlist');
    if(!isWishlistPage)return;
    const ids=getWishlistIds();
    const productsGrid=document.querySelector('.hdt-products-grid,.hdt-grid,.wishlist-grid,[data-wishlist-grid],.collection-products,.products-grid');
    if(!productsGrid)return;
    const productCards=productsGrid.querySelectorAll('.hdt-card-product,.hdt-card,.product-card,[data-product-id],.wishlist-product-item');
    productCards.forEach(card=>{
      let productId=card.dataset.productId||card.dataset.id||card.querySelector('hdt-wishlist')?.dataset.id||card.querySelector('[data-product-id]')?.dataset.productId||card.querySelector('[data-wishlist-btn]')?.dataset.productId;
      if(productId&&!ids.includes(productId.toString())){card.style.transition='all 0.5s ease';card.classList.add('is-removing');setTimeout(()=>{card.remove();checkWishlistPageEmpty();},500);}
    });
    setTimeout(checkWishlistPageEmpty,600);
  }

  async function fetchAndCacheProducts(){
    if(Object.keys(productCache).length>0)return;
    try{
      const response=await fetch('/products.json?limit=250'); const data=await response.json();
      data.products.forEach(p=>{productCache[p.id.toString()]=p;productCache[p.handle]=p;});
    }catch(e){console.error('Error fetching products:',e);}
  }

  window.addEventListener('storage',function(e){if(e.key===WL_KEY){updateWishlistUI();renderWishlist();syncWishlistPage();}});
  document.addEventListener('visibilitychange',function(){if(document.visibilityState==='visible'){updateWishlistUI();renderWishlist();syncWishlistPage();}});
  window.addEventListener('pageshow',function(e){if(e.persisted){updateWishlistUI();renderWishlist();syncWishlistPage();}});

  document.addEventListener('DOMContentLoaded',async()=>{
    await fetchAndCacheProducts();
    updateWishlistUI();renderWishlist();syncWishlistPage();
    const leftPanel=document.querySelector('.cart-drawer-left-panel-full');
    if(leftPanel)leftPanel.classList.remove('is-visible');
    const recsSection=document.getElementById('cart-recommendations');
    if(recsSection)recsSection.classList.remove('is-visible');

    // ── CHANGE 3: Watch HDT discount section for apply/remove → auto refresh ─
    const discountSection=document.querySelector('.hdt-cart-discount-section');
    if(discountSection){
      const discountObserver=new MutationObserver(()=>{
        clearTimeout(window._discountRefreshTimer);
        window._discountRefreshTimer=setTimeout(refreshCart,700);
      });
      discountObserver.observe(discountSection,{childList:true,subtree:true});
    }
    // ─────────────────────────────────────────────────────────────────────────
    
    var currencyEvents = ['currency:changed', 'shopify:currency:changed', 'theme:currency:changed'];
    currencyEvents.forEach(function(evt) {
      document.addEventListener(evt, reRenderRelatedWithNewCurrency);
    });
    document.addEventListener('change', function(e) {
      if (e.target.closest('form[action*="localization"]') ||
          e.target.closest('[name="currency"]') ||
          e.target.closest('.shopify-currency-form')) {
        setTimeout(reRenderRelatedWithNewCurrency, 800);
      }
    });

    setTimeout(()=>{
      fetch('/cart.js').then(r=>r.json()).then(cart=>{
        updateShippingBar(cart.items_subtotal_price);
      }).catch(()=>{});
    },900);
  });

  setTimeout(()=>{updateWishlistUI();renderWishlist();syncWishlistPage();},1000);
})();

const cartDialogFix=document.getElementById('CartDrawer');
if(cartDialogFix){
  const fixObserver=new MutationObserver(()=>{
    if(cartDialogFix.hasAttribute('open')){
      requestAnimationFrame(()=>{
        cartDialogFix.scrollTop=0;
        const wrapper=cartDialogFix.querySelector('.cart-drawer-wrapper');
        if(wrapper)wrapper.scrollTop=0;
      });
    }
  });
  fixObserver.observe(cartDialogFix,{attributes:true,attributeFilter:['open']});
}
</script>

{%- endif -%}

<script>
  // Bypass app's thumbnail scrollIntoView
(function () {
  const _original = Element.prototype.scrollIntoView;
  Element.prototype.scrollIntoView = function (options) {
    if (
      this.matches('.hdt-slider__slide') ||
      this.closest('.hdt-slider__slide')
    ) {
      return; // block scroll on thumb slides
    }
    return _original.call(this, options);
  };
})();
</script>

