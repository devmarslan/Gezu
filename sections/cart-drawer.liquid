    fetch('/products.json?limit=250').then(r=>r.json()).then(data=>{ data.products.forEach(p=>productCache[p.id.toString()]=p); renderWishlistHTML(ids,container); }).catch(e=>{ console.error('Wishlist fetch error:',e); container.innerHTML='<div class="wishlist-error">Unable to load wishlist</div>'; });
