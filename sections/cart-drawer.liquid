{{- '<!-- CQV PRE-RENDERED BLOCKS (Liquid, correct market currency) -->' -}}
{%- if section.settings.collection != blank -%}
  {%- for product in collections[section.settings.collection].products limit: 5 -%}
    {%- assign first_variant = product.variants | first -%}
    {%- assign has_compare = false -%}
    {%- if product.compare_at_price > product.price -%}{%- assign has_compare = true -%}{%- endif -%}
    {%- assign discount_pct = 0 -%}
    {%- if has_compare -%}{%- assign discount_pct = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}{%- endif -%}
    <div class="cqv-prerendered" data-cqv-handle="{{ product.handle }}" style="display:none">
      <div class="cqv-product{% if product.images.size > 1 %} has-gallery{% endif %}">
        <div class="cqv-product__images">
          <div class="cqv-gallery">
            {%- if product.images.size > 0 -%}
              {%- for img in product.images -%}
                <div class="cqv-gallery__item"><img src="{{ img | image_url: width: 800 }}" alt="{{ img.alt | escape }}" loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"></div>
              {%- endfor -%}
            {%- else -%}
              <div class="cqv-gallery__placeholder">No image</div>
            {%- endif -%}
          </div>
        </div>
        <div class="cqv-product__info">
          <h2 class="cqv-product__title">{{ product.title }}</h2>
          <div class="cqv-product__pricing">
            <div class="hdt-price-wrapp cqv-hdt-price{% if has_compare %} hdt-price--show-badge{% endif %}">
              <div class="hdt-price__container">
                <div class="hdt-price__sale hdt-price__list">
                  <hdt-compare-at-price class="hdt-compare-at-price"{% unless has_compare %} hidden{% endunless %}>
                    <span class="hdt-money">{% if has_compare %}{{ product.compare_at_price | money }}{% endif %}</span>
                  </hdt-compare-at-price>
                  <hdt-price class="hdt-price" data-qv-price>
                    <span class="hdt-money">{{ product.price | money }} <span class="tax-text" style="color:#000;font-size: 12px; font-weight: 400;" >Inc VAT</span></span>
                  </hdt-price>
                </div>
              </div>
              {% if has_compare and discount_pct > 0 %}<span class="sale-badge">{{ discount_pct }}% OFF</span>{% endif %}
            </div>
          </div>
          {% comment %} <p class="cqv-product__tax">Tax included.</p> {% endcomment %}
          {%- if product.variants.size > 1 -%}
            {%- for option in product.options -%}
              {%- assign opt_idx = forloop.index0 -%}
              <div class="cqv-option" data-option-index="{{ opt_idx }}">
                <div class="cqv-option__label">{{ option }}: <strong data-option-selected="{{ opt_idx }}">{{ product.variants[0].options[opt_idx] }}</strong></div>
                <div class="cqv-option__btns">
                  {%- assign seen_values = '' -%}
                  {%- for variant in product.variants -%}
                    {%- assign opt_val = variant.options[opt_idx] -%}
                    {%- unless seen_values contains opt_val -%}
                      {%- assign seen_values = seen_values | append: opt_val | append: '|||' -%}
                      {%- assign is_first = forloop.first -%}
                      <button type="button" class="cqv-option__btn {% if is_first %}is-active{% endif %} {% unless variant.available %}is-soldout{% endunless %}" data-option-index="{{ opt_idx }}" data-option-value="{{ opt_val }}">{{ opt_val }}</button>
                    {%- endunless -%}
                  {%- endfor -%}
                </div>
              </div>
            {%- endfor -%}
          {%- endif -%}
          <div class="cqv-product__availability" data-qv-availability>{% unless first_variant.available %}<span class="cqv-soldout-text">Sold Out</span>{% endunless %}</div>
          <div class="cqv-product__actions">
            <div class="cqv-qty">
              <button type="button" class="cqv-qty__btn" data-qv-minus>−</button>
              <input type="text" class="cqv-qty__input" value="1" data-qv-qty readonly>
              <button type="button" class="cqv-qty__btn" data-qv-plus>+</button>
            </div>
            <button type="button" class="cqv-add {% unless first_variant.available %}is-disabled{% endunless %}" data-qv-add data-variant-id="{{ first_variant.id }}" {% unless first_variant.available %}disabled{% endunless %}>{% if first_variant.available %}ADD TO CART{% else %}SOLD OUT{% endif %}</button>
          </div>
          <button type="button" class="cqv-wishlist" data-qv-wishlist data-product-id="{{ product.id }}">
            <svg width="13" height="16" viewBox="0 0 13 16" fill="none"><path d="M12.5 0H0.5C0.367 0 0.24 0.056 0.146 0.156C0.053 0.255 0 0.39 0 0.531V15.399C0 15.5 0.027 15.599 0.078 15.684C0.129 15.769 0.202 15.837 0.288 15.88C0.374 15.922 0.47 15.938 0.564 15.925C0.658 15.913 0.747 15.871 0.82 15.807L6.5 10.78L12.18 15.807C12.27 15.886 12.383 15.93 12.5 15.93C12.573 15.93 12.646 15.913 12.712 15.88C12.798 15.837 12.871 15.769 12.922 15.684C12.973 15.599 13 15.5 13 15.399V0.531C13 0.39 12.947 0.255 12.854 0.156C12.76 0.056 12.633 0 12.5 0ZM12 14.266L6.82 9.681C6.73 9.602 6.617 9.558 6.5 9.558C6.383 9.558 6.27 9.602 6.18 9.681L1 14.266V1.062H12V14.266Z" fill="currentColor"></path></svg>
            <span class="cqv-wishlist__text">Add to Wishlist</span>
          </button>
        </div>
      </div>
      {{- '<!-- VARIANTS_JSON_START -->' -}}
      <script type="application/json" class="cqv-variants-json">
        [{% for variant in product.variants %}{%- assign v_has_compare = false -%}{%- if variant.compare_at_price > variant.price -%}{%- assign v_has_compare = true -%}{%- endif -%}{%- assign v_discount = 0 -%}{%- if v_has_compare -%}{%- assign v_discount = variant.compare_at_price | minus: variant.price | times: 100 | divided_by: variant.compare_at_price -%}{%- endif -%}{"id":{{ variant.id }},"price":"{{ variant.price | money }}","compare_price":"{% if v_has_compare %}{{ variant.compare_at_price | money }}{% endif %}","has_compare":{{ v_has_compare }},"discount_pct":{{ v_discount }},"available":{{ variant.available }},"options":[{% for opt in variant.options %}"{{ opt }}"{% unless forloop.last %},{% endunless %}{% endfor %}]}{% unless forloop.last %},{% endunless %}{% endfor %}]
      </script>
    </div>
  {%- endfor -%}
{%- endif -%}

