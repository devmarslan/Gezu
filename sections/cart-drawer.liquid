  const qvPriceCache = {};

  async function fetchLiquidPrice(handle) {
    if (qvPriceCache[handle]) return qvPriceCache[handle];
    const root = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) || '/';
    const url  = root.replace(/\/$/, '') + '/products/' + handle;
    try {
      const res  = await fetch(url);
