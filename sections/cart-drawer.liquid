                  {%- endfor -%}
                {%- endif -%}

                <div class="cart-drawer-summary__row cart-drawer-summary__row--total"><span class="ct-btm-total">Total</span><span data-cart-total>{{ cart.total_price | money }} <span class="tax-text" style="color:#000;font-size:12px;font-weight:400;">Inc VAT</span></span></div>

              </div>
              {%- if section.settings.show_vat_validation -%}
