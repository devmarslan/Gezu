            <img 
              src="{{ section.settings.image | image_url: width: 1920 }}" 
              alt="{{ section.settings.heading | default: 'Solutions image' }}"
              class="solutions-image solutions-image-desktop"
              data-default-src="{{ section.settings.image | image_url: width: 1920 }}"
              loading="lazy"
              width="1920"
              height="auto"
            >
          {% endif %}

          {% if section.settings.image_mobile != blank %}
            <img 
              src="{{ section.settings.image_mobile | image_url: width: 800 }}" 
              alt="{{ section.settings.heading | default: 'Solutions image' }}"
              class="solutions-image solutions-image-mobile"
              data-default-src="{{ section.settings.image_mobile | image_url: width: 800 }}"
              loading="lazy"
              width="800"
              height="auto"
            >
          {% endif %}

          {% comment %} Hotspots {% endcomment %}
          {% for block in section.blocks %}
            {% if block.type == 'hotspot' %}
              {% assign product = block.settings.product %}
              {% assign mobile_x = block.settings.position_x_mobile | default: block.settings.position_x %}
              {% assign mobile_y = block.settings.position_y_mobile | default: block.settings.position_y %}
              
              {% comment %} Prepare hotspot image data {% endcomment %}
              {% assign hotspot_desktop_image = '' %}
              {% assign hotspot_mobile_image = '' %}
              
              {% if block.settings.hotspot_image != blank %}
                {% assign hotspot_desktop_image = block.settings.hotspot_image | image_url: width: 1920 %}
              {% endif %}
              
              {% if block.settings.hotspot_image_mobile != blank %}
                {% assign hotspot_mobile_image = block.settings.hotspot_image_mobile | image_url: width: 800 %}
              {% elsif block.settings.hotspot_image != blank %}
                {% comment %} Fallback to desktop image for mobile if mobile not set {% endcomment %}
                {% assign hotspot_mobile_image = block.settings.hotspot_image | image_url: width: 800 %}
              {% endif %}
              
              <div 
                class="hotspot" 
                style="--desktop-x: {{ block.settings.position_x }}%; --desktop-y: {{ block.settings.position_y }}%; --mobile-x: {{ mobile_x }}%; --mobile-y: {{ mobile_y }}%;"
                data-hotspot-id="{{ block.id }}"
                {% if hotspot_desktop_image != '' %}data-desktop-image="{{ hotspot_desktop_image }}"{% endif %}
                {% if hotspot_mobile_image != '' %}data-mobile-image="{{ hotspot_mobile_image }}"{% endif %}
                {{ block.shopify_attributes }}
              >
                <button class="hotspot-button" aria-label="View product details">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                    <path class="icon-horizontal" d="M0 7h14" stroke="currentColor" stroke-width="2"/>
                    <path class="icon-vertical" d="M7 0v14" stroke="currentColor" stroke-width="2"/>
                  </svg>
                </button>

                {% comment %} Product Popup {% endcomment %}
                <div class="hotspot-popup" data-position="{{ block.settings.popup_position }}" data-mobile-position="{{ block.settings.popup_position_mobile | default: 'top' }}">
                  <div class="popup-inner">
                    {% if product != blank %}
                      <div class="popup-image">
                        {% if product.featured_image %}
                          <img src="{{ product.featured_image | image_url: width: 200 }}" alt="{{ product.title }}" loading="lazy">
                        {% endif %}
                      </div>
                      <div class="popup-content">
                        <h4 class="popup-title">{{ product.title }}</h4>
                        <div class="popup-price">
                          <span class="current-price">{{ product.price | money }}</span>
                          {% if product.compare_at_price > product.price %}
                            <span class="compare-price">{{ product.compare_at_price | money }}</span>
                            <span class="discount-badge">
                              {% assign discount = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round %}
                              {{ discount }}% OFF
                            </span>
                          {% endif %}
                        </div>
                        <form action="/cart/add" method="post" class="popup-form">
                          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                          <input type="hidden" name="quantity" value="1">
                          <button type="submit" class="popup-add-btn" {% unless product.available %}disabled{% endunless %}>
                            {% if product.available %}
                              {{ section.settings.add_to_cart_text }}
                            {% else %}
                              {{ section.settings.sold_out_text }}
                            {% endif %}
                          </button>
                        </form>
                      </div>
                    {% else %}
                      <div class="popup-image">
                        {% if block.settings.custom_image != blank %}
                          <img src="{{ block.settings.custom_image | image_url: width: 200 }}" alt="{{ block.settings.custom_title }}" loading="lazy">
                        {% endif %}
                      </div>
                      <div class="popup-content">
                        <h4 class="popup-title">{{ block.settings.custom_title | default: 'Product Title' }}</h4>
                        <div class="popup-price">
                          <span class="current-price">{{ block.settings.custom_price | default: '£50.00' }}</span>
                          {% if block.settings.custom_compare_price != blank %}
                            <span class="compare-price">{{ block.settings.custom_compare_price }}</span>
                            <span class="discount-badge">{{ block.settings.custom_discount | default: '20% OFF' }}</span>
                          {% endif %}
                        </div>
                        <a href="{{ block.settings.custom_link }}" class="popup-add-btn">
                          {{ section.settings.add_to_cart_text }}
                        </a>
                      </div>
                    {% endif %}
                  </div>
                  <div class="popup-arrow"></div>
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>

    {% if section.settings.full_width %}
      </div>
    {% else %}
        </div>
      </div>
    {% endif %}
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.getElementById('shoppable-solutions-{{ section.id }}');
    if (!section) return;

    const hotspots = section.querySelectorAll('.hotspot');
    const desktopImage = section.querySelector('.solutions-image-desktop');
    const mobileImage = section.querySelector('.solutions-image-mobile');
    
    // Store default images
    const defaultDesktopSrc = desktopImage ? desktopImage.dataset.defaultSrc : null;
    const defaultMobileSrc = mobileImage ? mobileImage.dataset.defaultSrc : null;
    
    // Function to check if mobile view
    function isMobileView() {
      return window.innerWidth <= 749;
    }
    
    // Function to update main image with fade effect
    function updateMainImage(desktopSrc, mobileSrc) {
      const targetImage = isMobileView() ? mobileImage : desktopImage;
      const newSrc = isMobileView() ? (mobileSrc || desktopSrc) : desktopSrc;
      
      if (!targetImage || !newSrc) return;
      
      // Add fade out
      targetImage.classList.add('fade-out');
      
      setTimeout(() => {
        targetImage.src = newSrc;
        // Remove fade out after image loads
        targetImage.onload = function() {
          targetImage.classList.remove('fade-out');
        };
        // Fallback remove fade if onload doesn't fire (cached image)
        setTimeout(() => {
          targetImage.classList.remove('fade-out');
        }, 100);
      }, 300);
    }
    
    // Function to reset to default image
    function resetToDefaultImage() {
      if (desktopImage && defaultDesktopSrc) {
        desktopImage.classList.add('fade-out');
        setTimeout(() => {
          desktopImage.src = defaultDesktopSrc;
          setTimeout(() => desktopImage.classList.remove('fade-out'), 100);
        }, 300);
      }
      
      if (mobileImage && defaultMobileSrc) {
        mobileImage.classList.add('fade-out');
        setTimeout(() => {
          mobileImage.src = defaultMobileSrc;
          setTimeout(() => mobileImage.classList.remove('fade-out'), 100);
        }, 300);
      }
    }
    
    hotspots.forEach(hotspot => {
      const button = hotspot.querySelector('.hotspot-button');
      const hotspotDesktopImage = hotspot.dataset.desktopImage;
      const hotspotMobileImage = hotspot.dataset.mobileImage;
      
      button.addEventListener('click', function(e) {
        e.stopPropagation();
        
        const wasActive = hotspot.classList.contains('active');
        
        // Close all other popups
        hotspots.forEach(h => {
          if (h !== hotspot) {
            h.classList.remove('active');
          }
        });
        
        // Toggle current popup
        hotspot.classList.toggle('active');
        
        // Update image based on state
        if (!wasActive) {
          // Opening this hotspot
          if (hotspotDesktopImage || hotspotMobileImage) {
            // Has image - update to hotspot image
            updateMainImage(hotspotDesktopImage, hotspotMobileImage);
          } else {
            // No image - reset to default
            resetToDefaultImage();
          }
        } else {
          // Closing this hotspot - reset to default
          resetToDefaultImage();
        }
      });
    });
    
    // Close popup when clicking outside
    document.addEventListener('click', function(e) {
      if (!e.target.closest('.hotspot')) {
        const anyWasActive = Array.from(hotspots).some(h => h.classList.contains('active'));
        hotspots.forEach(h => h.classList.remove('active'));
        
        // Reset to default image if any hotspot was active
        if (anyWasActive) {
          resetToDefaultImage();
        }
      }
    });
    
    // Close popup on escape key
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        const anyWasActive = Array.from(hotspots).some(h => h.classList.contains('active'));
        hotspots.forEach(h => h.classList.remove('active'));
        
        // Reset to default image if any hotspot was active
        if (anyWasActive) {
          resetToDefaultImage();
        }
      }
    });

    // Prevent popup clicks from closing
    section.querySelectorAll('.hotspot-popup').forEach(popup => {
      popup.addEventListener('click', function(e) {
        e.stopPropagation();
      });
    });
  });
</script>

