{% comment %} {% comment %}
  Shoppable Solutions Section
  - Desktop: Section title, content area (heading + description) aligned right, then full-width image with hotspots
  - Mobile: Section title, heading, description, then image with hotspots
  - Clickable hotspot markers positioned on products
  - Product popup with configurable position (desktop & mobile)
  - Fully responsive with mobile-specific images and hotspot positions
{% endcomment %}

{{ 'section-shoppable-solutions.css' | asset_url | stylesheet_tag }}

<style>
  #shoppable-solutions-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --section-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --section-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --hotspot-color: {{ section.settings.hotspot_color }};
    --hotspot-bg: {{ section.settings.hotspot_bg }};
    --hotspot-size: {{ section.settings.hotspot_size }}px;
    --hotspot-size-mobile: {{ section.settings.hotspot_size_mobile }}px;
    --popup-bg: {{ section.settings.popup_bg }};
    --popup-title-color: {{ section.settings.popup_title_color }};
    --popup-title-size: {{ section.settings.popup_title_font_size }}px;
    --popup-price-color: {{ section.settings.popup_price_color }};
    --popup-price-size: {{ section.settings.popup_price_font_size }}px;
    --popup-compare-color: {{ section.settings.popup_compare_price_color }};
    --popup-discount-color: {{ section.settings.popup_discount_color }};
    --popup-btn-bg: {{ section.settings.popup_btn_bg }};
    --popup-btn-color: {{ section.settings.popup_btn_color }};
    --section-bg: {{ section.settings.section_bg_color }};
    --content-bg: {{ section.settings.content_bg_color }};
  }
</style>

<section id="shoppable-solutions-{{ section.id }}" class="shoppable-solutions-section">
  <div class="solutions-wrapper hdt-container">
    {% if section.settings.full_width %}
      <div class="solutions-container full-width">
    {% else %}
      <div class="page-width">
        <div class="solutions-container">
    {% endif %}

    {% comment %} Section Title - Above everything {% endcomment %}
    {% if section.settings.section_title != blank %}
      <div class="solutions-section-title">
        <h2 style="font-size: {{ section.settings.section_title_font_size }}px; color: {{ section.settings.section_title_color }};">
          {{ section.settings.section_title }}
        </h2>
      </div>
    {% endif %}

    <div class="solutions-layout">
      {% comment %} Content Area - Above Image {% endcomment %}
      <div class="solutions-content-area">
        <div class="solutions-content-box">
        {% if section.settings.heading != blank %}
          <h3 class="solutions-heading" style="font-size: {{ section.settings.heading_font_size }}px; color: {{ section.settings.heading_color }};">
            {{ section.settings.heading }}
          </h3>
        {% endif %}
        
        {% if section.settings.description != blank %}
          <div class="solutions-description" style="font-size: {{ section.settings.description_font_size }}px; color: {{ section.settings.description_color }};">
            {{ section.settings.description }}
          </div>
        {% endif %}

        {% if section.settings.button_text != blank %}
          <a href="{{ section.settings.button_link }}" class="solutions-button" style="background-color: {{ section.settings.button_bg }}; color: {{ section.settings.button_color }};">
            {{ section.settings.button_text }}
          </a>
        {% endif %}
      </div>
      </div>

      {% comment %} Image with Hotspots {% endcomment %}
      <div class="solutions-image-wrapper">
        <div class="solutions-image-container" {% if section.settings.image_mobile != blank %}data-has-mobile-image="true"{% endif %}>
          {% if section.settings.image != blank %}
            <img 
              src="{{ section.settings.image | image_url: width: 1920 }}" 
              alt="{{ section.settings.heading | default: 'Solutions image' }}"
              class="solutions-image solutions-image-desktop"
              loading="lazy"
              width="1920"
              height="auto"
            >
          {% endif %}

          {% if section.settings.image_mobile != blank %}
            <img 
              src="{{ section.settings.image_mobile | image_url: width: 800 }}" 
              alt="{{ section.settings.heading | default: 'Solutions image' }}"
              class="solutions-image solutions-image-mobile"
              loading="lazy"
              width="800"
              height="auto"
            >
          {% endif %}

          {% comment %} Hotspots {% endcomment %}
          {% for block in section.blocks %}
            {% if block.type == 'hotspot' %}
              {% assign product = block.settings.product %}
              {% assign mobile_x = block.settings.position_x_mobile | default: block.settings.position_x %}
              {% assign mobile_y = block.settings.position_y_mobile | default: block.settings.position_y %}
              <div 
                class="hotspot" 
                style="--desktop-x: {{ block.settings.position_x }}%; --desktop-y: {{ block.settings.position_y }}%; --mobile-x: {{ mobile_x }}%; --mobile-y: {{ mobile_y }}%;"
                data-hotspot-id="{{ block.id }}"
                {{ block.shopify_attributes }}
              >
                <button class="hotspot-button" aria-label="View product details">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                    <path class="icon-horizontal" d="M0 7h14" stroke="currentColor" stroke-width="2"/>
                    <path class="icon-vertical" d="M7 0v14" stroke="currentColor" stroke-width="2"/>
                  </svg>
                </button>

                {% comment %} Product Popup {% endcomment %}
                <div class="hotspot-popup" data-position="{{ block.settings.popup_position }}" data-mobile-position="{{ block.settings.popup_position_mobile | default: 'top' }}">
                  <div class="popup-inner">
                    {% if product != blank %}
                      <div class="popup-image">
                        {% if product.featured_image %}
                          <img src="{{ product.featured_image | image_url: width: 200 }}" alt="{{ product.title }}" loading="lazy">
                        {% endif %}
                      </div>
                      <div class="popup-content">
                        <h4 class="popup-title">{{ product.title }}</h4>
                        <div class="popup-price">
                          <span class="current-price">{{ product.price | money }}</span>
                          {% if product.compare_at_price > product.price %}
                            <span class="compare-price">{{ product.compare_at_price | money }}</span>
                            <span class="discount-badge">
                              {% assign discount = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round %}
                              {{ discount }}% OFF
                            </span>
                          {% endif %}
                        </div>
                        <form action="/cart/add" method="post" class="popup-form">
                          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                          <input type="hidden" name="quantity" value="1">
                          <button type="submit" class="popup-add-btn" {% unless product.available %}disabled{% endunless %}>
                            {% if product.available %}
                              {{ section.settings.add_to_cart_text }}
                            {% else %}
                              {{ section.settings.sold_out_text }}
                            {% endif %}
                          </button>
                        </form>
                      </div>
                    {% else %}
                      <div class="popup-image">
                        {% if block.settings.custom_image != blank %}
                          <img src="{{ block.settings.custom_image | image_url: width: 200 }}" alt="{{ block.settings.custom_title }}" loading="lazy">
                        {% endif %}
                      </div>
                      <div class="popup-content">
                        <h4 class="popup-title">{{ block.settings.custom_title | default: 'Product Title' }}</h4>
                        <div class="popup-price">
                          <span class="current-price">{{ block.settings.custom_price | default: '£50.00' }}</span>
                          {% if block.settings.custom_compare_price != blank %}
                            <span class="compare-price">{{ block.settings.custom_compare_price }}</span>
                            <span class="discount-badge">{{ block.settings.custom_discount | default: '20% OFF' }}</span>
                          {% endif %}
                        </div>
                        <a href="{{ block.settings.custom_link }}" class="popup-add-btn">
                          {{ section.settings.add_to_cart_text }}
                        </a>
                      </div>
                    {% endif %}
                  </div>
                  <div class="popup-arrow"></div>
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>

    {% if section.settings.full_width %}
      </div>
    {% else %}
        </div>
      </div>
    {% endif %}
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.getElementById('shoppable-solutions-{{ section.id }}');
    if (!section) return;

    const hotspots = section.querySelectorAll('.hotspot');
    
    hotspots.forEach(hotspot => {
      const button = hotspot.querySelector('.hotspot-button');
      
      button.addEventListener('click', function(e) {
        e.stopPropagation();
        
        // Close all other popups
        hotspots.forEach(h => {
          if (h !== hotspot) {
            h.classList.remove('active');
          }
        });
        
        // Toggle current popup
        hotspot.classList.toggle('active');
      });
    });
    
    // Close popup when clicking outside
    document.addEventListener('click', function(e) {
      if (!e.target.closest('.hotspot')) {
        hotspots.forEach(h => h.classList.remove('active'));
      }
    });
    
    // Close popup on escape key
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        hotspots.forEach(h => h.classList.remove('active'));
      }
    });

    // Prevent popup clicks from closing
    section.querySelectorAll('.hotspot-popup').forEach(popup => {
      popup.addEventListener('click', function(e) {
        e.stopPropagation();
      });
    });
  });
</script>

