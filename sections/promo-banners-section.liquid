                      <img src="{{ block.settings.product_image | image_url: width: 400 }}" 
                           alt="{{ block.settings.title }}"
                           loading="lazy"
                           width="400"
                           height="300">
                    </div>
                  {% endif %}
                </div>
              </div>
              
            {% endif %}
          {% endfor %}
        </div>
      </div>
      
