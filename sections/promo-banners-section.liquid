                    {% endif %}
                  </div>
                </div>
              </div>
            {% endif %}
          {% endfor %}
          
          {% comment %} Members Card - Full Width {% endcomment %}
          {% for block in section.blocks %}
            {% if block.type == 'members_card' %}
              <div class="promo-mobile-full">
                <div class="members-card members-card-{{ block.id }}" {{ block.shopify_attributes }}>
                  <div class="members-content">
                    <div class="members-text">
                      {% if block.settings.title != blank %}
                        <h3 class="members-title">{{ block.settings.title }}</h3>
                      {% endif %}
                      {% if block.settings.subtitle != blank %}
