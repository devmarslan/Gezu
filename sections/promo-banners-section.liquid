                    {% endif %}
                    {% if members_block.settings.benefit_2 != blank %}
                      <li class="benefit-item">{{ members_block.settings.benefit_2 }}</li>
                    {% endif %}
                    {% if members_block.settings.benefit_3 != blank %}
                      <li class="benefit-item">{{ members_block.settings.benefit_3 }}</li>
                    {% endif %}
                    {% if members_block.settings.benefit_4 != blank %}
                      <li class="benefit-item">{{ members_block.settings.benefit_4 }}</li>
                    {% endif %}
                  </ul>
                  {% if members_block.settings.button_text != blank %}
                    <a href="{{ members_block.settings.button_link }}" class="members-btn">
                      {{ members_block.settings.button_text }}
                    </a>
                  {% endif %}
                </div>
                {% if members_block.settings.decorative_image != blank %}
                  <div class="members-decoration">
                    <img src="{{ members_block.settings.decorative_image | image_url: width: 200 }}" 
                         alt=""
                         loading="lazy"
                         width="200"
                         height="200">
                  </div>
                {% endif %}
              </div>
            </div>
          {% endif %}
        </div>
        
        {% comment %} Bottom Row - Promo Cards {% endcomment %}
        <div class="promo-bottom-row">
          {% for block in section.blocks %}
            {% if block.type == 'promo_card' %}
              <div class="promo-card promo-card-{{ block.id }}" {{ block.shopify_attributes }}>
                <div class="promo-card-content" style="">
                  <div class="promo-card-text">
                    {% if block.settings.upto_text != blank %}
                      <span class="upto-text">{{ block.settings.upto_text }}</span>
                    {% endif %}
                    <div class="promo-discount-wrap">
                      <span class="promo-discount-number">{{ block.settings.discount_number }}</span>
                      <div class="promo-discount-percent-wrap">
                        <span class="promo-discount-percent">%</span>
                        <span class="promo-discount-off">OFF</span>
                      </div>
                    </div>
                    {% if block.settings.title != blank %}
