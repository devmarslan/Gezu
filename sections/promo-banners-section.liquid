                      {% endif %}
                      <ul class="benefits-list">
                        {% if block.settings.benefit_1 != blank %}
                          <li class="benefit-item">{{ block.settings.benefit_1 }}</li>
                        {% endif %}
                        {% if block.settings.benefit_2 != blank %}
                          <li class="benefit-item">{{ block.settings.benefit_2 }}</li>
                        {% endif %}
                        {% if block.settings.benefit_3 != blank %}
                          <li class="benefit-item">{{ block.settings.benefit_3 }}</li>
                        {% endif %}
                        {% if block.settings.benefit_4 != blank %}
                          <li class="benefit-item">{{ block.settings.benefit_4 }}</li>
                        {% endif %}
                      </ul>
                      {% if block.settings.button_text != blank %}
