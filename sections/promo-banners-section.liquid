          #promo-banners-{{ section.id }} .promo-card-{{ block.id }} .upto-text {
            font-size: {{ block.settings.upto_font_size_mobile }}px;
          }
          #promo-banners-{{ section.id }} .promo-card-{{ block.id }} .promo-discount-number {
            font-size: {{ block.settings.discount_font_size_mobile }}px;
          }
          #promo-banners-{{ section.id }} .promo-card-{{ block.id }} .promo-discount-percent {
            font-size: {{ block.settings.discount_percent_size_mobile }}px;
          }
          #promo-banners-{{ section.id }} .promo-card-{{ block.id }} .promo-title {
            font-size: {{ block.settings.title_font_size_mobile }}px;
          }
          #promo-banners-{{ section.id }} .promo-card-{{ block.id }} .promo-description {
            font-size: {{ block.settings.description_font_size_mobile }}px;
          }
          {% if block.settings.bgimg_contain %}
          #promo-banners-{{ section.id }} .promo-card-{{ block.id }} {
            background-size: contain;
            background-position: right;
          }
          {% endif %}
        }
    {% endcase %}
  {% endfor %}
</style>

<section id="promo-banners-{{ section.id }}" class="promo-banners-section">
  <div class="promo-banners-wrapper">
    <div class="hdt-container">
      {% comment %} Desktop Layout {% endcomment %}
      <div class="promo-banners-grid desktop-grid">
        {% assign hero_block = null %}
        {% assign members_block = null %}
        {% assign promo_blocks = '' %}
        
        {% for block in section.blocks %}
          {% if block.type == 'hero_banner' %}
            {% assign hero_block = block %}
          {% elsif block.type == 'members_card' %}
            {% assign members_block = block %}
          {% elsif block.type == 'promo_card' %}
            {% if promo_blocks == '' %}
              {% assign promo_blocks = block.id %}
            {% else %}
              {% assign promo_blocks = promo_blocks | append: ',' | append: block.id %}
            {% endif %}
          {% endif %}
        {% endfor %}
        
        {% comment %} Top Row {% endcomment %}
        <div class="promo-top-row">
          {% comment %} Hero Banner {% endcomment %}
          {% if hero_block %}
            <div class="hero-banner hero-banner-{{ hero_block.id }}" {{ hero_block.shopify_attributes }}>
              <div class="hero-content">
                <div class="hero-text">
                  {% if hero_block.settings.upto_text != blank %}
                    <span class="upto-text">{{ hero_block.settings.upto_text }}</span>
                  {% endif %}
                  <div class="discount-wrap">
                    <span class="discount-number">{{ hero_block.settings.discount_number }}</span>
                    <div class="discount-percent-wrap">
                      <span class="discount-percent">%</span>
                      <span class="discount-off">OFF</span>
                    </div>
                  </div>
                  {% if hero_block.settings.title != blank %}
                    <h2 class="hero-title">{{ hero_block.settings.title }}</h2>
                  {% endif %}
                  {% if hero_block.settings.description != blank %}
                    <p class="hero-description">{{ hero_block.settings.description }}</p>
                  {% endif %}
                  {% if hero_block.settings.button_text != blank %}
                    <a href="{{ hero_block.settings.button_link }}" class="hero-btn">
                      {{ hero_block.settings.button_text }}
                    </a>
                  {% endif %}
                </div>
                {% if hero_block.settings.product_image != blank %}
                  <div class="hero-image">
                    <img src="{{ hero_block.settings.product_image | image_url: width: 600 }}" 
                         alt="{{ hero_block.settings.title }}"
                         loading="lazy"
                         width="600"
                         height="400">
                  </div>
                {% endif %}
              </div>
            </div>
          {% endif %}
          
          {% comment %} Members Card {% endcomment %}
