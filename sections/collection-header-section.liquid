                <path d="M29.3196 3.49296V1.78286C29.3196 1.67486 29.2745 1.57177 29.1952 1.49844L27.8393 0.244478C27.6903 0.106661 27.4601 0.107235 27.3118 0.245793L25.9706 1.49861C25.8922 1.57187 25.8477 1.67439 25.8477 1.78171V3.49296C25.8477 3.70692 26.0211 3.88037 26.2351 3.88037H28.9322C29.1461 3.88037 29.3196 3.70692 29.3196 3.49296Z" fill="#0047AB"/>
                <path d="M29.3196 51.875V53.5851C29.3196 53.6931 29.2745 53.7962 29.1952 53.8695L27.8393 55.1234C27.6903 55.2613 27.4601 55.2607 27.3118 55.1221L25.9706 53.8693C25.8922 53.7961 25.8477 53.6935 25.8477 53.5862V51.875C25.8477 51.661 26.0211 51.4876 26.2351 51.4876H28.9322C29.1461 51.4876 29.3196 51.661 29.3196 51.875Z" fill="#0047AB"/>
                <path d="M51.8742 29.5339L53.5843 29.5339C53.6923 29.5339 53.7954 29.4888 53.8687 29.4096L55.1227 28.0536C55.2605 27.9046 55.26 27.6745 55.1214 27.5262L53.8686 26.185C53.7953 26.1065 53.6928 26.062 53.5855 26.062L51.8742 26.062C51.6603 26.062 51.4868 26.2355 51.4868 26.4494V29.1465C51.4868 29.3605 51.6603 29.5339 51.8742 29.5339Z" fill="#0047AB"/>
                <path d="M3.49296 29.5339L1.78286 29.5339C1.67486 29.5339 1.57177 29.4888 1.49844 29.4096L0.244478 28.0536C0.106661 27.9046 0.107235 27.6745 0.245793 27.5262L1.49861 26.185C1.57187 26.1065 1.67439 26.062 1.78171 26.062L3.49296 26.062C3.70692 26.062 3.88037 26.2355 3.88037 26.4494V29.1465C3.88037 29.3605 3.70692 29.5339 3.49296 29.5339Z" fill="#0047AB"/>
              </svg>
            </div>
          {%- endif -%}
          
          <div class="membership-rewards-banner__badge-text">
            {%- if section.settings.badge_title != blank -%}
              <span class="membership-rewards-banner__badge-title">{{ section.settings.badge_title }}</span>
            {%- endif -%}
            {%- if section.settings.badge_subtitle != blank -%}
              <span class="membership-rewards-banner__badge-subtitle">{{ section.settings.badge_subtitle }}</span>
            {%- endif -%}
          </div>
        </div>
      </div>
      
      <!-- Right Content Section -->
      <div class="membership-rewards-banner__right">
        <div class="membership-rewards-banner__content">
          <div class="membership-rewards-banner__text">
            {%- if section.settings.heading != blank or section.settings.heading_highlight != blank -%}
              <h2 class="membership-rewards-banner__heading">
                {{ section.settings.heading }}
                {%- if section.settings.heading_highlight != blank -%}
                  <span class="membership-rewards-banner__heading-highlight">{{ section.settings.heading_highlight }}</span>
                {%- endif -%}
              </h2>
            {%- endif -%}
            
            {%- if section.settings.description != blank -%}
              <p class="membership-rewards-banner__description">{{ section.settings.description }}</p>
            {%- endif -%}
            
            {%- if section.settings.cta_text != blank -%}
              <a href="{{ section.settings.cta_link }}" class="membership-rewards-banner__cta">
                {{ section.settings.cta_text }}
              </a>
            {%- endif -%}
          </div>
          
          {% comment %} {%- if section.settings.show_coins -%}
            <div class="membership-rewards-banner__coins">
              <div class="membership-rewards-banner__coin membership-rewards-banner__coin--1">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" width="50" height="50">
                  <circle cx="20" cy="20" r="18" fill="{{ section.settings.coin_color }}"/>
                  <circle cx="20" cy="20" r="14" fill="{{ section.settings.coin_inner_color }}"/>
                  <text x="20" y="25" text-anchor="middle" font-size="14" font-weight="bold" fill="{{ section.settings.coin_symbol_color }}">$</text>
                </svg>
              </div>
              <div class="membership-rewards-banner__coin membership-rewards-banner__coin--2">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" width="35" height="35">
                  <circle cx="20" cy="20" r="18" fill="{{ section.settings.coin_color }}"/>
                  <circle cx="20" cy="20" r="14" fill="{{ section.settings.coin_inner_color }}"/>
                  <text x="20" y="25" text-anchor="middle" font-size="14" font-weight="bold" fill="{{ section.settings.coin_symbol_color }}">$</text>
                </svg>
              </div>
            </div>
          {%- endif -%} {% endcomment %}
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Collection Header Banner",
  "tag": "section",
  "class": "membership-rewards-section",
  "settings": [
    {
      "type": "header",
      "content": "Badge Settings"
    },
    {
      "type": "image_picker",
      "id": "badge_icon",
      "label": "Badge Icon"
    },
    {
      "type": "text",
      "id": "badge_title",
      "label": "Badge Title",
      "default": "My Gezu's"
    },
    {
      "type": "text",
      "id": "badge_subtitle",
      "label": "Badge Subtitle",
      "default": "Rewards"
    },
    {
      "type": "header",
      "content": "Content Settings"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Members Save More."
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Heading Highlight Text",
      "default": "Become our member today"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Become a GeZu Member and unlock special pricing, early offers, and pro-level guidance."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Text",
      "default": "Join for free"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Link"
    },
    {
      "type": "checkbox",
      "id": "show_coins",
      "label": "Show Coins",
      "default": true
    },
    {
      "type": "header",
      "content": "Background Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background Color",
      "default": "#fff"
    },
    {
      "type": "color_background",
      "id": "cont_bg_color",
      "label": "Container Background Color",
      "default": "#1a365d"
    },
    {
      "type": "image_picker",
      "id": "cont_bg_img",
      "label": "Container Background Image(Desktop)"
    },
    {
      "type": "image_picker",
      "id": "cont_bg_img_mbl",
      "label": "Container Background Image(Mobile)"
    },
    
    {
      "type": "image_picker",
      "id": "cont_absol_img",
      "label": "Container Absolute Image"
    },
    {
      "type": "header",
      "content": "Badge Typography"
    },
    {
      "type": "color",
