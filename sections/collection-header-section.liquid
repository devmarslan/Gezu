{% comment %}
  Membership Rewards Banner Section
  Dynamic section with customizable text, colors, fonts, and padding
{% endcomment %}

{%- style -%}
  /* Membership Rewards Banner Styles */
  .membership-rewards-banner {
    position: relative;
    overflow: hidden;
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .membership-rewards-banner__wrapper {
    display: flex;
    align-items: stretch;
    min-height: 215px;
    border-radius: 12px;
    overflow: visible;
    {% if section.settings.cont_bg_img != blank %}
    background: url({{ section.settings.cont_bg_img | img_url: 'master' }});
    background-size: cover;
    background-repeat: no-repeat;
    {% else %}
    background: {{ section.settings.cont_bg_color }};
    {% endif %}
    position: relative;
  }
  .membership-rewards-banner__wrapper:after {
    content: "";
    background: url({{ section.settings.cont_absol_img | img_url: 'master' }});
    background-repeat: no-repeat;
    background-size: contain;
    width: 100px;
    height: 100px;
    position: absolute;
    right: -30px;
    bottom: -30px;
    display: block;
  }

  /* Left Badge Section */
  .membership-rewards-banner__left {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px 40px;
    min-width: 420px;
    /* background-color: {{ section.settings.left_bg_color }};
    clip-path: ellipse(100% 100% at 0% 50%); */
  }

  /* .membership-rewards-banner__left::after {
    content: '';
    position: absolute;
    right: -50px;
    top: 0;
    bottom: 0;
    width: 100px;
    background: inherit;
    border-radius: 0 50% 50% 0;
  } */

  .membership-rewards-banner__badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: relative;
    z-index: 1;
    justify-content: space-between;
    height: 80%;
  }

  .membership-rewards-banner__icon {
    margin-bottom: 5px;
  }

  .membership-rewards-banner__icon img {
    display: block;
  }

  .membership-rewards-banner__icon--default {
    color: {{ section.settings.badge_title_color }};
  }

  .membership-rewards-banner__icon--default svg {
    display: block;
  }

  .membership-rewards-banner__badge-text {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }

  .membership-rewards-banner__badge-title {
    font-weight: 400;
    letter-spacing: 0.02em;
    color: {{ section.settings.badge_title_color }};
    font-size: {{ section.settings.badge_title_font_size }}px;
  }

  .membership-rewards-banner__badge-subtitle {
    font-weight: 700;
    letter-spacing: 0.02em;
    color: {{ section.settings.badge_subtitle_color }};
    font-size: {{ section.settings.badge_subtitle_font_size }}px;
  }

  /* Right Content Section */
  .membership-rewards-banner__right {
    flex: 1;
    display: flex;
    align-items: center;
    padding: 20px 40px 20px 80px;
    width: 70%;
  }

  .membership-rewards-banner__content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    gap: 30px;
  }

  .membership-rewards-banner__text {
    flex: 1;
  }

  .membership-rewards-banner__heading {
    margin: 0 0 8px 0;
    font-weight: 600;
    line-height: 1.3;
    color: {{ section.settings.heading_color }};
    font-size: {{ section.settings.heading_font_size }}px;
  }

  .membership-rewards-banner__heading-highlight {
    font-weight: 400;
    color: {{ section.settings.heading_highlight_color }};
  }

  .membership-rewards-banner__description {
    margin: 0 0 20px 0;
    line-height: 1.5;
    max-width: 400px;
    color: {{ section.settings.description_color }};
    font-size: {{ section.settings.description_font_size }}px;
  }

  .membership-rewards-banner__cta {
    display: inline-block;
    text-decoration: underline;
    font-weight: 600;
    transition: color 0.3s ease;
    color: {{ section.settings.cta_color }};
    font-size: {{ section.settings.cta_font_size }}px;
  }

  .membership-rewards-banner__cta:hover {
    text-decoration: underline;
    color: {{ section.settings.cta_hover_color }};
  }

  /* Coins */
  .membership-rewards-banner__coins {
    position: relative;
    width: 80px;
    height: 80px;
    flex-shrink: 0;
  }

  .membership-rewards-banner__coin {
    position: absolute;
    animation: membershipCoinFloat 3s ease-in-out infinite;
  }

  .membership-rewards-banner__coin--1 {
    top: 0;
    right: 0;
    animation-delay: 0s;
  }

  .membership-rewards-banner__coin--2 {
    bottom: 5px;
    right: 25px;
    animation-delay: 0.5s;
  }

  @keyframes membershipCoinFloat {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-8px);
    }
  }

  /* Responsive Styles */
  @media screen and (max-width: 989px) {
    .membership-rewards-banner__left {
      min-width: 150px;
      padding: 15px 30px 15px 80px;
    }
    
    .membership-rewards-banner__right {
      padding: 15px 30px 15px 140px;
    }
    
    .membership-rewards-banner__description {
      max-width: 300px;
    }
  }
@media (min-width: 769px) and (max-width: 810px) {
.membership-rewards-banner__description
 {
    font-size: 12px;
}
.membership-rewards-banner__heading {
    font-size: 20px;
}
}

  @media screen and (max-width: 768px) {
    .membership-rewards-banner__wrapper {
        {% if section.settings.cont_bg_img != blank %}
        background: url({{ section.settings.cont_bg_img_mbl | img_url: 'master' }});
        background-size: cover;
        {% endif %}
        min-height: 265px;
        background-position: bottom;
    }
    .membership-rewards-banner__wrapper:after {
        width: 80px;
        height: 80px;
        right: unset;
        left: 0;
        bottom: -20px;
    }
    .membership-rewards-banner__left {
       display: none;
    }
    .membership-rewards-banner__right{
        width: 100%;
    }
    .membership-rewards-banner__text {
      text-align: center;
    }
  /* }

  @media screen and (max-width: 749px) { */
    .membership-rewards-banner {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }

    .membership-rewards-banner__wrapper {
      flex-direction: column;
      border-radius: 12px;
    }
    
    .membership-rewards-banner__left {
      clip-path: none;
      border-radius: 12px 12px 0 0;
      padding: 20px;
      min-width: auto;
    }
    
    .membership-rewards-banner__left::after {
      display: none;
    }
    
    .membership-rewards-banner__badge {
      flex-direction: row;
      gap: 12px;
    }
    
    .membership-rewards-banner__badge-text {
      text-align: left;
    }
    
    .membership-rewards-banner__icon {
      margin-bottom: 0;
    }
    
    .membership-rewards-banner__right {
      padding: 20px;
      border-radius: 0 0 12px 12px;
    }
    
    .membership-rewards-banner__content {
      flex-direction: column;
      text-align: center;
      gap: 20px;
    }
    
    
    
    .membership-rewards-banner__heading {
      font-size: {{ section.settings.heading_font_size_mobile }}px;
    }

    .membership-rewards-banner__description {
      max-width: none;
      font-size: {{ section.settings.description_font_size_mobile }}px;
    }
    
    .membership-rewards-banner__coins {
      width: 70px;
      height: 60px;
    }
    
    .membership-rewards-banner__coin--1 svg {
      width: 40px;
      height: 40px;
    }
    
    .membership-rewards-banner__coin--2 svg {
      width: 28px;
      height: 28px;
    }
  }

  @media screen and (max-width: 480px) {
    .membership-rewards-banner__heading {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }
  }
{%- endstyle -%}

<div class="membership-rewards-banner">
  <div class="hdt-container">
    <div class="membership-rewards-banner__wrapper">
      <!-- Left Badge Section -->
      <div class="membership-rewards-banner__left">
        <div class="membership-rewards-banner__badge">
          {%- if section.settings.badge_icon != blank -%}
            <div class="membership-rewards-banner__icon">
              <img 
                src="{{ section.settings.badge_icon | image_url: width: 60 }}" 
                alt="{{ section.settings.badge_title }}"
                width="60"
                height="60"
                loading="lazy"
              >
            </div>
          {%- else -%}
            <div class="membership-rewards-banner__icon membership-rewards-banner__icon--default">
              <svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" viewBox="0 0 56 56" fill="none">
