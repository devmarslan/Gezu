      "label": "Badge Title Color",
      "default": "#2563eb"
    },
    {
      "type": "range",
      "id": "badge_title_font_size",
      "label": "Badge Title Font Size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "badge_subtitle_color",
      "label": "Badge Subtitle Color",
      "default": "#2563eb"
    },
    {
      "type": "range",
      "id": "badge_subtitle_font_size",
      "label": "Badge Subtitle Font Size",
      "min": 14,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 22
    },
    {
      "type": "header",
      "content": "Heading Typography"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_highlight_color",
      "label": "Heading Highlight Color",
      "default": "#94a3b8"
    },
    {
      "type": "range",
