{% comment %}
  Rewards & Content Section
  - Left: Rewards Card with tabs (Personal/Business) - Content switches based on tab
  - Middle Top: Promo Banner (Christmas Sale)
  - Middle Bottom: Blog Posts Row
  - Right: Blog/Tips Intro Card
  - Fully responsive with mobile slider
{% endcomment %}

<style>
  #rewards-content-{{ section.id }} {
    --section-bg-color: {{ section.settings.section_bg_color }};
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --section-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --section-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    
    /* Rewards Card */
    --rewards-bg: {{ section.settings.rewards_bg_gradient }};
    --rewards-title-color: {{ section.settings.rewards_title_color }};
    --rewards-title-size: {{ section.settings.rewards_title_font_size }}px;
    --rewards-title-size-mobile: {{ section.settings.rewards_title_font_size_mobile }}px;
    --rewards-subtitle-color: {{ section.settings.rewards_subtitle_color }};
    --rewards-subtitle-size: {{ section.settings.rewards_subtitle_font_size }}px;
    --rewards-text-color: {{ section.settings.rewards_text_color }};
    --rewards-text-size: {{ section.settings.rewards_text_font_size }}px;
    --rewards-btn-bg: {{ section.settings.rewards_btn_bg }};
    --rewards-btn-color: {{ section.settings.rewards_btn_color }};
    
    /* Promo Card */
    --promo-bg-color: {{ section.settings.promo_bg_color }};
    --promo-title-color: {{ section.settings.promo_title_color }};
    --promo-title-size: {{ section.settings.promo_title_font_size }}px;
    --promo-title-size-mobile: {{ section.settings.promo_title_font_size_mobile }}px;
    --promo-text-color: {{ section.settings.promo_text_color }};
    --promo-text-size: {{ section.settings.promo_text_font_size }}px;
    --promo-link-color: {{ section.settings.promo_link_color }};
    
    /* Blog Intro Card */
    --blog-intro-bg: {{ section.settings.blog_intro_bg }};
    --blog-intro-title-color: {{ section.settings.blog_intro_title_color }};
    --blog-intro-title-size: {{ section.settings.blog_intro_title_font_size }}px;
    --blog-intro-text-color: {{ section.settings.blog_intro_text_color }};
    --blog-intro-text-size: {{ section.settings.blog_intro_text_font_size }}px;
    --blog-intro-link-color: {{ section.settings.blog_intro_link_color }};
    
    /* Tips Section */
    --tips-title-color: {{ section.settings.tips_title_color }};
    --tips-title-size: {{ section.settings.tips_title_font_size }}px;
    --tips-title-size-mobile: {{ section.settings.tips_title_font_size_mobile }}px;
    
    /* Blog Card */
    --blog-card-bg: {{ section.settings.blog_card_bg }};
    --blog-card-title-color: {{ section.settings.blog_card_title_color }};
    --blog-card-title-size: {{ section.settings.blog_card_title_font_size }}px;
    --blog-card-title-size-mobile: {{ section.settings.blog_card_title_font_size_mobile }}px;
  }

  #rewards-content-{{ section.id }} .rewards-content-wrapper {
    padding-top: var(--section-padding-top);
    padding-bottom: var(--section-padding-bottom);
    {% if section.settings.section_bg_image != blank %}
    background-image: url('{{ section.settings.section_bg_image | image_url: width: 1920 }}');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    {% endif %}
  }

  @media (max-width: 768px) {
    #rewards-content-{{ section.id }} .rewards-content-wrapper {
      padding-top: var(--section-padding-top-mobile);
      padding-bottom: var(--section-padding-bottom-mobile);
    }
  }
  /* ==========================================================================
   Rewards & Content Section - CSS
   ========================================================================== */

/* Base Styles */
.rewards-content-section {
  width: 100%;
}

.rewards-content-wrapper {
  position: relative;
}

/* ==========================================================================
   Main Grid Layout
   ========================================================================== */
.rewards-content-grid {
  display: grid;
  grid-template-columns: 440px 1fr;
  gap: 24px;
  align-items: flex-start;
}

/* ==========================================================================
   Left Column - Rewards Card
   ========================================================================== */
.rewards-card-column {
  position: sticky;
  top: 20px;
}

.rewards-card {
  border-radius: 16px;
  padding: 30px 20px;
  position: relative;
  overflow: hidden;
  min-height: 650px;
  display: flex;
  flex-direction: column;
      border: 1px solid #0047AB;
}

/* Rewards Card Background Image */
.rewards-card-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 0;
}

.rewards-card-bg img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.rewards-card-bg-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--rewards-bg);
  opacity: 0.85;
}

.rewards-card > *:not(.rewards-card-bg) {
  position: relative;
  z-index: 1;
}

/* Decorative Elements - Repositioned */
.rewards-decorations {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 2;
}

.deco-coin {
  position: absolute;
  object-fit: contain;
}

/* Coin 1 - Top Left Corner (partially outside) */
.deco-coin.coin-1 {
  width: {{ section.settings.coin_1_size }}px;
  height: {{ section.settings.coin_1_size }}px;
  top: {{ section.settings.coin_1_top }}px;
  left: {{ section.settings.coin_1_left }}px;
  animation: float 3s ease-in-out infinite;
}

/* Coin 2 - Right Side Middle */
.deco-coin.coin-2 {
  width: {{ section.settings.coin_2_size }}px;
  height: {{ section.settings.coin_2_size }}px;
  top: {{ section.settings.coin_2_top }}px;
  right: {{ section.settings.coin_2_right }}px;
  animation: float 3s ease-in-out infinite 0.5s;
}

.default-coin {
  display: flex;
  align-items: center;
  justify-content: center;
}

.default-coin.coin-1 {
  font-size: {{ section.settings.coin_1_size | times: 0.7 }}px;
}

.default-coin.coin-2 {
  font-size: {{ section.settings.coin_2_size | times: 0.7 }}px;
}

.deco-star {
  position: absolute;
  top: 0px;
  right: 50%;
  transform: translateX(50%);
  {% comment %} color: #60a5fa;
  opacity: 0.8; {% endcomment %}
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8px); }
}

/* Rewards Header */
.rewards-header {
  text-align: center;
  margin-top: 60px;
  margin-bottom: 20px;
}

.rewards-logo {
  max-width: 80px;
  margin-bottom: 10px;
}

.rewards-main-title {
  margin-top: 30px;
  margin-bottom: 50px;
}

.rewards-main-title .title-small {
  display: block;
  font-size: calc(var(--rewards-title-size, 24px) * 0.6);
  font-weight: 400;
  opacity: 0.9;
  color:  #000;
}

.rewards-main-title .title-large {
  display: block;
  font-size: var(--rewards-title-size, 40px);
  font-weight: 500;
  line-height: 1.1;
  color: var(--rewards-title-color, #ffffff);
}

/* Tabs */
.rewards-tabs {
  display: flex;
  gap: 10px;
  justify-content: center;
  margin-bottom: 24px;
}

.tab-btn {
  padding: 10px 24px;
  border-radius: 12px;
  border: none;
  font-size: 16px;
  font-weight: 400;
  cursor: pointer;
  transition: all 0.3s ease;
  background-color: rgba(255, 255, 255, 0.2);
  color: #ffffff;
}

.tab-btn.active {
  background-color: #ffffff;
  color: #1e5799;
  font-weight: 700;
}

.tab-btn:hover:not(.active) {
  background-color: rgba(255, 255, 255, 0.3);
}

/* Rewards Content - Tab Panels */
.rewards-content {
  flex: 1;
}

.tab-panel {
  display: none;
}

.tab-panel.active {
  display: block;
}

.rewards-subtitle {
  font-size: var(--rewards-subtitle-size, 24px);
  font-weight: 700;
  color: var(--rewards-subtitle-color, #ffffff);
  margin: 0 0 12px;
  text-align: center;
}

.rewards-description {
  font-size: var(--rewards-text-size, 14px);
  color: var(--rewards-text-color, #e0e7ff);
  text-align: center;
  margin: 0 0 24px;
  line-height: 1.6;
  padding:0 8%;
}

/* Benefits List */
.rewards-benefits {
  list-style: none;
  padding: 0 15%;
  margin: 0 0 24px;
}

.benefit-item {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  margin-bottom: 12px;
  font-size: var(--rewards-text-size, 14px);
  color: var(--rewards-text-color, #e0e7ff);
  line-height: 1.4;
}

.benefit-item .check-icon {
  flex-shrink: 0;
  color: #ffffff;
  margin-top: 2px;
}

/* CTA Button */
.rewards-btn-wrapper {
  margin-top: auto;
}

.rewards-btn-panel {
  display: none;
}

.rewards-btn-panel.active {
  display: block;
}

.rewards-btn {
  display: block;
  width: 100%;
  padding: 16px 24px;
  background-color: var(--rewards-btn-bg, #ffffff);
  color: var(--rewards-btn-color, #1e5799);
  text-align: center;
  text-decoration: none;
  font-weight: 500;
  font-size: 14px;
  border-radius: 12px;
  transition: all 0.3s ease;
}

.rewards-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(0, 0, 0, 0.2);
}

/* ==========================================================================
   Content Columns (Middle + Right)
   ========================================================================== */
.content-columns {
  display: flex;
  flex-direction: column;
  gap: 20px;
  background-color: var(--section-bg-color);
  padding: 20px;
  border-radius: 20px;
}

/* Top Row - Promo + Blog Intro */
.content-top-row {
  display: grid;
  grid-template-columns: 1.5fr 1fr;
  gap: 20px;
}

/* Promo Card */
#shopify-section-{{ section.id }} .promo-card {
  background-color: var(--promo-bg-color, #ffffff);
  border-radius: 12px;
  padding: 28px;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 0px;
}

.promo-content {
  flex: 1;
}

.promo-title {
  font-size: var(--promo-title-size, 24px);
  font-weight: 500;
  color: var(--promo-title-color, #000000);
  margin: 0 0 12px;
  line-height: 1.3;
}

.promo-text {
  font-size: var(--promo-text-size, 14px);
  color: var(--promo-text-color, #666666);
  margin: 0 0 16px;
  line-height: 1.6;
}

.promo-link {
  font-size: 14px;
  font-weight: 400;
  color: var(--promo-link-color, #0066cc);
  text-decoration: none;
  transition: color 0.3s ease;
}

.promo-link:hover {
  text-decoration: underline;
}

.promo-image {
  flex-shrink: 0;
  height: 100%;
  display: flex;
  align-items: flex-end;
}

.promo-image img {
  max-width: 100px;
  height: auto;
}

/* Blog Intro Card */
.blog-intro-card {
  background-color: var(--blog-intro-bg, #ffffff);
  border-radius: 12px;
  padding: 28px;
}

.blog-intro-title {
  font-size: var(--blog-intro-title-size, 20px);
  font-weight: 500;
  color: var(--blog-intro-title-color, #000000);
  margin: 0 0 12px;
  line-height: 1.3;
}

.blog-intro-text {
  font-size: var(--blog-intro-text-size, 14px);
  color: var(--blog-intro-text-color, #666666);
  margin: 0 0 25px;
  line-height: 1.6;
}

.blog-intro-link {
  font-size: 14px;
  font-weight: 400;
  color: var(--blog-intro-link-color, #0066cc);
  text-decoration: underline;
  transition: color 0.3s ease;
}

.blog-intro-link:hover {
  text-decoration: underline;
}
.middle-bordr {
    display: block;
    width: max-content;
    height: 100%;
}

.middle-bordr:after {
    content: "";
    width: 2px;
    height: 50%;
    background: #5080c5;
    display: block;
    vertical-align: middle;
    margin: auto;
}

/* ==========================================================================
   Bottom Row - Tips/Blog Section
   ========================================================================== */
.content-bottom-row {
  background-color: #ffffff;
  border-radius: 12px;
  padding: 24px;
}

.tips-title {
  font-size: var(--tips-title-size, 18px);
  font-weight: 500;
  color: var(--tips-title-color, #000000);
  margin: 0 0 20px;
}

/* Blog Posts Grid */
.blog-posts-grid.desktop-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
}

.blog-posts-mobile-slider {
  display: none;
}

/* Blog Post Card */
.blog-post-card {
  text-decoration: none;
  display: block;
  transition: transform 0.3s ease;
}

{% comment %} .blog-post-card:hover {
  transform: translateY(-4px);
} {% endcomment %}

.post-image {
  aspect-ratio: 6/4;
  border-radius: 10px;
  overflow: hidden;
  margin-bottom: 12px;
  background-color: #f5f5f5;
}

.post-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s ease;
}
.blog-post-card:hover .post-title {
  text-decoration: underline;
}

{% comment %} .blog-post-card:hover .post-image img {
  transform: scale(1.05);
} {% endcomment %}

.post-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #e0e0e0;
}

.post-placeholder svg {
  width: 40%;
  height: 40%;
  opacity: 0.4;
}

.post-title {
  font-size: var(--blog-card-title-size, 14px);
  color: var(--blog-card-title-color, #333333);
  margin: 0;
  line-height: 1.5;
  font-weight: 400;
}

/* ==========================================================================
   Mobile Slider Styles
   ========================================================================== */
.blog-posts-mobile-slider .swiper {
  width: 100%;
  padding-bottom: 40px;
}

.blog-posts-mobile-slider .swiper-slide {
  height: auto;
}

.blog-posts-mobile-slider .swiper-pagination {
  bottom: 0 !important;
}

.blog-posts-mobile-slider .swiper-pagination-bullet {
  width: 8px;
  height: 8px;
  background: #ccc;
  opacity: 1;
}

.blog-posts-mobile-slider .swiper-pagination-bullet-active {
  background: #000;
  width: 24px;
  border-radius: 4px;
}

{% if section.settings.hide_reward_box %}
  .rewards-card-column {
    display: none !important;
  }
  .content-columns {
    grid-column: span 2 !important;
  }
{% endif %}  


/* ==========================================================================
   Responsive Styles
   ========================================================================== */

/* Large Desktop */
@media (min-width: 1200px) {
  .rewards-content-grid {
    gap: 30px;
  }
  .rewards-description {
  line-height: normal;
}
.rewards-benefits {
  padding: 0 12%;
}
  .content-top-row {
    gap: 24px;
  }
  
  .blog-posts-grid.desktop-grid {
    gap: 24px;
  }
}

/* Medium Desktop */
@media (max-width: 1199px) and (min-width: 992px) {
  .rewards-content-grid {
    grid-template-columns: 380px 1fr;
    gap: 20px;
  }
  
  .rewards-card {
    padding: 24px 20px;
  }
  
  .content-top-row {
    grid-template-columns: 1fr !important;
  }
  
  .promo-image img {
    max-width: 100px;
  }
}

/* Tablet Landscape */
@media (max-width: 991px) and (min-width: 769px) {
  .rewards-content-grid {
    grid-template-columns: 320px 1fr;
    gap: 16px;
  }
  
  .rewards-card {
    padding: 20px 20px;
    min-height: 450px;
  }
  
  .rewards-main-title .title-large {
    font-size: 32px;
  }
  
  .content-top-row {
    grid-template-columns: 1fr;
    gap: 16px;
  }
  
  #shopify-section-{{ section.id }} .promo-card {
    padding: 24px;
  }
  
  .blog-intro-card {
    padding: 24px;
  }
  
  .blog-posts-grid.desktop-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }
}
  a.promo-link.mobile-link {
    display: none !important;
  }
/* Tablet Portrait */
@media (max-width: 768px) {
  .rewards-content-grid {
    grid-template-columns: 1fr;
    gap: 20px;
  }
  .rewards-description {
    max-width: 90%;
    margin: 0 auto 24px;
    padding: 0;
  }
  .rewards-benefits {
    padding: 0 10%;
  }
  .content-columns {
    border-radius: 12px;
  }
  
  .rewards-card-column {
    position: relative;
    top: 0;
  }
  
  .rewards-card {
    min-height: auto;
    padding: 28px 24px;
  }
  
  .rewards-main-title .title-small {
    font-size: 18px;
  }
  
  .rewards-main-title .title-large {
    font-size: var(--rewards-title-size-mobile, 32px);
  }
  
  .content-top-row {
    grid-template-columns: 1fr;
    gap: 16px;
  }
  
  {% comment %} .promo-card {
    flex-direction: column;
    text-align: center;
  } {% endcomment %}
  
  {% comment %} .promo-image {
    order: -1;
  } {% endcomment %}
  
  .promo-title {
    font-size: var(--promo-title-size-mobile, 20px);
  }
  
  .blog-intro-card {
    padding: 24px;
  }
  
  .content-bottom-row {
    padding: 20px;
    {% comment %} display: none; {% endcomment %}
  }
  
  .tips-title {
    font-size: var(--tips-title-size-mobile, 16px);
  }
  
  .blog-posts-grid.desktop-grid {
    {% comment %} display: none; {% endcomment %}
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }
  
  .blog-posts-mobile-slider {
    display: block;
  }
  
  .post-title {
    font-size: var(--blog-card-title-size-mobile, 13px);
  }
  
  /* Mobile coin adjustments */
  .deco-coin.coin-1 {
    width: {{ section.settings.coin_1_size | times: 0.7 }}px;
    height: {{ section.settings.coin_1_size | times: 0.7 }}px;
  }
  
  .deco-coin.coin-2 {
    width: {{ section.settings.coin_2_size | times: 0.7 }}px;
    height: {{ section.settings.coin_2_size | times: 0.7 }}px;
    top: 100px;
    right: -35px;
  }
  
  .promo-image {
    height: max-content;
    justify-content: space-between;
    width: auto;
    align-items: center;
  }
}
@media (min-width: 500px) and (max-width: 768px) {
  .rewards-card-bg img {
    object-position: 100% 36%;
  }
  .deco-coin.coin-1 {
    width: 80px;
    height: 80px;
  }
  .deco-coin.coin-2 {
    width: 120px;
    height: 120px;
    right: 0px;
  }
  .rewards-description {
    max-width: 60%;
  }
  .rewards-benefits {
    padding: 0px 23%;
  }
  .rewards-main-title .title-large {
    font-size: 42px;
  }
}

/* Small Mobile */
@media (max-width: 500px) {
  .rewards-card {
    padding: 24px 20px;
  }
  
  .rewards-header {
    margin-top: 50px;
  }
  
  .deco-coin.coin-1 {
    width: {{ section.settings.coin_1_size | times: 0.9 }}px;
    height: {{ section.settings.coin_1_size | times: 0.9 }}px;
  }
  
  .deco-coin.coin-2 {
    width: {{ section.settings.coin_2_size | times: 1 }}px;
    height: {{ section.settings.coin_2_size | times: 1 }}px;
  }
  
  .default-coin.coin-1 {
    font-size: {{ section.settings.coin_1_size | times: 0.4 }}px;
  }
  
  .default-coin.coin-2 {
    font-size: {{ section.settings.coin_2_size | times: 0.4 }}px;
  }
  
  .rewards-tabs {
    gap: 8px;
  }
  
  .tab-btn {
    padding: 8px 18px;
    font-size: 13px;
  }
  
  .rewards-subtitle {
    font-size: 24px;
  }
  
  .rewards-btn {
    padding: 17px 20px;
    font-size: 13px;
  }
  
  #shopify-section-{{ section.id }} .promo-card,
  .blog-intro-card {
    padding: 20px;
    flex-direction: column;
  }
  .promo-image {width:100%;}
  
  .content-bottom-row {
    padding: 16px;
  }
  .promo-card a.promo-link {
    display: none;
  }
  a.promo-link.mobile-link {
    display: block !important;
    margin-top: 50px;
  }
}

/* ==========================================================================
   Accessibility
   ========================================================================== */
{% comment %} .tab-btn:focus {
  outline: 2px solid #fff;
  outline-offset: 2px;
} {% endcomment %}

.rewards-btn:focus,
.promo-link:focus,
.blog-intro-link:focus,
.blog-post-card:focus {
  outline: 2px solid #0066cc;
  outline-offset: 2px;
}

/* Reduced Motion */
@media (prefers-reduced-motion: reduce) {
  .deco-coin {
    animation: none;
  }
  
  .rewards-btn,
  .blog-post-card,
  .tab-btn,
  .post-image img {
    transition: none;
  }
  
  .rewards-btn:hover,
  .blog-post-card:hover {
    transform: none;
  }
}

/* ==========================================================================
   Print Styles
   ========================================================================== */
@media print {
  .rewards-content-grid {
    display: block;
  }
  
  .rewards-card {
    page-break-inside: avoid;
  }
  
  .blog-posts-mobile-slider {
    display: none;
  }
  
  .blog-posts-grid.desktop-grid {
    display: grid !important;
  }
}

/* ==========================================================================
   High Contrast Mode
   ========================================================================== */
@media (forced-colors: active) {
  .rewards-card {
    border: 2px solid currentColor;
  }
  
  .tab-btn {
    border: 1px solid currentColor;
  }
  
  #shopify-section-{{ section.id }} .promo-card,
  .blog-intro-card,
  .content-bottom-row {
    border: 1px solid currentColor;
  }
}


</style>

