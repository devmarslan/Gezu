  "tag": "section",
  "class": "promo-banner-section",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "image_picker",
      "id": "cont_bgimg",
      "label": "Content Background Image"
    },
    {
      "type": "image_picker",
      "id": "cont_bgimg_mbl",
      "label": "Content Mobile Background Image"
    },
    {
      "type": "text",
      "id": "heading_before_highlight",
      "label": "Heading (before highlight)",
      "default": "Shop new limited time"
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Heading (highlighted text)",
      "default": "20% OFF"
    },
    {
      "type": "text",
      "id": "heading_after_highlight",
      "label": "Heading (after highlight)",
