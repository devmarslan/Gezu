{%- if template == 'product.only_config' and request.design_mode == false -%}
  <hdt-lazy-modal color-scheme="{{ section.settings.color_scheme }}" section-id="{{ section.id }}" class="hdt-contents" effect="slide">
    <dialog id="hdt-quick-view-modal" class="hdt-dialog hdt-dialog-modal hdt-quick-view-modal hdt-s-gradient" scroll-lock>
      <button ref="closeButton" class="hdt-s-text hdt-dialog-btn__close" aria-controls="hdt-quick-view-modal" aria-label="{{ 'accessibility.close' | t | escape }}">{%- render 'icon' with 'close' -%}</button>
      <div class="hdt-dialog-modal__inner hdt-current-scrollbar"></div>
    </dialog>
  </hdt-lazy-modal>
{%- else -%}
  {%- if template == 'product.only_config' -%}
    <hdt-modal un-detect color-scheme="{{ section.settings.color_scheme }}" section-id="{{ section.id }}" class="hdt-contents" effect="slide">
      <dialog id="hdt-quick-view-modal" class="hdt-dialog hdt-dialog-modal hdt-quick-view-modal hdt-s-gradient" scroll-lock>
  {%- endif -%}
  <div class="hdt-s-gradient hdt-main-product-quick-view" color-scheme="{{ section.settings.color_scheme }}">
      <div class="hdt-row-grid hdt-grid-cols-1 md:hdt-grid-cols-2" style="--spacing-x:0px;--spacing-y:0px;">
        {% content_for 'block', type: '_quickview-medias', id: 'quickview-medias' %}
        {% content_for 'blocks' %}
      </div>
  </div>
  {%- if template == 'product.only_config' -%}
    </dialog>
  </hdt-modal>
  <script>
    document.addEventListener('DOMContentLoaded', (event) => {
      if (!Shopify.designMode) return;
      document.addEventListener("shopify:section:select", (event) => {
        const modal = event.target.querySelector('#hdt-quick-view-modal');
        if (modal) modal.parentElement.open();
      });
      document.addEventListener("shopify:section:deselect", (event) => {
        const modal = event.target.querySelector('#hdt-quick-view-modal');
        if (modal) modal.parentElement.close();
      });
    });
  </script>
  {%- endif -%}
{%- endif -%}

<script>
  (function() {
    // Close quick view when cart is updated (product added successfully)
    function closeQuickView() {
      const modal = document.getElementById('hdt-quick-view-modal');
      if (!modal || !modal.hasAttribute('open')) return;
      
      const parentModal = modal.closest('hdt-lazy-modal') || modal.closest('hdt-modal');
      if (parentModal && typeof parentModal.close === 'function') {
        parentModal.close();
      } else {
        modal.close ? modal.close() : modal.removeAttribute('open');
        modal.style.opacity = '';
        modal.style.transform = '';
      }
      // Remove scroll lock
      document.body.classList.remove('hdt-scroll-locked');
      document.documentElement.classList.remove('hdt-scroll-locked');
    }

    // Listen for all common cart update events
    ['cart:updated', 'cart:add', 'ajaxProduct:added', 'cart:item-added', 'theme:cart:update'].forEach(function(evt) {
      document.addEventListener(evt, closeQuickView);
    });

    // Also watch for cart drawer opening via DOM mutation
    var observer = new MutationObserver(function(mutations) {
      mutations.forEach(function(mutation) {
        var target = mutation.target;
        if (target && target.id && (
          target.id.includes('cart') || 
          target.id.includes('Cart') ||
          (target.classList && (target.classList.contains('hdt-cart-drawer') || target.classList.contains('cart-drawer')))
        )) {
          if (target.hasAttribute('open') || target.classList.contains('is-open') || target.classList.contains('active')) {
            closeQuickView();
          }
        }
      });
    });

    observer.observe(document.body, {
      attributes: true,
      attributeFilter: ['open', 'class'],
      subtree: true
    });

    // Fallback: watch the add to cart button click inside quick view
    document.addEventListener('click', function(e) {
      var btn = e.target.closest('#hdt-quick-view-modal .hdt-product-form__submit');
      if (!btn) return;
      
      // Poll for cart drawer to appear, then close quick view
      var attempts = 0;
      var check = setInterval(function() {
        attempts++;
        var cartDrawer = document.querySelector('[id*="cart-drawer"][open], [id*="CartDrawer"][open], .hdt-cart-drawer[open], dialog[open][id*="cart"], dialog[open][id*="Cart"]');
        if (cartDrawer || attempts > 30) {
          clearInterval(check);
          if (cartDrawer) closeQuickView();
        }
      }, 100);
    });
  })();
</script>
{% schema %}
{
  "name": "t:sections.main-quick-view.name",
  "tag": "section",
  "class": "hdt-main-section hdt-main-section--quick-view hdt-quick-view-modal-",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    }
  ],
  "max_blocks": 1,
  "blocks": [
    {
      "type": "_quickview-content"
    },
    {
      "type": "_quickview-medias"
    }
  ]
}
{% endschema %}