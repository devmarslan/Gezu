{%- if template == 'product.only_config' and request.design_mode == false -%}
  <hdt-lazy-modal color-scheme="{{ section.settings.color_scheme }}" section-id="{{ section.id }}" class="hdt-contents" effect="slide">
    <dialog id="hdt-quick-view-modal" class="hdt-dialog hdt-dialog-modal hdt-quick-view-modal hdt-s-gradient" scroll-lock>
      <button ref="closeButton" class="hdt-s-text hdt-dialog-btn__close" aria-controls="hdt-quick-view-modal" aria-label="{{ 'accessibility.close' | t | escape }}">{%- render 'icon' with 'close' -%}</button>
      <div class="hdt-dialog-modal__inner hdt-current-scrollbar"></div>
    </dialog>
  </hdt-lazy-modal>
{%- else -%}
  {%- if template == 'product.only_config' -%}
    <hdt-modal un-detect color-scheme="{{ section.settings.color_scheme }}" section-id="{{ section.id }}" class="hdt-contents" effect="slide">
      <dialog id="hdt-quick-view-modal" class="hdt-dialog hdt-dialog-modal hdt-quick-view-modal hdt-s-gradient" scroll-lock>
  {%- endif -%}
  
  <div class="hdt-s-gradient hdt-main-product-quick-view" color-scheme="{{ section.settings.color_scheme }}">
      <div class="hdt-row-grid hdt-grid-cols-1 md:hdt-grid-cols-2" style="--spacing-x:0px;--spacing-y:0px;">
        {% content_for 'block', type: '_quickview-medias', id: 'quickview-medias' %}
        {% content_for 'blocks' %}
      </div>
  </div>

  {%- if template == 'product.only_config' -%}
      </dialog>
    </hdt-modal>
  {%- endif -%}
{%- endif -%}

<style>
  /* ---- Quick View layout-stability fixes ----
     Strengthen the existing dialog hiding rule by also collapsing the custom-element
     wrappers (hdt-popover / hdt-modal) when they have no open dialog. Without this,
     after a variant change re-renders the info column, these wrappers can briefly
     contribute their default block height to the scroll container, producing the
     "empty space after Add to cart" gap and the extra space at the bottom. */
  .hdt-main-product-quick-view hdt-popover,
  .hdt-main-product-quick-view hdt-modal {
    display: contents;
  }
  /* When the inner dialog is open, the custom element needs to participate in
     layout again so the dialog can use it as its positioning context. */
  .hdt-main-product-quick-view hdt-popover:has(> dialog[open]),
  .hdt-main-product-quick-view hdt-modal:has(> dialog[open]) {
    display: block;
  }
  /* Belt-and-suspenders: ensure the info-list height tracks its content tightly
     so a re-rendered variant section can't leave residual height behind. */
  .hdt-main-product-quick-view .hdt-product-info__list {
    height: auto !important;
    min-height: 0 !important;
  }
</style>
<script>
  // Inject &variant=<id> into the Quick View / Quick Add section-render fetch
  // when the triggering button carries a `variant` attribute. Without this,
  // Shopify renders the section with selected_or_first_available_variant — which
  // can show a different price than the product card (e.g. card shows price_min
  // for products where prices vary across variants).
  (function() {
    if (window.__hdtQVFetchPatched) return;
    window.__hdtQVFetchPatched = true;
    const origFetch = window.fetch.bind(window);
    const productSectionRe = /\/products\/[^/?#]+\?(?:[^#]*&)?section_id=/;
    window.fetch = function(input, init) {
      try {
        const url = typeof input === 'string' ? input : (input && input.url) || '';
        if (productSectionRe.test(url) && !/[?&]variant=/.test(url)) {
          const btn = document.querySelector(
            '[aria-controls="hdt-quick-view-modal"][aria-busy="true"][variant],' +
            '[aria-controls="hdt-quick-add-modal"][aria-busy="true"][variant]'
          );
          const variantId = btn && btn.getAttribute('variant');
          if (variantId) {
            const newUrl = url + '&variant=' + encodeURIComponent(variantId);
            if (typeof input === 'string') return origFetch(newUrl, init);
            return origFetch(new Request(newUrl, input), init);
          }
        }
      } catch (_) { /* fall through to original fetch */ }
      return origFetch(input, init);
    };
  })();
</script>
<script>
  (function() {
    // Reset scroll & force reflow on variant change inside Quick View.
    // - Without scrollTop = 0, the info list keeps its prior scroll position
    //   after the section re-renders, which hides the product title.
    // - Forcing a reflow clears any stale height from popover/modal wrappers
    //   that were open before the re-render.
    if (!window.hdtQVVariantSyncBound) {
      document.addEventListener('variant:change', function(e) {
        const modal = document.getElementById('hdt-quick-view-modal');
        if (!modal) return;
        const isOpen = modal.hasAttribute('open') || modal.open;
        if (!isOpen) return;
        if (!modal.contains(e.target)) return;

        // Wait one frame so the section-render swap finishes before we measure.
        requestAnimationFrame(function() {
          const list = modal.querySelector('.hdt-product-info__list');
          if (!list) return;
          list.scrollTop = 0;
          // Toggle a no-op style to force layout recalculation.
          const prev = list.style.minHeight;
          list.style.minHeight = '0px';
          void list.offsetHeight;
          list.style.minHeight = prev;
        });
      });
      window.hdtQVVariantSyncBound = true;
    }

    // 1. Global Reset Function (Ensures buttons work on every click)
    // We define this on window to keep it consistent across AJAX reloads
    window.hdtResetQuickView = window.hdtResetQuickView || function(e) {
      // If triggered by an event, check if it's the right one.
      // `target.querySelector` only exists on Elements / Documents — guard
      // against non-Element targets (e.g. native `close` event from <select>
      // in some browsers) to avoid "undefined is not a function".
      if (e && e.target) {
        const target = e.target;
        if (target.id !== 'hdt-quick-view-modal') {
          if (typeof target.querySelector !== 'function') return;
          if (!target.querySelector('#hdt-quick-view-modal')) return;
        }
      }

      // Clear loading/open states on all Quickview trigger wrappers site-wide
      document.querySelectorAll('wrapp-hdt-open-modal-btn, .hdt-theme-quick-view-wrapper').forEach(wrapper => {
        ['open', 'loading', 'aria-busy'].forEach(attr => wrapper.removeAttribute(attr));
      });

      // Clear states on the buttons themselves
      document.querySelectorAll('[aria-controls="hdt-quick-view-modal"], .hdt-theme-quick-view-btn').forEach(btn => {
        btn.setAttribute('aria-expanded', 'false');
        btn.removeAttribute('aria-busy');
        btn.classList.remove('loading');
      });

      // Ensure scroll lock is released from both HTML and BODY
      document.documentElement.classList.remove('hdt-scroll-locked', 'overflow-hidden');
      document.body.classList.remove('hdt-scroll-locked', 'overflow-hidden');
    };

    // 2. Clear and Re-attach Listeners to prevent "Double Listener" bugs on AJAX reload
    document.removeEventListener('dialog:close', window.hdtResetQuickView);
    document.addEventListener('dialog:close', window.hdtResetQuickView);

    // Native dialog close listener (handles Escape key and browser-level closing)
    document.removeEventListener('close', window.hdtResetQuickView, true);
    document.addEventListener('close', window.hdtResetQuickView, true);

    // 3. Handle Auto-Close on Cart Events (with stale-event guard)
    if (!window.hdtCartCloseBound) {
      const cartEvents = ['cart:updated', 'cart:add', 'ajaxProduct:added', 'theme:cart:update'];
      cartEvents.forEach(evt => {
        document.addEventListener(evt, () => {
          const modal = document.getElementById('hdt-quick-view-modal');
          if (modal && (modal.hasAttribute('open') || modal.open)) {
            // Skip if modal was just opened — this event is stale from a previous session
            if (window.__hdtQVOpenedAt && (Date.now() - window.__hdtQVOpenedAt) < 2000) return;

            const parent = modal.closest('hdt-lazy-modal, hdt-modal');
            if (parent && typeof parent.close === 'function') {
              parent.close();
            } else {
              modal.removeAttribute('open');
              window.hdtResetQuickView();
            }
          }
        });
      });
      window.hdtCartCloseBound = true;
    }

    // Shopify Design Mode Support
    // Guard `Shopify.designMode` — some apps run scripts before the Shopify
    // global is defined, and a bare property access throws
    // "undefined is not an object" early in page load.
    if (typeof Shopify !== 'undefined' && Shopify.designMode && !window.hdtDesignModeBound) {
      document.addEventListener("shopify:section:select", (event) => {
        const t = event && event.target;
        if (!t || typeof t.querySelector !== 'function') return;
        const modal = t.querySelector('#hdt-quick-view-modal');
        if (modal) {
          const parent = modal.closest('hdt-lazy-modal, hdt-modal');
          if (parent && parent.open) parent.open();
        }
      });
      document.addEventListener("shopify:section:deselect", (event) => {
        const t = event && event.target;
        if (!t || typeof t.querySelector !== 'function') return;
        const modal = t.querySelector('#hdt-quick-view-modal');
        if (modal) {
          const parent = modal.closest('hdt-lazy-modal, hdt-modal');
          if (parent && parent.close) parent.close();
        }
      });
      window.hdtDesignModeBound = true;
    }

  })();
</script>
{% schema %}
{
  "name": "t:sections.main-quick-view.name",
  "tag": "section",
  "class": "hdt-main-section hdt-main-section--quick-view hdt-quick-view-modal-",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    }
  ],
  "max_blocks": 1,
  "blocks": [
    {
      "type": "_quickview-content"
    },
    {
      "type": "_quickview-medias"
    }
  ]
}
{% endschema %}