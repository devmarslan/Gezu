{% comment %}
  FAQ Section
  - Left: Heading, description, contact card
  - Right: Accordion FAQ items
  - Fully responsive
{% endcomment %}

{{ 'section-faq.css' | asset_url | stylesheet_tag }}

<style>
  #faq-section-{{ section.id }} {
    --section-bg-color: {{ section.settings.section_bg_color }};
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --section-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --section-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --heading-color: {{ section.settings.heading_color }};
    --heading-size: {{ section.settings.heading_font_size }}px;
    --heading-size-mobile: {{ section.settings.heading_font_size_mobile }}px;
    --description-color: {{ section.settings.description_color }};
    --description-size: {{ section.settings.description_font_size }}px;
    --description-size-mobile: {{ section.settings.description_font_size_mobile }}px;
    --contact-bg: {{ section.settings.contact_bg_color }};
    --contact-title-color: {{ section.settings.contact_title_color }};
    --contact-title-size: {{ section.settings.contact_title_font_size }}px;
    --contact-text-color: {{ section.settings.contact_text_color }};
    --contact-text-size: {{ section.settings.contact_text_font_size }}px;
    --question-color: {{ section.settings.question_color }};
    --question-size: {{ section.settings.question_font_size }}px;
    --question-size-mobile: {{ section.settings.question_font_size_mobile }}px;
    --answer-color: {{ section.settings.answer_color }};
    --answer-size: {{ section.settings.answer_font_size }}px;
    --answer-size-mobile: {{ section.settings.answer_font_size_mobile }}px;
    --accordion-border-color: {{ section.settings.accordion_border_color }};
    --accordion-icon-color: {{ section.settings.accordion_icon_color }};
  }
  #faq-section-{{ section.id }} .accordion-item:first-child {
    border-top: none !important;
  }
  {% if section.settings.cont_bgcolor != blank %}
  #faq-section-{{ section.id }} .faq-container {
    padding: 50px;
    background: {{ section.settings.cont_bgcolor }};
    border-radius: 12px;
  }
   @media (max-width: 768px) {
    #faq-section-{{ section.id }} .faq-container {
      padding: 30px 15px;
    }
  }
  {% endif %}

  {% if section.settings.faq_cont_bgcolor != blank %}
  #faq-section-{{ section.id }} .faq-accordion-column {
        background: {{ section.settings.faq_cont_bgcolor }};
        padding: 20px 40px;
        border-radius: 12px;
  }
  @media (max-width: 768px) {
    #faq-section-{{ section.id }} .faq-accordion-column {
          padding: 20px;
    }
  }
  {% endif %}

  #faq-section-{{ section.id }} .faq-wrapper {
    padding-top: var(--section-padding-top);
    padding-bottom: var(--section-padding-bottom);
    background-color: var(--section-bg-color);
    {% if section.settings.section_bg_image != blank %}
    background-image: url('{{ section.settings.section_bg_image | image_url: width: 1920 }}');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    {% endif %}
  }
  @media (min-width: 769px) {
    .faq-contact-card.mbl-contact-card {
      display: none;
    }
  }

  @media (max-width: 768px) {
    #faq-section-{{ section.id }} .faq-wrapper {
      padding-top: var(--section-padding-top-mobile);
      padding-bottom: var(--section-padding-bottom-mobile);
    }
    .faq-contact-card.dsk-contact-card {
      display: none;
    }
    .faq-contact-card.mbl-contact-card {
      margin-bottom: -70px;
    }
  }
</style>

<section id="faq-section-{{ section.id }}" class="faq-section">
  <div class="faq-wrapper">
    <div class="hdt-container">
      <div class="faq-container">
        {% comment %} Left Column - Header & Contact {% endcomment %}
        <div class="faq-header-column">
          <div class="faq-header">
            {% if section.settings.heading != blank %}
              <h2 class="faq-heading">{{ section.settings.heading }}</h2>
            {% endif %}
            {% if section.settings.description != blank %}
              <p class="faq-description">{{ section.settings.description }}</p>
            {% endif %}
          </div>

          {% comment %} Contact Card {% endcomment %}
          {% if section.settings.show_contact_card %}
            <div class="faq-contact-card dsk-contact-card">
              {% if section.settings.contact_image != blank %}
                <div class="contact-avatar">
                  <img 
                    src="{{ section.settings.contact_image | image_url: width: 100 }}" 
                    alt="{{ section.settings.contact_title }}"
                    width="50"
                    height="50"
                    loading="lazy"
                  >
                </div>
              {% endif %}
              <div class="contact-content">
                {% if section.settings.contact_title != blank %}
                  <h4 class="contact-title">{{ section.settings.contact_title }}</h4>
                {% endif %}
                {% if section.settings.contact_text != blank %}
                  <p class="contact-text">{{ section.settings.contact_text }}</p>
                {% endif %}
              </div>
            </div>
          {% endif %}
        </div>

        {% comment %} Right Column - Accordion {% endcomment %}
        <div class="faq-accordion-column">
          <div class="faq-accordion">
            {% for block in section.blocks %}
              {% if block.type == 'faq_item' %}
                <div class="accordion-item {% if forloop.first and section.settings.first_open %}active{% endif %}" {{ block.shopify_attributes }}>
                  <button class="accordion-header" aria-expanded="{% if forloop.first and section.settings.first_open %}true{% else %}false{% endif %}">
                    <span class="accordion-question">{{ block.settings.question }}</span>
                    <span class="accordion-icon">
                      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M5 7.5l5 5 5-5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </span>
                  </button>
                  <div class="accordion-content" {% if forloop.first and section.settings.first_open %}style="max-height: 500px;"{% endif %}>
                    <div class="accordion-answer">
                      {{ block.settings.answer }}
                    </div>
                  </div>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
        {% if section.settings.show_contact_card %}
            <div class="faq-contact-card mbl-contact-card">
              {% if section.settings.contact_image != blank %}
                <div class="contact-avatar">
                  <img 
                    src="{{ section.settings.contact_image | image_url: width: 100 }}" 
                    alt="{{ section.settings.contact_title }}"
                    width="50"
                    height="50"
                    loading="lazy"
                  >
                </div>
              {% endif %}
              <div class="contact-content">
                {% if section.settings.contact_title != blank %}
                  <h4 class="contact-title">{{ section.settings.contact_title }}</h4>
                {% endif %}
                {% if section.settings.contact_text != blank %}
                  <p class="contact-text">{{ section.settings.contact_text }}</p>
                {% endif %}
              </div>
            </div>
          {% endif %}
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.getElementById('faq-section-{{ section.id }}');
    const accordionItems = section.querySelectorAll('.accordion-item');
    const allowMultiple = {{ section.settings.allow_multiple }};
    
    accordionItems.forEach(item => {
      const header = item.querySelector('.accordion-header');
      const content = item.querySelector('.accordion-content');
      
      header.addEventListener('click', function() {
        const isActive = item.classList.contains('active');
        
        // Close all if not allowing multiple
        if (!allowMultiple) {
          accordionItems.forEach(otherItem => {
            if (otherItem !== item) {
              otherItem.classList.remove('active');
              otherItem.querySelector('.accordion-header').setAttribute('aria-expanded', 'false');
              otherItem.querySelector('.accordion-content').style.maxHeight = null;
            }
          });
        }
        
        // Toggle current item
        if (isActive) {
          item.classList.remove('active');
          header.setAttribute('aria-expanded', 'false');
          content.style.maxHeight = null;
        } else {
          item.classList.add('active');
          header.setAttribute('aria-expanded', 'true');
          content.style.maxHeight = content.scrollHeight + 'px';
        }
      });
    });
  });
</script>

