{%- liquid
  unless product 
    assign product = section.settings.product
    if product == null
      assign product = null | default: title: "Example product title", price: 1999, compare_at_price: 2500, available: true, vendor: "Ecomus"
    endif
  endunless
-%}

<style>
  .hdt-alt-promo-banner-{{ block.id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.content_gap }}px;
    flex-wrap: wrap;
    {% if block.settings.show_background and block.settings.fultext_background %}
      justify-content: space-between;
    {% else %}
      justify-content: flex-start;
    {% endif %}
    {%- if block.settings.show_background and block.settings.fultext_background %}
      justify-content: space-between;
      background-color: {{ block.settings.bg_color }};
      padding: {{ block.settings.padding_y }}px {{ block.settings.padding_x }}px;
      border-radius: {{ block.settings.border_radius }}px;
    {%- endif %}
    {%- if block.settings.show_border and block.settings.fultext_background %}
      border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    {%- endif %}
  }
  
  {%- if block.settings.hide_prod_info_icotext %}
  @media (min-width:769px){
    #shopify-section-{{ section.id }} .hdt-product-info__list .hdt-product-info__item.hdt-product__alt-promo-banner {
      display: none !important;
    }
  }
  {%- endif %}

  .hdt-product-media-wrapps .hdt-product-info__item.hdt-product__alt-promo-banner {
    margin-top: 30px;
  }
  .hdt-product-media__collapsible-content .hdt-product-accordion__item {
    margin-bottom: 0;
  }

  .hdt-alt-promo-banner-{{ block.id }} .hdt-alt-promo-left {
    display: flex;
    align-items: center;
    gap: {{ block.settings.icon_text_gap }}px;
    flex-wrap: wrap;
    {%- if block.settings.show_background and block.settings.fultext_background == false %}
      background-color: {{ block.settings.bg_color }};
      padding: {{ block.settings.padding_y }}px {{ block.settings.padding_x }}px;
      border-radius: {{ block.settings.border_radius }}px;
    {%- endif %}
    {%- if block.settings.show_border and block.settings.fultext_background == false %}
      border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    {%- endif %}
  }

  .hdt-alt-promo-banner-{{ block.id }} .hdt-alt-promo-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .hdt-alt-promo-banner-{{ block.id }} .hdt-alt-promo-icon img {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
  }

  .hdt-alt-promo-banner-{{ block.id }} .hdt-alt-promo-icon svg {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    stroke: {{ block.settings.icon_color }};
  }

  .hdt-alt-promo-banner-{{ block.id }} .hdt-alt-promo-text {
    color: {{ block.settings.text_color }};
    font-weight: {{ block.settings.text_font_weight }};
    line-height: 1.4;
  }
  

  .hdt-alt-promo-banner-{{ block.id }} .hdt-alt-promo-cta {
    flex-shrink: 0;
  }

  .hdt-alt-promo-banner-{{ block.id }} .hdt-alt-promo-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: {{ block.settings.cta_text_color }};
    font-weight: {{ block.settings.cta_font_weight }};
    font-size: inherit;
    text-decoration: none;
    transition: opacity 0.3s ease;
  }

  .hdt-alt-promo-banner-{{ block.id }} .hdt-alt-promo-cta-btn:hover {
    opacity: 0.8;
  }

  {%- if block.settings.cta_style == 'button' %}
    .hdt-alt-promo-banner-{{ block.id }} .hdt-alt-promo-cta-btn {
      background-color: {{ block.settings.cta_bg_color }};
      padding: {{ block.settings.cta_padding_y }}px {{ block.settings.cta_padding_x }}px;
      border-radius: {{ block.settings.cta_border_radius }}px;
      color: #ffffff;
    }
  {%- elsif block.settings.cta_style == 'outline' %}
    .hdt-alt-promo-banner-{{ block.id }} .hdt-alt-promo-cta-btn {
      background-color: transparent;
      padding: {{ block.settings.cta_padding_y }}px {{ block.settings.cta_padding_x }}px;
      border: 1px solid {{ block.settings.cta_text_color }};
      border-radius: {{ block.settings.cta_border_radius }}px;
    }
  {%- else %}
    .hdt-alt-promo-banner-{{ block.id }} .hdt-alt-promo-cta-btn {
      background-color: transparent;
      text-decoration: underline;
    }
  {%- endif %}

  @media (max-width:768px){
    .hdt-product-media-wrapps .hdt-product-info__item.hdt-product__alt-promo-banner {
      display: none;
    }
  }
</style>

<div class="hdt-product-info__item hdt-product__alt-promo-banner" data-type="{{ block.type }}" {{ block.shopify_attributes }}>

  <div class="hdt-alt-promo-banner-{{ block.id }}">
    
    {%- comment -%} Left Content - Icon + Text {%- endcomment -%}
    <div class="hdt-alt-promo-left">
      
      {%- if block.settings.show_icon -%}
        <div class="hdt-alt-promo-icon">
          {%- if block.settings.custom_icon != blank -%}
            <img 
              src="{{ block.settings.custom_icon | image_url: width: 100 }}" 
              alt="Promo icon" 
              width="{{ block.settings.icon_size }}" 
              height="{{ block.settings.icon_size }}"
              loading="lazy"
            >
          {%- else -%}
            {%- case block.settings.icon_type -%}
              {%- when 'gift' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 12 20 22 4 22 4 12"></polyline>
                  <rect x="2" y="7" width="20" height="5"></rect>
                  <line x1="12" y1="22" x2="12" y2="7"></line>
                  <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"></path>
                  <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"></path>
                </svg>
              {%- when 'percent' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="19" y1="5" x2="5" y2="19"></line>
                  <circle cx="6.5" cy="6.5" r="2.5"></circle>
                  <circle cx="17.5" cy="17.5" r="2.5"></circle>
                </svg>
              {%- when 'tag' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
                  <line x1="7" y1="7" x2="7.01" y2="7"></line>
                </svg>
              {%- when 'star' -%}
                <svg viewBox="0 0 24 24" fill="{{ block.settings.icon_color }}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                </svg>
              {%- when 'truck' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="1" y="3" width="15" height="13"></rect>
                  <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
                  <circle cx="5.5" cy="18.5" r="2.5"></circle>
                  <circle cx="18.5" cy="18.5" r="2.5"></circle>
                </svg>
              {%- when 'shield' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                  <polyline points="9 12 11 14 15 10"></polyline>
                </svg>
              {%- when 'coin' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"></circle>
                  <path d="M12 6v12"></path>
                  <path d="M15 9.5c0-1.38-1.34-2.5-3-2.5s-3 1.12-3 2.5 1.34 2.5 3 2.5 3 1.12 3 2.5-1.34 2.5-3 2.5"></path>
                </svg>
              {%- else -%}
                <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 12 20 22 4 22 4 12"></polyline>
                  <rect x="2" y="7" width="20" height="5"></rect>
                  <line x1="12" y1="22" x2="12" y2="7"></line>
                  <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"></path>
                  <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"></path>
                </svg>
            {%- endcase -%}
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if block.settings.promo_text != blank -%}
        <div class="hdt-alt-promo-text hdt-{{ block.settings.text_font_size }}">
          {{ block.settings.promo_text }}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} Right Content - CTA Button {%- endcomment -%}
    {%- if block.settings.show_cta and block.settings.cta_text != blank -%}
      <div class="hdt-alt-promo-cta">
        <a href="{{ block.settings.cta_link }}" class="hdt-alt-promo-cta-btn">
          {{ block.settings.cta_text }}
          {%- if block.settings.show_cta_arrow -%}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          {%- endif -%}
        </a>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Product Link Text 2",
  "tag": null,
  "settings": [
    {
      "type": "checkbox",
      "id": "hide_prod_info_icotext",
      "label": "Hide Product Info IconText(desktop)",
      "default": false
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "richtext",
      "id": "promo_text",
      "label": "Promo Text",
      "default": "<p>Earn atleast <strong>2% points</strong> on purchase and <strong>Save upto 15%</strong></p>"
    },
    {
      "type": "header",
      "content": "Icon Settings"
    },
    {
      "type": "checkbox",
      "id": "show_icon",
      "label": "Show Icon",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "custom_icon",
      "label": "Custom Icon Image",
      "info": "Leave empty to use built-in icons"
    },
    {
      "type": "select",
      "id": "icon_type",
      "label": "Built-in Icon",
      "options": [
        { "value": "gift", "label": "Gift" },
        { "value": "percent", "label": "Percent" },
        { "value": "tag", "label": "Tag" },
        { "value": "star", "label": "Star" },
        { "value": "truck", "label": "Truck / Shipping" },
        { "value": "shield", "label": "Shield / Guarantee" },
        { "value": "coin", "label": "Coin / Money" }
      ],
      "default": "gift",
      "info": "Used when no custom icon is uploaded"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon Size",
      "min": 14,
      "max": 40,
      "step": 1,
      "default": 20,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon Color",
      "default": "#666666"
    },
    {
      "type": "header",
      "content": "Text Styling"
    },
    {
      "type": "select",
      "id": "text_font_size",
      "label": "Text Font Size",
      "options": [
        { "value": "text-xs", "label": "Extra Small" },
        { "value": "text-sm", "label": "Small" },
        { "value": "base", "label": "Base" },
        { "value": "text-lg", "label": "Large" },
        { "value": "h6", "label": "H6" },
        { "value": "h5", "label": "H5" }
      ],
      "default": "text-sm"
    },
    {
      "type": "select",
      "id": "text_font_weight",
      "label": "Text Font Weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "400"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#333333"
    },
    {
      "type": "header",
      "content": "CTA Button"
    },
    {
      "type": "checkbox",
      "id": "show_cta",
      "label": "Show CTA Button",
      "default": true
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Text",
      "default": "Claim free membership"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Link"
    },
    {
      "type": "select",
      "id": "cta_style",
      "label": "CTA Style",
      "options": [
        { "value": "link", "label": "Link (Underlined)" },
        { "value": "button", "label": "Button (Filled)" },
        { "value": "outline", "label": "Button (Outline)" }
      ],
      "default": "link"
    },
    {
      "type": "checkbox",
      "id": "show_cta_arrow",
      "label": "Show Arrow Icon",
      "default": true
    },
    {
      "type": "color",
      "id": "cta_text_color",
      "label": "CTA Text Color",
      "default": "#E07B5B"
    },
    {
      "type": "color",
      "id": "cta_bg_color",
      "label": "CTA Background Color",
      "default": "#E07B5B",
      "info": "Only applies to filled button style"
    },
    {
      "type": "select",
      "id": "cta_font_weight",
      "label": "CTA Font Weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "500"
    },
    {
      "type": "range",
      "id": "cta_padding_x",
      "label": "CTA Horizontal Padding",
      "min": 0,
      "max": 30,
      "step": 1,
      "default": 12,
      "unit": "px",
      "info": "Only applies to button styles"
    },
    {
      "type": "range",
      "id": "cta_padding_y",
      "label": "CTA Vertical Padding",
      "min": 0,
      "max": 20,
      "step": 1,
      "default": 6,
      "unit": "px",
      "info": "Only applies to button styles"
    },
    {
      "type": "range",
      "id": "cta_border_radius",
      "label": "CTA Border Radius",
      "min": 0,
      "max": 20,
      "step": 1,
      "default": 4,
      "unit": "px",
      "info": "Only applies to button styles"
    },
    {
      "type": "header",
      "content": "Banner Background & Border"
    },
    {
      "type": "checkbox",
      "id": "show_background",
      "label": "Show Background",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "fultext_background",
      "label": "Show Full Background",
      "default": false
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F9F9F9"
    },
    {
      "type": "range",
      "id": "padding_x",
      "label": "Horizontal Padding",
      "min": 0,
      "max": 40,
      "step": 1,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Vertical Padding",
      "min": 0,
      "max": 30,
      "step": 1,
      "default": 12,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border Radius",
      "min": 0,
      "max": 20,
      "step": 1,
      "default": 8,
      "unit": "px"
    },
    {
      "type": "checkbox",
      "id": "show_border",
      "label": "Show Border",
      "default": true
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border Color",
      "default": "#E5E5E5"
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "Border Width",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 1,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "content_gap",
      "label": "Gap Between Content & CTA",
      "min": 0,
      "max": 40,
      "step": 1,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "icon_text_gap",
      "label": "Gap Between Icon & Text",
      "min": 0,
      "max": 20,
      "step": 1,
      "default": 10,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Product Link Text 2"
    }
  ]
}
{% endschema %}
