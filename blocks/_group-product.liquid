{{ 'hdt-product-tabs.css' | asset_url | stylesheet_tag }}
{%- style -%}
.hdt-group-product-block{z-index:2}

@media (min-width: 768px) {.hdt-group-product-block{position: sticky;top: 3rem;} }
{%- endstyle -%}
<div class="hdt-group-product-block hdt-s-gradient hdt-relative" {{ block.shopify_attributes }}>
  <div id="product-zoom-{{ section.id }}" class="hdt-produc-zoom--wrapp hdt-w-full"></div>
  <div id="product-info-{{ section.id }}" class="hdt-product-info__list hdt-w-full">
    {% content_for "blocks" %}
  </div>
</div>
<style>
  @media(min-width:769px){
    #shopify-section-{{ section.id }} .hdt-product-form__buttons .hdt-product-form-buttons .hdt-product-form__btn-wishlist,
    #shopify-section-{{ section.id }} .hdt-product-form__buttons .hdt-product-form-buttons .hdt-product-form__btn-compare {display:flex !important;}
  }
  #shopify-section-{{ section.id }} .hdt-product-form__buttons .hdt-product-form-buttons .hdt-product-form__btn-wishlist {
    position: absolute;
    top: 1%;
    right: 0;
    display: flex;
    border-radius: 50% !important;
  }
  #shopify-section-{{ section.id }} .hdt-product-form__buttons .hdt-product-form-buttons .hdt-product-form__btn-wishlist:hover{background: #0047ab;border-color:#0047ab;}

  #shopify-section-{{ section.id }} .hdt-product-form__buttons .hdt-product-form-buttons .hdt-product-form__btn-compare {
    position: absolute;
    top: 75px;
    right: 0;
    display: flex;
    border-radius: 50% !important;
  }
  #shopify-section-{{ section.id }} .hdt-product-form__buttons .hdt-product-form-buttons .hdt-product-form__btn-compare svg{color: #fff !important;}
  #shopify-section-{{ section.id }} .hdt-product-form__buttons .hdt-product-form-buttons .hdt-product-form__btn-compare[action="added"] {  background: #0047ab;border-color:#0047ab; }
</style>
