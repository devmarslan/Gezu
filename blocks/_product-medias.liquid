{% liquid
  unless product
    assign product = section.settings.product
  endunless
  assign un_no_pick = true
  if settings.pick_mode == 'no' and product.variants.size > 1
    assign selected_variant = product.selected_variant
    unless selected_variant
      assign un_no_pick = false
    endunless
  elsif settings.pick_mode == 'first' and settings.hide_sold_out == false
    assign selected_variant = product.selected_variant | default: product.variants.first
  else
    assign selected_variant = product.selected_or_first_available_variant
  endif
  assign product_form_id = 'product-form-' | append: section.id | append: product.id
  assign selected_variant_featured_media = selected_variant.featured_media
  assign group_media_obj = product.metafields.theme.group_media_obj.value
  assign variant_images = product.images | where: 'attached_to_variant?', true | map: 'src'
  assign desktop_media_layout = block.settings.desktop_media_layout
  assign mobile_media_layout = block.settings.mobile_media_layout
  if product.media.size < 1
    assign desktop_media_layout = 'no_media_size'
  elsif product.media.size == 1
    assign desktop_media_layout = 'one_media_size'
  endif
  if section.settings.image != blank
    assign desktop_media_layout = 'no_media_size'
  endif
  assign models = product.media | where: 'media_type', 'model'
  assign first_3d_model = models | first

  comment
    360 SPIN CONFIGURATION
  endcomment
  assign enable_360_spin = block.settings.enable_360_spin
  assign spin_image_count = 12
  assign spin_sensitivity = 5
%}

{% style %}
  .hdt-group-block--{{ block.id }} {
    {%- capture width -%}
    --width-group: {{ block.settings.width }}%; --width-group-md: {{ block.settings.width_md }}%; --width-group-lg: {{ block.settings.width_lg }}%;
    {%- endcapture -%}
    {{ width | replace: ' 8%', '8.33333333%' | replace: ' 16%', '16.66666667%' | replace: ' 33%', '33.33333333%' | replace: ' 41%', '41.66666667%' | replace: ' 58%', '58.33333333%' | replace: ' 66%', '66.66666667%' | replace: ' 83%', '83.33333333%' | replace: ' 91%', '91.66666667%' }}
    --padding-group:0px; --padding-group-md: 0px; --padding-group-lg: 0px;
    --space-group: 0px; --space-group-md: 0px; --space-group-lg: 0px;
  }
{% endstyle %}

{%- comment -%} 360 SPIN STYLES {%- endcomment -%}
{% if enable_360_spin and product.images.size >= 2 %}
  <style>
    /* 360 Thumbnail Styles */
    .spin360-thumb-slide {
      position: relative !important;
      cursor: pointer !important;
    }
    .spin360-thumb-slide .spin360-thumb-inner {
      position: relative;
      width: 100%;
      height: 100%;
      background: rgba(248, 248, 248, 1);
      border-radius: 12px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 6px;
      aspect-ratio: 1;
    }
    .spin360-thumb-slide .spin360-thumb-icon {
      width: 85%;
      height: 85%;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      {% comment %} animation: spin360pulse 2s ease-in-out infinite; {% endcomment %}
    }
    .spin360-thumb-slide .spin360-thumb-icon svg {
      width: 100%;
      height: 100%;
      color: #fff;
    }
    .spin360-thumb-slide .spin360-thumb-text {
      font-size: 11px;
      font-weight: 700;
      color: #0047AB;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    @keyframes spin360pulse {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.08); }
    }

    /* 360 Main Slide Styles */
    .spin360-main-slide {
      position: relative !important;
    }
    .spin360-main-slide .spin360-container {
      position: relative;
      width: 100%;
      padding-bottom: 100%;
      background: #fff;
    }
    .spin360-main-slide .spin360-inner {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      cursor: grab;
    }
    .spin360-main-slide .spin360-inner:active,
    .spin360-main-slide .spin360-inner.dragging {
      cursor: grabbing;
    }
    .spin360-main-slide .spin360-image {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      object-fit: contain;
      pointer-events: none;
      user-select: none;
    }
    .spin360-main-slide .spin360-badge {
      position: absolute;
      top: 12px;
      left: 12px;
      background: #0047AB;
      color: #fff;
      font-size: 13px;
      font-weight: 700;
      padding: 10px 16px;
      border-radius: 25px;
      z-index: 10;
      display: flex;
      align-items: center;
      gap: 8px;
      box-shadow: 0 4px 12px rgba(0,71,171,0.3);
    }
    .spin360-main-slide .spin360-badge svg {
      width: 18px;
      height: 18px;
      animation: spin360rotate 3s linear infinite;
    }
    @keyframes spin360rotate {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }
    .spin360-main-slide .spin360-hint {
      position: absolute;
      bottom: 20px;
      left: 50%;
      transform: translateX(-50%);
      background: rgba(0,0,0,0.8);
      color: #fff;
      padding: 10px 20px;
      border-radius: 25px;
      font-size: 13px;
      font-weight: 500;
      z-index: 10;
      display: flex;
      align-items: center;
      gap: 8px;
      transition: opacity 0.3s;
    }
    .spin360-main-slide .spin360-hint.hidden {
      opacity: 0;
      pointer-events: none;
    }
    .spin360-main-slide .spin360-loader {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      background: #fff;
      padding: 16px 28px;
      border-radius: 12px;
      box-shadow: 0 8px 24px rgba(0,0,0,0.15);
      z-index: 20;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 10px;
    }
    .spin360-main-slide .spin360-loader.hidden {
      display: none;
    }
    .spin360-main-slide .spin360-spinner {
      width: 32px;
      height: 32px;
      border: 3px solid #e5e7eb;
      border-top-color: #0047AB;
      border-radius: 50%;
      animation: spin360spin 0.7s linear infinite;
    }
    @keyframes spin360spin {
      to { transform: rotate(360deg); }
    }
    .spin360-main-slide .spin360-progress {
      font-size: 13px;
      font-weight: 600;
      color: #374151;
    }
  </style>
{% endif %}

<div
  class="hdt-product-media-wrapps hdt-group-blockss hdt-s-gradient hdt-group-block--{{ block.id }}"
  {% if block.settings.display_by_block %}
    color-scheme="{{ block.settings.color_scheme }}"
  {% endif %}
  {{ block.shopify_attributes }}
>
  {%- if product != blank -%}
    {%- if block.settings.mobile_prod_top_info -%}
      <div id="prod-media-top-{{ section.id }}" class="hdt-product-mediatop-mbl" style="display:none;">
        {% content_for 'block', type: '_product-title', id: 'mob-product-title' %}
        {% content_for 'block', type: '_product-meta-sku', id: 'mob-product-meta-sku' %}
        {% content_for 'block', type: '_product_review_rating', id: 'mob-product-review-rating' %}

        <div class="areviews_header_stars"></div>

        <div class="whish mbl-compare-topbtn">
          {%- liquid
            render 'btn-wishlist', class: 'hdt-product-form__btn-wishlist hdt-flex hdt-align-center hdt-justify-center hdt-relative hdt-s-text', placement: 'top'
          %}
          {%- liquid
            render 'btn-compare', product_id: product.id, product_handle: product.handle, class: 'hdt-product-form__btn-compare hdt-flex hdt-align-center hdt-justify-center hdt-relative hdt-s-text', placement: 'top'
          %}
        </div>
        {% comment %} <div class="mbl-compare-topbtn">
          {%- liquid
            render 'btn-compare', product_id: product.id, product_handle: product.handle, class: 'hdt-product-form__btn-compare hdt-flex hdt-align-center hdt-justify-center hdt-relative hdt-s-text', placement: 'top'
          %}
        </div> {% endcomment %}
      </div>
      <style>
        .areviews_main_header_container {display: block !important;}

        @media(max-width:767px){
          .hdt-product-mediatop-mbl {
              display: flex !important;
              align-items: flex-start;
              flex-direction: column;
              gap: 0px;
              {% comment %} margin: 5px 0 60px; {% endcomment %}
              padding: 14px 0 0;
              position :relative;
              border-top: 1px solid #ddd;
          }
          .hdt-product-mediatop-mbl .hdt-rating-badge {
              background-color: transparent !important;
              padding: 0 !important;
          }
            .hdt-product-info__list .hdt-product__title,
            .hdt-product-info__list .hdt-sku-wrapper.hdt-product__meta-item,
            .hdt-product-info__list .hdt-product-info__item.hdt-product__rating {display:none;}
          }
          .hdt-product-mediatop-mbl .whish {
              position: absolute;
              right: 0 !important;
          }
          .hdt-product-mediatop-mbl .mbl-compare-topbtn .hdt-product-form__btn-compare {
              margin-top: 10px;
              {% comment %} position: absolute;
              right: 0 !important;
              top: 45px !important; {% endcomment %}
          }
          .hdt-product-mediatop-mbl .hdt-product-form__btn-wishlist,
          .hdt-product-mediatop-mbl .hdt-product-form__btn-compare {
            border-radius: 50% !important;
            min-width: 3.6rem;
            width: 3.6rem;
            height: 3.6rem;
            line-height: 3.6rem;
          }
          .hdt-product-mediatop-mbl .hdt-product-form__btn-wishlist svg {
            width: 14px;
          }
          .hdt-product-mediatop-mbl h1.hdt-product__title.hdt-h5 {
            font-weight: 700;
            max-width:90%;
            margin-bottom: 10px;
          }
          #shopify-section-{{ section.id }} .hdt-product-info__list .hdt-product__buy-button .hdt-product-form__btn-wishlist, 
          #shopify-section-{{ section.id }} .hdt-product-info__list .hdt-product__buy-button .hdt-product-form__btn-compare {
            display:none !important;
          }
          #shopify-section-{{ section.id }} .hdt-product-info__list .areviews_main_header_container{display:none;}

        }
      </style>
    {% endif %}

    {%- capture start_index -%}
    {%- unless group_media_obj.size > 0 %}, "startIndex": {% if block.settings.show_first_media or un_no_pick == false %}0{% else %}{{ selected_variant_featured_media.position | default: 1 | minus: 1 }}{% endif %}{% endunless -%}
    {%- endcapture -%}

    {%- if first_3d_model -%}
      <link
        rel="stylesheet"
        href="https://cdn.shopify.com/shopifycloud/model-viewer-ui/assets/v1.0/model-viewer-ui.css"
        media="print"
        onload="this.media='all'; this.onload = null"
      >
    {%- endif -%}
    <hdt-product-media
      show-thumb
      section-id="{{ section.id }}"
      class="hdt-product-media hdt-product-media__layout-{{ desktop_media_layout }} hdt-product-thumb-size__{{ block.settings.media_size }} hdt-mobile-media-layout--{{ mobile_media_layout }}"
      form="{{ product_form_id }}"
      {% if block.settings.enable_media_autoplay %}
        autoplay-media
      {% endif -%}
      {% if variant_images.size > 0 and product.images.size > 1 and block.settings.use_select_varaint_change_media %}
        update-when-variant-change
      {% endif %}
      image-zoom="{{ block.settings.image_zoom }}"
      max-zoom="{{ block.settings.max_zoom_lightbox }}"
      zoom-options='{"type": "{{ block.settings.image_zoom_type }}","magnify": {{ block.settings.zoom_level }}}'
      {% if group_media_obj.size > 0 %}
        can-has-media-group
      {% endif %}
    >
      {%- case desktop_media_layout -%}
        {%- when 'no_media_size' -%}
          {%- assign image = section.settings.image | default: settings.placeholder_img -%}
          {%- if image != blank -%}
            <div class="hdt-product-media__main hdt-ratio--{{ block.settings.image_ratio }}{% unless block.settings.image_size %} hdt-ratio--contain{% endunless %}">
              <div
                class="hdt-ratio hdt-product__media"
                style="{% if block.settings.image_ratio == 'adapt_image' %}--aspect-ratioapt:{{ image.aspect_ratio }};{% endif %}--mw-media:{{ image.width }}px"
              >
                {{
                  image
                  | image_url: width: image.width
                  | image_tag: widths: '246, 493, 600, 713, 823, 990, 1100, 1206, 1346, 1426, 1646, 1946'
                }}
              </div>
            </div>
          {%- endif -%}

        {%- when 'one_media_size' -%}
          <div class="hdt-product-media__main hdt-ratio--{{ block.settings.image_ratio }}{% unless block.settings.image_size %} hdt-ratio--contain{% endunless %}">
            {%- render 'media',
              media: product.media.first,
              lazy_load: false,
              product: product,
              autoplay: block.settings.enable_media_autoplay,
              loop: block.settings.enable_video_looping
            -%}
          </div>

        {%- when 'thumbnail_bottom', 'thumbnail_left', 'thumbnail_right', 'without_thumbnails' -%}
          <div class="hdt-product-media__main ab">
            <hdt-slider
              id="slider-{{ block.id }}-{{ product.id }}"
              aria-controls="slider-thumb-{{ block.id }}-{{ product.id }}"
              autoheight
              class="hdt-slider hdt-medias-slider hdt-slider-parent hdt-relative hdt-ratio--{{ block.settings.image_ratio }}{% unless block.settings.image_size %} hdt-ratio--contain{% endunless %} {% if block.settings.navUI %} hdt-slider-has-nav hdt-nav-btns-{{ block.settings.nav_des }} hdt-nav-shape_{{ block.settings.nav_shape }} hdt-nav-{{ block.settings.nav_pos }} hdt-nav-{{ block.settings.nav_size }}{% endif %}"
              config='{ "autoHeight": true{{ start_index }}, "slidesToScroll": 1, "watchDrag": "onlyTypeImage", "navUI": true ,"slides": ".hdt-slider__slide:not([hidden])" }'
            >
              <div class="hdt-slider__viewport">
                <div class="hdt-slider__container">
                  {%- comment -%} 360 SPIN MAIN SLIDE {%- endcomment -%}
                  {% if enable_360_spin and product.images.size >= 2 %}
                    <div
                      class="hdt-slider__slide hdt-product__media-item spin360-main-slide"
                      data-media-type="360-spin"
                      data-media-id="spin360-{{ product.id }}"
                    >
                      <div class="spin360-container">
                        <div class="spin360-inner" id="spin360-canvas-{{ product.id }}">
                          <div class="spin360-badge">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                              <circle cx="12" cy="12" r="10"/>
                              <path d="M12 6v6l4 2"/>
                            </svg>
                            360° View
                          </div>
                          <img
                            class="spin360-image"
                            id="spin360-img-{{ product.id }}"
                            src="{{ product.images[0] | image_url: width: 1000 }}"
                            alt="360 View"
                          >
                          <div class="spin360-hint" id="spin360-hint-{{ product.id }}">
                            <svg
                              viewBox="0 0 24 24"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="2"
                              width="16"
                              height="16"
                            >
                              <path d="M5 12h14M5 12l4-4m-4 4l4 4m10-4l-4-4m4 4l-4 4"/>
                            </svg>
                            Drag to rotate
                          </div>
                          <div class="spin360-loader" id="spin360-loader-{{ product.id }}">
                            <div class="spin360-spinner"></div>
                            <span class="spin360-progress" id="spin360-progress-{{ product.id }}">0%</span>
                          </div>
                        </div>
                      </div>
                    </div>
                  {% endif %}

                  {%- liquid
                    for media in product.media
                      assign lazy_load = false
                      if media.position > 1
                        assign lazy_load = true
                      endif
                      render 'media', media: media, selected_variant: selected_variant, un_no_pick: un_no_pick, position: media.position, group_media_obj: group_media_obj, variant_images: variant_images, class: 'hdt-slider__slide', autoplay: block.settings.enable_media_autoplay, loop: block.settings.enable_video_looping, lazy_load: lazy_load, product: product
                    endfor
                  -%}
                </div>
              </div>
              {%- if block.settings.navUI -%}
                <button
                  aria-controls="slider-{{ block.id }}-{{ product.id }}"
                  class="hdt-slider__button hdt-slider-nav hdt-inline-flex hdt-align-center hdt-justify-center hdt-slider__button--prev"
                  type="button"
                  disabled
                  name="previous"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="7" height="11" viewBox="0 0 7 11" fill="none">
                    <path d="M5.5 11L0 5.5L5.5 0L6.47625 0.97625L1.9525 5.5L6.47625 10.0238L5.5 11Z" fill="currentColor"/>
                  </svg>
                </button>
                <button
                  aria-controls="slider-{{ block.id }}-{{ product.id }}"
                  class="hdt-slider__button hdt-slider-nav hdt-inline-flex hdt-align-center hdt-justify-center hdt-slider__button--next"
                  type="button"
                  disabled
                  name="next"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="7" height="11" viewBox="0 0 7 11" fill="none">
                    <path d="M1.5 11L7 5.5L1.5 0L0.52375 0.97625L5.0475 5.5L0.52375 10.0238L1.5 11Z" fill="currentColor"/>
                  </svg>
                </button>
              {%- endif -%}
            </hdt-slider>
            <div id="prod-media-{{ section.id }}" class="hdt-product-media-icotxt">
              {% content_for 'block', type: '_prod-media-icotext', id: 'media-icontext' %}
            </div>
          </div>
          <div class="hdt-product-media__thumb hdt-text-center">
            <hdt-slider-thumb
              {% if block.settings.enable_thumb_efect %}
                stagger
              {% endif %}
              id="slider-thumb-{{ block.id }}-{{ product.id }}"
              aria-controls="slider-{{ block.id }}-{{ product.id }}"
              autoheight
              class="hdt-slider hdt-ratio--{{ block.settings.image_ratio }}{% unless block.settings.image_size %} hdt-ratio--contain{% endunless %} hdt-slides-5 hdt-slide-spacing-10{% if mobile_media_layout != 'thumbnails' %} hdt-hidden lg:hdt-block{% endif %}"
              config='{ "active": {% if mobile_media_layout != 'thumbnails' %}false{% else %}true{% endif %}{{ start_index }}, "autoHeight": false, "classNames": false, "dragFree": false, "slidesToScroll": 1, "align": "center", "axis": "x", "slides": ".hdt-slider__slide:not([hidden])"{% if desktop_media_layout == 'thumbnail_left' or desktop_media_layout == 'thumbnail_right' %}, "breakpoints": { "(min-width: 1150px)": { "active": true, "axis": "y", "watchSlides": false } }{% endif %} }'
            >
              <div class="hdt-slider__viewport">
                <div class="hdt-slider__container">
                  {%- comment -%} 360 SPIN THUMBNAIL {%- endcomment -%}
                  {% if enable_360_spin and product.images.size >= 2 %}
                    <div
                      class="hdt-slider__slide hdt-thumbnail__media spin360-thumb-slide"
                      data-media-type="360-spin"
                      data-media-id="spin360-{{ product.id }}"
                    >
                      <div class="spin360-thumb-inner">
                        <div class="spin360-thumb-icon">
                          <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="73"
                            height="73"
                            viewBox="0 0 73 73"
                            fill="none"
                          >
