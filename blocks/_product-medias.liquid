{%- comment -%} 360 SPIN JAVASCRIPT {%- endcomment -%}
{% if enable_360_spin and product.images.size >= 2 %}
  <script>
    (function() {
      'use strict';

      var PRODUCT_ID = '{{ product.id }}';
      var SENSITIVITY = {{ spin_sensitivity }};
      var IMAGES = [
        {% for image in product.images limit: spin_image_count %}
        "{{ image | image_url: width: 1000 }}"{% unless forloop.last %},{% endunless %}
        {% endfor %}
      ];

      console.log('[360 Spin] Product:', PRODUCT_ID, 'Images:', IMAGES.length);

      var currentFrame = 0;
      var isDragging = false;
      var lastX = 0;
      var velocity = 0;
      var loadedCount = 0;
      var isReady = false;
      var preloaded = [];

      var canvas, spinImg, hint, loader, progress;

      function init() {
        canvas = document.getElementById('spin360-canvas-' + PRODUCT_ID);
        spinImg = document.getElementById('spin360-img-' + PRODUCT_ID);
        hint = document.getElementById('spin360-hint-' + PRODUCT_ID);
        loader = document.getElementById('spin360-loader-' + PRODUCT_ID);
        progress = document.getElementById('spin360-progress-' + PRODUCT_ID);

        if (!canvas || !spinImg) {
          console.log('[360 Spin] Elements not found, retrying...');
          setTimeout(init, 300);
          return;
        }

        console.log('[360 Spin] Initializing...');

        preloadImages();
        setupEvents();

        console.log('[360 Spin] Ready!');
      }

      function preloadImages() {
        IMAGES.forEach(function(url, i) {
          var img = new Image();
          img.onload = function() {
            preloaded[i] = img;
            loadedCount++;

            var pct = Math.round((loadedCount / IMAGES.length) * 100);
            if (progress) progress.textContent = pct + '%';

            if (loadedCount === IMAGES.length) {
              isReady = true;
              if (loader) loader.classList.add('hidden');
              console.log('[360 Spin] All images loaded!');
            }
          };
          img.onerror = function() {
            loadedCount++;
            console.warn('[360 Spin] Failed to load:', url);
          };
          img.src = url;
        });
      }

      function setupEvents() {
        // Mouse events
        canvas.addEventListener('mousedown', function(e) {
          if (!isReady) return;
          isDragging = true;
          lastX = e.clientX;
          velocity = 0;
          canvas.classList.add('dragging');
          if (hint) hint.classList.add('hidden');
          e.preventDefault();
        });

        document.addEventListener('mousemove', function(e) {
          if (!isDragging) return;
          var dx = e.clientX - lastX;
          velocity = dx;
          updateFrame(dx);
          lastX = e.clientX;
        });

        document.addEventListener('mouseup', function() {
          if (!isDragging) return;
          isDragging = false;
          canvas.classList.remove('dragging');
          if (Math.abs(velocity) > 1) inertia();
        });

        // Touch events
        canvas.addEventListener('touchstart', function(e) {
          if (!isReady) return;
          isDragging = true;
          lastX = e.touches[0].clientX;
          velocity = 0;
          canvas.classList.add('dragging');
          if (hint) hint.classList.add('hidden');
        }, {passive: true});

        canvas.addEventListener('touchmove', function(e) {
          if (!isDragging) return;
          var dx = e.touches[0].clientX - lastX;
          velocity = dx;
          updateFrame(dx);
          lastX = e.touches[0].clientX;
        }, {passive: true});

        canvas.addEventListener('touchend', function() {
          if (!isDragging) return;
          isDragging = false;
          canvas.classList.remove('dragging');
          if (Math.abs(velocity) > 1) inertia();
        });
      }

      function updateFrame(delta) {
        var change = Math.round(delta / SENSITIVITY);
        currentFrame = (currentFrame - change + IMAGES.length) % IMAGES.length;

        if (spinImg && IMAGES[currentFrame]) {
          spinImg.src = IMAGES[currentFrame];
        }
      }

      function inertia() {
        if (Math.abs(velocity) < 0.3) return;
        updateFrame(velocity);
        velocity *= 0.9;
        requestAnimationFrame(inertia);
      }

      // Start
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function() {
          setTimeout(init, 200);
        });
      } else {
        setTimeout(init, 200);
      }
    })();
  </script>
{% endif %}
<script>
(function(){
  var lastMediaId = '';
  var sectionId = '{{ section.id }}';

  function sync(){
    var wrapper = document.querySelector('.hdt-group-block--{{ block.id }}');
    if(!wrapper) return;

    var mediaEl = wrapper.querySelector('hdt-product-media.starapps')
                || wrapper.querySelector('hdt-product-media');
    if(!mediaEl) return;

    var mainSlider = mediaEl.querySelector('hdt-slider');
    var thumbSlider = mediaEl.querySelector('hdt-slider-thumb');
    if(!mainSlider || !thumbSlider) return;

    var activeSlide = mainSlider.querySelector('.hdt-slider__slide.is-selected.is-in-view')
                   || mainSlider.querySelector('.hdt-slider__slide.is-selected');
    if(!activeSlide) return;

    var mediaId = activeSlide.getAttribute('data-media-id');
    if(!mediaId || mediaId === lastMediaId) return;
    lastMediaId = mediaId;

    var currentThumb = thumbSlider.querySelector('.is-thumb-selected');
    if(currentThumb && currentThumb.getAttribute('data-media-id') === mediaId) return;

    thumbSlider.querySelectorAll('.is-thumb-selected').forEach(function(t){
      t.classList.remove('is-thumb-selected');
    });

    var match = thumbSlider.querySelector('[data-media-id="'+mediaId+'"]');
    if(match){
      match.classList.add('is-thumb-selected');
    }
  }

  setInterval(sync, 150);
})();
</script>
