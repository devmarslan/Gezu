{%- liquid
  unless product 
    assign product = section.settings.product
    if product == null
      assign product = null | default: title: "Example product title", price: 1999, compare_at_price: 2500, available: true, vendor: "Ecomus"
    endif
  endunless

  # Check metafield first, fallback to block settings
  assign metafield_obj = product.metafields[block.settings.metafield_namespace][block.settings.metafield_key]
  assign features_content = blank
  
  if metafield_obj != blank and metafield_obj.type == 'rich_text_field'
    # Rich text metafields need special handling - capture the rendered output
    capture rendered_metafield
      echo metafield_obj | metafield_tag
    endcapture
    # Extract inner HTML (metafield_tag wraps in a div)
    assign features_content = rendered_metafield | remove: '<div class="metafield-rich_text_field">' | remove: '</div>'
  elsif metafield_obj != blank
    assign features_content = metafield_obj
  endif
  
  if features_content == blank
    assign features_content = block.settings.features_list
  endif

  # Separate description (paragraphs) from list items
  assign has_list = false
  assign description_part = ''
  assign list_part = ''

  if features_content contains '<ul>'
    assign has_list = true
    assign content_split = features_content | split: '<ul>'
    assign description_part = content_split[0]
    assign list_part = content_split[1] | split: '</ul>' | first
  elsif features_content contains '<ol>'
    assign has_list = true
    assign content_split = features_content | split: '<ol>'
    assign description_part = content_split[0]
    assign list_part = content_split[1] | split: '</ol>' | first
  else
    assign description_part = features_content
  endif
-%}

<style>
  .hdt-product-features-{{ block.id }} {
    {%- if block.settings.show_background %}
      background-color: {{ block.settings.bg_color }};
      padding: {{ block.settings.padding_y }}px {{ block.settings.padding_x }}px;
      border-radius: {{ block.settings.border_radius }}px;
    {%- endif %}
    {%- if block.settings.show_border %}
      border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    {%- endif %}
    margin-top: 20px;
  }

  .hdt-product-features-{{ block.id }} .hdt-features-description {
    color: {{ block.settings.description_color }};
    font-weight: {{ block.settings.description_font_weight }};
    line-height: {{ block.settings.description_line_height }};
    margin-bottom: {{ block.settings.description_margin_bottom }}px;
  }

  .hdt-product-features-{{ block.id }} .hdt-features-description p {
    margin: 0;
  }

  .hdt-product-features-{{ block.id }} .hdt-features-list {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.list_gap }}px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .hdt-product-features-{{ block.id }} .hdt-feature-item {
    display: flex;
    align-items: {{ block.settings.icon_vertical_align }};
    gap: {{ block.settings.icon_text_gap }}px;
  }

  .hdt-product-features-{{ block.id }} .hdt-feature-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
  }

  .hdt-product-features-{{ block.id }} .hdt-feature-icon svg {
    width: 100%;
    height: 100%;
  }

  .hdt-product-features-{{ block.id }} .hdt-feature-text {
    color: {{ block.settings.feature_text_color }};
    font-weight: {{ block.settings.feature_font_weight }};
    line-height: 1.4;
  }

  @media screen and (max-width: 768px) {
    .hdt-product-features-{{ block.id }} {
      background-color: transparent;
      padding: 10px 0px;
      border-radius: 0px;
      border: none;
    }
  }
</style>

<div class="hdt-product-info__item hdt-product__features" data-type="{{ block.type }}" {{ block.shopify_attributes }}>
  <div class="hdt-product-features-{{ block.id }}">

    {%- comment -%} Description Part (no tick icons) {%- endcomment -%}
    {%- assign description_stripped = description_part | strip_html | strip -%}
    {%- if description_stripped != blank -%}
      <div class="hdt-features-description hdt-{{ block.settings.description_font_size }}">
        {{ description_part }}
      </div>
    {%- endif -%}

    {%- comment -%} List Items (with tick icons) {%- endcomment -%}
    {%- if has_list and list_part != blank -%}
      {%- assign features_array = list_part | split: '</li>' -%}
      
      <ul class="hdt-features-list">
        {%- for feature in features_array -%}
          {%- assign feature_trimmed = feature | strip_html | strip -%}
          {%- if feature_trimmed != blank -%}
            <li class="hdt-feature-item">
              <span class="hdt-feature-icon">
                {% comment %} <svg viewBox="0 0 24 24" fill="none" stroke="{{ block.settings.icon_color }}" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg> {% endcomment %}
                <svg viewBox="0 0 24 24" fill="{{ block.settings.icon_color }}" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                </svg>
              </span>
              <span class="hdt-feature-text hdt-{{ block.settings.feature_font_size }}">{{ feature_trimmed }}</span>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    {%- endif -%}

  </div>
</div>

