{% liquid
  if article == blank
    continue
  endif
  assign article_id = article.id
  assign reading_speed = block.settings.reading_speed | default: 200
%}

{%- style -%}
  #hdt-article-related-sidebar-{{ block.id }} {
    --sidebar-pt: {{ block.settings.padding_top }}px;
    --sidebar-pb: {{ block.settings.padding_bottom }}px;
  }
  #hdt-article-related-sidebar-{{ block.id }} .hdt-related-sidebar {
    background: var(--color-background);
    border-radius: {{ block.settings.border_radius }}px;
    padding: {{ block.settings.inner_padding }}px;
  }
  #hdt-article-related-sidebar-{{ block.id }} .hdt-related-sidebar__heading {
    font-size: {{ block.settings.heading_size }}px;
    margin-bottom: 20px;
    font-weight: 500;
    color: #000;
    padding-bottom: 15px;
    border-bottom: 1px solid #999;
  }
  #hdt-article-related-sidebar-{{ block.id }} .hdt-related-sidebar__item {
    display: flex;
    gap: 15px;
    padding: 15px 0;
    border-bottom: 1px solid rgba(var(--color-foreground-rgb), 0.1);
  }
  #hdt-article-related-sidebar-{{ block.id }} .hdt-related-sidebar__item:first-child {
    padding-top: 0;
  }
  #hdt-article-related-sidebar-{{ block.id }} .hdt-related-sidebar__item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }
  #hdt-article-related-sidebar-{{ block.id }} .hdt-related-sidebar__thumb {
    flex-shrink: 0;
    width: {{ block.settings.thumb_size }}px;
    height: {{ block.settings.thumb_size }}px;
    border-radius: {{ block.settings.thumb_radius }}px;
    overflow: hidden;
  }
  #hdt-article-related-sidebar-{{ block.id }} .hdt-related-sidebar__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  #hdt-article-related-sidebar-{{ block.id }} .hdt-related-sidebar__thumb:hover img {
    transform: scale(1.05);
  }
  #hdt-article-related-sidebar-{{ block.id }} .hdt-related-sidebar__content {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 5px;
  }
  #hdt-article-related-sidebar-{{ block.id }} .hdt-related-sidebar__title {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 500;
    line-height: 1.3;
    margin: 0;
  }
  #hdt-article-related-sidebar-{{ block.id }} .hdt-related-sidebar__title a {
    color: {{ block.settings.title_color }};
    text-decoration: underline;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  #hdt-article-related-sidebar-{{ block.id }} .hdt-related-sidebar__title a:hover {
    text-decoration: underline;
  }
  #hdt-article-related-sidebar-{{ block.id }} .hdt-related-sidebar__excerpt {
    font-size: {{ block.settings.excerpt_size }}px;
    color: rgba(var(--color-foreground-rgb), 0.7);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0;
  }
  #hdt-article-related-sidebar-{{ block.id }} .hdt-related-sidebar__meta {
    font-size: {{ block.settings.meta_size }}px;
    color: rgba(var(--color-foreground-rgb), 0.5);
  }
  #hdt-article-related-sidebar-{{ block.id }} .hdt-related-sidebar__btn {
    display: block;
    width: 100%;
    margin-top: 20px;
    padding: 14px 20px;
    background: {{ block.settings.button_bg }};
    color: {{ block.settings.button_text }};
    border: none;
    border-radius: {{ block.settings.button_radius }}px;
    font-size: 14px;
    font-weight: 500;
    text-align: center;
    text-decoration: none;
    transition: opacity 0.3s ease;
  }
  #hdt-article-related-sidebar-{{ block.id }} .hdt-related-sidebar__btn:hover {
    opacity: 0.9;
  }
  @media (max-width: 990px) {
    #hdt-article-related-sidebar-{{ block.id }} .hdt-related-sidebar__thumb {
      width: {{ block.settings.thumb_size | times: 0.8 | round }}px;
      height: {{ block.settings.thumb_size | times: 0.8 | round }}px;
    }
  }
{%- endstyle -%}

<div id="hdt-article-related-sidebar-{{ block.id }}" class="hdt-article-related-sidebar" style="padding-top: var(--sidebar-pt); padding-bottom: var(--sidebar-pb);" {{ block.shopify_attributes }}>
  <div class="hdt-related-sidebar" color-scheme="{{ block.settings.color_scheme }}">
    {%- if block.settings.heading != blank -%}
      <h3 class="hdt-related-sidebar__heading">{{ block.settings.heading }}</h3>
    {%- endif -%}

    <div class="hdt-related-sidebar__list">
      {%- assign count = 0 -%}
      {%- for related_article in blog.articles limit: block.settings.limit -%}
        {%- if related_article.id == article_id -%}
          {%- continue -%}
        {%- endif -%}
        {%- assign count = count | plus: 1 -%}
        {%- if count > block.settings.limit -%}
          {%- break -%}
        {%- endif -%}

        {%- comment -%} Calculate read time {%- endcomment -%}
        {%- assign words = related_article.content | strip_html | split: ' ' | size -%}
        {%- assign read_time = words | divided_by: reading_speed -%}
        {%- if read_time < 1 -%}
          {%- assign read_time = 1 -%}
        {%- endif -%}

        <div class="hdt-related-sidebar__item">
          {%- if related_article.image != blank and block.settings.show_image -%}
            <a href="{{ related_article.url }}" class="hdt-related-sidebar__thumb">
              {{ related_article.image | image_url: width: 200 | image_tag: loading: 'lazy', width: 200, height: 200, class: 'hdt-related-sidebar__img' }}
            </a>
          {%- endif -%}

          <div class="hdt-related-sidebar__content">
            <h4 class="hdt-related-sidebar__title">
              <a href="{{ related_article.url }}">{{ related_article.title }}</a>
            </h4>

            {%- if block.settings.show_excerpt -%}
              <p class="hdt-related-sidebar__excerpt">
                {%- if related_article.excerpt.size > 0 -%}
                  {{ related_article.excerpt | strip_html | truncate: 80 }}
                {%- else -%}
                  {{ related_article.content | strip_html | truncate: 80 }}
                {%- endif -%}
              </p>
            {%- endif -%}

            {%- if block.settings.show_read_time -%}
              <span class="hdt-related-sidebar__meta">
                {{ 'blogs.article.article' | t | default: 'Article' }}: {{ read_time }} {{ 'blogs.article.min_read' | t | default: 'min read' }}
              </span>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>

    {%- if block.settings.show_view_more and block.settings.view_more_text != blank -%}
      <a href="{{ blog.url }}" class="hdt-related-sidebar__btn">
        {{ block.settings.view_more_text }}
      </a>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Related Sidebar",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Related Articles"
    },
    {
      "type": "range",
      "id": "limit",
      "min": 1,
      "max": 10,
      "step": 1,
      "label": "Number of articles",
      "default": 3
    },
    {
      "type": "range",
      "id": "reading_speed",
      "min": 100,
      "max": 300,
      "step": 10,
      "label": "Reading speed (words/min)",
      "default": 200,
      "info": "Used to calculate read time"
    },
    {
      "type": "header",
      "content": "Display Options"
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "label": "Show thumbnail",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "label": "Show excerpt",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_read_time",
      "label": "Show read time",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_view_more",
      "label": "Show view more button",
      "default": true
    },
    {
      "type": "text",
      "id": "view_more_text",
      "label": "View more button text",
      "default": "View More Articles"
    },
    {
      "type": "header",
      "content": "Thumbnail Settings"
    },
    {
      "type": "range",
      "id": "thumb_size",
      "min": 60,
      "max": 120,
      "step": 5,
      "unit": "px",
      "label": "Thumbnail size",
      "default": 85
    },
    {
      "type": "range",
      "id": "thumb_radius",
      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Thumbnail border radius",
      "default": 8
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 14,
      "max": 32,
      "step": 1,
      "unit": "px",
      "label": "Heading size",
      "default": 20
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Title size",
      "default": 14
    },
    {
      "type": "range",
      "id": "excerpt_size",
      "min": 11,
      "max": 16,
      "step": 1,
      "unit": "px",
      "label": "Excerpt size",
      "default": 13
    },
    {
      "type": "range",
      "id": "meta_size",
      "min": 10,
      "max": 14,
      "step": 1,
      "unit": "px",
      "label": "Meta text size",
      "default": 12
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title link color",
      "default": "#1a4b8c"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button background",
      "default": "#1a4b8c"
    },
    {
      "type": "color",
      "id": "button_text",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Box Settings"
    },
    {
      "type": "range",
      "id": "inner_padding",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Inner padding",
      "default": 0
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Box border radius",
      "default": 0
    },
    {
      "type": "range",
      "id": "button_radius",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Button border radius",
      "default": 25
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding bottom",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Related Sidebar"
    }
  ]
}
{% endschema %}
