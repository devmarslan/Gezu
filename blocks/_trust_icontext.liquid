<style>
  .hdt-trust-badges {
    background-color: {{ block.settings.bg_color }};
    padding: 14px 20px;
    margin-top: 15px;
    border-radius: 12px;
  }

  .hdt-trust-badges__container {
    display: flex;
    justify-content: space-around;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }

  .hdt-trust-badges__item {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .hdt-trust-badges__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ block.settings.icon_color }};
    width: 22px;
    height: 22px;
    flex-shrink: 0;
  }

  .hdt-trust-badges__icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .hdt-trust-badges__text {
    font-size: 14px;
    font-weight: 500;
    color: {{ block.settings.text_color }};
    letter-spacing: 0.02em;
    white-space: nowrap;
  }
 @media (min-width: 768px) and (max-width: 849px) {
    .hdt-trust-badges__text {
    font-size: 12px !important;
    }
  }
  @media screen and (max-width: 749px) {
    .hdt-trust-badges {
      padding: 20px 15px;
    }
    
    .hdt-trust-badges__container {
      gap: 15px;
      justify-content: space-between;
    }
    .hdt-product-info__list .hdt-trust-badges__container {justify-content: space-around !important;}
    
    .hdt-trust-badges__item {
      gap: 6px;
      flex-direction: column;
      position: relative;
    }

    .hdt-trust-badges__item:not(.hdt-trust-badges__item:last-child):after {
      content: "";
      background: #d1d1d1;
      width: 1px;
      height: 90%;
      position: absolute;
      right: -50%;
      top: 0;
      display: block;
    }
    
    .hdt-trust-badges__icon {
      width: 18px;
      height: 18px;
    }
    
    .hdt-trust-badges__icon svg {
      width: 18px;
      height: 18px;
    }
    
    .hdt-trust-badges__text {
      font-size: 11px;
    }
  }

  @media screen and (max-width: 480px) {
    .hdt-trust-badges__container {
      gap: 10px;
    }
    
    .hdt-trust-badges__icon {
      width: 16px;
      height: 16px;
    }
    
    .hdt-trust-badges__icon svg {
      width: 16px;
      height: 16px;
    }
    
    .hdt-trust-badges__text {
      font-size: 10px;
    }
  }
</style>

{% schema %}
{
  "name": "Trust Icon Text",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Badge 1"
    },
    {
      "type": "image_picker",
      "id": "badge_1_image",
      "label": "Custom image",
      "info": "Upload custom icon (overrides icon selection)"
    },
    {
      "type": "select",
      "id": "badge_1_icon",
      "label": "Or select icon",
      "default": "certified",
      "options": [
        { "value": "certified", "label": "Certified Quality" },
        { "value": "delivery", "label": "Delivery Truck" },
        { "value": "return", "label": "Return Arrow" },
        { "value": "check", "label": "Checkmark" },
        { "value": "shield", "label": "Shield" },
        { "value": "star", "label": "Star" },
        { "value": "heart", "label": "Heart" },
        { "value": "lock", "label": "Lock (Secure)" },
        { "value": "gift", "label": "Gift" }
      ]
    },
    {
      "type": "text",
      "id": "badge_1_text",
      "label": "Text",
      "default": "Certified Quality"
    },
    {
      "type": "header",
      "content": "Badge 2"
    },
    {
      "type": "image_picker",
      "id": "badge_2_image",
      "label": "Custom image",
      "info": "Upload custom icon (overrides icon selection)"
    },
    {
      "type": "select",
      "id": "badge_2_icon",
      "label": "Or select icon",
      "default": "delivery",
      "options": [
        { "value": "certified", "label": "Certified Quality" },
        { "value": "delivery", "label": "Delivery Truck" },
        { "value": "return", "label": "Return Arrow" },
        { "value": "check", "label": "Checkmark" },
