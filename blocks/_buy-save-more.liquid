{%- liquid
  unless product 
    assign product = section.settings.product
    if product == null
      assign product = null | default: title: "Example product title", price: 1999, compare_at_price: 2500, available: true, vendor: "Ecomus"
    endif
  endunless

  assign product_form_id = 'product-form-' | append: section.id | append: product.id

  if settings.pick_mode == 'no' and product.variants.size > 1
    assign selected_variant = product.selected_variant
  elsif settings.pick_mode == 'first' and settings.hide_sold_out == false
    assign selected_variant = product.selected_variant | default: product.variants.first
  else
    assign selected_variant = product.selected_or_first_available_variant
  endif

  assign base_price = selected_variant.price | default: product.price | default: 0
-%}

{%- style -%}
  .hdt-buy-more-save-more-{{ block.id }} {
    background-color: {{ block.settings.section_bg_color }};
    padding: {{ block.settings.section_padding_top }}px {{ block.settings.section_padding_right }}px {{ block.settings.section_padding_bottom }}px {{ block.settings.section_padding_left }}px;
    border-radius: {{ block.settings.section_border_radius }}px;
  }
  .hdt-buy-more-save-more-{{ block.id }} .hdt-bmsm__header {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
    gap: 8px;
  }
  .hdt-buy-more-save-more-{{ block.id }} .hdt-bmsm__title {
    font-size: {{ block.settings.title_font_size_desktop }}px;
    font-weight: {{ block.settings.title_font_weight }};
    color: {{ block.settings.title_color }};
    margin: 0;
    text-transform: {{ block.settings.title_text_transform }};
    letter-spacing: {{ block.settings.title_letter_spacing }}px;
  }
  .hdt-buy-more-save-more-{{ block.id }} .hdt-bmsm__validity {
    font-size: {{ block.settings.validity_font_size_desktop }}px;
    font-weight: {{ block.settings.validity_font_weight }};
    color: {{ block.settings.validity_color }};
    font-style: {{ block.settings.validity_font_style }};
  }
  .hdt-buy-more-save-more-{{ block.id }} .hdt-bmsm__grid {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }
  .hdt-buy-more-save-more-{{ block.id }} .hdt-bmsm__item {
    background-color: {{ block.settings.item_bg_color }};
    border: {{ block.settings.item_border_width }}px solid {{ block.settings.item_border_color }};
    border-radius: {{ block.settings.item_border_radius }}px;
    padding: {{ block.settings.item_padding }}px;
    text-align: center;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  .hdt-buy-more-save-more-{{ block.id }} .hdt-bmsm__item:hover,
  .hdt-buy-more-save-more-{{ block.id }} .hdt-bmsm__item.is-active {
    border-color: {{ block.settings.item_active_border_color }};
    box-shadow: {{ block.settings.item_active_shadow }};
  }
  .hdt-buy-more-save-more-{{ block.id }} .hdt-bmsm__quantity {
    font-size: {{ block.settings.quantity_font_size_desktop }}px;
    font-weight: {{ block.settings.quantity_font_weight }};
    color: {{ block.settings.quantity_color }};
    margin-bottom: 8px;
  }
  .hdt-buy-more-save-more-{{ block.id }} .hdt-bmsm__price {
    margin-bottom: 0px;
    line-height: 1;
  }
  .hdt-buy-more-save-more-{{ block.id }} .hdt-bmsm__price-value {
    font-size: {{ block.settings.price_font_size_desktop }}px;
    font-weight: {{ block.settings.price_font_weight }};
    color: {{ block.settings.price_color }};
  }
  .hdt-buy-more-save-more-{{ block.id }} .hdt-bmsm__vat {
    font-size: {{ block.settings.vat_font_size_desktop }}px;
    color: {{ block.settings.vat_color }};
    margin-bottom: 8px;
  }
  .hdt-buy-more-save-more-{{ block.id }} .hdt-bmsm__savings {
    font-size: {{ block.settings.savings_font_size_desktop }}px;
    font-weight: {{ block.settings.savings_font_weight }};
    color: {{ block.settings.savings_color }};
  }
  @media screen and (max-width: 999px) {
    .hdt-buy-more-save-more-{{ block.id }} .hdt-bmsm__grid {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }
  }
  @media screen and (max-width: 749px) {
    .hdt-buy-more-save-more-{{ block.id }} .hdt-bmsm__header {
      flex-direction: column;
      text-align: center;
    }
    .hdt-buy-more-save-more-{{ block.id }} .hdt-bmsm__title {
      font-size: {{ block.settings.title_font_size_mobile }}px;
    }
    .hdt-buy-more-save-more-{{ block.id }} .hdt-bmsm__validity {
      font-size: {{ block.settings.validity_font_size_mobile }}px;
    }
    .hdt-buy-more-save-more-{{ block.id }} .hdt-bmsm__quantity {
      font-size: {{ block.settings.quantity_font_size_mobile }}px;
    }
    .hdt-buy-more-save-more-{{ block.id }} .hdt-bmsm__price-value {
      font-size: {{ block.settings.price_font_size_mobile }}px;
    }
    .hdt-buy-more-save-more-{{ block.id }} .hdt-bmsm__vat {
      font-size: {{ block.settings.vat_font_size_mobile }}px;
    }
    .hdt-buy-more-save-more-{{ block.id }} .hdt-bmsm__savings {
      font-size: {{ block.settings.savings_font_size_mobile }}px;
    }
  }
{%- endstyle -%}

<div class="hdt-product-info__item hdt-buy-more-save-more-{{ block.id }}" 
     data-type="{{ block.type }}" 
     data-section-id="{{ section.id }}"
     data-product-id="{{ product.id }}"
     data-base-price="{{ base_price }}"
     data-currency-symbol="{{ cart.currency.symbol }}"
     data-form-id="{{ product_form_id }}"
     data-price-display="{{ block.settings.price_display }}"
     data-vat-incl-text="{{ block.settings.vat_text_incl }}"
     data-vat-excl-text="{{ block.settings.vat_text_excl }}"
     {{ block.shopify_attributes }}>
  
  <div class="hdt-bmsm__header">
    {%- if block.settings.title != blank -%}
      <{{ block.settings.title_tag }} class="hdt-bmsm__title">{{ block.settings.title }}</{{ block.settings.title_tag }}>
    {%- endif -%}
    {%- if block.settings.show_validity and block.settings.validity_text != blank -%}
      <span class="hdt-bmsm__validity">{{ block.settings.validity_text }}</span>
    {%- endif -%}
  </div>

  <div class="hdt-bmsm__grid">
    {%- for i in (1..4) -%}
      {%- liquid
        case i
          when 1
            assign qty = block.settings.tier_1_quantity | plus: 0
            assign discount = block.settings.tier_1_discount | plus: 0
            assign show_tier = block.settings.show_tier_1
          when 2
            assign qty = block.settings.tier_2_quantity | plus: 0
            assign discount = block.settings.tier_2_discount | plus: 0
            assign show_tier = block.settings.show_tier_2
          when 3
            assign qty = block.settings.tier_3_quantity | plus: 0
            assign discount = block.settings.tier_3_discount | plus: 0
            assign show_tier = block.settings.show_tier_3
          when 4
            assign qty = block.settings.tier_4_quantity | plus: 0
            assign discount = block.settings.tier_4_discount | plus: 0
            assign show_tier = block.settings.show_tier_4
        endcase

        assign discount_multiplier = 100 | minus: discount | divided_by: 100.0
        assign tier_unit_price = base_price | times: discount_multiplier | round
        assign tier_total_price = tier_unit_price | times: qty | round

        assign price_to_display = tier_unit_price
        if block.settings.price_display == 'total'
          assign price_to_display = tier_total_price
        endif
      -%}

      {%- if show_tier -%}
        <div class="hdt-bmsm__item" 
             data-tier="{{ i }}" 
             data-quantity="{{ qty }}"
             data-discount="{{ discount }}"
             data-unit-price="{{ tier_unit_price }}"
             data-total-price="{{ tier_total_price }}">
          <div class="hdt-bmsm__quantity">{{ block.settings.quantity_prefix }} {{ qty }}+</div>
          <div class="hdt-bmsm__price">
            {%- comment -%}
              NO .money class — Taxify must NOT touch these.
              JS formats them using the currency prefix from .taxify-amount.
            {%- endcomment -%}
            <span class="hdt-bmsm__price-value" data-bmsm-price>{{ price_to_display | money }}</span>
          </div>
          {%- if block.settings.show_vat_text -%}
            <div class="hdt-bmsm__vat">{{ block.settings.vat_text_incl }}</div>
          {%- endif -%}
          {%- if discount > 0 -%}
            <div class="hdt-bmsm__savings">{{ block.settings.savings_prefix }} {{ discount }}%</div>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

<script>
  (function() {
    var container = document.querySelector('.hdt-buy-more-save-more-{{ block.id }}');
    if (!container) return;

    var items = container.querySelectorAll('.hdt-bmsm__item');
    var sectionId = container.dataset.sectionId;
    var formId = container.dataset.formId;
    var priceDisplayMode = container.dataset.priceDisplay || 'unit';
    var vatInclText = container.dataset.vatInclText || 'Incl. VAT';
    var vatExclText = container.dataset.vatExclText || 'Excl. VAT';

    var basePrice = parseFloat(container.dataset.basePrice);
    var isUpdatingPrice = false;

    // Currency prefix extracted from .taxify-amount text (e.g. "Lek ", "€", "$ ")
    var currencyPrefix = container.dataset.currencySymbol || '€';

    var tierDiscounts = {};
    items.forEach(function(item) {
      tierDiscounts[parseInt(item.dataset.quantity)] = parseFloat(item.dataset.discount);
    });
    var thresholds = Object.keys(tierDiscounts).map(Number).sort(function(a, b) { return a - b; });

    // ═══════════════════════════════════════════
    //  PARSE TAXIFY-AMOUNT TEXT
    //  e.g. "Lek 2,203.56" → { prefix: "Lek ", amount: 220356 }
    //  e.g. "€19,25"       → { prefix: "€",   amount: 1925 }
    //  e.g. "$15.76"       → { prefix: "$",    amount: 1576 }
    // ═══════════════════════════════════════════

    function parseTaxifyAmount(text) {
      if (!text) return null;
      text = text.trim();

      // Find where the first digit starts
      var firstDigit = text.search(/\d/);
      if (firstDigit === -1) return null;

      var prefix = text.substring(0, firstDigit);
      var numPart = text.substring(firstDigit);

      // Find where digits end (allow digits, commas, dots, spaces within number)
      var suffix = '';
      var numMatch = numPart.match(/^[\d.,\s]+/);
      if (numMatch) {
        numPart = numMatch[0].trim();
        suffix = text.substring(firstDigit + numMatch[0].length).trim();
      }

      // Parse the number
      var cleaned = numPart.replace(/\s/g, '');
      if (!cleaned) return null;

      // European format: 2.203,56 or 1.781,97
      if (cleaned.indexOf(',') > -1 && cleaned.indexOf('.') > -1) {
        if (cleaned.lastIndexOf(',') > cleaned.lastIndexOf('.')) {
          // Comma is decimal separator: 2.203,56
          cleaned = cleaned.replace(/\./g, '').replace(',', '.');
        } else {
          // Dot is decimal separator: 2,203.56
          cleaned = cleaned.replace(/,/g, '');
        }
      } else if (cleaned.indexOf(',') > -1) {
        // Could be decimal (19,25) or thousand (1,781)
        var parts = cleaned.split(',');
        if (parts.length === 2 && parts[1].length === 2) {
          // Decimal: 19,25
          cleaned = cleaned.replace(',', '.');
        } else {
          // Thousand separator: 1,781
          cleaned = cleaned.replace(/,/g, '');
        }
      }

      var num = parseFloat(cleaned);
      if (isNaN(num)) return null;

      // If prefix is empty, suffix might have it (e.g. "2,203.56 Lek")
      if (!prefix && suffix) {
        prefix = suffix + ' ';
        // For suffix currencies, we'll handle formatting differently
      }

      return {
        prefix: prefix || '',
        suffix: suffix || '',
        amount: Math.round(num * 100)
      };
    }

    // ═══════════════════════════════════════════
    //  FORMAT PRICE using prefix from main price
    //  Mirrors the format seen in .taxify-amount
    // ═══════════════════════════════════════════

    var lastSeenFormat = null; // Store the number formatting style

    function detectNumberFormat(text) {
      if (!text) return null;
      // Check if number uses dot as thousands + comma as decimal (European)
      if (text.match(/\d{1,3}\.\d{3},\d{2}/)) return 'eu'; // 2.203,56
      // Check if number uses comma as thousands + dot as decimal (US/UK)
      if (text.match(/\d{1,3},\d{3}\.\d{2}/)) return 'us'; // 2,203.56
      // Simple comma decimal: 19,53
      if (text.match(/\d+,\d{2}$/)) return 'eu';
      // Simple dot decimal: 19.53
      if (text.match(/\d+\.\d{2}$/)) return 'us';
      // Check comma as thousands, no decimal
      if (text.match(/\d{1,3},\d{3}(?!\d)/)) return 'us';
      // Check dot as thousands, no decimal
      if (text.match(/\d{1,3}\.\d{3}(?!\d)/)) return 'eu';
      return 'us'; // Default
    }

    var currencySuffix = '';

    // ═══════════════════════════════════════════
    //  FORMAT PRICE — mirrors Taxify's exact format
    //  by using its own rendered text as a template
    // ═══════════════════════════════════════════

    function formatTierPrice(cents) {
      // Try to mirror Taxify's exact number format from its own text
      var mainEl = findMainTaxifyAmount();
      var fmt = 'us';
      var prefix = currencyPrefix;
      var suffix = currencySuffix;

      if (mainEl) {
        var raw = mainEl.textContent.trim();
        fmt = detectNumberFormat(raw) || lastSeenFormat || 'us';

        // Re-extract prefix/suffix fresh from current Taxify text
        var firstDigit = raw.search(/\d/);
        if (firstDigit > -1) {
          prefix = raw.substring(0, firstDigit);
          var afterNum = raw.substring(firstDigit).match(/^[\d.,\s]+/);
          suffix = afterNum ? raw.substring(firstDigit + afterNum[0].length).trim() : '';
        }
      }

      var num = cents / 100;
      var whole = Math.floor(num);
      var dec = Math.round((num - whole) * 100);
      var decSep = (fmt === 'eu') ? ',' : '.';
      var thousandSep = (fmt === 'eu') ? '.' : ',';

      var str = whole.toString();
      var result = '';
      var count = 0;
      for (var i = str.length - 1; i >= 0; i--) {
        if (count > 0 && count % 3 === 0) result = thousandSep + result;
        result = str[i] + result;
        count++;
      }
      result += decSep + (dec < 10 ? '0' + dec : '' + dec);

      if (suffix) return prefix + result + ' ' + suffix;
      return prefix + result;
    }

    // ═══════════════════════════════════════════
    //  READ MAIN PRICE FROM TAXIFY-AMOUNT
    // ═══════════════════════════════════════════

    function findMainTaxifyAmount() {
      // Find .taxify-amount inside the main product price, not inside BMSM
      var candidates = document.querySelectorAll('.taxify-amount');
      for (var i = 0; i < candidates.length; i++) {
        var el = candidates[i];
        // Skip if inside our BMSM block
        if (el.closest('.hdt-buy-more-save-more-{{ block.id }}')) continue;
        // Skip if inside sticky bar or cart drawer
        if (el.closest('.hdt-sticky-add-to-cart') || el.closest('.hdt-cart-drawer')) continue;
        // Skip compare/was prices
        if (el.closest('s') || el.closest('del') || el.closest('.hdt-price--compare') || el.closest('.hdt-price__was')) continue;
        return el;
      }
      return null;
    }

    function readMainPrice() {
      var el = findMainTaxifyAmount();
      if (!el) return null;
      return parseTaxifyAmount(el.textContent);
    }

    // ═══════════════════════════════════════════
    //  VAT TEXT — read from .taxify-text-after
    // ═══════════════════════════════════════════

    function readTaxState() {
      // Find .taxify-text-after next to main price
      var mainAmount = findMainTaxifyAmount();
      if (!mainAmount) return;
      var parent = mainAmount.parentElement;
      if (!parent) return;
      var textAfter = parent.querySelector('.taxify-text-after');
      if (!textAfter) return;
      var txt = textAfter.textContent.trim().toLowerCase();
      // Detect tax state from Taxify's own label
      if (txt.indexOf('incl') > -1 || txt.indexOf('inkl') > -1 || txt.indexOf('tax incl') > -1) {
        setVatText(true);
      } else if (txt.indexOf('excl') > -1 || txt.indexOf('tax excl') > -1) {
        setVatText(false);
      }
    }

    function setVatText(incl) {
      var vatEls = container.querySelectorAll('.hdt-bmsm__vat');
      var target = incl ? vatInclText : vatExclText;
      vatEls.forEach(function(el) {
        if (el.textContent !== target) el.textContent = target;
      });
    }

    // ═══════════════════════════════════════════
    //  TIER PRICE RECALC
    // ═══════════════════════════════════════════

    function recalcTierPrices() {
      console.group('[BMSM] recalcTierPrices | basePrice:', basePrice, '(' + (basePrice/100) + ') | mode:', priceDisplayMode);
      items.forEach(function(item) {
        var qty = parseInt(item.dataset.quantity);
        var discount = tierDiscounts[qty] || 0;
        var unitPrice = Math.round(basePrice * (100 - discount) / 100);
        var totalPrice = unitPrice * qty;
        item.dataset.unitPrice = unitPrice;
        item.dataset.totalPrice = totalPrice;
        var show = priceDisplayMode === 'total' ? totalPrice : unitPrice;
        var formatted = formatTierPrice(show);

        console.log(
          'Tier qty:', qty,
          '| discount:', discount + '%',
          '| basePrice cents:', basePrice, '(' + (basePrice/100) + ')',
          '| unitPrice cents:', unitPrice, '(' + (unitPrice/100) + ')',
          '| totalPrice cents:', totalPrice, '(' + (totalPrice/100) + ')',
          '| showing:', (priceDisplayMode === 'total' ? 'total' : 'unit'),
          '| formatted:', formatted
        );

        var priceEl = item.querySelector('[data-bmsm-price]');
        if (priceEl) {
          priceEl.textContent = formatted;
        }
      });
      console.groupEnd();
    }

    // ═══════════════════════════════════════════
    //  SYNC CURRENCY FORMAT FROM TAXIFY
    //  Only updates prefix/suffix/number format.
    //  NEVER reads price from Taxify — that comes
    //  directly from variant:change event data.
    // ═══════════════════════════════════════════

    function syncFromMainPrice() {
      var mainEl = findMainTaxifyAmount();
      if (!mainEl) return;

      var raw = mainEl.textContent.trim();
      var fmt = detectNumberFormat(raw);
      if (fmt) lastSeenFormat = fmt;

      var firstDigit = raw.search(/\d/);
      if (firstDigit > -1) {
        var pfx = raw.substring(0, firstDigit);
        var afterNum = raw.substring(firstDigit).match(/^[\d.,\s]+/);
        var sfx = afterNum ? raw.substring(firstDigit + afterNum[0].length).trim() : '';
        if (pfx) { currencyPrefix = pfx; currencySuffix = ''; }
        else if (sfx) { currencySuffix = sfx; currencyPrefix = ''; }
      }

      readTaxState();
      // Reformat with updated currency/format — basePrice stays unchanged
      recalcTierPrices();
      console.log('[BMSM] Currency format synced | prefix:', currencyPrefix, '| suffix:', currencySuffix, '| format:', lastSeenFormat, '| basePrice cents:', basePrice, '(' + (basePrice / 100) + ')');
    }

    // ═══════════════════════════════════════════
    //  SYNC BASE PRICE FROM VARIANT DATA
    //  Called on every variant:change event.
    //  Uses e.detail.variant.price (cents) directly.
    // ═══════════════════════════════════════════

    function syncVariantPrice(price) {
      if (!price || price <= 0) return;
      console.log('[BMSM] Variant price received | cents:', price, '(' + (price / 100) + ') | prev basePrice:', basePrice);
      basePrice = price;
      container.dataset.basePrice = basePrice;
      recalcTierPrices();
    }

    // ═══════════════════════════════════════════
    //  WATCH .taxify-amount ON MAIN PRICE
    //  This catches: currency switch, tax toggle,
    //  variant change — everything Taxify updates
    // ═══════════════════════════════════════════

    var taxifyObserver = null;
    var taxifyObserverTarget = null;

    function watchTaxifyAmount() {
      // Find the taxify price container (parent of .taxify-amount)
      var mainAmount = findMainTaxifyAmount();
      if (!mainAmount) {
        // Taxify not loaded yet, retry
        setTimeout(watchTaxifyAmount, 1000);
        return;
      }

      // Watch the parent container so we catch .taxify-amount being replaced or updated
      var watchTarget = mainAmount.closest('.taxify-price-container') || mainAmount.parentElement;
      if (!watchTarget) {
        setTimeout(watchTaxifyAmount, 1000);
        return;
      }

      // Don't re-attach if already watching same target
      if (taxifyObserverTarget === watchTarget) return;
      if (taxifyObserver) taxifyObserver.disconnect();

      taxifyObserverTarget = watchTarget;
      var debounce = null;

      taxifyObserver = new MutationObserver(function() {
        clearTimeout(debounce);
        debounce = setTimeout(function() {
          syncFromMainPrice();
        }, 350);
      });

      taxifyObserver.observe(watchTarget, {
        childList: true,
        subtree: true,
        characterData: true
      });

      console.log('[BMSM] Watching .taxify-price-container for changes');
    }

    // ═══════════════════════════════════════════
    //  FALLBACK: Watch for Taxify to appear
    //  (if page loads before Taxify initializes)
    // ═══════════════════════════════════════════

    function watchForTaxifyInit() {
      // Watch the main price area for Taxify to inject its container
      var selectors = [
        '.hdt-product__price .hdt-price',
        '.hdt-product__price',
        '.hdt-price'
      ];
      var priceArea = null;
      for (var i = 0; i < selectors.length; i++) {
        var els = document.querySelectorAll(selectors[i]);
        for (var j = 0; j < els.length; j++) {
          if (els[j].closest('.hdt-sticky-add-to-cart') || els[j].closest('.hdt-cart-drawer')) continue;
          priceArea = els[j];
          break;
        }
        if (priceArea) break;
      }

      if (!priceArea) return;

      var initObs = new MutationObserver(function() {
        var mainAmount = findMainTaxifyAmount();
        if (mainAmount) {
          initObs.disconnect();
          syncFromMainPrice();
          watchTaxifyAmount();
        }
      });

      initObs.observe(priceArea, { childList: true, subtree: true });
    }

    // ═══════════════════════════════════════════
    //  TAXIFY TOGGLE — poll sync after click
    // ═══════════════════════════════════════════

    function watchTaxifySwitcher() {
      document.addEventListener('click', function(e) {
        var switcher = e.target.closest('.taxify-switcher, .taxify-switcher__toggle, .taxify-switcher__track, .taxify-switcher__thumb, #customTaxifyTarget');
        if (!switcher) return;
        // Wait for Taxify to update text-after (VAT label), then sync format only
        [300, 700, 1500].forEach(function(d) {
          setTimeout(syncFromMainPrice, d);
        });
      }, true);
    }

    // ═══════════════════════════════════════════
    //  VARIANT CHANGE WATCHERS
    // ═══════════════════════════════════════════

    ['variant:change', 'hdt:variant:change'].forEach(function(evt) {
      document.addEventListener(evt, function(e) {
        var variant = e.detail && (e.detail.variant || e.detail);
        if (variant && variant.price) {
          // Use variant.price directly — no DOM parsing needed
          syncVariantPrice(variant.price);
        } else {
          // Fallback: no price in event, wait for Taxify to update then sync format only
          setTimeout(syncFromMainPrice, 500);
        }
        // Always sync currency format after variant change
        setTimeout(syncFromMainPrice, 600);
      });
    });

    function watchVariantInput() {
      var sel = 'input[name="id"][form="' + formId + '"], #product-form-' + sectionId + ' input[name="id"], form[id="' + formId + '"] input[name="id"]';
      var inp = document.querySelector(sel);
      if (!inp) return;
      var obs = new MutationObserver(function(muts) {
        muts.forEach(function(m) {
          if (m.type === 'attributes' && m.attributeName === 'value') {
            // Input value changed — re-fetch variant price via product JSON
            var variantId = inp.value;
            if (!variantId) return;
            fetch('/products/' + container.dataset.productId + '.js')
              .then(function(r) { return r.json(); })
              .then(function(p) {
                var v = p.variants.find(function(v) { return v.id == variantId; });
                if (v && v.price) {
                  console.log('[BMSM] Variant input changed | variantId:', variantId, '| price cents:', v.price);
                  syncVariantPrice(v.price);
                }
              })
              .catch(function(err) { console.warn('[BMSM] product.js fetch failed', err); });
          }
        });
      });
      obs.observe(inp, { attributes: true, attributeFilter: ['value'] });
    }

    // ═══════════════════════════════════════════
    //  TIER CLICK + QUANTITY
    // ═══════════════════════════════════════════

    function findTier(qty) {
      var matched = null;
      for (var i = thresholds.length - 1; i >= 0; i--) {
        if (qty >= thresholds[i]) { matched = thresholds[i]; break; }
      }
      return matched;
    }

    function getQty() {
      var inp = document.querySelector('#Quantity-' + sectionId + ', .hdt-quantity__input[form="' + formId + '"], input[name="quantity"]');
      return inp ? (parseInt(inp.value) || 1) : 1;
    }

    function updateActive(qty) {
      var matched = findTier(qty);
      items.forEach(function(item) {
        item.classList.remove('is-active');
        if (matched && parseInt(item.dataset.quantity) === matched) {
          item.classList.add('is-active');
        }
      });
    }

    items.forEach(function(item) {
      item.addEventListener('click', function() {
        var quantity = parseInt(this.dataset.quantity);
        var qtyInput = document.querySelector('#Quantity-' + sectionId + ', .hdt-quantity__input[form="' + formId + '"], input[name="quantity"]');
        if (qtyInput) {
          qtyInput.value = quantity;
          qtyInput.dispatchEvent(new Event('change', { bubbles: true }));
          qtyInput.dispatchEvent(new Event('input', { bubbles: true }));
        }
        updateActive(quantity);
      });
    });

    function setupQuantityListener() {
      var qtyInput = document.querySelector('#Quantity-' + sectionId + ', .hdt-quantity__input[form="' + formId + '"], input[name="quantity"]');
      if (qtyInput) {
        ['change', 'input'].forEach(function(evt) {
          qtyInput.addEventListener(evt, function() {
            updateActive(parseInt(this.value) || 1);
          });
        });
        updateActive(parseInt(qtyInput.value) || 1);
      }
    }

    document.addEventListener('hdt:quantity:change', function(e) {
      if (e.detail && e.detail.quantity) updateActive(e.detail.quantity);
    });

    // ═══════════════════════════════════════════
    //  INIT
    // ═══════════════════════════════════════════

    function init() {
      setupQuantityListener();
      watchVariantInput();
      watchTaxifySwitcher();

      // Try to sync from Taxify immediately
      var mainAmount = findMainTaxifyAmount();
      if (mainAmount) {
        syncFromMainPrice();
        watchTaxifyAmount();
      } else {
        // Taxify not ready yet — watch for it
        watchForTaxifyInit();
        // Also retry on timers
        [1000, 2000, 3000, 5000].forEach(function(d) {
          setTimeout(function() {
            if (!taxifyObserverTarget) {
              var el = findMainTaxifyAmount();
              if (el) {
                syncFromMainPrice();
                watchTaxifyAmount();
              }
            }
          }, d);
        });
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function() { setTimeout(init, 800); });
    } else {
      setTimeout(init, 800);
    }

    document.addEventListener('shopify:section:load', function(e) {
      if (e.detail.sectionId === sectionId) setTimeout(init, 800);
    });
  })();
</script>

