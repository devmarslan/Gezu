{% comment %}
  Rewards & Content Section
  - Left: Rewards Card with tabs (Personal/Business)
  - Middle Top: Promo Banner (Christmas Sale)
  - Middle Bottom: Blog Posts Row
  - Right: Blog/Tips Intro Card
  - Fully responsive with mobile slider
{% endcomment %}

{{ 'section-rewards-content.css' | asset_url | stylesheet_tag }}

<style>
  #rewards-content-{{ section.id }} {
    --section-bg-color: {{ section.settings.section_bg_color }};
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --section-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --section-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    
    /* Rewards Card */
    --rewards-bg: {{ section.settings.rewards_bg_gradient }};
    --rewards-title-color: {{ section.settings.rewards_title_color }};
    --rewards-title-size: {{ section.settings.rewards_title_font_size }}px;
    --rewards-title-size-mobile: {{ section.settings.rewards_title_font_size_mobile }}px;
    --rewards-subtitle-color: {{ section.settings.rewards_subtitle_color }};
    --rewards-subtitle-size: {{ section.settings.rewards_subtitle_font_size }}px;
    --rewards-text-color: {{ section.settings.rewards_text_color }};
    --rewards-text-size: {{ section.settings.rewards_text_font_size }}px;
    --rewards-btn-bg: {{ section.settings.rewards_btn_bg }};
    --rewards-btn-color: {{ section.settings.rewards_btn_color }};
    
    /* Promo Card */
    --promo-bg-color: {{ section.settings.promo_bg_color }};
    --promo-title-color: {{ section.settings.promo_title_color }};
    --promo-title-size: {{ section.settings.promo_title_font_size }}px;
    --promo-title-size-mobile: {{ section.settings.promo_title_font_size_mobile }}px;
    --promo-text-color: {{ section.settings.promo_text_color }};
    --promo-text-size: {{ section.settings.promo_text_font_size }}px;
    --promo-link-color: {{ section.settings.promo_link_color }};
    
    /* Blog Intro Card */
    --blog-intro-bg: {{ section.settings.blog_intro_bg }};
    --blog-intro-title-color: {{ section.settings.blog_intro_title_color }};
    --blog-intro-title-size: {{ section.settings.blog_intro_title_font_size }}px;
    --blog-intro-text-color: {{ section.settings.blog_intro_text_color }};
    --blog-intro-text-size: {{ section.settings.blog_intro_text_font_size }}px;
    --blog-intro-link-color: {{ section.settings.blog_intro_link_color }};
    
    /* Tips Section */
    --tips-title-color: {{ section.settings.tips_title_color }};
    --tips-title-size: {{ section.settings.tips_title_font_size }}px;
    --tips-title-size-mobile: {{ section.settings.tips_title_font_size_mobile }}px;
    
    /* Blog Card */
    --blog-card-bg: {{ section.settings.blog_card_bg }};
    --blog-card-title-color: {{ section.settings.blog_card_title_color }};
    --blog-card-title-size: {{ section.settings.blog_card_title_font_size }}px;
    --blog-card-title-size-mobile: {{ section.settings.blog_card_title_font_size_mobile }}px;
  }

  #rewards-content-{{ section.id }} .rewards-content-wrapper {
    padding-top: var(--section-padding-top);
    padding-bottom: var(--section-padding-bottom);
    background-color: var(--section-bg-color);
    {% if section.settings.section_bg_image != blank %}
    background-image: url('{{ section.settings.section_bg_image | image_url: width: 1920 }}');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    {% endif %}
  }

  @media (max-width: 768px) {
    #rewards-content-{{ section.id }} .rewards-content-wrapper {
      padding-top: var(--section-padding-top-mobile);
      padding-bottom: var(--section-padding-bottom-mobile);
    }
  }
</style>

<section id="rewards-content-{{ section.id }}" class="rewards-content-section">
  <div class="rewards-content-wrapper">
    <div class="page-width">
      <div class="rewards-content-grid">
        
        {% comment %} Left Column - Rewards Card {% endcomment %}
        <div class="rewards-card-column">
          <div class="rewards-card" style="background: var(--rewards-bg);">
            {% comment %} Decorative Elements {% endcomment %}
            <div class="rewards-decorations">
              {% if section.settings.coin_image_1 != blank %}
                <img src="{{ section.settings.coin_image_1 | image_url: width: 80 }}" alt="" class="deco-coin coin-1">
              {% else %}
                <div class="deco-coin coin-1 default-coin">💰</div>
              {% endif %}
              {% if section.settings.coin_image_2 != blank %}
                <img src="{{ section.settings.coin_image_2 | image_url: width: 80 }}" alt="" class="deco-coin coin-2">
              {% else %}
                <div class="deco-coin coin-2 default-coin">💵</div>
              {% endif %}
              <div class="deco-star">
                <svg width="40" height="40" viewBox="0 0 40 40" fill="currentColor">
                  <path d="M20 0l2 18h18l-14 10 6 18-12-10-12 10 6-18L0 18h18z"/>
                </svg>
              </div>
            </div>

            {% comment %} Logo/Title {% endcomment %}
            <div class="rewards-header">
              {% if section.settings.rewards_logo != blank %}
                <img src="{{ section.settings.rewards_logo | image_url: width: 200 }}" alt="" class="rewards-logo">
              {% endif %}
              <h2 class="rewards-main-title">
                <span class="title-small">{{ section.settings.rewards_title_small }}</span>
                <span class="title-large">{{ section.settings.rewards_title_large }}</span>
              </h2>
            </div>

            {% comment %} Tabs {% endcomment %}
            <div class="rewards-tabs">
              <button class="tab-btn active" data-tab="personal">{{ section.settings.tab_1_text }}</button>
              <button class="tab-btn" data-tab="business">{{ section.settings.tab_2_text }}</button>
            </div>

            {% comment %} Content {% endcomment %}
            <div class="rewards-content">
              <h3 class="rewards-subtitle">{{ section.settings.rewards_subtitle }}</h3>
              <p class="rewards-description">{{ section.settings.rewards_description }}</p>
              
              <ul class="rewards-benefits">
                {% for block in section.blocks %}
                  {% if block.type == 'benefit' %}
                    <li class="benefit-item" {{ block.shopify_attributes }}>
                      <svg class="check-icon" width="18" height="18" viewBox="0 0 18 18" fill="none">
                        <circle cx="9" cy="9" r="8" stroke="currentColor" stroke-width="1.5"/>
                        <path d="M5.5 9l2.5 2.5 4.5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                      <span>{{ block.settings.benefit_text }}</span>
                    </li>
                  {% endif %}
                {% endfor %}
              </ul>
            </div>

            {% comment %} CTA Button {% endcomment %}
            <a href="{{ section.settings.rewards_btn_link }}" class="rewards-btn">
              {{ section.settings.rewards_btn_text }}
            </a>
          </div>
        </div>

        {% comment %} Middle & Right Columns {% endcomment %}
        <div class="content-columns">
          {% comment %} Top Row - Promo + Blog Intro {% endcomment %}
          <div class="content-top-row">
            {% comment %} Promo Card {% endcomment %}
            <div class="promo-card">
              <div class="promo-content">
                <h3 class="promo-title">{{ section.settings.promo_title }}</h3>
                <p class="promo-text">{{ section.settings.promo_description }}</p>
                <a href="{{ section.settings.promo_link_url }}" class="promo-link">{{ section.settings.promo_link_text }}</a>
              </div>
              {% if section.settings.promo_image != blank %}
                <div class="promo-image">
                  <img src="{{ section.settings.promo_image | image_url: width: 200 }}" alt="" loading="lazy">
                </div>
              {% endif %}
            </div>

            {% comment %} Blog Intro Card {% endcomment %}
            <div class="blog-intro-card">
              <h3 class="blog-intro-title">{{ section.settings.blog_intro_title }}</h3>
              <p class="blog-intro-text">{{ section.settings.blog_intro_description }}</p>
              <a href="{{ section.settings.blog_intro_link_url }}" class="blog-intro-link">{{ section.settings.blog_intro_link_text }}</a>
            </div>
          </div>

          {% comment %} Bottom Row - Tips/Blog Posts {% endcomment %}
          <div class="content-bottom-row">
            <div class="tips-section">
              <h4 class="tips-title">{{ section.settings.tips_title }}</h4>
              
              {% comment %} Blog Posts Grid - Desktop {% endcomment %}
              <div class="blog-posts-grid desktop-grid">
                {% if section.settings.blog != blank %}
                  {% for article in blogs[section.settings.blog].articles limit: section.settings.posts_count %}
                    <a href="{{ article.url }}" class="blog-post-card">
                      <div class="post-image">
                        {% if article.image %}
                          <img src="{{ article.image | image_url: width: 400 }}" alt="{{ article.title }}" loading="lazy">
                        {% else %}
                          <div class="post-placeholder">
                            {{ 'image' | placeholder_svg_tag }}
                          </div>
                        {% endif %}
                      </div>
                      <p class="post-title">{{ article.title | truncate: 60 }}</p>
                    </a>
                  {% endfor %}
                {% else %}
                  {% for i in (1..4) %}
                    <div class="blog-post-card">
                      <div class="post-image">
                        <div class="post-placeholder">
                          {{ 'image' | placeholder_svg_tag }}
                        </div>
                      </div>
                      <p class="post-title">Lorem ipsum dolor sit amet consectetur.</p>
                    </div>
                  {% endfor %}
                {% endif %}
              </div>

              {% comment %} Blog Posts Slider - Mobile {% endcomment %}
              {% if section.settings.enable_mobile_slider %}
                <div class="blog-posts-mobile-slider mobile-slider">
                  <div class="swiper blog-swiper-{{ section.id }}">
                    <div class="swiper-wrapper">
                      {% if section.settings.blog != blank %}
                        {% for article in blogs[section.settings.blog].articles limit: section.settings.posts_count %}
                          <div class="swiper-slide">
                            <a href="{{ article.url }}" class="blog-post-card">
                              <div class="post-image">
                                {% if article.image %}
                                  <img src="{{ article.image | image_url: width: 400 }}" alt="{{ article.title }}" loading="lazy">
                                {% else %}
                                  <div class="post-placeholder">
                                    {{ 'image' | placeholder_svg_tag }}
                                  </div>
                                {% endif %}
                              </div>
                              <p class="post-title">{{ article.title | truncate: 60 }}</p>
                            </a>
                          </div>
                        {% endfor %}
                      {% else %}
                        {% for i in (1..4) %}
                          <div class="swiper-slide">
                            <div class="blog-post-card">
                              <div class="post-image">
                                <div class="post-placeholder">
                                  {{ 'image' | placeholder_svg_tag }}
                                </div>
                              </div>
                              <p class="post-title">Lorem ipsum dolor sit amet consectetur.</p>
                            </div>
                          </div>
                        {% endfor %}
                      {% endif %}
                    </div>
                    {% if section.settings.show_mobile_pagination %}
                      <div class="swiper-pagination blog-pagination-{{ section.id }}"></div>
                    {% endif %}
                  </div>
                </div>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.getElementById('rewards-content-{{ section.id }}');
    
    // Tabs functionality
    const tabs = section.querySelectorAll('.tab-btn');
    tabs.forEach(tab => {
      tab.addEventListener('click', function() {
        tabs.forEach(t => t.classList.remove('active'));
        this.classList.add('active');
      });
    });

    {% if section.settings.enable_mobile_slider %}
    // Mobile Slider
    const blogSwiper{{ section.id | replace: '-', '_' }} = new Swiper('.blog-swiper-{{ section.id }}', {
      slidesPerView: 1.3,
      spaceBetween: 16,
      centeredSlides: false,
      loop: {{ section.settings.mobile_slider_loop }},
      autoplay: {% if section.settings.mobile_slider_autoplay %}{ delay: {{ section.settings.mobile_slider_autoplay_speed }}, disableOnInteraction: false }{% else %}false{% endif %},
      pagination: {
        el: '.blog-pagination-{{ section.id }}',
        clickable: true,
      },
      breakpoints: {
        400: {
          slidesPerView: 1.5,
          spaceBetween: 16,
        },
        550: {
          slidesPerView: 2.2,
          spaceBetween: 16,
        }
      }
    });
    {% endif %}
  });
</script>

