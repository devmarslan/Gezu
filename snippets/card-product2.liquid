{%- comment -%}
  Renders a product card

  Accepts:
  - card_product: {Object} Product Liquid object (required)
  - section_id: {String} The ID of the section that contains this card. (required)
  - sizes: {String} a list sizes of image.
  - class: {String} a list class.
  - image_ratio: {String} Size of the product image card. Values are "square" and "portrait". Default is "square" (optional)
  - show_vendor: {Boolean} Show the product vendor. Default: false
  - show_rating: {Boolean} Show the product rating. Default: false
  - color_list: {Array}
  - size_list: {Array}

  Usage:
  {%- render 'card-product', card_product: product, show_vendor: section.settings.show_vendor -%}
{%- endcomment -%}
<style>
  .card-2 hdt-badge.hdt-badge.hdt-badge__on-sale {
    display: none;
}
.card-2 .ict-2, .card-2 .ict-1 {
  display: flex;
  align-items: center;
  margin-bottom: 5px;
  gap: 5px;
}
.card-2 .star-ratings, .hdt-card-product__info .star-ratings {
  display: flex;
  gap: 5px;
  align-items: center;
}
.card-2 .star-ratings .rating, .hdt-card-product__info .star-ratings .rating {
    font-size: 13px;
}
.card-2 .star-ratings .stars, .hdt-card-product__info .star-ratings .stars {
    display: flex;
}
.card-2 .tax {
  font-weight: 400;
  font-size: 12px;
  line-height: 100%;
}
.card-2 a.hdt-card-product__title {
  font-weight: 700;
  font-size: 14px;
  line-height: 100%;
  -webkit-line-clamp: 1;
}
.card-2 .ict-text {
  font-weight: 400;
  font-size: 12px;
  line-height: 100%;
  color: rgba(32, 32, 32, 1);
}

.card-2 .hdt-price__list .hdt-price,
.card-2 .taxify-price .taxify-amount {
  font-weight: 700;
  font-size: 18px;
  color: rgba(0, 71, 171, 1);
  line-height: 100%;
}
.card-2 span.taxify-text-after {
    font-weight: 500;
    font-size: 12px;
    line-height: normal;
    display: none;
}
.card-2 .hdt-product-btns.hdt-pr-btns-group2.hdt-absolute {
  left: unset !important;
  right: 12px;
}
.card-2 .hdt-card-product__media .hdt-pr_btn {
  color: #fff;
}
.card-2 button.hdt-card-product__btn-quick-view.hdt-pr_btn {
  background: #0047AB !important;
  width: 100% !important;
  max-width: 100% !important;
  border-radius: 10px !important;
  aspect-ratio: 0;
  height: 50px;
  font-weight: 500 !important;
  font-size: 14px !important;
  text-transform: capitalize;
}
.card-2 wrapp-hdt-open-modal-btn.hdt-card-product__btn-qv {
  max-width: 100%;
  width: 100%;
}
hdt-wishlist.hdt-card-product__btn-wishlist.hdt-pr_btn {
  background: #F8F8F8 !important;
  border-radius: 30px !important;
  padding: 7px 10px !important;
  display: flex !important;
}
.card-2 .hdt-card-product__media .hdt-product-btns.hdt-pr-btns-group2.compare_absol_btn .hdt-card-product__btn-compare {
  border-radius: 50%;
  box-shadow: none;
  background: #f8f8f8;
  display: flex !important;
}
.card-2 .hdt-card-product__media .hdt-product-btns.hdt-pr-btns-group2.compare_absol_btn .hdt-card-product__btn-compare[action="added"] {
    background: #0047ab;
}

.card-2 wrapp-hdt-open-modal-btn.hdt-card-product__btn-qv span {
    font-weight: 500;
    font-size: 14px;
}
hdt-wishlist.hdt-card-product__btn-wishlist.hdt-pr_btn[action="added"],hdt-wishlist.hdt-product-form__btn-wishlist[action="added"],
hdt-wishlist.hdt-card-product__btn-wishlist.hdt-pr_btn[action="remove"] {
  background: #0047AB !important;
  border-color: #0047AB !important;
}

.hdt-card-product .hdt-price-wrapp hdt-compare-at-price {
    color: rgba(0, 0, 0, 0.32) ;
}
.card-2 hdt-compare-at-price.hdt-compare-at-price .hdt-money {
    color: rgba(0, 0, 0, 0.32);
    font-size: 16px !important;
    font-weight: 400 !important;
    opacity: 1 !important;
}
.card-2 .hdt-price-decimal {
  font-size: 0.65em;
  vertical-align: super;
}
/* Sale Badge Styles */
.card-2 .sale-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background-color: #CB2424;
  color: #fff;
  font-weight: 700;
  font-size: 12px;
  line-height: 1;
  padding: 6px 10px;
  margin-left: 8px;
  white-space: nowrap;
}
.card-2 .price-with-badge {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 5px;
}



{% if section.settings.show_compare_solid_btn %}
.hdt-product-btns.compare-solid-btn.hdt-pr-btns-group2 { width: 100%;}
.hdt-product-btns.compare-solid-btn hdt-compare.hdt-card-product__btn-compare {
    width: 100%;
    background: #fff;
    height: 40px;
    border-radius: 6px;
    border: 2px solid #e8e8e8;
    box-shadow: none;
}
#shopify-section-{{section.id }} .hdt-product-btns.hdt-pr-btns-group2.hdt-absolute.compare_absol_btn .hdt-card-product__btn-compare {
    display: none;
}
.hdt-card-product .hdt-product-btns.hdt-pr-btns-group2 .hdt-card-product__btn-compare svg.hdt-svg-cp.is-ic--added {
    fill: #000 !important;
}
.hdt-card-product__info .hdt-pr_btn.hdt-card-product__btn-compare {color:#fff;}
.hdt-card-product__info .hdt-pr_btn.hdt-card-product__btn-compare:hover {color:#000 !important;}
.hdt-product-btns.hdt-pr-btns-group2 span.compare-txt {
    margin-left: 10px;
    color: #000 !important;
}
{% endif %}

/* ===== MOBILE SLIDER STYLES ===== */
@media (max-width: 768px) {
  .card-2 .hdt-product-btns.hdt-pr-btns-group2.hdt-absolute {
    left: 86% !important;
    right: 10% !important;
  }
  .card-2 span.badge-text {
    display: none;
  }
  .card-2 button.hdt-card-product__btn-quick-view.hdt-pr_btn {
    height: 40px;
    aspect-ratio: 0;
  }
  .card-2 wrapp-hdt-open-modal-btn.hdt-card-product__btn-qv span {
    display: block;
    font-weight: 400;
    font-size: 12px;
  }
  .card-2 .sale-badge {
    font-size: 11px;
    padding: 4px 8px;
  }
  .card-2 .hdt-badge {
    height: 25px !important;
  }

  /* Hide the old hover image on mobile */
  .card-2 .hdt-card-product__media--hover {
    display: none !important;
  }

  /* Hide the <a> tag images on mobile - slider replaces them */
  .card-2 .hdt-card-product__media-wrapp {
    pointer-events: none;
  }
  .card-2 .hdt-card-product__media-wrapp .hdt-card-product__media--main {
    opacity: 0 !important;
  }

  /* Slider track: positioned on top of the <a> tag */
  .card-2 .mobile-slider-track {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
    z-index: 3;
    touch-action: pan-x;
    overscroll-behavior-x: contain; /* Prevent scroll chaining to parent */
  }
  .card-2 .mobile-slider-track::-webkit-scrollbar {
    display: none;
  }
  .card-2 .mobile-slider-slide {
    flex: 0 0 100%;
    width: 100%;
    scroll-snap-align: start;
    position: relative;
  }
  .card-2 .mobile-slider-slide img {
    width: 100%;
    height: 100%;
    object-fit: contain !important;
    display: block;
  }

  /* ===== TAP TO REVEAL: Hide overlays by default ===== */
  .card-2 .hdt-pr-btns-group1,
  .card-2 .hdt-pr-btns-group2.compare_absol_btn,
  .card-2 .hdt-badge__wrapp/*,
  .card-2 .hdt-color-picker-wrapper*/ {
    opacity: 0 !important;
    visibility: hidden !important;
    pointer-events: none !important;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  /* Show overlays when tapped */
  .card-2 .hdt-card-product__media.mobile-tapped .hdt-pr-btns-group1,
  .card-2 .hdt-card-product__media.mobile-tapped .hdt-pr-btns-group2.compare_absol_btn,
  .card-2 .hdt-card-product__media.mobile-tapped .hdt-badge__wrapp,
  .card-2 .hdt-card-product__media.mobile-tapped .hdt-color-picker-wrapper {
    opacity: 1 !important;
    visibility: visible !important;
    pointer-events: auto !important;
    z-index: 5 !important;
  }
}

/* Desktop: hide mobile slider elements */
@media (min-width: 769px) {
  .mobile-slider-track,
  .mobile-slider-dots {
    display: none !important;
  }
}
</style>
{%- liquid
  unless product_url
    assign product_url = card_product.url
  endunless
  assign featured_media = card_product.featured_media | default: settings.placeholder_img
  assign color_count = 0
  assign size_count = 0
  
  if card_product.has_only_default_variant == false and settings.color_mode != 'hide' or settings.size_mode != 'hide'
     assign available_variants = card_product.variants | where: "available"
     for option in card_product.options_with_values
        assign name_downcase = option.name | downcase
        if settings.color_mode != 'hide' and color_list contains name_downcase and color_count == 0
          assign color_option_index = 'option' | append: forloop.index
          assign color_variants = option.values
          assign color_variants_avai = available_variants | map: color_option_index | uniq
          if settings.color_type == 'all'
            assign color_count = color_variants.size
          else
            if card_product.options_with_values.size == 1
              assign color_variants = color_variants_avai
            endif
            assign color_count = color_variants_avai.size
          endif
        elsif settings.size_mode != 'hide' and size_list contains name_downcase and size_count == 0
          assign size_option_index = 'option' | append: forloop.index
          assign size_variants_avai = available_variants | map: size_option_index | uniq
          assign size_variants = option.values
          if settings.size_type == 'all'
            assign size_count = size_variants.size
          else
            if card_product.options_with_values.size == 1
              assign size_variants = size_variants_avai
            endif
            assign size_count = size_variants_avai.size
          endif
        endif
     endfor
  endif

  # Calculate discount percentage
  assign on_sale = false
  assign discount_percentage = 0
  if card_product.compare_at_price > card_product.price
    assign on_sale = true
    assign savings = card_product.compare_at_price | minus: card_product.price
    assign discount_percentage = savings | times: 100.0 | divided_by: card_product.compare_at_price | round
  endif
  -%}
  
  <hdt-card-product class="hdt-card-product card-{{ card_product.id }} {{ class }}{% if card_product.available == false %} hdt-pr-sold_out{% endif %} card-2 hdt-pr-border_{{ section.settings.pr_border }}" data-product-handle="{{ card_product.handle }}">
    <div class="hdt-card-product__wrapper" hdt-reveal="slide-in" timeline>
      <div class="hdt-card-product__media hdt-relative hdt-oh{% if size_count > 0 %} hdt-has-size-list{% endif %}">
        <a data-pr-url href="{{ product_url }}" data-instant calc-nav class="hdt-card-product__media-wrapp hdt-ratio"{% if image_ratio == 'adapt_image' %} style="--aspect-ratioapt: {{ featured_media.aspect_ratio | default: '127.7777778%' }}"{% endif %}>
          {%- if featured_media -%}
            {%- liquid
              echo featured_media | image_url: width: featured_media.width | image_tag: loading: 'lazy', sizes: sizes, widths: '165, 360, 533, 668, 720, 940, 940, 1066, 1200, 1450', data-widths: '[165, 360, 533, 668, 720, 940, 940, 1066, 1200, 1450]', class: 'hdt-card-product__media--main'
              if card_product.media[1] != null and settings.show_secondary_image
                assign next_media = card_product.media[featured_media.position] | default: card_product.media[1]
                echo next_media | image_url: width: next_media.width | image_tag: loading: 'lazy', sizes: sizes, widths: '165, 360, 533, 668, 720, 940, 940, 1066, 1200, 1450', class: 'hdt-card-product__media--hover'
              endif
            -%}
          {%- endif -%}
        </a>

        {%- comment -%} Mobile Slider: OUTSIDE the <a> tag to prevent navigation conflicts {%- endcomment -%}
        <div class="mobile-slider-track" data-product-id="{{ card_product.id }}">
          {%- for media in card_product.media -%}
            {%- if media.media_type == 'image' -%}
              <div class="mobile-slider-slide" data-slide-index="{{ forloop.index0 }}" data-media-id="{{ media.id }}">
                {{ media | image_url: width: 720 | image_tag: loading: 'lazy', sizes: sizes, widths: '165, 360, 533, 668, 720', class: 'mobile-slider-img' }}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
         {%- liquid
            if color_count > 0
              render 'color-list', section_id: section_id, color_picker_btnicon: settings.color_picker_btnicon, product: card_product, product_url: product_url, color_variants: color_variants, color_variants_avai: color_variants_avai, color_count: color_count, color_option_index: color_option_index, placement: 'top'
            endif
          -%}
          {%- if color_count > 0 -%}
          <style>
                  .card-{{ card_product.id }} .hdt-card-product__wrapper .hdt-badge__wrapp { left: 50px !important; }
          </style>
  {% endif %}
        {%- render 'badges', product: card_product, use_variant: false -%}
        <div class="hdt-product-btns aa hdt-pr-btns-group2 hdt-absolute compare_absol_btn">
          {%- liquid
            echo btn_wishlist_code | replace_first: '19041994', card_product.id | replace_first: 'handle_nt_94', card_product.handle
            if settings.compare_mode != "0"
              render 'btn-compare', product_id: card_product.id, product_handle: card_product.handle, class: 'hdt-pr_btn hdt-card-product__btn-compare', placement: 'right'
            endif -%}
        </div>
        {%- if card_product.metafields.theme.countdown.value != blank %}{% render 'countdown' with card_product.metafields.theme.countdown.value, class: "hdt-pr-countdown hdt-text-base hdt-font-semibold" %}{% endif -%}
        <div class="hdt-product-btns hdt-pr-btns-group1 hdt-absolute">
          {%- if settings.show_ultra_btn %}
            {% render 'btn-ultra', class: 'hdt-pr_btn', product: card_product, product_url: product_url, section_id: section_id, disable_sr_only: true, show_qty: settings.show_qty %}
          {% endif -%}
          {%- if settings.show_quick_view %}{% render 'btn-quick-view', class: 'hdt-pr_btn', product: card_product, section_id: section_id, disable_sr_only: true %}{% endif -%}
        </div>
        {%- liquid 
          if size_count > 0
            render 'size-list', size_variants: size_variants, size_variants_avai: size_variants_avai, size_count: size_count
          endif -%}
          {% render 'scrolling_badge', product: card_product %}
      </div>
      <div class="hdt-card-product__info hdt-card-align-{{ settings.pr_card_alignment }}">
        {%- if settings.show_rating %}{% render 'hdt-pr-card-rating', product: card_product %}{% endif -%}
        {%- liquid
        if card_product.vendor.size > 0 and show_vendor
          render 'vendor' with card_product.vendor, class: 'hdt-inline-block hdt-text-base hdt-font-normal'
        endif -%}
        <div class="star-ratings" style="display:none;">
          <div class="stars">
            {% liquid
              if card_product.metafields.reviews.rating.value != blank
                assign rating_value = card_product.metafields.reviews.rating.value.rating
              else
                assign rating_value = 4.9
              endif
              assign rating_floor = rating_value | floor
              assign rating_decimal = rating_value | modulo: 1
              assign next_star = rating_floor | plus: 1
            %}
            
            {% for i in (1..5) %}
              {% if i <= rating_floor %}
                <svg width="16" height="15" viewBox="0 0 16 15" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M7.6084 0L9.40451 5.52786H15.2169L10.5146 8.94427L12.3107 14.4721L7.6084 11.0557L2.90612 14.4721L4.70223 8.94427L-5.38826e-05 5.52786H5.81229L7.6084 0Z" fill="#F0BE61"/>
                </svg>
              {% elsif i == next_star and rating_decimal > 0 %}
                <svg width="16" height="15" viewBox="0 0 16 15" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <defs>
                    <linearGradient id="partial-fill-{{ card_product.id }}-{{ i }}">
                      <stop offset="{{ rating_decimal | times: 100 }}%" stop-color="#F0BE61"/>
                      <stop offset="{{ rating_decimal | times: 100 }}%" stop-color="#D9D9D9"/>
                    </linearGradient>
                  </defs>
                  <path d="M7.6084 0L9.40451 5.52786H15.2169L10.5146 8.94427L12.3107 14.4721L7.6084 11.0557L2.90612 14.4721L4.70223 8.94427L-5.38826e-05 5.52786H5.81229L7.6084 0Z" fill="url(#partial-fill-{{ card_product.id }}-{{ i }})"/>
                </svg>
              {% else %}
                <svg width="16" height="15" viewBox="0 0 16 15" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M7.6084 0L9.40451 5.52786H15.2169L10.5146 8.94427L12.3107 14.4721L7.6084 11.0557L2.90612 14.4721L4.70223 8.94427L-5.38826e-05 5.52786H5.81229L7.6084 0Z" fill="#D9D9D9"/>
                </svg>
              {% endif %}
            {% endfor %}
          </div>  
          <div class="rating">{{ rating_value }}</div>  
        </div>
        <div class="areviews_product_item areviews_stars{{ card_product.id }}" data-product-id="{{ card_product.id }}"></div>

        <a data-pr-url href="{{ product_url }}" class="hdt-card-product__title hdt-text-{{ settings.pr_title_size }} hdt-font-{{ settings.pr_title_weight }} {% if settings.hdt_show_long_title == false %} hdt-line-clamp {% endif %}" data-instant>{{ card_product.title | escape }}</a>
        <div class="ict-wrapper">
          <div class="ict-1">
            <svg class="ict-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="10" cy="10" r="7.5" stroke="black" stroke-width="1.45833"/>
              <path d="M6.66671 10L9.16671 12.5L13.3334 7.5" stroke="black" stroke-width="1.45833"/>
            </svg>
            <div class="ict-text">
              {% if card_product.metafields.custom.card_product_text != blank %}
                {{ card_product.metafields.custom.card_product_text }}
              {% else %} 
                In Stock, Same day shipping
              {% endif %}
            </div>
          </div>
          <div class="ict-2">
            <svg class="ict-icon-2" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="10" cy="10" r="7.5" stroke="black" stroke-width="1.45833"/>
              <path d="M6.66671 10L9.16671 12.5L13.3334 7.5" stroke="black" stroke-width="1.45833"/>
            </svg>
            <div class="ict-text">
              {% if card_product.metafields.custom.card_product_text_2 != blank %}
                {{ card_product.metafields.custom.card_product_text_2 }}
              {% else %} 
                Certified Quality
              {% endif %}
            </div>
          </div>
        </div>
        <div class="price-with-badge">
          {%- liquid
            render 'card-price', product: card_product, show_volume_note: true, price_class: "hdt-text-base hdt-font-semibold"
          -%}
          {%- if on_sale -%}
            <span class="sale-badge">{{ discount_percentage }}% OFF</span>
          {%- endif -%}
        </div>

        {% if section.settings.show_compare_solid_btn %}
        <div class="hdt-product-btns compare-solid-btn hdt-pr-btns-group2">
          {%- liquid
            if settings.compare_mode != "0"
              render 'btn-compare', product_id: card_product.id, product_handle: card_product.handle, class: 'hdt-pr_btn hdt-card-product__btn-compare', placement: 'right'
            endif -%}
        </div>
        {% endif %}
      </div>
    </div>
  </hdt-card-product>

<script>
(function() {
  /* Only run once globally */
  if (window.__card2MobileInit) return;
  window.__card2MobileInit = true;

  function isMobile() { return window.innerWidth <= 768; }

  /* ===== CRITICAL: Block outer carousel from capturing inner slider touches ===== */
  /* The outer featured-collection-carousel uses capture:true on .hdt-slider__viewport.
     We register on document FIRST (before carousel script runs) so our capture listener
     fires before theirs on the same capture phase traversal down the DOM. */
  if (isMobile() && !window.__mobileSliderGuard) {
    window.__mobileSliderGuard = true;
    var innerSliderActive = false;

    document.addEventListener('touchstart', function(e) {
      if (e.target.closest && e.target.closest('.mobile-slider-track')) {
        innerSliderActive = true;
      } else {
        innerSliderActive = false;
      }
    }, true);

    // On the viewport level, intercept and stop if inner slider is active
    // We do this after DOMContentLoaded when viewports exist
    function guardViewports() {
      document.querySelectorAll('.hdt-slider__viewport').forEach(function(vp) {
        if (vp.dataset.innerGuard) return;
        vp.dataset.innerGuard = 'true';

        ['touchstart', 'touchmove', 'touchend', 'touchcancel'].forEach(function(evt) {
          vp.addEventListener(evt, function(e) {
            if (e.target.closest && e.target.closest('.mobile-slider-track')) {
              e.stopImmediatePropagation();
            }
          }, true);
        });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', guardViewports);
    } else {
      guardViewports();
    }
    // Also guard any dynamically added viewports
    new MutationObserver(function() { guardViewports(); })
      .observe(document.body || document.documentElement, { childList: true, subtree: true });
  }

  function initCard2Mobile() {
    if (!isMobile()) return;

    /* ===== STOP SLIDER FROM PROPAGATING TO PARENT CAROUSEL ===== */
    document.querySelectorAll('.card-2 .mobile-slider-track').forEach(function(track) {
      if (track.dataset.stopInit) return;
      track.dataset.stopInit = 'true';
      
      // Additional bubble-phase stopPropagation as backup
      ['touchstart', 'touchmove', 'touchend', 'touchcancel'].forEach(function(evt) {
        track.addEventListener(evt, function(e) {
          e.stopPropagation();
        }, { passive: true });
      });

      // Watch scroll position for swipe detection
      setupTrackScrollWatch(track);
    });

    /* ===== BLOCK <a> LINK INSIDE MEDIA ON MOBILE ===== */
    document.querySelectorAll('.card-2 .hdt-card-product__media a[data-pr-url]').forEach(function(link) {
      if (link.dataset.blockInit) return;
      link.dataset.blockInit = 'true';
      link.addEventListener('click', function(e) {
        if (isMobile()) { e.preventDefault(); e.stopPropagation(); }
      }, true);
    });
  }

  /* ===== TAP/CLICK TO REVEAL OVERLAYS ===== */
  /* Uses click event only - works for both real devices and DevTools */
  /* Touch events may be blocked by the viewport guard, so we detect swipe via scroll position */

  // Track scroll on each slider track to detect swipes
  var trackScrollState = new WeakMap();

  document.addEventListener('mousedown', function(e) {
    if (!isMobile()) return;
    var track = e.target.closest('.mobile-slider-track');
    if (track) {
      trackScrollState.set(track, track.scrollLeft);
    }
  }, true);

  // For touch - use a capturing listener on each track (registered in initCard2Mobile)
  function setupTrackScrollWatch(track) {
    track.addEventListener('touchstart', function() {
      trackScrollState.set(track, track.scrollLeft);
    });
  }

  // Click handler does all the work
  document.addEventListener('click', function(e) {
    if (!isMobile()) return;

    var mediaEl = e.target.closest('.card-2 .hdt-card-product__media');
    if (!mediaEl) {
      // Click outside - close all
      closeAllOverlays();
      return;
    }

    if (isOverlayElement(e.target)) return;
    if (!isImageArea(e.target)) return;

    // Check if the slider was swiped (scroll position changed)
    var track = mediaEl.querySelector('.mobile-slider-track');
    if (track && trackScrollState.has(track)) {
      var startScroll = trackScrollState.get(track);
      if (Math.abs(track.scrollLeft - startScroll) > 10) {
        // Was a swipe, don't toggle
        return;
      }
    }

    toggleOverlay(mediaEl);
  });

  function isOverlayElement(el) {
    return el.closest('.hdt-pr-btns-group1') ||
      el.closest('.hdt-pr-btns-group2') ||
      el.closest('.hdt-color-picker-wrapper') ||
      el.closest('.hdt-color-picker-trigger') ||
      el.closest('hdt-wishlist') ||
      el.closest('hdt-compare') ||
      el.closest('wrapp-hdt-open-modal-btn') ||
      el.closest('.hdt-badge__wrapp');
  }

  function isImageArea(el) {
    return el.closest('.mobile-slider-track') ||
      el.closest('.mobile-slider-slide') ||
      el.closest('.hdt-card-product__media-wrapp') ||
      el.classList.contains('hdt-card-product__media--main') ||
      el.classList.contains('mobile-slider-img');
  }

  function toggleOverlay(mediaEl) {
    var isActive = mediaEl.classList.contains('mobile-tapped');
    closeAllOverlays(mediaEl);
    mediaEl.classList.toggle('mobile-tapped', !isActive);
  }

  function closeAllOverlays(except) {
    document.querySelectorAll('.card-2 .hdt-card-product__media.mobile-tapped').forEach(function(c) {
      if (c !== except) c.classList.remove('mobile-tapped');
    });
  }

  /* ===== COLOR PICKER → VARIANT IMAGE CHANGE ===== */
  document.addEventListener('click', function(e) {
    if (!isMobile()) return;

    // Match the label.hdt-color-swatch or anything inside it
    var swatch = e.target.closest('.hdt-color-swatch, .hdt-color-picker__item, .hdt-color-picker__btn');
    if (!swatch) return;

    var cardProduct = swatch.closest('hdt-card-product');
    if (!cardProduct) return;

    var track = cardProduct.querySelector('.mobile-slider-track');
    if (!track) return;

    // Get the input inside the swatch - it has data-image and data-variant-id
    var input = swatch.querySelector('input[data-image]') || swatch.querySelector('input[data-variant-id]');
    
    // Also check if clicked element itself has data-image
    var dataImage = null;
    var variantId = null;

    if (input) {
      dataImage = input.getAttribute('data-image');
      variantId = input.getAttribute('data-variant-id');
    }

    // Fallback: check swatch itself or parent
    if (!dataImage) {
      dataImage = swatch.getAttribute('data-image') || e.target.getAttribute('data-image');
    }

    // METHOD 1: Direct image URL from data-image attribute (fastest, no API call needed)
    if (dataImage) {
      // Clean URL and find matching slide by comparing image src
      var cleanUrl = dataImage.replace(/^\/\//, 'https://').split('?')[0].toLowerCase();
      
      var slides = track.querySelectorAll('.mobile-slider-slide');
      var matched = false;

      for (var i = 0; i < slides.length; i++) {
        var slideImg = slides[i].querySelector('img');
        if (!slideImg) continue;
        var slideSrc = (slideImg.getAttribute('src') || '').split('?')[0].toLowerCase();
        
        // Compare the filename portion
        var dataFilename = cleanUrl.split('/').pop();
        var slideFilename = slideSrc.split('/').pop();
        
        if (dataFilename && slideFilename && dataFilename === slideFilename) {
          track.scrollTo({ left: i * track.offsetWidth, behavior: 'smooth' });
          matched = true;
          break;
        }
      }

      // Also update the main (desktop) image
      var mainImg = cardProduct.querySelector('.hdt-card-product__media--main');
      if (mainImg) {
        var newSrc = dataImage.replace(/^\/\//, 'https://');
        mainImg.setAttribute('src', newSrc);
        mainImg.setAttribute('srcset', '');
      }

      // If no slide matched by filename, try API fallback
      if (!matched && variantId) {
        var handle = cardProduct.getAttribute('data-product-handle');
        if (handle) {
          fetch('/products/' + handle + '.js')
            .then(function(res) { return res.json(); })
            .then(function(data) {
              for (var v = 0; v < data.variants.length; v++) {
                if (String(data.variants[v].id) === String(variantId) && data.variants[v].featured_media) {
                  var mediaId = data.variants[v].featured_media.id;
                  var targetSlide = track.querySelector('[data-media-id="' + mediaId + '"]');
                  if (targetSlide) {
                    track.scrollTo({ left: parseInt(targetSlide.dataset.slideIndex) * track.offsetWidth, behavior: 'smooth' });
                  }
                  break;
                }
              }
            })
            .catch(function() {});
        }
      }
      return;
    }

    // METHOD 2: No data-image, use variant-id + API
    if (variantId) {
      var handle = cardProduct.getAttribute('data-product-handle');
      if (!handle) return;

      fetch('/products/' + handle + '.js')
        .then(function(res) { return res.json(); })
        .then(function(data) {
          for (var v = 0; v < data.variants.length; v++) {
            if (String(data.variants[v].id) === String(variantId) && data.variants[v].featured_media) {
              var mediaId = data.variants[v].featured_media.id;
              var targetSlide = track.querySelector('[data-media-id="' + mediaId + '"]');
              if (targetSlide) {
                track.scrollTo({ left: parseInt(targetSlide.dataset.slideIndex) * track.offsetWidth, behavior: 'smooth' });
              }
              if (data.variants[v].featured_media.preview_image) {
                var mainImg = cardProduct.querySelector('.hdt-card-product__media--main');
                if (mainImg) {
                  mainImg.setAttribute('src', data.variants[v].featured_media.preview_image.src);
                  mainImg.setAttribute('srcset', '');
                }
              }
              break;
            }
          }
        })
        .catch(function(err) { console.warn('Color picker fetch error:', err); });
    }
  });

  /* ===== INIT ===== */
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCard2Mobile);
  } else {
    initCard2Mobile();
  }
  document.addEventListener('shopify:section:load', initCard2Mobile);

  new MutationObserver(function(mutations) {
    var hasNew = false;
    mutations.forEach(function(m) { if (m.addedNodes.length) hasNew = true; });
    if (hasNew) initCard2Mobile();
  }).observe(document.body, { childList: true, subtree: true });

})();
</script>
