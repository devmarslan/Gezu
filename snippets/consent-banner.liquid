<!-- ===== CONSENT BANNER V2 — gezuimpex.com ===== -->
<style>
  #cm-overlay {
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.55);
    z-index: 999998;
    display: flex; align-items: center; justify-content: center;
    padding: 16px;
  }
  #cm-box {
    background: #fff;
    border-radius: 12px;
    max-width: 520px; width: 100%;
    padding: 36px 32px;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }
  #cm-box h2 { font-size: 20px; font-weight: 600; color: #111; margin: 0 0 10px; }
  #cm-box p  { font-size: 14px; color: #555; line-height: 1.6; margin: 0; }
  .cm-icon-wrap {
    width: 40px; height: 40px; border-radius: 50%;
    background: #fdecea;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 12px;
  }
  .cm-label {
    font-size: 11px; font-weight: 600; color: #0047ab;
    letter-spacing: 0.08em; text-transform: uppercase;
    margin: 0 0 8px; text-align: center;
  }
  .cm-btn-accept {
    width: 100%; padding: 13px;
    background: #0047ab; color: #fff;
    border: none; border-radius: 8px;
    font-size: 15px; font-weight: 600; cursor: pointer;
  }
  .cm-btn-manage {
    width: 100%; padding: 13px;
    background: #fff; color: #111;
    border: 1.5px solid #ddd; border-radius: 8px;
    font-size: 15px; font-weight: 500; cursor: pointer;
    margin-top: 10px;
  }
  .cm-footer { text-align: center; font-size: 12px; color: #999; margin: 16px 0 0; }
  .cm-footer a { color: #0047ab; text-decoration: none; }
  #cm-prefs { display: none; }
  .cm-toggle-row {
    display: flex; justify-content: space-between; align-items: center;
    padding: 12px 0; border-bottom: 1px solid #f0f0f0;
  }
  .cm-toggle-row:last-of-type { border-bottom: none; }
  .cm-toggle-label { font-size: 14px; font-weight: 500; color: #111; }
  .cm-toggle-desc { font-size: 12px; color: #888; margin-top: 2px; }
  .cm-switch { position: relative; display: inline-block; width: 42px; height: 24px; flex-shrink: 0; }
  .cm-switch input { opacity: 0; width: 0; height: 0; }
  .cm-slider {
    position: absolute; inset: 0;
    background: #ddd; border-radius: 24px;
    cursor: pointer; transition: 0.2s;
  }
  .cm-slider:before {
    content: ''; position: absolute;
    width: 18px; height: 18px; left: 3px; bottom: 3px;
    background: #fff; border-radius: 50%; transition: 0.2s;
  }
  .cm-switch input:checked + .cm-slider { background: #0047ab; }
  .cm-switch input:checked + .cm-slider:before { transform: translateX(18px); }
  .cm-switch input:disabled + .cm-slider { opacity: 0.5; cursor: not-allowed; }
  .cm-btn-save {
    width: 100%; padding: 13px;
    background: #0047ab; color: #fff;
    border: none; border-radius: 8px;
    font-size: 15px; font-weight: 600; cursor: pointer;
    margin-top: 20px;
  }
  .cm-back {
    font-size: 13px; color: #0047ab; cursor: pointer;
    display: inline-flex; align-items: center; gap: 4px;
    margin-bottom: 16px; background: none; border: none; padding: 0;
  }
</style>

<div id="cm-overlay" style="display:none;">
  <div id="cm-box">

    <!-- Schermata principale -->
    <div id="cm-main">
      <div style="text-align:center; margin-bottom:20px;">
        <div class="cm-icon-wrap">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#a81d06" stroke-width="2">
            <circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/>
          </svg>
        </div>
        <p class="cm-label" id="cm-t-label"></p>
        <h2 id="cm-t-title"></h2>
        <p id="cm-t-body"></p>
      </div>
      <button class="cm-btn-accept" id="cm-accept-all"></button>
      <button class="cm-btn-manage" id="cm-open-prefs"></button>
      <p class="cm-footer">
        <a href="/fr/policies/privacy-policy" id="cm-t-privacy"></a>
        &nbsp;·&nbsp;
        <a href="/fr/policies/cookie-policy" id="cm-t-cookies"></a>
      </p>
    </div>

    <!-- Pannello preferenze -->
    <div id="cm-prefs">
      <button class="cm-back" id="cm-back"></button>
      <h2 id="cm-t-prefs-title" style="margin-bottom:4px;"></h2>
      <p id="cm-t-prefs-body" style="margin-bottom:20px;"></p>

      <div class="cm-toggle-row">
        <div>
          <div class="cm-toggle-label" id="cm-t-necessary"></div>
          <div class="cm-toggle-desc" id="cm-t-necessary-desc"></div>
        </div>
        <label class="cm-switch">
          <input type="checkbox" checked disabled>
          <span class="cm-slider"></span>
        </label>
      </div>

      <div class="cm-toggle-row">
        <div>
          <div class="cm-toggle-label" id="cm-t-analytics"></div>
          <div class="cm-toggle-desc" id="cm-t-analytics-desc"></div>
        </div>
        <label class="cm-switch">
          <input type="checkbox" id="cm-analytics">
          <span class="cm-slider"></span>
        </label>
      </div>

      <div class="cm-toggle-row">
        <div>
          <div class="cm-toggle-label" id="cm-t-marketing"></div>
          <div class="cm-toggle-desc" id="cm-t-marketing-desc"></div>
        </div>
        <label class="cm-switch">
          <input type="checkbox" id="cm-marketing">
          <span class="cm-slider"></span>
        </label>
      </div>

      <button class="cm-btn-save" id="cm-save-prefs"></button>
    </div>

  </div>
</div>

<script>
(function() {
  var COOKIE = 'gezuimpex_consent_v2';
  var DAYS   = 365;

  var i18n = {
    fr: {
      label:         'Gestion des cookies',
      title:         'Votre vie privée nous importe',
      body:          'Nous utilisons des cookies pour améliorer votre expérience, analyser le trafic et personnaliser les publicités. Vous pouvez accepter tous les cookies ou gérer vos préférences.',
