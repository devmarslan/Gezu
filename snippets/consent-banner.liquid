    },
    en: {
      label:         'Cookie settings',
      title:         'Your privacy matters to us',
      body:          'We use cookies to improve your browsing experience, analyse traffic and personalise ads. You can accept all cookies or manage your preferences.',
      acceptAll:     'Accept all',
      manage:        'Manage preferences',
      privacy:       'Privacy policy',
      cookies:       'Cookie policy',
      prefsTitle:    'Cookie preferences',
      prefsBody:     'Enable or disable each category according to your preferences.',
      back:          '← Back',
      necessary:     'Necessary',
      necessaryDesc: 'Required for the website to function',
      analytics:     'Analytics',
      analyticsDesc: 'Google Analytics — anonymous audience measurement',
      marketing:     'Marketing',
      marketingDesc: 'Google Ads, Meta — personalised advertising',
      save:          'Save my choices'
    },
    nl: {
      label:         'Cookiebeheer',
      title:         'Uw privacy is belangrijk voor ons',
      body:          'Wij gebruiken cookies om uw browse-ervaring te verbeteren, verkeer te analyseren en advertenties te personaliseren. U kunt alle cookies accepteren of uw voorkeuren beheren.',
      acceptAll:     'Alles accepteren',
      manage:        'Voorkeuren beheren',
      privacy:       'Privacybeleid',
      cookies:       'Cookiebeleid',
      prefsTitle:    'Cookie-voorkeuren',
      prefsBody:     'Schakel elke categorie in of uit volgens uw voorkeuren.',
      back:          '← Terug',
      necessary:     'Noodzakelijk',
      necessaryDesc: 'Vereist voor het functioneren van de website',
      analytics:     'Analytisch',
      analyticsDesc: 'Google Analytics — anonieme publieksmeting',
      marketing:     'Marketing',
      marketingDesc: 'Google Ads, Meta — gepersonaliseerde advertenties',
      save:          'Mijn keuzes opslaan'
    },
    de: {
      label:         'Cookie-Einstellungen',
      title:         'Ihre Privatsphäre ist uns wichtig',
      body:          'Wir verwenden Cookies, um Ihr Erlebnis zu verbessern, den Datenverkehr zu analysieren und Werbung zu personalisieren. Sie können alle Cookies akzeptieren oder Ihre Einstellungen verwalten.',
      acceptAll:     'Alle akzeptieren',
      manage:        'Einstellungen verwalten',
      privacy:       'Datenschutzrichtlinie',
      cookies:       'Cookie-Richtlinie',
      prefsTitle:    'Cookie-Einstellungen',
      prefsBody:     'Aktivieren oder deaktivieren Sie jede Kategorie nach Ihren Wünschen.',
      back:          '← Zurück',
      necessary:     'Notwendig',
      necessaryDesc: 'Für den Betrieb der Website erforderlich',
      analytics:     'Analytisch',
      analyticsDesc: 'Google Analytics — anonyme Zielgruppenmessung',
      marketing:     'Marketing',
      marketingDesc: 'Google Ads, Meta — personalisierte Werbung',
      save:          'Meine Auswahl speichern'
    },
    it: {
      label:         'Gestione cookie',
      title:         'La tua privacy è importante per noi',
      body:          'Utilizziamo i cookie per migliorare la tua esperienza, analizzare il traffico e personalizzare gli annunci. Puoi accettare tutti i cookie o gestire le tue preferenze.',
      acceptAll:     'Accetta tutto',
      manage:        'Gestisci preferenze',
      privacy:       'Informativa sulla privacy',
      cookies:       'Informativa sui cookie',
      prefsTitle:    'Preferenze cookie',
      prefsBody:     'Attiva o disattiva ogni categoria secondo le tue preferenze.',
      back:          '← Indietro',
      necessary:     'Necessari',
      necessaryDesc: 'Indispensabili per il funzionamento del sito',
      analytics:     'Analitici',
      analyticsDesc: 'Google Analytics — misurazione anonima del pubblico',
      marketing:     'Marketing',
      marketingDesc: 'Google Ads, Meta — pubblicità personalizzata',
      save:          'Salva le mie scelte'
    },
    es: {
      label:         'Gestión de cookies',
      title:         'Tu privacidad nos importa',
      body:          'Usamos cookies para mejorar tu experiencia, analizar el tráfico y personalizar los anuncios. Puedes aceptar todas las cookies o gestionar tus preferencias.',
      acceptAll:     'Aceptar todo',
      manage:        'Gestionar preferencias',
      privacy:       'Política de privacidad',
      cookies:       'Política de cookies',
      prefsTitle:    'Preferencias de cookies',
      prefsBody:     'Activa o desactiva cada categoría según tus preferencias.',
      back:          '← Volver',
      necessary:     'Necesarias',
      necessaryDesc: 'Imprescindibles para el funcionamiento del sitio',
      analytics:     'Analíticas',
      analyticsDesc: 'Google Analytics — medición anónima de audiencia',
      marketing:     'Marketing',
      marketingDesc: 'Google Ads, Meta — publicidad personalizada',
      save:          'Guardar mis preferencias'
    }
  };

  var lang = (navigator.language || navigator.userLanguage || 'en').slice(0,2).toLowerCase();
  var t    = i18n[lang] || i18n['en'];

  function applyTranslations() {
    document.getElementById('cm-t-label').textContent         = t.label;
    document.getElementById('cm-t-title').textContent         = t.title;
    document.getElementById('cm-t-body').textContent          = t.body;
    document.getElementById('cm-accept-all').textContent      = t.acceptAll;
    document.getElementById('cm-open-prefs').textContent      = t.manage;
    document.getElementById('cm-t-privacy').textContent       = t.privacy;
    document.getElementById('cm-t-cookies').textContent       = t.cookies;
    document.getElementById('cm-back').textContent            = t.back;
    document.getElementById('cm-t-prefs-title').textContent   = t.prefsTitle;
    document.getElementById('cm-t-prefs-body').textContent    = t.prefsBody;
    document.getElementById('cm-t-necessary').textContent     = t.necessary;
    document.getElementById('cm-t-necessary-desc').textContent= t.necessaryDesc;
    document.getElementById('cm-t-analytics').textContent     = t.analytics;
    document.getElementById('cm-t-analytics-desc').textContent= t.analyticsDesc;
    document.getElementById('cm-t-marketing').textContent     = t.marketing;
    document.getElementById('cm-t-marketing-desc').textContent= t.marketingDesc;
    document.getElementById('cm-save-prefs').textContent      = t.save;
  }

  function gtag() { window.dataLayer = window.dataLayer || []; window.dataLayer.push(arguments); }

  function setCookie(val) {
    var d = new Date();
    d.setTime(d.getTime() + DAYS * 86400000);
    document.cookie = COOKIE + '=' + encodeURIComponent(JSON.stringify(val))
      + ';expires=' + d.toUTCString() + ';path=/;SameSite=Lax;Secure';
  }

  function getCookie() {
    var m = document.cookie.match('(^| )' + COOKIE + '=([^;]+)');
    try { return m ? JSON.parse(decodeURIComponent(m[2])) : null; } catch(e) { return null; }
  }

  function applyConsent(analytics, marketing) {
    var a = analytics ? 'granted' : 'denied';
    var m = marketing  ? 'granted' : 'denied';
    gtag('consent', 'update', {
      'analytics_storage':     a,
      'ad_storage':            m,
      'ad_user_data':          m,
      'ad_personalization':    m,
      'functionality_storage': a
    });
    window.dataLayer.push({
      event:             'consent_update',
      consent_analytics: a,
      consent_marketing: m
    });
  }

  function hideOverlay() {
    document.getElementById('cm-overlay').style.display = 'none';
    document.body.style.overflow = '';
  }

  var saved = getCookie();

  if (saved) {
    applyConsent(saved.analytics, saved.marketing);
  } else {
    applyTranslations();
    document.getElementById('cm-overlay').style.display = 'flex';
    document.body.style.overflow = 'hidden';

    document.getElementById('cm-accept-all').addEventListener('click', function() {
      setCookie({ analytics: true, marketing: true });
      applyConsent(true, true);
      hideOverlay();
    });

    document.getElementById('cm-open-prefs').addEventListener('click', function() {
      document.getElementById('cm-main').style.display  = 'none';
      document.getElementById('cm-prefs').style.display = 'block';
    });

    document.getElementById('cm-back').addEventListener('click', function() {
      document.getElementById('cm-prefs').style.display = 'none';
      document.getElementById('cm-main').style.display  = 'block';
    });

    document.getElementById('cm-save-prefs').addEventListener('click', function() {
      var a = document.getElementById('cm-analytics').checked;
      var m = document.getElementById('cm-marketing').checked;
      setCookie({ analytics: a, marketing: m });
      applyConsent(a, m);
      hideOverlay();
    });
  }

})();
</script>
<!-- ===== END CONSENT BANNER ===== -->