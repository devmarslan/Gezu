{%- comment -%}
  Renders a color list with color picker popup
  - NO HOVER required: Always visible
  - Instant image swapping
  - Supports theme sliders (auto-scrolling)
  - Features JSON fallback for variant images
{%- endcomment -%}

{%- if settings.color_mode == 'color' -%}
  {%- liquid
    assign colors = shop.metafields.ecomrise.colors.value
    assign color_values = shop.metaobjects.theme_swatch.values | first
    assign colors_2 = color_values.colors.value
    
    assign selected_variant = product.selected_or_first_available_variant | default: product.variants.first
    assign selected_color = selected_variant[color_option_index]
  -%}

  <style>
    /* 1. Hide theme's native color trigger icons */
    .hdt-color-picker-trigger, 
    .hdt-color-picker-btn,
    .hdt-color-list > button,
    button[class*="color-picker"],
    [class*="color-picker-trigger"] {
      display: none !important;
    }

    /* 2. Style the new permanent horizontal swatch list */
    .hdt-color-picker-wrapper.js-color-picker {
      position: relative !important;
      z-index: 5 !important;
      display: flex !important;
      opacity: 1 !important;
      visibility: visible !important;
      pointer-events: auto !important;
      background: transparent !important;
      backdrop-filter: none !important;
      padding: 0 !important;
      margin:0 !important;
      border-radius: 0 !important;
      box-shadow: none !important;
      transform: none !important;
      transition: all 0.3s ease !important;
    }

    .hdt-color-picker-colors {
      display: flex !important;
      flex-direction: row !important; /* Horizontal layout */
      flex-wrap: wrap !important;
      align-items: center !important;
      gap: 6px !important;
      opacity: 1 !important;
      visibility: visible !important;
    }

    .hdt-color-swatch-item {
      position: relative !important;
      width: 24px !important;
      height: 24px !important;
      border-radius: 50% !important;
      cursor: pointer !important;
      border: 1px solid #e8e8e8 !important;
      transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1) !important;
      display: block !important;
    }

    .hdt-color-swatch-item:hover {
      transform: scale(1.1) !important;
    }

    .hdt-color-swatch-item.is-selected {
      border-color: #0047AB !important; /* Premium blue accent */
      border-width: 2px !important;
    }

    .hdt-color-swatch-item .color-bg {
      position: absolute !important;
      top: 2px !important;
      left: 2px !important;
      right: 2px !important;
      bottom: 2px !important;
      border-radius: 50% !important;
      background-color: var(--swatch-color, #ccc);
      background-image: var(--swatch-image, none);
      background-size: cover;
      display: block !important;
    }

    @media (max-width: 768px) {
      .hdt-color-swatch-item {
        width: 20px !important;
        height: 20px !important;
      }
    }
  </style>

  <div class="hdt-color-picker-wrapper js-color-picker" data-product-handle="{{ product.handle }}">
    <div class="hdt-color-picker-colors js-color-list">
      {%- for color in color_variants -%}
        {%- liquid
          unless color_variants_avai contains color or settings.color_type == 'all'
            continue
          endunless
          assign color_handle = color | handle
          assign color_obj = colors[color_handle] | default: colors_2[color_handle]
          
          assign variants_has_color = product.variants | where: color_option_index, color
          
          comment
            Robust image detection. Some stores use featured_image, others use image or featured_media.
          endcomment
          assign variant_with_image = variants_has_color | where: 'featured_image' | first
          if variant_with_image == blank
            assign variant_with_image = variants_has_color | where: 'image' | first
          endif
          assign variant_first = variant_with_image | default: variants_has_color.first
          
          assign variant_image_url = ''
          if variant_first.featured_image
            assign variant_image_url = variant_first.featured_image | image_url: width: 1000
          elsif variant_first.image
            assign variant_image_url = variant_first.image | image_url: width: 1000
          endif

          assign is_selected = false
          if selected_color == color
            assign is_selected = true
          endif
        -%}

        {%- capture swatch_style -%}
          {%- if color.swatch.color != blank -%}
            --swatch-color: {{ color.swatch.color }};
          {%- elsif color_obj.colorsCSS != blank -%}
             {%- assign css_val = color_obj.colorsCSS | split: ':' | last | remove: ';' | strip -%}
             {%- if color_obj.colorsCSS contains 'image' -%}
                --swatch-image: url({{ css_val }});
             {%- else -%}
                --swatch-color: {{ css_val }};
             {%- endif -%}
          {%- else -%}
            {%- case color_handle -%}
              {%- when 'black', 'noir', 'nero', 'negro', 'zwart' -%} --swatch-color: #000;
              {%- when 'white', 'blanc', 'bianco', 'blanco', 'wit' -%} --swatch-color: #fff;
              {%- when 'pc-brown' -%} --swatch-color: #4d3326;
              {%- when 'hot-dip-galvanised', 'galvanised', 'silver', 'argent', 'plata', 'zilver' -%} --swatch-color: #9BA4A9;
              {%- when 'grey', 'gray', 'gris', 'grigio', 'grijs' -%} --swatch-color: #808080;
              {%- when 'red', 'rouge', 'rosso', 'rojo', 'rood' -%} --swatch-color: #ff0000;
              {%- when 'blue', 'bleu', 'blu', 'azul', 'blauw' -%} --swatch-color: #0000ff;
              {%- when 'green', 'vert', 'verde', 'groen' -%} --swatch-color: #008000;
              {%- when 'yellow', 'jaune', 'giallo', 'amarillo', 'geel' -%} --swatch-color: #ffff00;
              {%- when 'orange', 'arancio', 'naranja' -%} --swatch-color: #ffa500;
              {%- when 'brown', 'marron', 'marrone', 'marrón', 'bruin' -%} --swatch-color: #a52a2a;
              {%- else -%} --swatch-color: #cccccc;
            {%- endcase -%}
          {%- endif -%}
        {%- endcapture -%}

        {%- capture price_html -%}
          {%- assign money_price = variant_first.price | money -%}
          {%- if money_price contains '.' -%}
            {%- assign parts = money_price | split: '.' -%}
            {{ parts[0] }}.<span class="hdt-price__decimal">{{ parts[1] | slice: 0, 2 }}</span>
          {%- else -%}
            {{ money_price }}
          {%- endif -%}
        {%- endcapture -%}

        {%- liquid
          assign stock_text = 'products.product.in_stock_shipping' | t
          if variant_first.available == false
            assign stock_text = 'products.product.sold_out' | t
          elsif variant_first.metafields.custom.variant_usps.value != blank
            assign stock_text = variant_first.metafields.custom.variant_usps.value
          endif

          assign stock_text_2 = 'products.product.certified_quality' | t
          if variant_first.metafields.custom.variant_usps_second.value != blank
            assign stock_text_2 = variant_first.metafields.custom.variant_usps_second.value
          endif
        -%}
        <div class="hdt-color-swatch-item js-permanent-swatch{% if is_selected %} is-selected{% endif %}" 
             title="{{ color | escape }}" 
             style="{{ swatch_style | strip_newlines }}"
             data-variant-id="{{ variant_first.id }}"
             data-image-src="{{ variant_image_url }}"
             data-price-html='{{ price_html | strip }}'
             data-stock-text="{{ stock_text | escape }}"
             data-stock-text-2="{{ stock_text_2 | escape }}"
             data-available="{{ variant_first.available }}">
          <span class="color-bg"></span>
        </div>
      {%- endfor -%}
    </div>
  </div>

  <script>
    (function(){
      if (window.hdtSwatchEngineActive) return;
      window.hdtSwatchEngineActive = true;

      function performImageSwap(card, imageUrl, variantId) {
        if (!card) return;

        /* Strip query string and Shopify size suffix (_300x.jpg, _500x500.jpg)
           so URLs that point to the same source image match across sizes. */
        function baseName(url) {
          if (!url) return '';
          var clean = url.split('?')[0].toLowerCase();
          var name = clean.split('/').pop();
          return name.replace(/_\d+x(\d+)?(\.\w+)$/, '$2');
        }

        function updateDOM(url) {
          if (!url || url.trim() === '') return;

          /* A. Handle Slider Cards */
          var track = card.querySelector('.mobile-slider-track');
          var swipedSlider = false;

          if (track) {
            var slides = track.querySelectorAll('.mobile-slider-slide img');
            var target = baseName(url);
            for (var i = 0; i < slides.length; i++) {
              if (baseName(slides[i].src) === target) {
                track.scrollTo({ left: i * track.offsetWidth, behavior: 'smooth' });
                swipedSlider = true;
                break;
              }
            }
          }

          /* B. Handle Static Image Cards */
          var imgWrap = card.querySelector('.hdt-card-product__media-wrapp') || card.querySelector('.hdt-card-product__media');
          if (imgWrap) {
            /* Destroy any <source> tags which override the <img> tags based on screen sizes or WebP capabilities */
            var sources = imgWrap.querySelectorAll('source');
            sources.forEach(s => s.remove());

            /* Update ALL images that could potentially be visible using very aggressive attribute stripping */
            var targetImgs = imgWrap.querySelectorAll('img.hdt-card-product__media--main, img.hdt-card-product__media--hover, img[class*="main"]');
            targetImgs.forEach(function(img) {
              img.style.opacity = '0.3';
              img.removeAttribute('srcset');
              img.removeAttribute('data-srcset');
              img.removeAttribute('sizes');
              img.removeAttribute('data-src');
              img.srcset = '';
              img.src = url;
              setTimeout(() => img.style.opacity = '1', 800);
            });
          }
        }

        /* If we have direct image, use it. Otherwise, fetch fallback via API */
        if (imageUrl && imageUrl.trim() !== '') {
          updateDOM(imageUrl);
        } else if (variantId) {
          var handle = card.getAttribute('data-product-handle');
          if (!handle) {
            var picker = card.querySelector('.js-color-picker');
            handle = picker ? picker.getAttribute('data-product-handle') : null;
          }
          
          if (handle) {
            fetch('/products/' + handle + '.js')
              .then(response => response.json())
              .then(data => {
                var foundVariant = data.variants.find(v => String(v.id) === String(variantId));
                if (foundVariant && foundVariant.featured_media && foundVariant.featured_media.preview_image) {
                  updateDOM(foundVariant.featured_media.preview_image.src);
                } else if (foundVariant && foundVariant.featured_image) {
                   updateDOM(foundVariant.featured_image.src);
                }
              })
              .catch(err => console.warn('Fetch fallback error', err));
          }
        }
      }

      /* Sync the card's price element to the initially-selected swatch's
         data-price-html so the price on refresh matches what a swatch click
         would show. card-price.liquid renders product.price / price_min,
         which can differ from the selected variant's actual price. */
      function syncInitialPrice(card, picker) {
        if (!card) return;
        var selected = picker.querySelector('.js-permanent-swatch.is-selected')
                    || picker.querySelector('.js-permanent-swatch');
        if (!selected) return;
        var priceHtml = selected.getAttribute('data-price-html');
        if (!priceHtml) return;
        var priceEl = card.querySelector('.js-card-price');
        if (!priceEl) return;
        if (priceEl.innerHTML.trim() === priceHtml.trim()) return;
        priceEl.innerHTML = priceHtml;
        if (window.Taxify && typeof window.Taxify.rescanAllElements === 'function') {
          window.Taxify.rescanAllElements();
        }
        document.dispatchEvent(new CustomEvent('recently-viewed:loaded'));
      }

      function initPermanentSwatches() {
        document.querySelectorAll('.js-color-picker:not([data-hdt-processed])').forEach(picker => {
          picker.dataset.hdtProcessed = 'true';
          /* Find parent card element regardless of specific template structure */
          var card = picker.closest('hdt-card-product') || picker.closest('.hdt-card-product') || picker.closest('.hdt-product-item');

          syncInitialPrice(card, picker);

          picker.querySelectorAll('.js-permanent-swatch').forEach(swatch => {
            swatch.onclick = function(e) {
              e.preventDefault();
              e.stopPropagation();
              
              picker.querySelectorAll('.js-permanent-swatch').forEach(s => s.classList.remove('is-selected'));
              this.classList.add('is-selected');
              
              var targetImg = this.getAttribute('data-image-src');
              var variantId = this.getAttribute('data-variant-id');
              var priceHtml = this.getAttribute('data-price-html');
              var stockText = this.getAttribute('data-stock-text');
              var stockText2 = this.getAttribute('data-stock-text-2');
              
              performImageSwap(card, targetImg, variantId);
              
              /* Update price on card */
              if (priceHtml && card) {
                var priceEl = card.querySelector('.js-card-price');
                if (priceEl) {
                  priceEl.innerHTML = priceHtml;
                  /* Trigger Taxify rescan if available */
                  if (window.Taxify && typeof window.Taxify.rescanAllElements === 'function') {
                    window.Taxify.rescanAllElements();
                  }
                  /* Trigger decimal formatter if available */
                  document.dispatchEvent(new CustomEvent('recently-viewed:loaded'));
                }
              }

              /* Update stock status and USPs on card */
              if (card) {
                var stockEl = card.querySelector('.js-ict-text-1');
                if (stockEl && stockText) stockEl.textContent = stockText;
                var stockEl2 = card.querySelector('.js-ict-text-2');
                if (stockEl2 && stockText2) stockEl2.textContent = stockText2;
              }
            };
          });
        });
      }

      initPermanentSwatches();
      document.addEventListener('shopify:section:load', initPermanentSwatches);
      new MutationObserver(initPermanentSwatches).observe(document.body, { childList: true, subtree: true });
    })();
  </script>
{%- else -%}
  <div class="hdt-color-list">
    <p class="hdt-color-count">{{- 'products.product.colors_count' | t: count: color_count -}}</p>
  </div>
{%- endif -%}
