<script>
if (!window._cardPriceSymbolFixed) {
  window._cardPriceSymbolFixed = true;

  var RIGHT_SYMBOLS = ['kč', 'kr.', 'kr', 'ft', 'ден', 'zł', 'lei', 'рсд', 'км', 'l'];

  function isRight(sym) {
    return RIGHT_SYMBOLS.indexOf(sym.trim().toLowerCase()) !== -1;
  }

  function reformatCardPrices() {
    document.querySelectorAll('.hdt-price__list.de hdt-price .hdt-money, .hdt-price__list.de .hdt-compare-at-price .hdt-money').forEach(function(el) {
      // Collect text nodes only (skip sr-only, skip decimal spans already set)
      var text = '';
      el.childNodes.forEach(function(node) {
        if (node.nodeType === 3) text += node.textContent;
        else if (node.nodeType === 1 && !node.classList.contains('sr-only') && !node.classList.contains('hdt-price__decimal')) {
          text += node.textContent;
        }
      });
      text = text.trim();
      if (!text) return;

      // LEFT symbol pattern: e.g. £15.40 or €15,40 or CHF 15.40
      var leftMatch = text.match(/^([^\d\s,\.]+)\s*([\d.,]+(?:<[^>]+>\d+<\/[^>]+>)?)$/);
      // RIGHT symbol pattern: e.g. 15.40kr or 15.40 KM
      var rightMatch = text.match(/^([\d.,]+)\s*([^\d\s,\.]+)$/);

      if (leftMatch) {
        var sym = leftMatch[1].trim();
        var num = leftMatch[2].trim();
        if (isRight(sym)) {
          // Move symbol to right
          var decimalSpan = el.querySelector('.hdt-price__decimal');
          var decHTML = decimalSpan ? '.<span class="hdt-price__decimal">' + decimalSpan.textContent + '</span>' : '';
          var numClean = decimalSpan ? num.split('.')[0] : num;
          el.innerHTML = (decimalSpan ? numClean + decHTML : num) + sym;
        } else {
          // Keep left but ensure space
          if (el.innerHTML.indexOf(sym) === -1 && el.innerHTML.indexOf(sym + ' ') === -1) {
            el.innerHTML = el.innerHTML.replace(sym, sym);
          }
        }
      } else if (rightMatch) {
        var num = rightMatch[1].trim();
        var sym = rightMatch[2].trim();
        if (!isRight(sym)) {
          // Move to left
          el.innerHTML = sym + num;
        }
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', reformatCardPrices);
  } else {
    reformatCardPrices();
  }

  // Re-run for dynamic loads (recently viewed, quick view etc)
  document.addEventListener('recently-viewed:loaded', reformatCardPrices);
  document.addEventListener('cart:updated', reformatCardPrices);
}
</script>