<script>
(function() {
  document.addEventListener('DOMContentLoaded', function() {
    initMobilePanelMenu();
  });

  // Re-init when drawer opens (for lazy loaded content)
  document.addEventListener('click', function(e) {
    if (e.target.closest('[aria-controls="menu_mobile"]')) {
      setTimeout(initMobilePanelMenu, 100);
    }
  });

  function initMobilePanelMenu() {
    const panelMenu = document.querySelector('.mobile-panel-menu');
    if (!panelMenu) return;
    
    // Prevent double initialization
    if (panelMenu.dataset.initialized === 'true') return;
    panelMenu.dataset.initialized = 'true';

    const panels = panelMenu.querySelectorAll('.menu-panel');
    const panelHistory = ['main'];

    // Handle all clicks in panel menu
    panelMenu.addEventListener('click', function(e) {
      // Open panel button
      const openBtn = e.target.closest('[data-open-panel]');
      if (openBtn) {
        e.preventDefault();
        e.stopPropagation();
        const targetPanel = openBtn.getAttribute('data-open-panel');
        openPanel(targetPanel);
        return;
      }

      // Back button
      const backBtn = e.target.closest('[data-back-panel]');
      if (backBtn) {
        e.preventDefault();
        e.stopPropagation();
        const targetPanel = backBtn.getAttribute('data-back-panel');
        goBackToPanel(targetPanel);
        return;
      }

      // Close button
      const closeBtn = e.target.closest('.menu-panel__close');
      if (closeBtn) {
        e.preventDefault();
        e.stopPropagation();
        closeMenu();
        return;
      }
    });

    function openPanel(panelId) {
      const currentPanel = panelMenu.querySelector('.menu-panel.is-active');
      if (currentPanel) {
        currentPanel.classList.remove('is-active');
        currentPanel.classList.add('is-hidden');
      }

      const targetPanel = panelMenu.querySelector(`[data-panel="${panelId}"]`);
      if (targetPanel) {
        targetPanel.classList.remove('is-hidden');
        targetPanel.classList.add('is-active');
        panelHistory.push(panelId);
      }
    }

    function goBackToPanel(panelId) {
      const currentPanel = panelMenu.querySelector('.menu-panel.is-active');
      if (currentPanel) {
        currentPanel.classList.remove('is-active');
      }

      const targetPanel = panelMenu.querySelector(`[data-panel="${panelId}"]`);
      if (targetPanel) {
        targetPanel.classList.remove('is-hidden');
        targetPanel.classList.add('is-active');
        
        const index = panelHistory.indexOf(panelId);
        if (index > -1) {
          panelHistory.splice(index + 1);
        }
      }
    }

    function closeMenu() {
      const dialog = document.querySelector('#menu_mobile');
      
      // Method 1: Try clicking outside the dialog to trigger backdrop close
      const backdrop = document.querySelector('.hdt-dialog-backdrop, [data-dialog-backdrop]');
      if (backdrop) {
        backdrop.click();
      }
      
      // Method 2: Find and click the drawer's close button (ref="closeButton")
      const drawerCloseBtn = document.querySelector('#menu_mobile .hdt-dialog-btn__close, [ref="closeButton"]');
      if (drawerCloseBtn) {
        drawerCloseBtn.click();
      }
      
      // Method 3: Try native dialog close
      if (dialog && typeof dialog.close === 'function') {
        try {
          dialog.close();
        } catch(e) {
          console.log('Dialog close failed');
        }
      }
      
      // Method 4: Manually close - remove open attribute and hide
      if (dialog) {
        dialog.removeAttribute('open');
        dialog.classList.remove('hdt-dialog--open', 'is-open', 'active');
        dialog.style.visibility = 'hidden';
        dialog.style.opacity = '0';
        dialog.style.pointerEvents = 'none';
      }
      
      // Method 5: Find drawer component and trigger close
      const drawerElement = document.querySelector('hdt-drawer.hdt-drawer-menu-mb');
      if (drawerElement && drawerElement.close) {
        drawerElement.close();
      }
      
      // Method 6: Dispatch ESC keydown event to trigger dialog close
      document.dispatchEvent(new KeyboardEvent('keydown', {
        key: 'Escape',
        keyCode: 27,
        which: 27,
        bubbles: true
      }));
      
      // Method 7: Remove body scroll lock classes
      document.body.classList.remove('hdt-overflow-hidden', 'overflow-hidden', 'scroll-lock', 'hdt-body-scroll-lock');
      document.documentElement.classList.remove('hdt-overflow-hidden', 'overflow-hidden');
      document.body.style.overflow = '';
      document.body.style.position = '';
      
      // Reset panels after close
      setTimeout(function() {
        resetPanels();
        // Reset dialog visibility if it was manually hidden
        if (dialog) {
          dialog.style.visibility = '';
          dialog.style.opacity = '';
          dialog.style.pointerEvents = '';
        }
      }, 350);
    }

    function resetPanels() {
      panels.forEach(function(panel) {
        panel.classList.remove('is-active', 'is-hidden');
      });
      const mainPanel = panelMenu.querySelector('[data-panel="main"]');
      if (mainPanel) {
        mainPanel.classList.add('is-active');
      }
      panelHistory.length = 0;
      panelHistory.push('main');
    }

    // Listen for dialog close event to reset panels
    const menuDialog = document.querySelector('#menu_mobile');
    if (menuDialog) {
      menuDialog.addEventListener('close', resetPanels);
      
      // Also listen for when dialog is hidden via attribute change
      const observer = new MutationObserver(function(mutations) {
        mutations.forEach(function(mutation) {
          if (mutation.attributeName === 'open' && !menuDialog.hasAttribute('open')) {
            resetPanels();
          }
        });
      });
      observer.observe(menuDialog, { attributes: true });
    }
  }
})();
</script>
