<!-- Mobile Search - Dropdown Style (not full-screen overlay) -->
<script>
(function(){
  var MOBILE_BP = 1150;
  function isMobile(){ return window.innerWidth < MOBILE_BP; }

  function createMobileSearch(){
    if(document.getElementById('js-mbl-search')) return;

    /* ===== CREATE DROPDOWN CONTAINER ===== */
    var overlay = document.createElement('div');
    overlay.id = 'js-mbl-search';
    overlay.setAttribute('style',
      'display:none;position:fixed;top:0;left:0;right:0;bottom:0;z-index:99999;'
    );

    /* ===== BACKDROP (semi-transparent) ===== */
    var backdrop = document.createElement('div');
    backdrop.setAttribute('style',
      'position:absolute;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.4);z-index:1;'
    );

    /* ===== DROPDOWN PANEL ===== */
    var dropdown = document.createElement('div');
    dropdown.id = 'js-mbl-search-dropdown';
    dropdown.setAttribute('style',
      'position:relative;z-index:2;background:#fff;' +
      'box-shadow:0 4px 20px rgba(0,0,0,0.15);' +
      'display:flex;flex-direction:column;' +
      'font-family:-apple-system,BlinkMacSystemFont,Segoe UI,Roboto,sans-serif;' +
      'animation:mblSearchSlideDown 0.25s ease-out;'
    );

    /* ===== SEARCH BAR ===== */
    var bar = document.createElement('div');
    bar.setAttribute('style',
      'display:flex;align-items:center;gap:10px;padding:12px 15px;' +
      'padding-top:calc(env(safe-area-inset-top,0px) + 12px);' +
      'background:#fff;border-bottom:1px solid #e0e0e0;flex-shrink:0;'
    );

    /* Back/Close button */
    var backBtn = document.createElement('button');
    backBtn.setAttribute('style',
      'background:none;border:none;padding:6px;cursor:pointer;display:flex;align-items:center;flex-shrink:0;'
    );
    backBtn.innerHTML = '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#333" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>';

    /* Search form */
    var form = document.createElement('form');
    form.action = '/search';
    form.method = 'get';
    form.setAttribute('style','flex:1;margin:0;padding:0;');

    var hiddenType = document.createElement('input');
    hiddenType.type = 'hidden'; hiddenType.name = 'type'; hiddenType.value = 'product';

    var hiddenPrefix = document.createElement('input');
    hiddenPrefix.type = 'hidden'; hiddenPrefix.name = 'options[prefix]'; hiddenPrefix.value = 'last';

    var inputWrap = document.createElement('div');
    inputWrap.setAttribute('style',
      'display:flex;align-items:center;background:#f0f0f0;border:1px solid #ddd;' +
      'border-radius:8px;padding:0 12px;height:42px;gap:8px;'
    );

    var searchIcon = document.createElement('span');
    searchIcon.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>';
    searchIcon.setAttribute('style','display:flex;flex-shrink:0;');

    var searchInput = document.createElement('input');
    searchInput.type = 'search';
    searchInput.name = 'q';
    searchInput.placeholder = 'Search products...';
    searchInput.autocomplete = 'off';
    searchInput.setAttribute('style',
      'flex:1;border:none;background:none;outline:none;box-shadow:none;font-size:15px;' +
      'color:#333;padding:0;margin:0;height:40px;line-height:40px;width:100%;' +
      '-webkit-appearance:none;font-family:inherit;'
    );

    var clearBtn = document.createElement('button');
    clearBtn.type = 'button';
    clearBtn.setAttribute('style',
      'display:none;background:none;border:none;padding:4px;cursor:pointer;align-items:center;flex-shrink:0;'
    );
    clearBtn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>';

    inputWrap.appendChild(searchIcon);
    inputWrap.appendChild(searchInput);
    inputWrap.appendChild(clearBtn);
    form.appendChild(hiddenType);
    form.appendChild(hiddenPrefix);
    form.appendChild(inputWrap);
    bar.appendChild(backBtn);
    bar.appendChild(form);

    /* ===== RESULTS AREA ===== */
    var results = document.createElement('div');
    results.setAttribute('style',
      'overflow-y:auto;-webkit-overflow-scrolling:touch;background:#fff;color:#333;padding:0;' +
      'max-height:360px;'
    );
    var resultsInner = document.createElement('div');
    results.appendChild(resultsInner);

    dropdown.appendChild(bar);
    dropdown.appendChild(results);
    overlay.appendChild(backdrop);
    overlay.appendChild(dropdown);

    document.body.appendChild(overlay);

    /* ===== FUNCTIONS ===== */
    var timer = null;

    function openSearch(){
      overlay.style.display = 'block';
      dropdown.style.animation = 'none';
      dropdown.offsetHeight; /* reflow */
      dropdown.style.animation = 'mblSearchSlideDown 0.25s ease-out';
      document.body.style.overflow = 'hidden';
      document.documentElement.style.overflow = 'hidden';
      try{ document.querySelectorAll('dialog[open]').forEach(function(d){ d.close(); }); }catch(e){}
      setTimeout(function(){ searchInput.focus(); }, 200);
    }

    function closeSearch(){
      dropdown.style.animation = 'mblSearchSlideUp 0.2s ease-in forwards';
      setTimeout(function(){
        overlay.style.display = 'none';
        document.body.style.overflow = '';
        document.documentElement.style.overflow = '';
        searchInput.value = '';
        clearBtn.style.display = 'none';
        resultsInner.innerHTML = '';
      }, 200);
    }

    /* Back/Close button */
    backBtn.addEventListener('click', function(e){ e.preventDefault(); closeSearch(); });

    /* Backdrop click to close */
    backdrop.addEventListener('click', function(e){ e.preventDefault(); closeSearch(); });

    /* Clear button */
    clearBtn.addEventListener('click', function(e){
      e.preventDefault();
      searchInput.value = '';
      clearBtn.style.display = 'none';
      resultsInner.innerHTML = '';
      searchInput.focus();
    });

    /* Escape */
    document.addEventListener('keydown', function(e){
      if(e.key === 'Escape' && overlay.style.display === 'block') closeSearch();
    });

    /* Input - live search */
    searchInput.addEventListener('input', function(){
      var q = this.value.trim();
      clearBtn.style.display = q.length > 0 ? 'flex' : 'none';
      clearTimeout(timer);
      if(q.length < 2){ resultsInner.innerHTML = ''; return; }
      timer = setTimeout(function(){ fetchResults(q); }, 300);
    });

    function fetchResults(q){
      resultsInner.innerHTML =
        '<div style="display:flex;justify-content:center;padding:30px 16px;">' +
        '<div style="width:24px;height:24px;border:2px solid #e0e0e0;border-top:2px solid #333;border-radius:50%;animation:jsMblSpin .6s linear infinite;"></div>' +
        '</div>';

      var root = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) || '/';
      fetch(root + 'search/suggest.json?q=' + encodeURIComponent(q) + '&resources[type]=product&resources[limit]=6')
        .then(function(r){ return r.json(); })
        .then(function(d){ renderResults(d, q); })
        .catch(function(){ resultsInner.innerHTML = '<div style="padding:20px 16px;font-size:14px;color:#666;">Something went wrong.</div>'; });
    }

    function renderResults(data, q){
      var prods = (data.resources && data.resources.results && data.resources.results.products) || [];
      var h = '<div style="font-size:13px;font-weight:700;color:#000;padding:14px 16px 8px;text-transform:uppercase;letter-spacing:.5px;">Products</div>';

      if(!prods.length){
        h += '<div style="padding:16px;font-size:14px;color:#666;">No results could be found.</div>';
        h += '<div style="padding:0 16px 16px;"><button onclick="var o=document.getElementById(\'js-mbl-search\');o.querySelector(\'input[type=search]\').value=\'\';o.querySelector(\'input[type=search]\').focus();this.closest(\'div\').parentNode.querySelector(\'.js-mbl-results-inner\')&&(this.closest(\'div\').parentNode.querySelector(\'.js-mbl-results-inner\').innerHTML=\'\');" style="display:block;width:100%;padding:12px 24px;background:#000;color:#fff;text-align:center;font-size:13px;font-weight:600;text-transform:uppercase;letter-spacing:1px;border:none;cursor:pointer;">NEW SEARCH</button></div>';
      } else {
        prods.forEach(function(p){
          var img = p.image || '';
          if(img && img.indexOf('//')=== 0) img = 'https:' + img;
          var price = p.price ? fmt(p.price) : '';
          var cmp = (p.compare_at_price && parseFloat(p.compare_at_price) > parseFloat(p.price)) ? fmt(p.compare_at_price) : '';

          h += '<a href="'+p.url+'" style="display:flex;align-items:center;gap:14px;padding:10px 16px;text-decoration:none;color:#333;border-bottom:1px solid #f0f0f0;">';
          if(img) h += '<img src="'+img+'" alt="" loading="lazy" style="width:56px;height:56px;object-fit:cover;border-radius:4px;background:#f5f5f5;flex-shrink:0;">';
          h += '<div style="flex:1;min-width:0;">';
          h += '<div style="font-size:13px;font-weight:500;color:#333;margin:0 0 4px;line-height:1.3;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">'+esc(p.title)+'</div>';
          if(price){
            h += '<div style="font-size:13px;font-weight:600;color:#000;">'+price;
            if(cmp) h += ' <s style="color:#999;font-weight:400;margin-left:6px;">'+cmp+'</s>';
            h += '</div>';
          }
          h += '</div></a>';
        });
        h += '<a href="/search?q='+encodeURIComponent(q)+'&type=product" style="display:block;text-align:center;padding:14px 16px;font-size:13px;font-weight:600;color:#000;text-decoration:underline;">View all results</a>';
      }
      resultsInner.innerHTML = h;
    }

    function fmt(c){
      if(typeof c==='string') c = c.replace('.','');
      var a = (parseInt(c,10)/100).toFixed(2);
      return (window.Shopify && window.Shopify.currency && window.Shopify.currency.active) ? window.Shopify.currency.active+' '+a : '$'+a;
    }
    function esc(t){ var d=document.createElement('div'); d.textContent=t||''; return d.innerHTML; }

    /* ===== EXPOSE open/close ===== */
    window.__mblSearchOpen = openSearch;
    window.__mblSearchClose = closeSearch;
  }

  /* ===== ADD KEYFRAMES ===== */
  var style = document.createElement('style');
  style.textContent = 
    '@keyframes jsMblSpin{to{transform:rotate(360deg)}}' +
    '@keyframes mblSearchSlideDown{from{transform:translateY(-100%);opacity:0}to{transform:translateY(0);opacity:1}}' +
    '@keyframes mblSearchSlideUp{from{transform:translateY(0);opacity:1}to{transform:translateY(-100%);opacity:0}}' +
    '#js-mbl-search input[type="search"]::-webkit-search-cancel-button{-webkit-appearance:none;display:none;}' +
    '#js-mbl-search input[type="search"]::-ms-clear{display:none;width:0;height:0;}';
  document.head.appendChild(style);

  /* ===== INTERCEPT SEARCH ICON CLICKS ===== */
  document.addEventListener('click', function(e){
    if(!isMobile()) return;
    if(e.target.closest('.hdt-site-nav_search')){
      e.preventDefault(); e.stopPropagation(); e.stopImmediatePropagation();
      createMobileSearch();
      if(window.__mblSearchOpen) window.__mblSearchOpen();
      return false;
    }
  }, true);

  document.addEventListener('touchend', function(e){
    if(!isMobile()) return;
    if(e.target.closest('.hdt-site-nav_search')){
      e.preventDefault(); e.stopPropagation(); e.stopImmediatePropagation();
      createMobileSearch();
      if(window.__mblSearchOpen) window.__mblSearchOpen();
      return false;
    }
  }, true);

  /* Strip aria-controls */
  function stripAria(){
    if(!isMobile()) return;
    document.querySelectorAll('.hdt-site-nav_search [aria-controls]').forEach(function(el){
      el.removeAttribute('aria-controls');
    });
  }
  stripAria();
  document.addEventListener('DOMContentLoaded', stripAria);
  setTimeout(stripAria, 500);
  setTimeout(stripAria, 1500);
  window.addEventListener('resize', stripAria);
})();
</script>
