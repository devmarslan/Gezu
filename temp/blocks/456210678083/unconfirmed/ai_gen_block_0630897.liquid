{% doc %}
  @prompt
    On the product page, read the `custom/group_media_obj` metafield which is a JSON array of objects with fields: `mid` (media ID as integer), `option` (0 = Size, 1 = Color), and `value` (index of the option value). When a variant is selected, filter the product gallery to only show media images whose `mid` matches BOTH the selected Size option index AND the selected Color option index from the metafield mapping. Option 0 (Size) values: 0=4.5x45mm, 1=4.5x35mm, 2=4.5x25mm. Option 1 (Color) values: 0=Silver, 1=Anthracite Grey. The gallery should dynamically update on variant selection to show only the relevant images (approximately 7 per combination), hiding all others. Use JavaScript to listen for variant change events and filter the media gallery accordingly using the metafield data.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-variant-gallery-filter-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-variant-gallery-filter__message-{{ ai_gen_id }} {
    padding: 20px;
    background-color: {{ block.settings.message_bg_color }};
    color: {{ block.settings.message_text_color }};
    border-radius: 8px;
    text-align: center;
    font-size: 14px;
    margin-bottom: 20px;
  }

  .ai-variant-gallery-filter__status-{{ ai_gen_id }} {
    padding: 12px 16px;
    background-color: {{ block.settings.status_bg_color }};
    color: {{ block.settings.status_text_color }};
    border-radius: 4px;
    font-size: 13px;
    margin-bottom: 16px;
    display: none;
  }

  .ai-variant-gallery-filter__status-{{ ai_gen_id }}.active {
    display: block;
  }

  .ai-variant-gallery-filter__debug-{{ ai_gen_id }} {
    padding: 12px;
    background-color: #f5f5f5;
    border: 1px solid #ddd;
    border-radius: 4px;
    font-size: 12px;
    font-family: monospace;
    margin-top: 16px;
    display: none;
  }

  .ai-variant-gallery-filter__debug-{{ ai_gen_id }}.active {
    display: block;
  }
{% endstyle %}

<variant-gallery-filter-{{ ai_gen_id }}
  class="ai-variant-gallery-filter-{{ ai_gen_id }}"
  data-product-id="{{ product.id }}"
  data-metafield-key="custom.group_media_obj"
  {{ block.shopify_attributes }}
>
  {% if product.metafields.custom.group_media_obj == blank %}
    <div class="ai-variant-gallery-filter__message-{{ ai_gen_id }}">
      No media mapping metafield found. Please add the <strong>custom.group_media_obj</strong> metafield to this product.
    </div>
  {% endif %}

  <div class="ai-variant-gallery-filter__status-{{ ai_gen_id }}" id="ai-status-{{ ai_gen_id }}">
    Filtering gallery...
  </div>

  {% if block.settings.show_debug %}
    <div class="ai-variant-gallery-filter__debug-{{ ai_gen_id }}" id="ai-debug-{{ ai_gen_id }}">
      Debug info will appear here...
    </div>
  {% endif %}
</variant-gallery-filter-{{ ai_gen_id }}>

<script>
  (function() {
    class VariantGalleryFilter{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.productId = this.dataset.productId;
        this.metafieldKey = this.dataset.metafieldKey;
        this.mediaMapping = null;
        this.currentVariant = null;
        this.statusElement = this.querySelector('#ai-status-{{ ai_gen_id }}');
        this.debugElement = this.querySelector('#ai-debug-{{ ai_gen_id }}');
        this.showDebug = {{ block.settings.show_debug | json }};
        
        this.optionMapping = {
          size: {
            index: 0,
            values: {
              '4.5x45mm': 0,
              '4.5x35mm': 1,
              '4.5x25mm': 2
            }
          },
          color: {
            index: 1,
            values: {
              'Silver': 0,
              'Anthracite Grey': 1
            }
          }
        };
      }

      connectedCallback() {
        this.loadMetafield();
        this.setupVariantListener();
        this.filterGalleryOnLoad();
      }

      async loadMetafield() {
        try {
          const response = await fetch(`/products/${window.location.pathname.split('/').pop()}.js`);
          const productData = await response.json();
          
          if (productData.metafields && productData.metafields.custom && productData.metafields.custom.group_media_obj) {
            this.mediaMapping = JSON.parse(productData.metafields.custom.group_media_obj);
            this.log('Metafield loaded successfully', this.mediaMapping);
          } else {
            this.log('Metafield not found in product data');
          }
        } catch (error) {
          this.log('Error loading metafield: ' + error.message);
        }
      }

      setupVariantListener() {
        const productForm = document.querySelector('form[action*="/cart/add"]');
        
        if (productForm) {
          const variantIdInput = productForm.querySelector('[name="id"]');
          
          if (variantIdInput) {
            const observer = new MutationObserver(() => {
              this.handleVariantChange();
            });
            
            observer.observe(variantIdInput, {
              attributes: true,
              attributeFilter: ['value']
            });
            
            productForm.addEventListener('change', () => {
              setTimeout(() => this.handleVariantChange(), 100);
            });
          }
        }

        document.addEventListener('variant:change', (event) => {
          if (event.detail && event.detail.variant) {
            this.currentVariant = event.detail.variant;
            this.filterGallery();
          }
        });
      }

      filterGalleryOnLoad() {
        const urlParams = new URLSearchParams(window.location.search);
        const variantId = urlParams.get('variant');
        
        if (variantId) {
          this.findAndSetVariant(variantId);
        } else {
          setTimeout(() => this.handleVariantChange(), 500);
        }
      }

      async findAndSetVariant(variantId) {
        try {
          const response = await fetch(`/products/${window.location.pathname.split('/').pop()}.js`);
          const productData = await response.json();
          
          const variant = productData.variants.find(v => v.id == variantId);
          if (variant) {
            this.currentVariant = variant;
            this.filterGallery();
          }
        } catch (error) {
          this.log('Error finding variant: ' + error.message);
        }
      }

      handleVariantChange() {
        const productForm = document.querySelector('form[action*="/cart/add"]');
        
        if (productForm) {
          const variantIdInput = productForm.querySelector('[name="id"]');
          
          if (variantIdInput && variantIdInput.value) {
            this.findAndSetVariant(variantIdInput.value);
          }
        }
      }

      filterGallery() {
        if (!this.mediaMapping || !this.currentVariant) {
          this.log('Missing data - mediaMapping or currentVariant');
          return;
        }

        const sizeValue = this.currentVariant.options[this.optionMapping.size.index];
        const colorValue = this.currentVariant.options[this.optionMapping.color.index];
        
        const sizeIndex = this.optionMapping.size.values[sizeValue];
        const colorIndex = this.optionMapping.color.values[colorValue];

        this.log(`Filtering for Size: ${sizeValue} (${sizeIndex}), Color: ${colorValue} (${colorIndex})`);

        const validMediaIds = this.mediaMapping
          .filter(item => {
            const matchesSize = item.option === 0 && item.value === sizeIndex;
            const matchesColor = item.option === 1 && item.value === colorIndex;
            return matchesSize || matchesColor;
          })
          .reduce((acc, item) => {
            if (!acc.includes(item.mid)) {
              acc.push(item.mid);
            }
            return acc;
          }, []);

        const mediaIdsMatchingBoth = this.mediaMapping
          .filter(item => item.option === 0 && item.value === sizeIndex)
          .map(item => item.mid)
          .filter(mid => {
            return this.mediaMapping.some(item => 
              item.option === 1 && item.value === colorIndex && item.mid === mid
            );
          });

        const finalMediaIds = mediaIdsMatchingBoth.length > 0 ? mediaIdsMatchingBoth : validMediaIds;

        this.log(`Valid media IDs: ${finalMediaIds.join(', ')}`);

        this.applyGalleryFilter(finalMediaIds);
        this.showStatus(`Showing ${finalMediaIds.length} images for ${sizeValue} - ${colorValue}`);
      }

      applyGalleryFilter(validMediaIds) {
        const gallerySelectors = [
          '.product__media-list li',
          '.product-media-container .product__media-item',
          '.product__media-wrapper .product__media-item',
          '[data-media-id]',
          '.product-single__media',
          '.product__media'
        ];

        let mediaElements = [];
        
        for (const selector of gallerySelectors) {
          const elements = document.querySelectorAll(selector);
          if (elements.length > 0) {
            mediaElements = Array.from(elements);
            this.log(`Found ${mediaElements.length} media elements using selector: ${selector}`);
            break;
          }
        }

        if (mediaElements.length === 0) {
          this.log('No media elements found in gallery');
          return;
        }

        mediaElements.forEach((element, index) => {
          const mediaId = this.extractMediaId(element);
          
          if (mediaId && validMediaIds.includes(parseInt(mediaId))) {
            element.style.display = '';
            element.style.opacity = '1';
            element.style.visibility = 'visible';
            element.removeAttribute('hidden');
          } else {
            element.style.display = 'none';
            element.style.opacity = '0';
            element.style.visibility = 'hidden';
            element.setAttribute('hidden', '');
          }
        });

        const slider = document.querySelector('.product__media-list');
        if (slider && typeof slider.refresh === 'function') {
          slider.refresh();
        }
      }

      extractMediaId(element) {
        if (element.dataset.mediaId) {
          return element.dataset.mediaId;
        }
        
        const img = element.querySelector('img[data-media-id]');
        if (img && img.dataset.mediaId) {
          return img.dataset.mediaId;
        }

        const idMatch = element.id ? element.id.match(/media-(\d+)/) : null;
        if (idMatch) {
          return idMatch[1];
        }

        const classMatch = element.className.match(/media-(\d+)/);
        if (classMatch) {
          return classMatch[1];
        }

        return null;
      }

      showStatus(message) {
        if (this.statusElement) {
          this.statusElement.textContent = message;
          this.statusElement.classList.add('active');
          
          setTimeout(() => {
            this.statusElement.classList.remove('active');
          }, 3000);
        }
      }

      log(message, data = null) {
        if (this.showDebug && this.debugElement) {
          const timestamp = new Date().toLocaleTimeString();
          const logEntry = `[${timestamp}] ${message}`;
          
          if (data) {
            this.debugElement.textContent = logEntry + '\n' + JSON.stringify(data, null, 2);
          } else {
            this.debugElement.textContent = logEntry;
          }
          
          this.debugElement.classList.add('active');
        }
        
        console.log(`[VariantGalleryFilter] ${message}`, data || '');
      }
    }

    customElements.define('variant-gallery-filter-{{ ai_gen_id }}', VariantGalleryFilter{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Variant gallery filter",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Configuration"
    },
    {
      "type": "paragraph",
      "content": "This block filters the product gallery based on the selected variant using the custom.group_media_obj metafield. The metafield should contain a JSON array with objects having: mid (media ID), option (0=Size, 1=Color), and value (option value index)."
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Status message"
    },
    {
      "type": "color",
      "id": "status_bg_color",
      "label": "Background color",
      "default": "#f0f0f0"
    },
    {
      "type": "color",
      "id": "status_text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Error message"
    },
    {
      "type": "color",
      "id": "message_bg_color",
      "label": "Background color",
      "default": "#fff3cd"
    },
    {
      "type": "color",
      "id": "message_text_color",
      "label": "Text color",
      "default": "#856404"
    },
    {
      "type": "header",
      "content": "Debug"
    },
    {
      "type": "checkbox",
      "id": "show_debug",
      "label": "Show debug information",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Variant gallery filter"
    }
  ]
}
{% endschema %}