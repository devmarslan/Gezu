<script>
if (!customElements.get('country-filter')) {
  customElements.define('country-filter', class extends HTMLElement {
    connectedCallback() {
      this._input = this.querySelector('input[type="search"]');
      if (!this._input) return;

      this._input.addEventListener('input', () => this._filter());
      this._input.addEventListener('search', () => this._filter());
    }

    _filter() {
      const query = this._input.value.trim().toLowerCase();
      const list = this.closest('.hdt-popover__body')?.querySelector('hdt-richlist');
      if (!list) return;

      // Remove old separator
      list.querySelector('.cf-separator')?.remove();

      if (!this._origOrder) {
        this._origOrder = [...list.querySelectorAll('button[role="option"]')];
      }

      // Check if this is inside currency popover AND on mobile
      const isCurrencyPopover = !!this.closest('.hdt-popover-currencies');
      const isMobile = window.innerWidth <= 767;

      if (isCurrencyPopover && isMobile) {
        if (!query) {
          this._origOrder.forEach(btn => {
            btn.style.display = '';
            list.appendChild(btn);
          });
          return;
        }

        const matched = [];
        const unmatched = [];

        this._origOrder.forEach(btn => {
          const txt = (btn.textContent || '').toLowerCase();
          const val = (btn.getAttribute('value') || '').toLowerCase();
          const nm = (btn.getAttribute('data-name') || '').toLowerCase();

          if (txt.includes(query) || val.includes(query) || nm.includes(query)) {
            matched.push(btn);
          } else {
            unmatched.push(btn);
          }
        });

        matched.forEach(btn => {
          btn.style.display = '';
          list.appendChild(btn);
        });

        // Add separator between matched and unmatched
        if (matched.length && unmatched.length) {
          const sep = document.createElement('div');
          sep.className = 'cf-separator';
          sep.style.cssText = 'border-top:1px solid rgba(128,128,128,0.25);margin:8px 0 4px;padding:6px 0 2px;font-size:11px;color:rgba(128,128,128,0.8);letter-spacing:0.5px;text-transform:uppercase;pointer-events:none;';
          sep.textContent = 'Other Currencies';
          list.appendChild(sep);
        }

        unmatched.forEach(btn => {
          btn.style.display = '';
          list.appendChild(btn);
        });
        return;
      }

      // Default: hide non-matches (desktop, language popover, etc.)
      list.querySelectorAll('button[role="option"]').forEach(btn => {
        const name = (btn.dataset.name || btn.textContent).toLowerCase();
        btn.style.display = name.includes(query) ? '' : 'none';
      });
    }
  });
}
</script>

