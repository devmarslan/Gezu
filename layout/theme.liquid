<script>
  (function () {
  'use strict';

  function parsePrice(text) {
    if (!text) return NaN;
    // Remove currency symbols, spaces, commas — keep digits and dot
    return parseFloat(text.replace(/[^\d.]/g, ''));
  }

  function checkPriceContainer(container) {
    // Taxify-rendered compare-at price (the "exclusive" / tax-excl span)
    const compareEl = container.querySelector(
      '.taxify-price-container.hdt-compare-at-price .taxify-amount'
    );
    // Taxify-rendered base/current price
    const baseEl = container.querySelector(
      '.taxify-price-container.hdt-price .taxify-amount'
    );

    // Fallback to native Shopify money spans if Taxify hasn't fired yet
    const compareElFallback = container.querySelector('.hdt-compare-at-price .money');
    const baseElFallback    = container.querySelector('.hdt-price .money');

    const comparePrice = parsePrice((compareEl || compareElFallback)?.textContent);
    const basePrice    = parsePrice((baseEl    || baseElFallback)?.textContent);

    if (isNaN(comparePrice) || isNaN(basePrice)) return;

    // Walk up to the wrapper that holds the badge class
    const priceWrap = container.closest('.hdt-price-wrapp');

    if (comparePrice < basePrice) {
      // --- HIDE ---
      // Hide every compare-at element (native + taxify)
      container.querySelectorAll(
        '.hdt-compare-at-price, .taxify-price-container.hdt-compare-at-price'
      ).forEach(el => el.style.setProperty('display', 'none', 'important'));

      // Hide badge + strip the class that makes it visible
      if (priceWrap) {
        priceWrap.classList.remove('hdt-price--show-badge');
        priceWrap.querySelectorAll('.sale-badge').forEach(el =>
          el.style.setProperty('display', 'none', 'important')
        );
      }

    } else {
      // --- RESTORE (variant switch back to valid sale) ---
      container.querySelectorAll(
        '.hdt-compare-at-price, .taxify-price-container.hdt-compare-at-price'
      ).forEach(el => el.style.removeProperty('display'));

      if (priceWrap) {
        priceWrap.querySelectorAll('.sale-badge').forEach(el =>
          el.style.removeProperty('display')
        );
        // Re-add badge class only if there actually is a compare price
        if (compareEl || compareElFallback) {
          priceWrap.classList.add('hdt-price--show-badge');
        }
      }
    }
  }

  function runAll() {
    document.querySelectorAll('.hdt-price__container').forEach(checkPriceContainer);
  }

  // Run immediately (catches server-rendered prices)
  runAll();

  // Re-run whenever Taxify or variant JS mutates the price area
  const observer = new MutationObserver(runAll);
  observer.observe(document.body, {
    childList:       true,
    subtree:         true,
    attributes:      true,
    attributeFilter: ['data-taxify-processed', 'class', 'style']
  });

})();
</script>
<script>
  /** 
   * Option B: Standard Quick View Handler 
   * Replaces the heavy 'wrapp-hdt' component with a basic global listener.
   */
  document.addEventListener('click', function(e) {
    const btn = e.target.closest('.hdt-theme-quick-view-btn');
    if (!btn) return;

    // Direct attribute lookup for maximum reliability
    const modalId = btn.getAttribute('data-hdt-controls') || btn.getAttribute('aria-controls');
    const handle = btn.getAttribute('handle') || btn.dataset.handle;
    
    if (!modalId || !handle) return;
    const modal = document.getElementById(modalId);
    if (!modal) return;

    e.preventDefault();
    e.stopPropagation();

    // Reset current handle if modal is closed to allow re-opening same product
    if (!modal.hasAttribute('open') && !modal.open) {
      delete modal.dataset.currentHandle;
    }

    // Prevent redundant clicks while loading or if already open for same product
    if (btn.classList.contains('loading')) return;
    if (modal.dataset.currentHandle === handle && (modal.hasAttribute('open') || modal.open)) return;

    // 1. Show Loading State
    btn.classList.add('loading');
    btn.setAttribute('aria-busy', 'true');
    btn.setAttribute('aria-expanded', 'true');
    
    const sectionId = (modalId === 'hdt-quick-add-modal') ? 'main-quick-add' : 'main-quick-view';
    const fetchUrl = `${window.location.origin}/products/${handle}?section_id=${sectionId}`;
    
    fetch(fetchUrl)
      .then(response => response.text())
      .then(html => {
        const parser = new DOMParser();
        const doc = parser.parseFromString(html, 'text/html');
        const content = doc.querySelector('.hdt-main-product-quick-view, .hdt-main-product-quick-add');
        
        if (content) {
          const modalInner = modal.querySelector('.hdt-dialog-modal__inner');
          if (modalInner) {
            modalInner.innerHTML = '';
            modalInner.appendChild(document.createRange().createContextualFragment(content.innerHTML));
            modal.dataset.currentHandle = handle;
          }
          
          const modalWrapper = modal.closest('hdt-lazy-modal, hdt-modal');
          if (modalWrapper && typeof modalWrapper.open === 'function') {
            modalWrapper.open();
          } else if (typeof modal.showModal === 'function') {
            modal.showModal();
          } else {
            modal.setAttribute('open', '');
          }
          
          document.dispatchEvent(new CustomEvent('dialog:opening', { detail: { id: modalId } }));
          document.dispatchEvent(new CustomEvent('currency:update'));
        }
      })
      .catch(err => {
        console.error('Quick View AJAX Error:', err);
      })
      .finally(() => {
        btn.classList.remove('loading');
        btn.removeAttribute('aria-busy');
      });
  });
</script>
